          <tr>
            <th class="px-2 py-1 text-left"><%= t("sku") %></th>
            <th class="px-2 py-1 text-left"><%= t("article_name") %></th>
            <th class="px-2 py-1 text-left"><%= t("previous_rate") %></th>
            <th class="px-2 py-1 text-left"><%= t("new_rate") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100" data-labour-rate-bulk-body>
          <tr>
            <td class="px-2 py-2 text-slate-500" colspan="4"><%= t("no_entries") %></td>
          </tr>
        </tbody>
      </table>
