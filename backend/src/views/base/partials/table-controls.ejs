<%
  const statusEnabled = typeof showStatus === "boolean" ? showStatus : Boolean(showStatus);
  const filtersEnabled = typeof showFilters === "boolean" ? showFilters : false;
  const pageSizeFieldName = typeof pageSizeName === "string" ? pageSizeName : "";
  const statusFieldName = typeof statusName === "string" ? statusName : "";
  const searchFieldName = typeof searchName === "string" ? searchName : "";
  const searchInputValue = typeof searchValue === "string" ? searchValue : "";
  const searchInputPlaceholder = typeof searchPlaceholder === "string" ? searchPlaceholder : t("search");
  const incomingPageSizeOptions = typeof pageSizeOptions !== "undefined" ? pageSizeOptions : null;
  const incomingStatusOptions = typeof statusOptions !== "undefined" ? statusOptions : null;
  const incomingSelectedPageSize = typeof selectedPageSize !== "undefined" ? selectedPageSize : null;
  const incomingSelectedStatus = typeof selectedStatus !== "undefined" ? selectedStatus : null;
  const normalizedPageSizeOptions = Array.isArray(incomingPageSizeOptions) && incomingPageSizeOptions.length
    ? incomingPageSizeOptions
    : [
        { value: "10", label: "10" },
        { value: "25", label: "25" },
        { value: "50", label: "50" },
        { value: "all", label: t("all") },
      ];
  const normalizedStatusOptions = Array.isArray(incomingStatusOptions) && incomingStatusOptions.length
    ? incomingStatusOptions
    : [
        { value: "all", label: t("all") },
        { value: "active", label: t("active") },
        { value: "inactive", label: t("inactive") },
      ];
  const defaultStatusOption = normalizedStatusOptions.find((option) => String(option.value || "").toLowerCase() === "active")
    || normalizedStatusOptions[0];
  const selectedPageSizeValue = String(
    incomingSelectedPageSize !== undefined && incomingSelectedPageSize !== null
      ? incomingSelectedPageSize
      : normalizedPageSizeOptions[0].value
  ).toLowerCase();
  const selectedStatusValue = String(
    incomingSelectedStatus !== undefined && incomingSelectedStatus !== null
      ? incomingSelectedStatus
      : defaultStatusOption.value
  ).toLowerCase();
%>
<div class="flex flex-wrap items-center gap-3 text-xs text-slate-500" data-table-controls>
  <label class="flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 shadow-sm">
    <span class="text-[10px] uppercase tracking-[0.2em] text-slate-400"><%= t("show") %></span>
    <select
      class="w-16 bg-transparent text-xs font-semibold text-slate-700 focus:outline-none cursor-pointer"
      data-page-size
      data-searchable-variant="compact"
      <%= pageSizeFieldName ? `name="${pageSizeFieldName}"` : "" %>
    >
      <% normalizedPageSizeOptions.forEach(function(option) { %>
        <% const pageSizeValue = String(option.value).toLowerCase(); %>
        <option value="<%= option.value %>" <%= pageSizeValue === selectedPageSizeValue ? "selected" : "" %>><%= option.label %></option>
      <% }) %>
    </select>
    <span class="text-[10px] uppercase tracking-[0.2em] text-slate-400"><%= t("rows") %></span>
  </label>
  <% if (statusEnabled) { %>
    <label class="flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 shadow-sm">
      <span class="text-[10px] uppercase tracking-[0.2em] text-slate-400"><%= t("status") %></span>
      <select
        class="w-24 bg-transparent text-xs font-semibold text-slate-700 focus:outline-none cursor-pointer"
        data-status-filter
        data-searchable-variant="compact"
        <%= statusFieldName ? `name="${statusFieldName}"` : "" %>
      >
        <% normalizedStatusOptions.forEach(function(option) { %>
          <% const statusValue = String(option.value).toLowerCase(); %>
          <option value="<%= option.value %>" <%= statusValue === selectedStatusValue ? "selected" : "" %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>
  <% } %>
  <label class="flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 shadow-sm">
    <svg class="h-4 w-4 text-slate-400" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M9 15a6 6 0 1 1 4.24-1.76L17 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
    <input
      class="w-36 bg-transparent text-xs font-semibold text-slate-700 focus:outline-none"
      type="text"
      placeholder="<%= searchInputPlaceholder %>"
      value="<%= searchInputValue %>"
      data-search-input
      <%= searchFieldName ? `name="${searchFieldName}"` : "" %>
    />
  </label>
  <% if (filtersEnabled) { %>
    <button class="relative flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-600 shadow-sm transition hover:border-slate-300 hover:text-slate-800" type="button" data-filter-toggle>
      <span><%= t("filters") %></span>
      <span class="absolute -right-1 -top-1 hidden h-4 min-w-[16px] items-center justify-center rounded-full bg-rose-600 px-1 text-[9px] font-semibold text-white" data-filter-count></span>
    </button>
  <% } %>
</div>
