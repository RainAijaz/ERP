<style>
  [data-print-header] {
    display: none;
  }

  @media print {
    body * {
      visibility: hidden;
    }
    [data-print-area],
    [data-print-area] * {
      visibility: visible;
    }
    [data-print-area] {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      color: #111827;
      direction: var(--print-direction, ltr);
      unicode-bidi: plaintext;
    }
    [data-print-header] {
      display: block;
      margin-bottom: 12px;
      color: #111827;
    }
    [data-print-area] table {
      border-collapse: collapse;
      width: 100%;
    }
    [data-print-area] th,
    [data-print-area] td {
      color: #111827;
      border-bottom: 1px solid #e5e7eb;
    }
    [data-print-area] {
      overflow: visible !important;
      max-height: none !important;
    }
    [data-print-area] .overflow-x-auto {
      overflow: visible !important;
    }
    [data-print-area] .sticky-col-1,
    [data-print-area] .sticky-col-2,
    [data-print-area] .sticky-col-3 {
      position: static !important;
      left: auto !important;
      z-index: auto !important;
      min-width: auto !important;
      width: auto !important;
    }
    [data-print-area] table {
      table-layout: auto;
    }
    [data-print-area] th,
    [data-print-area] td {
      white-space: normal;
      word-break: break-word;
      overflow-wrap: anywhere;
    }
    @page {
      margin: 12mm;
      size: auto;
    }
  }

  .multi-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid #e2e8f0;
    border-radius: 9999px;
    padding: 4px 10px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #475569;
    background: #fff;
  }

  .multi-tag button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 9999px;
    border: 1px solid #e2e8f0;
    color: #64748b;
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .multi-tag button:hover {
    color: #0f172a;
    border-color: #cbd5f5;
  }

  [data-multi-select] [data-multi-menu] {
    width: 100%;
    max-width: 100%;
  }

  @media (max-width: 640px) {
    [data-multi-select] [data-multi-menu] {
      max-width: calc(100vw - 2rem);
    }
  }

  .sticky-col-1,
  .sticky-col-2,
  .sticky-col-3 {
    position: sticky;
    background: #fff;
  }

  thead .sticky-col-1,
  thead .sticky-col-2,
  thead .sticky-col-3 {
    background: #f8fafc;
    z-index: 3;
  }

  .sticky-col-1 {
    left: 0;
    min-width: 180px;
    z-index: 2;
  }

  .sticky-col-2 {
    left: 180px;
    min-width: 160px;
    z-index: 1;
  }

  .sticky-col-3 {
    left: 340px;
    min-width: 200px;
    z-index: 1;
  }

  @media (max-width: 640px) {
    [data-modal] {
      align-items: flex-end;
    }

    [data-modal] > div {
      width: 100%;
      max-width: 100%;
      border-radius: 18px 18px 0 0;
      margin: 0;
    }

    [data-modal] select {
      max-width: 100%;
    }

    .sticky-col-1,
    .sticky-col-2,
    .sticky-col-3 {
      position: static;
      left: auto;
      min-width: auto;
      z-index: auto;
    }
  }

  [data-compact-table] th,
  [data-compact-table] td {
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    white-space: normal;
    word-break: break-word;
    overflow-wrap: anywhere;
  }

  [data-print-area][data-scope-key="hr_payroll.labour_rates"][data-grouped-table-ready="false"]
    tbody
    [data-row],
  [data-print-area][data-scope-key="hr_payroll.commissions"][data-grouped-table-ready="false"]
    tbody
    [data-row] {
    display: none;
  }

  /* Commission 3-level: synthetic rate sub-header rows */
  [data-scope-key="hr_payroll.commissions"] tr.commission-sub-header {
    border-left: 3px solid rgb(129 140 248);
  }
  /* Commission 3-level: SKU child rows indented under sub-header */
  [data-scope-key="hr_payroll.commissions"] tr.commission-rule-child td:first-child {
    padding-left: 3.5rem;
  }
</style>

<script>
  (function () {
    // Wire up modal, filters, sorting, export, and table actions.
    const modal = document.querySelector("[data-modal]");
    const modalForm = document.querySelector("[data-modal-form]");
    const modalTitle = document.querySelector("[data-modal-title]");
    const openButtons = document.querySelectorAll("[data-modal-open]");
    const closeButtons = document.querySelectorAll("[data-modal-close]");
    const editButtons = document.querySelectorAll("[data-edit]");
    const searchInput = document.querySelector("[data-search-input]");
    const pageSizeSelect = document.querySelector("[data-page-size]");
    const prevButton = document.querySelector("[data-prev-page]");
    const nextButton = document.querySelector("[data-next-page]");
    const pageIndicator = document.querySelector("[data-page-indicator]");
    const downloadButton = document.querySelector("[data-download-button]");
    const printButton = document.querySelector("[data-print-button]");
    const sortButtons = Array.from(
      document.querySelectorAll("[data-sort-key]"),
    );
    const tableBody = document.querySelector("[data-table-body]");
    const statusFilter = document.querySelector("[data-status-filter]");
    const filterToggle = document.querySelector("[data-filter-toggle]");
    const filterPanel = document.querySelector("[data-filter-panel]");
    const filterAccountType = document.querySelector(
      "[data-filter-account-type]",
    );
    const filterAccountGroup = document.querySelector(
      "[data-filter-account-group]",
    );
    const filterPartyType = document.querySelector("[data-filter-party-type]");
    const filterPartyGroup = document.querySelector(
      "[data-filter-party-group]",
    );
    const filterBranch = document.querySelector("[data-filter-branch]");
    const filterCity = document.querySelector("[data-filter-city]");
    const filterCreatedBy = document.querySelector("[data-filter-created-by]");
    const filterSubgroup = document.querySelector("[data-filter-subgroup]");
    const filterRateView = document.querySelector("[data-filter-rate-view]");
    const filterCreatedAtStart = document.querySelector(
      "[data-filter-created-at-start]",
    );
    const filterCreatedAtEnd = document.querySelector(
      "[data-filter-created-at-end]",
    );
    const filterAddButtons = document.querySelectorAll("[data-filter-add]");
    const filterClose = document.querySelector("[data-filter-close]");
    const filterApply = document.querySelector("[data-filter-apply]");
    const filterClear = document.querySelector("[data-filter-clear]");
    const filterCountBadge = document.querySelector("[data-filter-count]");
    const confirmModal = document.querySelector("[data-confirm-modal]");
    const confirmForm = document.querySelector("[data-confirm-form]");
    const confirmTitle = document.querySelector("[data-confirm-title]");
    const confirmMessage = document.querySelector("[data-confirm-message]");
    const confirmClose = document.querySelectorAll("[data-confirm-close]");
    const toggleButtons = document.querySelectorAll("[data-toggle]");
    const deleteButtons = document.querySelectorAll("[data-delete]");
    const rowMenuButtons = document.querySelectorAll("[data-row-menu]");
    const rowMenuPanels = document.querySelectorAll("[data-row-menu-panel]");
    const modalError = document.querySelector("[data-modal-error]");
    const auditPanel = document.querySelector("[data-audit-panel]");
    const auditCreated = document.querySelector("[data-audit-created]");
    const auditUpdated = document.querySelector("[data-audit-updated]");
    const i18n = {
      add: '<%= t("add") %>',
      edit: '<%= t("edit") %>',
      confirm: '<%= t("confirm") %>',
      proceedChange: '<%= t("proceed_change") %>',
      permanentDelete: '<%= t("permanent_delete") %>',
      permanentDeleteMessage: '<%= t("permanent_delete_message") %>',
      showing: '<%= t("showing") %>',
      to: '<%= t("to") %>',
      of: '<%= t("of") %>',
      entries: '<%= t("entries") %>',
      unitCodeExists: '<%= t("unit_code_exists") %>',
      conversionSame: '<%= t("conversion_same_units") %>',
      conversionFactor: '<%= t("conversion_factor") %>',
      conversionExists: '<%= t("conversion_exists") %>',
      selectBranch: '<%= t("error_select_branch") %>',
      selectPhone: '<%= t("error_select_phone") %>',
    };
    const printDirection = '<%= locale === "ur" ? "rtl" : "ltr" %>';
    if (typeof document !== "undefined" && document.documentElement) {
      document.documentElement.style.setProperty(
        "--print-direction",
        printDirection,
      );
    }
    let filterPartyGroups = null;

    const getFilterValues = (selector) =>
      Array.from(document.querySelectorAll(selector))
        .map((el) => (el.value || "").trim())
        .filter(Boolean);

    const formatDisplayDate = (value) => {
      const text = String(value || "").trim();
      if (!text) return "-";
      const ymd = text.match(/^(\d{4})-(\d{2})-(\d{2})$/);
      if (ymd) return `${ymd[3]}-${ymd[2]}-${ymd[1]}`;
      const iso = text.match(/^(\d{4})-(\d{2})-(\d{2})[T\s].*$/);
      if (iso) return `${iso[3]}-${iso[2]}-${iso[1]}`;
      const dt = new Date(text);
      if (Number.isNaN(dt.getTime())) return text;
      const dd = String(dt.getDate()).padStart(2, "0");
      const mm = String(dt.getMonth() + 1).padStart(2, "0");
      const yyyy = String(dt.getFullYear());
      return `${dd}-${mm}-${yyyy}`;
    };

    const updateFilterCount = () => {
      if (!filterCountBadge) return;
      const createdByActive =
        filterCreatedBy && (filterCreatedBy.value || "").trim() ? 1 : 0;
      const subgroupActive =
        filterSubgroup && (filterSubgroup.value || "").trim() ? 1 : 0;
      const rateViewActive =
        filterRateView &&
        String(filterRateView.value || "")
          .trim()
          .toUpperCase() === "PER_PAIR"
          ? 1
          : 0;
      const createdAtActive =
        (filterCreatedAtStart && filterCreatedAtStart.value) ||
        (filterCreatedAtEnd && filterCreatedAtEnd.value)
          ? 1
          : 0;
      const activeFilters =
        [
          ...getFilterValues("[data-filter-account-type]"),
          ...getFilterValues("[data-filter-account-group]"),
          ...getFilterValues("[data-filter-party-type]"),
          ...getFilterValues("[data-filter-party-group]"),
          ...getFilterValues("[data-filter-branch]"),
          ...getFilterValues("[data-filter-city]"),
          ...getFilterValues("[data-filter-apply-on]"),
          ...getFilterValues("[data-filter-subgroup]"),
          ...getFilterValues("[data-filter-group]"),
          ...getFilterValues("[data-filter-article-type]"),
        ].length +
        createdByActive +
        createdAtActive +
        subgroupActive +
        rateViewActive;
      if (activeFilters > 0) {
        filterCountBadge.textContent = String(activeFilters);
        filterCountBadge.classList.remove("hidden");
      } else {
        filterCountBadge.classList.add("hidden");
      }
    };

    const autoCodeEnabled =
      "<%= page.autoCodeFromName ? 'true' : 'false' %>" === "true";
    const pageTitle = "<%= t(page.titleKey) %>";
    const basePath = "<%= basePath %>";
    const i18nSelect = '<%= t("select") %>';
    const i18nSelected = '<%= t("selected") %>';
    const i18nAll = '<%= t("all") %>';
    const i18nSearchInput = '<%= t("search") %>';

    const setModalBodyScrollLock = (locked) => {
      if (
        typeof window !== "undefined" &&
        typeof window.setBodyScrollLock === "function"
      ) {
        window.setBodyScrollLock(Boolean(locked));
        return;
      }
      if (typeof document === "undefined" || !document.body) return;
      if (locked) {
        document.body.classList.add("overflow-hidden");
      } else {
        document.body.classList.remove("overflow-hidden");
      }
    };

    const cleanModalPath = () => {
      if (
        typeof window === "undefined" ||
        !window.history ||
        !window.location ||
        !basePath
      )
        return;
      const currentPath = window.location.pathname || "";
      if (!currentPath.startsWith(basePath)) return;
      const suffix = currentPath.slice(basePath.length);
      if (!suffix) return;
      if (/^\/\d+(\/.*)?$/.test(suffix)) {
        window.history.replaceState(null, "", basePath);
      }
    };
    cleanModalPath();

    const openModal = (mode, data, options = {}) => {
      cleanModalPath();
      if (!modal || !modalForm) return;
      const payload = data || {};
      const preserveModalError = options && options.preserveModalError === true;
      const toSelectedList = (rawValue) => {
        if (Array.isArray(rawValue)) {
          return rawValue
            .map((value) => String(value || "").trim())
            .filter(Boolean);
        }
        if (rawValue && typeof rawValue === "object") {
          return Object.values(rawValue)
            .map((value) => String(value || "").trim())
            .filter(Boolean);
        }
        const text = String(rawValue || "").trim();
        if (!text) return [];
        return text
          .split(",")
          .map((value) => value.trim())
          .filter(Boolean);
      };
      // Populate modal fields from row data (or defaults on create).
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      setModalBodyScrollLock(true);
      modal.dataset.mode = mode;
      modalTitle.textContent =
        mode === "edit"
          ? i18n.edit + " " + pageTitle
          : i18n.add + " " + pageTitle;
      modalForm.setAttribute("action", payload.action || basePath);
      modal.dataset.currentId = payload.id || "";
      modalForm.querySelectorAll("[data-field]").forEach((input) => {
        const name = input.getAttribute("data-field");
        if (input.type === "checkbox") {
          if (input.dataset.multi === "true") {
            const selected = toSelectedList(payload[name]);
            input.checked = selected.includes(input.value);
          } else {
            input.checked = payload[name] === "true" || payload[name] === true;
          }
        } else if (input.tagName === "SELECT" && input.multiple) {
          const selected = toSelectedList(payload[name]);
          Array.from(input.options).forEach((option) => {
            option.selected = selected.includes(option.value);
          });
        } else {
          const hasPayloadValue = Object.prototype.hasOwnProperty.call(
            payload,
            name,
          );
          const defaultValue =
            mode === "create" && name === "status" ? "active" : "";
          input.value = hasPayloadValue ? payload[name] || "" : defaultValue;
          if (input.tagName === "SELECT") {
            input.dispatchEvent(new Event("change", { bubbles: true }));
          }
        }
      });
      modalForm.querySelectorAll("[data-hide-on-create]").forEach((node) => {
        const hideNode = mode === "create";
        if (hideNode) {
          node.classList.add("hidden");
        } else {
          node.classList.remove("hidden");
        }
        const controls = node.querySelectorAll("[data-field]");
        controls.forEach((control) => {
          if (!(control instanceof HTMLElement)) return;
          const searchableInput = control
            .closest("[data-searchable-wrapper]")
            ?.querySelector('input[type="text"]');
          if (hideNode) {
            control.setAttribute("disabled", "disabled");
            control.removeAttribute("required");
            if (searchableInput instanceof HTMLInputElement) {
              searchableInput.disabled = true;
              searchableInput.removeAttribute("required");
            }
          } else {
            control.removeAttribute("disabled");
            if (control.hasAttribute("data-required")) {
              control.setAttribute("required", "required");
            }
            if (searchableInput instanceof HTMLInputElement) {
              searchableInput.disabled = false;
              if (control.hasAttribute("data-required")) {
                searchableInput.setAttribute("required", "required");
              }
            }
          }
        });
      });
      modalForm.querySelectorAll('[data-field="code"]').forEach((input) => {
        if (mode === "edit") {
          input.disabled = true;
          input.readOnly = true;
          input.classList.add("cursor-not-allowed");
        } else {
          input.disabled = false;
          input.readOnly = false;
          input.classList.remove("cursor-not-allowed");
        }
      });
      if (modalError && !preserveModalError) {
        modalError.textContent = "";
        modalError.hidden = true;
        modalError.dataset.alertShown = "";
      }
      if (auditPanel && mode === "edit") {
        auditPanel.hidden = false;
        if (auditCreated) {
          auditCreated.textContent = payload.created_at
            ? formatDisplayDate(payload.created_at) +
              (payload.created_by ? " by " + payload.created_by : "")
            : "-";
        }
        if (auditUpdated) {
          auditUpdated.textContent = payload.updated_at
            ? formatDisplayDate(payload.updated_at) +
              (payload.updated_by ? " by " + payload.updated_by : "")
            : "-";
        }
      } else if (auditPanel) {
        auditPanel.hidden = true;
      }
      if (mode === "create" && autoCodeEnabled) {
        const codeInput = modalForm.querySelector('[data-field="code"]');
        if (codeInput) {
          codeInput.dataset.userEdited = "false";
        }
      }
      refreshMultiSelects();
      document.dispatchEvent(
        new CustomEvent("modal:opened", { detail: { mode } }),
      );
    };

    const closeModal = () => {
      if (!modal) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      setModalBodyScrollLock(false);
      cleanModalPath();
    };
    const showModalErrorAlertIfAny = () => {
      if (!modalError || modalError.hidden) return;
      const message = String(modalError.textContent || "").trim();
      if (!message || modalError.dataset.alertShown === "1") return;
      modalError.dataset.alertShown = "1";
      if (typeof window.showVoucherError === "function") {
        window.showVoucherError(message);
      }
    };
    const setModalError = (message) => {
      if (!modalError) return;
      const text = String(message || "").trim();
      modalError.textContent = text;
      modalError.hidden = !text;
      modalError.dataset.alertShown = "";
      showModalErrorAlertIfAny();
    };

    const openConfirm = (title, message, action) => {
      if (!confirmModal || !confirmForm) return;
      confirmTitle.textContent = title || i18n.confirm;
      confirmMessage.textContent = message || '<%= t("are_you_sure") %>';
      confirmForm.setAttribute("action", action || "");
      confirmModal.classList.remove("hidden");
      confirmModal.classList.add("flex");
    };

    const closeConfirm = () => {
      if (!confirmModal) return;
      confirmModal.classList.add("hidden");
      confirmModal.classList.remove("flex");
    };

    const table = document.querySelector("[data-table]");
    const scopeKey = "<%= page.scopeKey %>";
    const isLabourRates = scopeKey === "hr_payroll.labour_rates";
    const isCommissions = scopeKey === "hr_payroll.commissions";
    const isGroupedRatesTable = isLabourRates || isCommissions;
    const printArea = document.querySelector("[data-print-area]");
    if (printArea && isGroupedRatesTable) {
      printArea.setAttribute("data-grouped-table-ready", "false");
    }
    const serverPaginationEnabled =
      table?.dataset?.serverPagination === "true";
    const serverPageInitialRaw = Number.parseInt(
      String(table?.dataset?.serverPage || "1"),
      10,
    );
    const serverPageInitial =
      Number.isInteger(serverPageInitialRaw) && serverPageInitialRaw > 0
        ? serverPageInitialRaw
        : 1;
    const serverOffsetRaw = Number.parseInt(
      String(table?.dataset?.serverOffset || "0"),
      10,
    );
    const serverOffset =
      Number.isInteger(serverOffsetRaw) && serverOffsetRaw >= 0
        ? serverOffsetRaw
        : 0;
    const serverHasPrevPage = table?.dataset?.serverHasPrev === "true";
    const serverHasNextPage = table?.dataset?.serverHasNext === "true";
    const serverTotalRaw = Number.parseInt(
      String(table?.dataset?.serverTotal || "0"),
      10,
    );
    const serverTotal =
      Number.isInteger(serverTotalRaw) && serverTotalRaw >= 0
        ? serverTotalRaw
        : 0;

    const navigateServerPage = (nextPage) => {
      const page = Number(nextPage);
      if (!Number.isFinite(page) || page < 1) return;
      const url = new URL(window.location.href);
      if (page <= 1) {
        url.searchParams.delete("list_page");
      } else {
        url.searchParams.set("list_page", String(Math.floor(page)));
      }
      window.location.assign(url.toString());
    };

    let currentPage = serverPaginationEnabled ? serverPageInitial : 1;
    let pageSizeRaw = (pageSizeSelect && pageSizeSelect.value) || "10";
    if (isLabourRates && pageSizeSelect) {
      pageSizeRaw = "all";
      pageSizeSelect.value = "all";
    }
    let pageSize =
      pageSizeRaw === "all" ? Number.POSITIVE_INFINITY : Number(pageSizeRaw);
    let sortIndex = null;
    let sortDir = "asc";
    let sortType = "text";
    let rowsCache = [];
    let filterApplyTimer = null;
    const labourGroupOpenKeys = new Set();
    let labourGroupVisibleRows = [];

    const getRows = () => rowsCache;

    const getLabourGroupKey = (row) => {
      if (!row) return "";
      const explicit = String(row.dataset.groupName || "").trim();
      if (explicit) return explicit;
      const label = String(row.dataset.labourName || "").trim();
      if (label) return label;
      const fallback = String(row.dataset.labourId || "").trim();
      return fallback || "<%= t("none") %>";
    };

    const removeLabourGroupHeaders = () => {
      document.querySelectorAll("tr.group-header").forEach((row) => {
        row.remove();
      });
    };

    const buildLabourGroupHeader = ({
      groupKey,
      count,
      colspan,
      isOpen,
    }) => {
      const row = document.createElement("tr");
      row.className =
        "group group-header cursor-pointer bg-slate-50/80 text-slate-700 transition-colors hover:bg-slate-100 border-b border-slate-200";
      row.dataset.groupKey = groupKey;
      row.dataset.groupOpen = isOpen ? "true" : "false";

      const cell = document.createElement("td");
      cell.colSpan = colspan;
      cell.className = "px-4 py-3";

      const wrapper = document.createElement("div");
      wrapper.className = "flex items-center justify-between gap-4";

      const left = document.createElement("div");
      left.className = "flex items-center gap-3";

      const name = document.createElement("span");
      name.className = "text-sm font-semibold text-slate-700";
      name.textContent = groupKey;

      const countBadge = document.createElement("span");
      countBadge.className =
        "rounded-full border border-slate-200 bg-white px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-500";
      countBadge.textContent = `${count} <%= t("rates") %>`;

      left.appendChild(name);
      left.appendChild(countBadge);

      const iconWrap = document.createElement("span");
      iconWrap.className =
        "inline-flex h-8 w-8 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-600 transition group-hover:border-slate-300";
      iconWrap.setAttribute("data-labour-group-icon-wrap", "true");

      const iconShell = document.createElement("span");
      iconShell.className = "inline-flex";
      iconShell.innerHTML =
        '<svg class="h-4 w-4 transition-transform duration-200" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" data-labour-group-icon><path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path></svg>';
      const svg = iconShell.querySelector("svg");
      if (svg && isOpen) svg.classList.add("rotate-180");

      iconWrap.appendChild(iconShell);
      wrapper.appendChild(left);
      wrapper.appendChild(iconWrap);
      cell.appendChild(wrapper);
      row.appendChild(cell);
      return row;
    };

    const getGroupRows = (header) => {
      const rows = [];
      let node = header.nextElementSibling;
      while (node && !node.classList.contains("group-header")) {
        if (node.matches("[data-row]")) rows.push(node);
        node = node.nextElementSibling;
      }
      return rows;
    };

    const setGroupOpenState = (header, open) => {
      if (!header) return;
      header.dataset.groupOpen = open ? "true" : "false";
      const icon = header.querySelector("[data-labour-group-icon]");
      if (icon) icon.classList.toggle("rotate-180", open);
      if (isCommissions) {
        // For commissions, individual rows are managed by the rate sub-group toggle.
        // Here we only show/hide the synthetic sub-header rows for this employee group.
        getCommissionSubHeaders(header).forEach((sh) => {
          sh.classList.toggle("hidden", !open);
          // When closing, also hide the children of any expanded sub-group
          if (!open) {
            const subKey = sh.dataset.commissionSubKey || "";
            tableBody.querySelectorAll(`[data-commission-sub-group="${CSS.escape(subKey)}"]`).forEach((child) => {
              child.classList.add("hidden");
            });
          }
        });
        return;
      }
      getGroupRows(header).forEach((row) => {
        if (row.dataset.filterVisible !== "true") return;
        row.classList.toggle("hidden", !open);
      });
    };

    const applyLabourRatesGrouping = (visibleRows = []) => {
      if (!tableBody) return;
      removeLabourGroupHeaders();
      labourGroupVisibleRows = Array.isArray(visibleRows)
        ? visibleRows.slice()
        : [];
      if (!labourGroupVisibleRows.length) return;

      const groupCounts = new Map();
      labourGroupVisibleRows.forEach((row) => {
        const key = getLabourGroupKey(row);
        groupCounts.set(key, (groupCounts.get(key) || 0) + 1);
      });

      Array.from(labourGroupOpenKeys).forEach((key) => {
        if (!groupCounts.has(key)) labourGroupOpenKeys.delete(key);
      });

      const colspan =
        table?.querySelectorAll("thead th").length || 1;
      let lastKey = null;
      labourGroupVisibleRows.forEach((row) => {
        const key = getLabourGroupKey(row);
        if (key === lastKey) return;
        lastKey = key;
        const header = buildLabourGroupHeader({
          groupKey: key,
          count: groupCounts.get(key) || 0,
          colspan,
          isOpen: labourGroupOpenKeys.has(key),
        });
        tableBody.insertBefore(header, row);
      });

      tableBody
        .querySelectorAll("tr.group-header")
        .forEach((header) => {
          const key = header.dataset.groupKey || "";
          setGroupOpenState(header, labourGroupOpenKeys.has(key));
        });
    };

    // Tracks which commission rate sub-groups are expanded (key = empGroup||rateType||rateAmount)
    const commissionSubGroupKeys = new Set();

    const getCommissionSubHeaders = (empGroupHeader) => {
      const headers = [];
      let node = empGroupHeader.nextElementSibling;
      while (node && !node.classList.contains("group-header")) {
        if (node.classList.contains("commission-sub-header")) headers.push(node);
        node = node.nextElementSibling;
      }
      return headers;
    };

    // scopeInfoList: [{ applyOn: "SUBGROUP"|"GROUP", selectorDisplay: "Nike" }, ...]
    const buildCommissionSubHeader = ({ subKey, commissionType, rateType, rateAmount, count, colspan, isOpen, scopeInfoList }) => {
      const tr = document.createElement("tr");
      tr.className = "commission-sub-header hidden cursor-pointer border-b border-slate-100 bg-indigo-50/50 hover:bg-indigo-100/60 transition-colors";
      tr.dataset.commissionSubKey = subKey;

      const td = document.createElement("td");
      td.colSpan = colspan;
      td.className = "px-4 py-2.5 pl-10";

      const wrap = document.createElement("div");
      wrap.className = "flex items-center gap-2 flex-wrap";

      // Arrow icon
      const iconWrap = document.createElement("span");
      iconWrap.className = "inline-flex mr-1";
      iconWrap.innerHTML =
        '<svg data-commission-sub-icon class="h-3.5 w-3.5 text-indigo-500 transition-transform duration-150 ' +
        (isOpen ? "rotate-180" : "") +
        '" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5">' +
        '<path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      wrap.appendChild(iconWrap);

      // Commission type badge
      if (commissionType) {
        const ctColorMap = {
          SALESMAN_SALE: "border-blue-200 bg-blue-50 text-blue-700",
          BRANCH_SALE: "border-violet-200 bg-violet-50 text-violet-700",
          TRANSFER: "border-amber-200 bg-amber-50 text-amber-700",
          PARTY: "border-emerald-200 bg-emerald-50 text-emerald-700",
        };
        const ctLabelMap = {
          SALESMAN_SALE: "<%- t('commission_type_salesman_sale') || "Salesman's Sale" %>",
          BRANCH_SALE: "<%- t('commission_type_branch_sale') || 'Branch Sale' %>",
          TRANSFER: "<%- t('commission_type_transfer') || 'Transfer' %>",
          PARTY: "<%- t('commission_type_party') || 'Party' %>",
        };
        const ctBadge = document.createElement("span");
        ctBadge.className =
          "inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.1em] " +
          (ctColorMap[commissionType] || "border-slate-200 bg-white text-slate-600");
        ctBadge.textContent = ctLabelMap[commissionType] || commissionType;
        wrap.appendChild(ctBadge);

        const ctSep = document.createElement("span");
        ctSep.className = "text-slate-300 text-xs font-light";
        ctSep.textContent = "•";
        wrap.appendChild(ctSep);
      }

      // Scope badges: one per unique apply_on + selectorDisplay
      if (scopeInfoList && scopeInfoList.length) {
        scopeInfoList.forEach(({ applyOn, selectorDisplay }) => {
          const applyOnLabel =
            applyOn === "SUBGROUP"
              ? "<%= t('apply_on_subgroup') || 'Subgroup' %>"
              : applyOn === "GROUP"
                ? "<%= t('apply_on_group') || 'Group' %>"
                : applyOn;
          const scopeBadge = document.createElement("span");
          scopeBadge.className =
            "inline-flex items-center gap-1 rounded-full border border-violet-200 bg-violet-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-violet-700";
          scopeBadge.textContent = applyOnLabel + ": " + selectorDisplay;
          wrap.appendChild(scopeBadge);
        });

        // Separator
        const sep = document.createElement("span");
        sep.className = "text-slate-300 text-xs font-light";
        sep.textContent = "•";
        wrap.appendChild(sep);
      }

      // Rate type + amount label
      const rateTypeLabel =
        rateType === "PER_DOZEN"
          ? "<%= t('rate_type_per_dozen') %>"
          : rateType === "PER_PAIR"
            ? "<%= t('rate_type_per_pair') %>"
            : rateType || "—";
      const label = document.createElement("span");
      label.className = "text-xs font-semibold text-indigo-700";
      label.textContent = rateTypeLabel + "  —  " + (rateAmount || "—");
      wrap.appendChild(label);

      // SKU count badge
      const badge = document.createElement("span");
      badge.className =
        "rounded-full border border-indigo-200 bg-white px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-indigo-500 ml-1";
      badge.textContent = count + " <%= t('skus') || 'SKUs' %>";
      wrap.appendChild(badge);

      td.appendChild(wrap);
      tr.appendChild(td);

      tr.addEventListener("click", () => {
        const wasOpen = commissionSubGroupKeys.has(subKey);
        if (wasOpen) commissionSubGroupKeys.delete(subKey);
        else commissionSubGroupKeys.add(subKey);
        const nowOpen = !wasOpen;
        const svgIcon = tr.querySelector("[data-commission-sub-icon]");
        if (svgIcon) svgIcon.classList.toggle("rotate-180", nowOpen);
        tableBody.querySelectorAll(`[data-commission-sub-group="${CSS.escape(subKey)}"]`).forEach((child) => {
          if (child.dataset.filterVisible !== "true") return;
          child.classList.toggle("hidden", !nowOpen);
        });
      });

      return tr;
    };

    const applyCommissionSubGrouping = () => {
      if (!isCommissions || !tableBody) return;

      // Remove synthetic sub-headers from previous run
      tableBody.querySelectorAll("tr.commission-sub-header").forEach((r) => r.remove());

      // Reset sub-group markers
      tableBody.querySelectorAll("[data-row]").forEach((r) => {
        delete r.dataset.commissionSubGroup;
        r.classList.remove("commission-rule-child");
      });

      const colspan = table?.querySelectorAll("thead th").length || 1;

      // For each employee group, sub-group its rows by (rate_type + value)
      tableBody.querySelectorAll("tr.group-header").forEach((empHeader) => {
        const empKey = String(empHeader.dataset.groupKey || "");
        const empIsOpen = empHeader.dataset.groupOpen === "true";

        const empRows = getGroupRows(empHeader).filter((r) => r.dataset.filterVisible === "true");
        if (!empRows.length) return;

        // Build groups keyed by commission_type||rate_type||value (within this employee)
        const groups = new Map();
        empRows.forEach((row) => {
          const commissionType = row.dataset.commissionType || "";
          const rateType = row.dataset.rateType || "";
          const rateAmount = row.dataset.rateAmount || "";
          const subKey = empKey + "||" + commissionType + "||" + rateType + "||" + rateAmount;
          if (!groups.has(subKey)) groups.set(subKey, { commissionType, rateType, rateAmount, rows: [] });
          groups.get(subKey).rows.push(row);
        });

        // Mark rows as children and insert sub-header before each group's first row
        groups.forEach(({ commissionType, rateType, rateAmount, rows: groupRows }, subKey) => {
          const subIsOpen = commissionSubGroupKeys.has(subKey);

          // Extract scope info to show "SUBGROUP: Ballman" etc. on the sub-header.
          // Priority 1: SUBGROUP/GROUP rule rows within this group (have selector_display set)
          // Priority 2: Item-level subgroup/group of SKU rows (sku_subgroup_name / sku_group_name)
          const scopeInfoSeen = new Set();
          const scopeInfoList = [];

          // Priority 1: explicit scope rule rows
          groupRows.forEach((row) => {
            const ao = (row.dataset.applyOn || "").toUpperCase();
            if (ao !== "SUBGROUP" && ao !== "GROUP") return;
            const display = row.dataset.selectorDisplay || "";
            if (!display) return;
            const key = ao + "||" + display;
            if (scopeInfoSeen.has(key)) return;
            scopeInfoSeen.add(key);
            scopeInfoList.push({ applyOn: ao, selectorDisplay: display });
          });

          // Priority 2: if no explicit scope rows, infer from the SKUs' item subgroup/group
          if (!scopeInfoList.length) {
            const skuSubgroups = new Set();
            const skuGroups = new Set();
            groupRows.forEach((row) => {
              const sg = row.dataset.skuSubgroupName || "";
              const pg = row.dataset.skuGroupName || "";
              if (sg) skuSubgroups.add(sg);
              if (pg) skuGroups.add(pg);
            });
            if (skuSubgroups.size === 1) {
              // All SKUs in the same subgroup — show it
              scopeInfoList.push({ applyOn: "SUBGROUP", selectorDisplay: [...skuSubgroups][0] });
            } else if (skuSubgroups.size === 0 && skuGroups.size === 1) {
              // All SKUs in the same group — show group
              scopeInfoList.push({ applyOn: "GROUP", selectorDisplay: [...skuGroups][0] });
            }
            // If SKUs span multiple subgroups, show nothing (rate info alone is displayed)
          }

          groupRows.forEach((row) => {
            row.dataset.commissionSubGroup = subKey;
            row.classList.add("commission-rule-child");
            // Visible only when: employee group open AND this sub-group expanded
            row.classList.toggle("hidden", !(empIsOpen && subIsOpen));
          });

          const subHeader = buildCommissionSubHeader({
            subKey,
            commissionType,
            rateType,
            rateAmount,
            count: groupRows.length,
            colspan,
            isOpen: subIsOpen,
            scopeInfoList,
          });
          // Sub-header visible only when employee group is open
          if (empIsOpen) subHeader.classList.remove("hidden");
          tableBody.insertBefore(subHeader, groupRows[0]);
        });
      });
    };

    const buildRowSearchText = (row) =>
      String(
        row?.dataset?.search ||
          `${row?.dataset?.code || ""} ${row?.dataset?.name || ""} ${row?.dataset?.nameUr || ""} ${row?.textContent || ""}`,
      )
        .replace(/\s+/g, " ")
        .trim()
        .toLowerCase();

    const initializeRows = () => {
      rowsCache = Array.from(document.querySelectorAll("[data-row]"));
      rowsCache.forEach((row, index) => {
        if (!row.dataset.origIndex) {
          row.dataset.origIndex = String(index);
        }
        if (!row.dataset.searchNormalized) {
          row.dataset.searchNormalized = buildRowSearchText(row);
        }
      });
    };

    const normalizeValue = (value, type) => {
      const trimmed = (value || "").trim();
      if (!trimmed) return type === "number" ? 0 : "";
      if (type === "number") {
        const numberValue = Number(trimmed.replace(/[^0-9.-]+/g, ""));
        return Number.isNaN(numberValue) ? 0 : numberValue;
      }
      if (type === "date") {
        const dateValue = Date.parse(trimmed);
        return Number.isNaN(dateValue) ? 0 : dateValue;
      }
      return trimmed.toLowerCase();
    };

    const sortRows = (rows) => {
      if (sortIndex === null) {
        return rows.slice().sort((a, b) => {
          const aIndex = Number(a.dataset.origIndex || 0);
          const bIndex = Number(b.dataset.origIndex || 0);
          return aIndex - bIndex;
        });
      }

      const sorted = rows.slice().sort((a, b) => {
        const aCells = a.querySelectorAll("td");
        const bCells = b.querySelectorAll("td");
        const aCell = aCells[sortIndex];
        const bCell = bCells[sortIndex];
        const aRaw = aCell
          ? aCell.getAttribute("data-sort-value") || aCell.textContent
          : "";
        const bRaw = bCell
          ? bCell.getAttribute("data-sort-value") || bCell.textContent
          : "";
        const aValue = normalizeValue(aRaw, sortType);
        const bValue = normalizeValue(bRaw, sortType);
        if (aValue < bValue) return sortDir === "asc" ? -1 : 1;
        if (aValue > bValue) return sortDir === "asc" ? 1 : -1;
        const aIndex = Number(a.dataset.origIndex || 0);
        const bIndex = Number(b.dataset.origIndex || 0);
        return aIndex - bIndex;
      });

      if (tableBody) {
        sorted.forEach((row) => tableBody.appendChild(row));
      }
      return sorted;
    };

    const updateSortIndicators = () => {
      sortButtons.forEach((btn) => {
        const indicator = btn.querySelector("[data-sort-indicator]");
        if (!indicator) return;
        if (Number(btn.dataset.sortIndex) === sortIndex) {
          indicator.textContent = sortDir === "asc" ? "▲" : "▼";
        } else {
          indicator.textContent = "↕";
        }
      });
    };

    const applyFilters = () => {
      // Filter, sort, and paginate rows in-memory for fast UI updates.
      const query = ((searchInput && searchInput.value) || "")
        .trim()
        .toLowerCase();
      const status = statusFilter ? statusFilter.value || "active" : "all";
      const accountTypeFilters = getFilterValues("[data-filter-account-type]");
      const accountGroupFilters = getFilterValues(
        "[data-filter-account-group]",
      );
      const partyTypeFilters = getFilterValues("[data-filter-party-type]");
      const partyGroupFilters = getFilterValues("[data-filter-party-group]");
      const branchFilters = getFilterValues("[data-filter-branch]");
      const cityFilters = getFilterValues("[data-filter-city]");
      const createdByValue = (
        filterCreatedBy && filterCreatedBy.value ? filterCreatedBy.value : ""
      ).trim();
      const subgroupValue = (
        filterSubgroup && filterSubgroup.value ? filterSubgroup.value : ""
      ).trim();
      const createdAtStart = filterCreatedAtStart
        ? filterCreatedAtStart.value
        : "";
      const createdAtEnd = filterCreatedAtEnd ? filterCreatedAtEnd.value : "";
      const readFilterRows = (key) => {
        const rows = Array.from(
          document.querySelectorAll(
            `[data-filter-list="${key}"] [data-filter-${key}], [data-filter-list="${key}"] [data-filter-${key.replace("-", "_")}]`,
          ),
        );
        const list = document.querySelector(`[data-filter-list="${key}"]`);
        if (!list) return { include: [], exclude: [] };
        const selects = Array.from(
          list.querySelectorAll(`[data-filter-${key}]`),
        );
        const modes = Array.from(
          list.querySelectorAll(`[data-filter-${key}-mode]`),
        );
        const include = [];
        const exclude = [];
        selects.forEach((select, idx) => {
          const value = (select.value || "").trim();
          if (!value) return;
          const mode = (modes[idx] && modes[idx].value) || "include";
          if (mode === "exclude") {
            exclude.push(value);
          } else {
            include.push(value);
          }
        });
        return { include, exclude };
      };
      const accountTypeModes = readFilterRows("account-type");
      const accountGroupModes = readFilterRows("account-group");
      const partyTypeModes = readFilterRows("party-type");
      const partyGroupModes = readFilterRows("party-group");
      const branchModes = readFilterRows("branch");
      const cityModes = readFilterRows("city");
      const rows = getRows();
      if (isGroupedRatesTable) {
        removeLabourGroupHeaders();
      }
      const sorted = sortRows(rows);
      const filtered = sorted.filter((row) => {
        const searchText = row.dataset.searchNormalized || "";
        const matchesText = !query || searchText.includes(query);
        if (!matchesText) return false;
        if (status !== "all") {
          const isActive = row.dataset.active === "true";
          if (status === "active" ? !isActive : isActive) return false;
        }
        if (accountTypeModes.include.length) {
          const matches = accountTypeModes.include.includes(
            row.dataset.accountType || "",
          );
          if (!matches) return false;
        }
        if (accountTypeModes.exclude.length) {
          const matches = accountTypeModes.exclude.includes(
            row.dataset.accountType || "",
          );
          if (matches) return false;
        }
        if (accountGroupModes.include.length) {
          const matches = accountGroupModes.include.includes(
            row.dataset.accountGroup || "",
          );
          if (!matches) return false;
        }
        if (accountGroupModes.exclude.length) {
          const matches = accountGroupModes.exclude.includes(
            row.dataset.accountGroup || "",
          );
          if (matches) return false;
        }
        if (partyTypeModes.include.length) {
          const matches = partyTypeModes.include.includes(
            row.dataset.partyType || "",
          );
          if (!matches) return false;
        }
        if (partyTypeModes.exclude.length) {
          const matches = partyTypeModes.exclude.includes(
            row.dataset.partyType || "",
          );
          if (matches) return false;
        }
        if (partyGroupModes.include.length) {
          const matches = partyGroupModes.include.includes(
            row.dataset.partyGroup || "",
          );
          if (!matches) return false;
        }
        if (partyGroupModes.exclude.length) {
          const matches = partyGroupModes.exclude.includes(
            row.dataset.partyGroup || "",
          );
          if (matches) return false;
        }
        if (cityModes.include.length) {
          const matches = cityModes.include.includes(row.dataset.city || "");
          if (!matches) return false;
        }
        if (cityModes.exclude.length) {
          const matches = cityModes.exclude.includes(row.dataset.city || "");
          if (matches) return false;
        }
        if (branchModes.include.length || branchModes.exclude.length) {
          const branches = (row.dataset.branch || "")
            .split(",")
            .map((value) => value.trim())
            .filter(Boolean);
          if (branchModes.include.length) {
            const matches = branchModes.include.some((value) =>
              branches.includes(value),
            );
            if (!matches) return false;
          }
          if (branchModes.exclude.length) {
            const matches = branchModes.exclude.some((value) =>
              branches.includes(value),
            );
            if (matches) return false;
          }
        }
        if (createdByValue) {
          const matches = (row.dataset.createdBy || "") === createdByValue;
          if (!matches) return false;
        }
        if (subgroupValue) {
          const matches = (row.dataset.subgroupId || "") === subgroupValue;
          if (!matches) return false;
        }
        if (createdAtStart || createdAtEnd) {
          const rowDateValue = row.dataset.createdAt || "";
          const rowTime = Date.parse(rowDateValue);
          if (Number.isNaN(rowTime)) return false;
          if (createdAtStart) {
            const startTime = Date.parse(createdAtStart);
            if (!Number.isNaN(startTime) && rowTime < startTime) return false;
          }
          if (createdAtEnd) {
            const endTime = Date.parse(createdAtEnd);
            if (!Number.isNaN(endTime) && rowTime > endTime) return false;
          }
        }
        return true;
      });

      let totalPages;
      let start;
      let end;
      if (!Number.isFinite(pageSize)) {
        // 'All' selected: show all rows, avoid arithmetic with Infinity which yields NaN
        totalPages = 1;
        currentPage =
          serverPaginationEnabled && !Number.isFinite(pageSize)
            ? serverPageInitial
            : 1;
        start = 0;
        end = filtered.length;
      } else {
        totalPages = Math.max(1, Math.ceil(filtered.length / pageSize));
        currentPage = Math.min(currentPage, totalPages);
        start = (currentPage - 1) * pageSize;
        end = start + pageSize;
      }

      rows.forEach((row) => {
        row.classList.add("hidden");
        row.dataset.filterVisible = "false";
      });
      const visibleRows = filtered.slice(start, end);
      visibleRows.forEach((row) => {
        row.classList.remove("hidden");
        row.dataset.filterVisible = "true";
      });

      if (isGroupedRatesTable) {
        applyLabourRatesGrouping(visibleRows);
        if (isCommissions) applyCommissionSubGrouping();
      }

      if (printArea && isGroupedRatesTable) {
        printArea.setAttribute("data-grouped-table-ready", "true");
      }

      // --- HIDE EMPTY GROUPS (SKU PAGE) ---
      document.querySelectorAll(".sku-group-block").forEach((group) => {
        const groupRows = group.querySelectorAll("tr[data-row]");
        const anyVisible = Array.from(groupRows).some(
          (r) => !r.classList.contains("hidden"),
        );
        group.style.display = anyVisible ? "" : "none";
      });

      if (pageIndicator) {
        pageIndicator.textContent = String(currentPage);
      }
      if (prevButton) {
        const disablePrev =
          serverPaginationEnabled && !Number.isFinite(pageSize)
            ? !serverHasPrevPage
            : currentPage <= 1;
        prevButton.disabled = disablePrev;
        prevButton.classList.toggle("opacity-40", disablePrev);
      }
      if (nextButton) {
        const disableNext =
          serverPaginationEnabled && !Number.isFinite(pageSize)
            ? !serverHasNextPage
            : currentPage >= totalPages;
        nextButton.disabled = disableNext;
        nextButton.classList.toggle("opacity-40", disableNext);
      }

      const showing = document.querySelector("[data-showing-count]");
      if (showing) {
        const startLabel =
          filtered.length === 0
            ? 0
            : serverPaginationEnabled && !Number.isFinite(pageSize)
              ? serverOffset + 1
              : start + 1;
        const endLabel =
          serverPaginationEnabled && !Number.isFinite(pageSize)
            ? serverOffset + visibleRows.length
            : Math.min(start + visibleRows.length, filtered.length);
        const totalLabel =
          serverPaginationEnabled && serverTotal > 0
            ? serverTotal
            : filtered.length;
        showing.textContent =
          i18n.showing +
          " " +
          startLabel +
          " " +
          i18n.to +
          " " +
          endLabel +
          " " +
          i18n.of +
          " " +
          totalLabel +
          " " +
          i18n.entries;
      }
    };

    const scheduleApplyFilters = ({ resetPage = false, delay = 0 } = {}) => {
      if (resetPage) currentPage = 1;
      if (filterApplyTimer) {
        window.clearTimeout(filterApplyTimer);
      }
      filterApplyTimer = window.setTimeout(
        () => {
          filterApplyTimer = null;
          applyFilters();
        },
        Math.max(0, Number(delay) || 0),
      );
    };

    const cleanText = (value) => (value || "").replace(/\s+/g, " ").trim();

    const buildExportTable = () => {
      // Export only the currently visible rows (respects filters).
      // Some pages (e.g. SKUs) render one <table>/<thead> per group inside
      // [data-table-body], so we must only read the *first* header row -
      // not every thead th in the document - or headers/columns get
      // multiplied per group and desync from the actual row cells.
      const tableBodyEl = document.querySelector("[data-table-body]");
      const theadSource =
        (tableBodyEl &&
          (tableBodyEl.tagName === "TBODY"
            ? tableBodyEl.closest("table")?.querySelector("thead")
            : tableBodyEl.querySelector("table thead"))) ||
        document.querySelector("thead");
      const headers = Array.from(
        theadSource ? theadSource.querySelectorAll("th") : [],
      )
        .map((th) => cleanText(th.textContent))
        .filter((label) => label && label.toLowerCase() !== "actions");
      const rows = getRows().filter((row) => !row.classList.contains("hidden"));
      const body = rows.map((row) =>
        Array.from(row.querySelectorAll("td"))
          .slice(0, headers.length)
          .map((cell) => {
            const datasetValue =
              cell.dataset.summaryRates || cell.dataset.summaryAvg || "";
            return cleanText(datasetValue || cell.textContent);
          }),
      );
      return { headers, body };
    };

    const downloadCsv = () => {
      const { headers, body } = buildExportTable();
      const csvRows = [headers.join(",")];
      body.forEach((cells) => {
        const line = cells.map((value, idx) => {
          // If this is the Size column, format to prevent Excel date conversion
          if (headers[idx] && headers[idx].toLowerCase().includes("size")) {
            // If value matches N/N or N-N, prefix with S-
            if (/^\d{1,2}[\/\-]\d{1,2}$/.test(value.trim())) {
              value = `S-${value.trim()}`;
            }
          }
          return `"${value.replace(/"/g, '""')}"`;
        });
        csvRows.push(line.join(","));
      });

      const csvContent = "\uFEFF" + csvRows.join("\r\n");
      const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download =
        '<%= t(page.titleKey).replace(/\\s+/g, "_") %>_export.csv';
      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
    };

    const loadPdfLibs = () => {
      if (window.jspdf?.jsPDF) return Promise.resolve(window.jspdf.jsPDF);
      if (window.__pdfLibsPromise) return window.__pdfLibsPromise;
      const loadScript = (src) =>
        new Promise((resolve, reject) => {
          const script = document.createElement("script");
          script.src = src;
          script.async = true;
          script.onload = resolve;
          script.onerror = () => reject(new Error(`Failed to load ${src}`));
          document.head.appendChild(script);
        });
      window.__pdfLibsPromise = loadScript("/vendor/jspdf.umd.min.js")
        .then(() => loadScript("/vendor/jspdf.plugin.autotable.min.js"))
        .then(() => {
          if (!window.jspdf?.jsPDF) throw new Error("jsPDF loaded without jsPDF object");
          return window.jspdf.jsPDF;
        });
      return window.__pdfLibsPromise;
    };

    const downloadPdf = () => {
      loadPdfLibs()
        .then((jsPDF) => {
          const { headers, body } = buildExportTable();
          const orientation = headers.length > 6 ? "landscape" : "portrait";
          const doc = new jsPDF({ orientation, unit: "pt", format: "a4" });
          doc.setFontSize(13);
          doc.text(pageTitle, 28, 32);
          doc.setFontSize(9);
          doc.setTextColor(100);
          doc.text(new Date().toLocaleString(), 28, 46);
          doc.autoTable({
            head: [headers],
            body,
            startY: 58,
            margin: { left: 28, right: 28 },
            styles: { fontSize: 8, cellPadding: 4, overflow: "linebreak" },
            headStyles: { fillColor: [30, 41, 59], textColor: 255 },
            alternateRowStyles: { fillColor: [248, 250, 252] },
            horizontalPageBreak: true,
            horizontalPageBreakRepeat: 0,
          });
          doc.save(
            '<%= t(page.titleKey).replace(/\\s+/g, "_") %>_export.pdf',
          );
        })
        .catch((err) => {
          console.error(err);
          window.print();
        });
    };

    const showDownloadDropdown = (anchor, onExcel, onPdf) => {
      document.querySelector("[data-dl-dropdown]")?.remove();

      const menu = document.createElement("div");
      menu.setAttribute("data-dl-dropdown", "");
      const rect = anchor.getBoundingClientRect();
      menu.style.cssText = `position:fixed;top:${rect.bottom + 4}px;left:${rect.left}px;z-index:9999;min-width:${rect.width}px;`;
      menu.className = "rounded-lg border border-slate-200 bg-white shadow-lg overflow-hidden";

      let outsideClick;
      const makeBtn = (text, onClick) => {
        const btn = document.createElement("button");
        btn.type = "button";
        btn.textContent = text;
        btn.className = "block w-full px-5 py-2.5 text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 hover:bg-slate-50 transition cursor-pointer";
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          menu.remove();
          document.removeEventListener("click", outsideClick, true);
          onClick();
        });
        return btn;
      };

      menu.appendChild(makeBtn("Excel", onExcel));
      const pdfBtn = makeBtn("PDF", onPdf);
      pdfBtn.classList.add("border-t", "border-slate-200");
      menu.appendChild(pdfBtn);
      document.body.appendChild(menu);

      outsideClick = (e) => {
        if (!menu.contains(e.target)) {
          menu.remove();
          document.removeEventListener("click", outsideClick, true);
        }
      };
      setTimeout(() => document.addEventListener("click", outsideClick, true), 0);
    };

