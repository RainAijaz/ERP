        viewCostFields: can("REPORT", "expense_trends", "view_cost_fields"),
      },
      profitability_analysis: {
        print: can("REPORT", "profitability_analysis", "print"),
        export: can("REPORT", "profitability_analysis", "export_excel_csv"),
        details: can("REPORT", "profitability_analysis", "view_details"),
        filterAllBranches: can("REPORT", "profitability_analysis", "filter_all_branches"),
