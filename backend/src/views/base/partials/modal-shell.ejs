<div 
  id="modal-shell" 
  class="fixed inset-0 z-50 <%= typeof modalOpen !== 'undefined' && modalOpen ? 'flex' : 'hidden' %> items-center justify-center p-4 overflow-x-hidden"
  style="z-index: 100;"
  role="dialog"
  aria-modal="true"
  data-modal
  data-auto-open="<%= typeof modalOpen !== 'undefined' && modalOpen ? 'true' : 'false' %>"
  data-modal-mode="<%= typeof modalMode !== 'undefined' && modalMode ? modalMode : 'create' %>"
  data-modal-values="<%= JSON.stringify(typeof modalValues !== 'undefined' && modalValues ? modalValues : {}) %>"
  data-modal-field-errors="<%= JSON.stringify(typeof modalFieldErrors !== 'undefined' && modalFieldErrors ? modalFieldErrors : {}) %>"
>
  <div class="<%= typeof modalContainerClass !== 'undefined' && modalContainerClass ? modalContainerClass : "w-full max-w-lg rounded-2xl border border-slate-200 bg-white shadow-xl relative z-50 flex max-h-[90vh] flex-col overflow-hidden" %>">
    
    <div class="<%= typeof modalHeaderClass !== 'undefined' && modalHeaderClass ? modalHeaderClass : "flex items-center justify-between border-b border-slate-200 px-6 py-4" %>">
      <div>
        <div class="text-sm font-semibold text-slate-700" data-modal-title>
          <%= typeof modalTitle !== 'undefined' ? modalTitle : '' %>
        </div>
        <% if (typeof modalDescription !== 'undefined' && modalDescription) { %>
          <div class="mt-1 text-xs text-slate-500"><%= modalDescription %></div>
        <% } %>
      </div>
      <button type="button" onclick="closeModal()" class="rounded-lg p-1 text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-colors" data-modal-close>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <% if (typeof formAction !== 'undefined' && formAction) { %>
      <form
        class="<%= typeof formClass !== 'undefined' && formClass ? formClass : "px-6 py-5" %>"
        action="<%= formAction %>"
        method="POST"
        data-modal-form
        data-translate-mode="<%= typeof translateMode !== 'undefined' && translateMode ? translateMode : 'translate' %>"
      >
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <% } %>
        <% if (typeof modalError !== 'undefined' && modalError) { %>
          <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700" data-modal-error>
            <%= modalError %>
          </div>
        <% } else { %>
          <div class="mb-4 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700" data-modal-error hidden></div>
        <% } %>
        <div class="mb-4 rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700" data-modal-notice hidden></div>
        <div class="flex-1 overflow-y-auto overflow-x-hidden" id="modal-content">
          <% if (typeof bodyPartial !== 'undefined' && bodyPartial) { %>
            <%- include(bodyPartial, { fieldErrors: (typeof modalFieldErrors !== 'undefined' && modalFieldErrors ? modalFieldErrors : {}) }) %>
          <% } %>
        </div>
        <div class="mt-6 flex items-center justify-end gap-3">
          <button type="button" class="rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 hover:text-slate-800" data-modal-close><%= typeof cancelLabel !== 'undefined' ? cancelLabel : (typeof t !== 'undefined' ? t("cancel") : "Cancel") %></button>
          <button type="submit" class="rounded-lg bg-accent px-5 py-2 text-sm font-semibold text-white"><%= typeof saveLabel !== 'undefined' ? saveLabel : (typeof t !== 'undefined' ? t("save_changes") : "Save") %></button>
        </div>
      </form>
    <% } else { %>
      <div class="flex-1 overflow-y-auto overflow-x-hidden" id="modal-content">
        <% if (typeof bodyPartial !== 'undefined' && bodyPartial) { %>
          <%- include(bodyPartial) %>
        <% } else { %>
          <div class="flex h-40 items-center justify-center">
            <svg class="h-6 w-6 animate-spin text-slate-300" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<div id="modal-backdrop" onclick="closeModal()" class="fixed inset-0 z-40 <%= typeof modalOpen !== 'undefined' && modalOpen ? '' : 'hidden' %> bg-slate-900/40 backdrop-blur-sm transition-opacity"></div>

<script>
  function setBodyScrollLock(locked) {
    if (!document || !document.body) return;
    if (locked) {
      document.body.classList.add("overflow-hidden");
    } else {
      document.body.classList.remove("overflow-hidden");
    }
  }

  function closeModal() {
    const shell = document.getElementById('modal-shell');
    const backdrop = document.getElementById('modal-backdrop');
    if(shell) {
        shell.classList.add('hidden');
        shell.classList.remove('flex');
    }
    if(backdrop) backdrop.classList.add('hidden');
    setBodyScrollLock(false);
  }

  (function(){
    const shell = document.getElementById("modal-shell");
    if (shell && !shell.classList.contains("hidden")) {
      setBodyScrollLock(true);
    }
  })();

  (function () {
    const shell = document.getElementById("modal-shell");
    const notice = shell ? shell.querySelector("[data-modal-notice]") : null;
    if (!shell || !notice) return;

    const approvalSentText = <%- JSON.stringify(typeof t === "function" ? (t("approval_sent") || "") : "") %>;
    const approvalSubmittedText = <%- JSON.stringify(typeof t === "function" ? (t("approval_submitted") || "") : "") %>;
    const noticeLabel = <%- JSON.stringify(typeof t === "function" ? (t("notice") || "Notice") : "Notice") %>;
    const fallbackLinkLabel = <%- JSON.stringify(typeof t === "function" ? (t("view_pending_approval") || "View pending approval") : "View pending approval") %>;

    const clearUiNoticeCookie = () => {
      document.cookie = "ui_notice=; Max-Age=0; Path=/; SameSite=Lax";
    };

    const showQueuedToast = ({ message = "", linkHref = "", linkLabel = "" } = {}) => {
      const fallbackQueuedMessage = approvalSentText || approvalSubmittedText || "Change request sent for approval.";
      const text = String(message || "").trim() || fallbackQueuedMessage;
      if (!document.body) return;
      document.querySelector("[data-inline-approval-toast]")?.remove();

      const wrap = document.createElement("div");
      wrap.className = "fixed right-4 top-4 z-[220] w-[92vw] max-w-sm";
      wrap.setAttribute("data-inline-approval-toast", "true");
      wrap.innerHTML = `
        <div class="flex items-start gap-3 rounded-2xl border border-emerald-200 bg-white p-4 shadow-xl">
          <div class="mt-0.5 rounded-full bg-emerald-100 p-2 text-emerald-700">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div class="flex-1" data-inline-approval-toast-content>
            <div class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">${noticeLabel}</div>
            <p class="mt-1 text-sm text-slate-700" data-inline-approval-toast-message></p>
          </div>
          <button class="text-slate-400 hover:text-slate-600" type="button" data-inline-approval-toast-close aria-label="Close">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      `;
      wrap.querySelector("[data-inline-approval-toast-message]").textContent = text;

      const href = String(linkHref || "").trim();
      if (href) {
        const anchor = document.createElement("a");
        anchor.href = href;
        anchor.className = "mt-2 inline-flex items-center gap-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-accent hover:text-accent/80";
        anchor.textContent = String(linkLabel || "").trim() || fallbackLinkLabel;
        wrap.querySelector("[data-inline-approval-toast-content]")?.appendChild(anchor);
      }

      const dismiss = () => wrap.remove();
      wrap.querySelector("[data-inline-approval-toast-close]")?.addEventListener("click", dismiss);
      document.body.appendChild(wrap);
      clearUiNoticeCookie();
      window.setTimeout(dismiss, 5000);
    };

    const handleQueuedApproval = ({ message = "", linkHref = "", linkLabel = "", closeModalShell = true } = {}) => {
      if (closeModalShell) {
        closeModal();
      }
      showQueuedToast({ message, linkHref, linkLabel });
    };

    window.handleApprovalQueuedToast = handleQueuedApproval;

    document.addEventListener("erp:approval-queued", (event) => {
      const detail = event?.detail && typeof event.detail === "object" ? event.detail : {};
      handleQueuedApproval({
        message: detail.message || "",
        linkHref: detail.linkHref || "",
        linkLabel: detail.linkLabel || "",
        closeModalShell: detail.closeModalShell !== false,
      });
    });

    const extractMessageWithoutLink = () => {
      const clone = notice.cloneNode(true);
      clone.querySelectorAll("a").forEach((node) => node.remove());
      return String(clone.textContent || "").trim();
    };

    const maybeHandleQueuedNotice = () => {
      if (notice.hidden) return;
      if (notice.dataset.approvalHandled === "1") return;
      const text = String(notice.textContent || "").trim();
      if (!text) return;

      const approvalLink = notice.querySelector("a[href]");
      const href = String(approvalLink?.getAttribute("href") || "").trim();
      const hasApprovalsLink = href.includes("/administration/approvals");
      const looksLikeApprovalMessage =
        (approvalSentText && text.includes(approvalSentText)) ||
        (approvalSubmittedText && text.includes(approvalSubmittedText));

      if (!hasApprovalsLink && !looksLikeApprovalMessage) return;

      notice.dataset.approvalHandled = "1";
      const message = extractMessageWithoutLink() || text;
      const linkLabel = String(approvalLink?.textContent || "").trim();
      notice.textContent = "";
      notice.hidden = true;

      handleQueuedApproval({
        message,
        linkHref: hasApprovalsLink ? href : "",
        linkLabel: linkLabel || fallbackLinkLabel,
        closeModalShell: true,
      });
    };

    const observer = new MutationObserver(maybeHandleQueuedNotice);
    observer.observe(notice, {
      attributes: true,
      attributeFilter: ["hidden", "class"],
      childList: true,
      subtree: true,
      characterData: true,
    });

    const shellObserver = new MutationObserver(() => {
      if (shell.classList.contains("hidden")) return;
      notice.dataset.approvalHandled = "";
    });
    shellObserver.observe(shell, { attributes: true, attributeFilter: ["class"] });
  })();
</script>
