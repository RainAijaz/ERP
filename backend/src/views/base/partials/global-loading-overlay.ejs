<style>
  .erp-loading-overlay {
    position: absolute;
    inset: 0;
    z-index: 70;
    display: flex;
    justify-content: center;
    background: rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(1px);
  }

  .erp-loading-overlay[data-context="table"] {
    align-items: flex-start;
    padding-top: 3.25rem;
  }

  .erp-loading-overlay[data-context="report"] {
    align-items: center;
  }

  .erp-loading-overlay[data-context="page"] {
    position: fixed;
    z-index: 120;
    align-items: center;
  }

  .erp-loading-card {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid #e2e8f0;
    border-radius: 999px;
    padding: 0.5rem 0.85rem;
    background: #ffffff;
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.1);
  }

  .erp-loading-overlay[data-context="report"] .erp-loading-card {
    padding: 0.65rem 1rem;
    gap: 0.75rem;
  }

  .erp-loading-overlay[data-context="page"] .erp-loading-card {
    padding: 0.75rem 1.1rem;
    gap: 0.8rem;
  }

  .erp-loading-spinner {
    width: 1rem;
    height: 1rem;
    border-radius: 999px;
    border: 2px solid #cbd5e1;
    border-top-color: #0f172a;
    animation: erp-loading-spin 0.8s linear infinite;
    flex: 0 0 auto;
  }

  .erp-loading-overlay[data-context="table"] .erp-loading-spinner {
    width: 1rem;
    height: 1rem;
  }

  .erp-loading-overlay[data-context="report"] .erp-loading-spinner {
    width: 1.15rem;
    height: 1.15rem;
  }

  .erp-loading-overlay[data-context="page"] .erp-loading-spinner {
    width: 1.35rem;
    height: 1.35rem;
    border-width: 3px;
  }

  .erp-loading-text {
    font-size: 0.72rem;
    line-height: 1rem;
    font-weight: 700;
    letter-spacing: 0.11em;
    text-transform: uppercase;
    color: #334155;
    white-space: nowrap;
  }

  .erp-loading-overlay[data-context="report"] .erp-loading-text {
    font-size: 0.76rem;
  }

  .erp-loading-overlay[data-context="page"] .erp-loading-text {
    font-size: 0.8rem;
  }

  @keyframes erp-loading-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  (function () {
    const i18nLoading = <%- JSON.stringify(String(t("loading") || "Loading")) %>;
    const overlays = new Set();

    const isElement = (node) => node instanceof HTMLElement;

    const ensureRelativePosition = (target) => {
      if (!isElement(target) || target === document.body) return;
      const computed = window.getComputedStyle(target);
      if (computed.position === "static") target.style.position = "relative";
    };

    const resolveContext = (preferred, target) => {
      const value = String(preferred || "").trim().toLowerCase();
      if (value === "table" || value === "report" || value === "page")
        return value;
      if (target === document.body) return "page";
      if (
        target?.matches?.("[data-print-area], [data-report-area]") ||
        target?.querySelector?.("[data-report-controls], [data-print-report]")
      ) {
        return "report";
      }
      return "table";
    };

    const findTableTarget = (fromElement) => {
      if (isElement(fromElement)) {
        const local = fromElement.closest(
          "[data-print-area], section, [data-table], [data-table-controls]",
        );
        if (isElement(local)) return local;
      }
      const table = document.querySelector("[data-table]");
      if (isElement(table)) return table.closest("section") || table;
      return document.body;
    };

    const findReportTarget = (fromElement) => {
      if (isElement(fromElement)) {
        const local = fromElement.closest("[data-print-area], [data-report-area], section");
        if (isElement(local)) return local;
      }
      const reportArea = document.querySelector("[data-print-area], [data-report-area]");
      if (isElement(reportArea)) return reportArea;
      return document.body;
    };

    const buildOverlay = ({ context, target }) => {
      const overlay = document.createElement("div");
      overlay.className = "erp-loading-overlay";
      overlay.setAttribute("data-context", context);
      overlay.setAttribute("data-global-loading-overlay", "true");
      overlay.innerHTML = `
        <div class="erp-loading-card" role="status" aria-live="polite">
          <span class="erp-loading-spinner" aria-hidden="true"></span>
          <span class="erp-loading-text">${i18nLoading}</span>
        </div>
      `;
      ensureRelativePosition(target);
      target.appendChild(overlay);
      overlays.add(overlay);
      return overlay;
    };

    const showLoading = ({
      context = "",
      target = null,
      source = null,
    } = {}) => {
      const preferredTarget = isElement(target)
        ? target
        : String(context || "").toLowerCase() === "report"
          ? findReportTarget(source)
          : String(context || "").toLowerCase() === "table"
            ? findTableTarget(source)
            : findTableTarget(source);
      const finalTarget = isElement(preferredTarget) ? preferredTarget : document.body;
      const finalContext = resolveContext(context, finalTarget);

      const existing = finalTarget.querySelector("[data-global-loading-overlay='true']");
      if (existing) return existing;

      return buildOverlay({ context: finalContext, target: finalTarget });
    };

    const hideLoading = () => {
      overlays.forEach((overlay) => {
        if (isElement(overlay)) overlay.remove();
      });
      overlays.clear();
      document
        .querySelectorAll("[data-global-loading-overlay='true']")
        .forEach((node) => node.remove());
    };

    window.erpLoadingOverlay = {
      show: showLoading,
      hide: hideLoading,
    };

    document.addEventListener(
      "submit",
      (event) => {
        const form = event.target instanceof HTMLFormElement ? event.target : null;
        if (!form || event.defaultPrevented) return;
        const method = String(form.method || "GET").trim().toUpperCase();
        const isReportPage = String(window.location.pathname || "").startsWith("/reports/");
        const isFilterForm = form.matches("[data-filter-form]");
        if (!isReportPage && method !== "GET" && !isFilterForm) return;
        showLoading({
          context: isReportPage ? "report" : "table",
          source: form,
        });
      },
      true,
    );

    document.addEventListener(
      "click",
      (event) => {
        if (!(event.target instanceof HTMLElement)) return;
        const anchor = event.target.closest("a[href]");
        if (!(anchor instanceof HTMLAnchorElement)) return;
        if (anchor.target && anchor.target !== "_self") return;
        if (anchor.hasAttribute("download")) return;
        if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        const href = String(anchor.getAttribute("href") || "").trim();
        if (!href || href.startsWith("#") || href.startsWith("javascript:")) return;
        let url = null;
        try {
          url = new URL(anchor.href, window.location.origin);
        } catch (err) {
          return;
        }
        if (url.origin !== window.location.origin) return;
        if (url.pathname === window.location.pathname && url.search === window.location.search) return;
        const isReportTarget = url.pathname.startsWith("/reports/");
        const likelyTableNav =
          url.searchParams.has("page") ||
          url.searchParams.has("search") ||
          url.searchParams.has("status");
        if (!isReportTarget && !likelyTableNav) return;
        showLoading({
          context: isReportTarget ? "report" : "table",
          source: anchor,
        });
      },
      true,
    );

    window.addEventListener("pageshow", hideLoading);
    window.addEventListener("beforeunload", () => {
      // Keep visible while navigating away.
    });
  })();
</script>
