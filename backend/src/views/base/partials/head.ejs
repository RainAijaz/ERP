<style>
  [data-print-header] {
    display: none !important;
  }

  @media print {
    [data-print-header] {
      display: block !important;
    }

    @page {
      size: A4 landscape;
      margin: 10mm;
    }

    body.voucher-page {
      background: #fff !important;
      color: #000 !important;
    }

    body.voucher-page header,
    body.voucher-page nav,
    body.voucher-page footer,
    body.voucher-page [data-ui-notice-toast],
    body.voucher-page [data-ui-error-modal],
    body.voucher-page [data-delete-voucher],
    body.voucher-page [data-load-voucher],
    body.voucher-page [data-header-nav-btn],
    body.voucher-page [data-add-row],
    body.voucher-page [data-remove-row],
    body.voucher-page button[type="submit"] {
      display: none !important;
    }

    body.voucher-page main {
      padding: 0 !important;
      margin: 0 !important;
    }

    body.voucher-page main > .mx-auto,
    body.voucher-page section,
    body.voucher-page form {
      max-width: none !important;
      width: 100% !important;
      box-shadow: none !important;
      border-color: #d1d5db !important;
      background: #fff !important;
    }

    body.voucher-page [data-lines-table] {
      width: 100% !important;
      table-layout: auto !important;
      border-collapse: collapse !important;
      font-size: 10px !important;
    }

    body.voucher-page [data-lines-table] th,
    body.voucher-page [data-lines-table] td {
      border: 1px solid #d1d5db !important;
      background: #fff !important;
      color: #111827 !important;
      text-align: left !important;
      padding: 4px 6px !important;
    }

    body.voucher-page input,
    body.voucher-page select,
    body.voucher-page textarea {
      border: 0 !important;
      background: transparent !important;
      box-shadow: none !important;
      color: #111827 !important;
      padding: 0 !important;
      height: auto !important;
      appearance: none !important;
      -webkit-appearance: none !important;
    }
  }
</style>

<style id="dark-mode-styles">
  html.dark { color-scheme: dark; }

  html.dark body {
    background: linear-gradient(to bottom right, #0c1422, #112035, #0c1422);
    color: #e2e8f0;
  }

  /* Brand tokens */
  html.dark .text-ink   { color: #e2e8f0; }
  html.dark .text-muted { color: #94a3b8; }
  html.dark .text-accent                     { color: #38bdf8; }
  html.dark .hover\:text-accent:hover        { color: #7dd3fc; }
  html.dark .hover\:text-accent\/80:hover    { color: rgb(125 211 252 / 0.8); }
  html.dark .border-accent\/40               { border-color: rgb(56 189 248 / 0.4); }
  html.dark .hover\:border-accent\/40:hover  { border-color: rgb(56 189 248 / 0.4); }
  html.dark .bg-accent\/10                   { background-color: rgb(56 189 248 / 0.1); }
  html.dark .hover\:bg-accent\/10:hover      { background-color: rgb(56 189 248 / 0.12); }

  /* Surfaces — solid and opacity variants */
  html.dark .bg-white      { background-color: #162336; }
  html.dark .bg-white\/95  { background-color: #162336; }
  html.dark .bg-white\/90  { background-color: rgba(10, 17, 30, 0.96); }
  html.dark .bg-white\/80  { background-color: rgba(14, 26, 43, 0.96); }
  html.dark .bg-white\/70  { background-color: rgba(14, 26, 43, 0.92); }
  html.dark .bg-white\/60  { background-color: rgba(10, 18, 34, 0.85); }
  html.dark .bg-slate-50   { background-color: #0e1a2b; }
  html.dark .bg-slate-100  { background-color: #162336; }
  html.dark .bg-slate-200  { background-color: #1e3148; }

  /* Table zebra stripes and row hover */
  html.dark .odd\:bg-slate-50:nth-child(odd)  { background-color: #0e1a2b; }
  html.dark .even\:bg-white:nth-child(even)   { background-color: #162336; }
  html.dark .hover\:bg-slate-100:hover        { background-color: #1e3040; }
  html.dark .hover\:bg-slate-50:hover         { background-color: #152030; }

  /* Primary action buttons: dark bg → brand teal */
  html.dark .bg-slate-900               { background-color: #14526a; }
  html.dark .hover\:bg-slate-800:hover  { background-color: #0f3e51; }
  html.dark .hover\:bg-slate-900:hover  { background-color: #0f3e51; }
  html.dark .bg-slate-900\/40           { background-color: rgb(0 0 0 / 0.72); }

  /* Text */
  html.dark .text-slate-900 { color: #f1f5f9; }
  html.dark .text-slate-800 { color: #e2e8f0; }
  html.dark .text-slate-700 { color: #cbd5e1; }
  html.dark .text-slate-600 { color: #94a3b8; }
  html.dark .text-slate-500 { color: #94a3b8; }

  /* Borders */
  html.dark .border-slate-200 { border-color: #1e3148; }
  html.dark .border-slate-300 { border-color: #2a4263; }
  html.dark header            { border-color: #1a2d42; }

  /* Dividers */
  html.dark .divide-slate-100 > :not([hidden]) ~ :not([hidden]) { border-color: #1a2d42; }
  html.dark .divide-slate-200 > :not([hidden]) ~ :not([hidden]) { border-color: #1e3148; }

  /* Semantic colours — error toasts */
  html.dark .bg-rose-50       { background-color: #2a0f12; }
  html.dark .border-rose-300  { border-color: #9b1c1c; }
  html.dark .text-rose-700    { color: #fda4af; }
  html.dark .bg-rose-100      { background-color: #3b0d10; }

  /* Semantic colours — success / approval badges */
  html.dark .border-emerald-200 { border-color: #065f46; }
  html.dark .text-emerald-700   { color: #6ee7b7; }
  html.dark .bg-emerald-100     { background-color: #064e3b; }

  /* Semantic colours — warning / notice */
  html.dark .bg-amber-50        { background-color: #1e1400; }
  html.dark .bg-amber-100       { background-color: #2a1c00; }
  html.dark .text-amber-700     { color: #fbbf24; }
  html.dark .text-amber-800     { color: #f59e0b; }
  html.dark .border-amber-200   { border-color: #78350f; }

  /* Semantic colours — info / draft status */
  html.dark .bg-blue-100        { background-color: #0a1f3b; }
  html.dark .text-blue-700      { color: #60a5fa; }
  html.dark .border-blue-200    { border-color: #1e3a5f; }

  /* Form inputs */
  html.dark input:not([type="submit"]):not([type="button"]):not([type="checkbox"]):not([type="radio"]):not([type="range"]):not([type="color"]),
  html.dark select,
  html.dark textarea {
    background-color: #0e1a2b;
    border-color: #1e3148;
    color: #e2e8f0;
    color-scheme: dark;
  }
  html.dark input::placeholder,
  html.dark textarea::placeholder { color: #4a6480; }

  /* Radio / checkbox */
  html.dark input[type="radio"],
  html.dark input[type="checkbox"] { accent-color: #38bdf8; }

  /* Shadows */
  html.dark .shadow-sm { box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.5); }
  html.dark .shadow-md { box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.5), 0 2px 4px -2px rgb(0 0 0 / 0.4); }
  html.dark .shadow-xl { box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.7), 0 8px 10px -6px rgb(0 0 0 / 0.5); }

  /* Slate opacity variants */
  html.dark .bg-slate-50\/30  { background-color: rgba(14, 26, 43, 0.5); }
  html.dark .bg-slate-50\/40  { background-color: rgba(14, 26, 43, 0.6); }
  html.dark .bg-slate-200\/50 { background-color: rgba(30, 49, 72, 0.6); }
  html.dark .border-slate-200\/80 { border-color: rgba(30, 49, 72, 0.8); }

  /* Additional hover states */
  html.dark .hover\:bg-rose-100:hover  { background-color: #3b0d10; }
  html.dark .hover\:bg-amber-100:hover { background-color: #261600; }

  /* Additional text colours */
  html.dark .text-amber-900 { color: #f59e0b; }
  html.dark .text-sky-700   { color: #38bdf8; }

  /* BOM form view toggle — overrides hardcoded inline CSS in bom/form.ejs */
  html.dark #bom-form [data-rm-view-toggle] {
    border-color: #1e3148;
    background: #0e1a2b;
    color: #94a3b8;
  }
  html.dark #bom-form [data-rm-view-toggle][data-active="true"] {
    border-color: #14526a;
    background: #14526a;
    color: #e2e8f0;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  html.dark #bom-form [data-rm-view-toggle][data-active="false"] {
    border-color: #1e3148;
    background: #0e1a2b;
    color: #94a3b8;
  }
</style>
