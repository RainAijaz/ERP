<!--
  main.ejs - Main Application Layout
  Purpose: This is the universal layout template for all pages in the ERP web application.
  It defines the global HTML structure, header, navigation, main content area, modals, and global scripts.
  All page views are rendered inside this layout.
-->
<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" dir="<%= locale === 'ur' ? 'rtl' : 'ltr' %>" class="h-full overflow-x-hidden">
  <head>
    <!-- Head includes meta, title, and global styles/scripts -->
    <%- include("../partials/head", { title }) %>
    <style>
      body.voucher-page main > .mx-auto {
        width: 100%;
        max-width: none !important;
      }
    </style>
  </head>
  <body class="<%= locale === 'ur' ? 'font-urdu' : 'font-sans' %> min-h-screen overflow-x-hidden bg-linear-to-br from-amber-50 via-slate-50 to-amber-50 text-ink">
    <script>
      (function () {
        if (String(window.location.pathname || "").startsWith("/vouchers/")) {
          document.body.classList.add("voucher-page");
        }

        const fallbackAlert = (message) => {
          const text = String(message || "").trim();
          if (!text) return;
          window.alert(text);
        };

        window.showVoucherError = (message, title) => {
          const text = String(message || "").trim();
          if (!text) return;
          if (typeof window.showUiErrorModal === "function") {
            window.showUiErrorModal(text, title);
            window.requestAnimationFrame(() => {
              const closeBtn = document.querySelector("[data-ui-error-close]");
              if (closeBtn instanceof HTMLElement) closeBtn.focus();
            });
            return;
          }
          window.__pendingUiErrorModalPayload = { message: text, title: String(title || "").trim() };
          fallbackAlert(text);
        };
      })();
    </script>
    <script>
      (function () {
        const BRANCH_SYNC_KEY = "erp_branch_context_sync_v1";
        const tabId = `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        const currentBranchId = String(<%- JSON.stringify(branchId || "") %>).trim();
        const branchChangedPrompt = <%- JSON.stringify(String(t("branch_changed_reload_confirm") )) %>;
        const branchChangedTitle = <%- JSON.stringify(String(t("confirm") || "Confirm") ) %>;
        const branchChangedContinue = <%- JSON.stringify(String(t("continue") || "Continue") ) %>;
        const branchChangedCancel = <%- JSON.stringify(String(t("cancel") || "Cancel") ) %>;
        let hasUnsavedChanges = false;
        let branchReloadStarted = false;

        const isEditableField = (element) => {
          if (!(element instanceof HTMLInputElement || element instanceof HTMLTextAreaElement || element instanceof HTMLSelectElement)) {
            return false;
          }
          if (element.disabled || element.readOnly) return false;
          if (element instanceof HTMLInputElement) {
            const fieldType = String(element.type || "").toLowerCase();
            if (fieldType === "hidden" || fieldType === "submit" || fieldType === "button" || fieldType === "reset") {
              return false;
            }
          }
          return true;
        };

        const markDirtyFromEvent = (event) => {
          if (!event.isTrusted) return;
          if (!isEditableField(event.target)) return;
          hasUnsavedChanges = true;
        };

        const publishBranchSelection = (nextBranchId) => {
          const normalizedBranchId = String(nextBranchId || "").trim();
          if (!normalizedBranchId) return;
          try {
            localStorage.setItem(
              BRANCH_SYNC_KEY,
              JSON.stringify({
                tabId,
                branchId: normalizedBranchId,
                ts: Date.now(),
                path: String(window.location.pathname || ""),
              }),
            );
          } catch (err) {
            // ignore storage errors
          }
        };

        const navigateWithBranch = (nextBranchId) => {
          if (branchReloadStarted) return;
          const normalizedBranchId = String(nextBranchId || "").trim();
          if (!normalizedBranchId) return;
          branchReloadStarted = true;
          const nextUrl = new URL(window.location.href);
          nextUrl.searchParams.set("branch_id", normalizedBranchId);
          window.location.assign(nextUrl.toString());
        };

        window.__syncBranchSelection = publishBranchSelection;
        document.addEventListener("input", markDirtyFromEvent, true);
        document.addEventListener("change", markDirtyFromEvent, true);
        document.addEventListener(
          "submit",
          () => {
            hasUnsavedChanges = false;
          },
          true,
        );

        const branchSelect = document.getElementById("branch-select");
        if (branchSelect instanceof HTMLSelectElement) {
          branchSelect.addEventListener("change", () => {
            publishBranchSelection(branchSelect.value);
          });
        }

        window.addEventListener("storage", async (event) => {
          if (event.key !== BRANCH_SYNC_KEY) return;
          if (!event.newValue) return;

          let packet = null;
          try {
            packet = JSON.parse(event.newValue);
          } catch (err) {
            packet = null;
          }
          if (!packet || typeof packet !== "object") return;
          if (String(packet.tabId || "") === tabId) return;

          const nextBranchId = String(packet.branchId || "").trim();
          if (!nextBranchId || nextBranchId === currentBranchId) return;

          if (hasUnsavedChanges) {
            let shouldReload = false;
            if (typeof window.showUiConfirmModal === "function") {
              shouldReload = await window.showUiConfirmModal({
                title: branchChangedTitle,
                message: branchChangedPrompt,
                confirmLabel: branchChangedContinue,
                cancelLabel: branchChangedCancel,
              });
            } else {
              shouldReload = window.confirm(branchChangedPrompt);
            }
            if (!shouldReload) return;
          }
          navigateWithBranch(nextBranchId);
        });
      })();
    </script>
    <div class="flex min-h-screen flex-col">
      <!-- HEADER: Top navigation bar and brand -->
      <header class="sticky top-0 z-40 overflow-visible border-b border-slate-200 bg-white/90 backdrop-blur">
        <div class="mx-auto w-full overflow-visible px-4 lg:px-8">
          <input id="nav-toggle" type="checkbox" class="peer sr-only" />
          <div class="flex flex-wrap items-center justify-between gap-4 py-4 lg:py-5">
            <div class="flex items-center gap-4">
              <!-- Brand and ERP label -->
              <a class="text-2xl font-display text-accent transition hover:text-accent/80" href="/"><%= t("brand") %></a>
              <span class="hidden h-5 w-px bg-slate-200 lg:inline-flex"></span>
              <span class="hidden text-xs uppercase tracking-[0.4em] text-muted lg:inline-flex">ERP</span>
            </div>
            <div class="flex flex-wrap items-center gap-3">
              <!-- Main navigation links -->
              <%- include("../partials/navbar") %>
              <!-- Mobile menu toggle -->
              <label for="nav-toggle" class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 shadow-sm transition hover:border-accent/40 hover:text-accent lg:hidden">
                <span>Menu</span>
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 7h16M4 12h16M4 17h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                </svg>
              </label>
            </div>
          </div>
          <!-- NAVIGATION: Main and submenu navigation -->
          <nav class="hidden w-full flex-col gap-2 overflow-visible pb-4 peer-checked:flex lg:flex lg:flex-row lg:flex-nowrap lg:items-center lg:gap-1 lg:pb-6">
            <%- include("../partials/nav-menu", { navConfig, can, t }) %>
          </nav>
        </div>
      </header>
      <!-- MAIN CONTENT: Page-specific content and footer -->
      <main class="w-full flex-1 px-4 pb-10 pt-6 lg:px-8 lg:pt-8">
        <%- include(view) %>
        <%- include("../partials/footer") %>
      </main>
    </div>
    <!-- GLOBAL MODALS: Notice and error modals -->
    <%- include("../partials/notice-modal") %>
    <%- include("../partials/error-modal") %>
    <div class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/40 p-4" data-global-delete-confirm-modal>
      <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white shadow-xl">
        <div class="border-b border-slate-200 px-6 py-4">
          <div class="text-sm font-semibold text-slate-700" data-global-delete-confirm-title><%= t("confirm_delete") %></div>
          <p class="mt-1 text-xs text-slate-500" data-global-delete-confirm-message><%= t("permanent_delete_message") %></p>
        </div>
        <div class="flex items-center gap-2 px-6 py-5">
          <button type="button" class="flex-1 rounded-xl bg-slate-900 px-4 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-slate-800" data-global-delete-confirm-yes><%= t("continue") %></button>
          <button type="button" class="flex-1 rounded-xl border border-slate-200 bg-white px-4 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800" data-global-delete-confirm-no><%= t("cancel") %></button>
        </div>
      </div>
    </div>
    <script>
      (function () {
        const modal = document.querySelector("[data-global-delete-confirm-modal]");
        const titleEl = modal?.querySelector("[data-global-delete-confirm-title]");
        const messageEl = modal?.querySelector("[data-global-delete-confirm-message]");
        const yesBtn = modal?.querySelector("[data-global-delete-confirm-yes]");
        const noBtn = modal?.querySelector("[data-global-delete-confirm-no]");
        if (!(modal instanceof HTMLElement) || !(yesBtn instanceof HTMLElement) || !(noBtn instanceof HTMLElement)) return;

        const defaultTitle = <%- JSON.stringify(String(t("confirm_delete") || t("confirm") || "").trim() || "Confirm Delete") %>;
        const defaultMessage = <%- JSON.stringify(String(t("permanent_delete_message") || t("are_you_sure") || "").trim() || "This action permanently deletes the record.") %>;
        const defaultYesLabel = String(yesBtn.textContent || "").trim() || "Continue";
        const defaultNoLabel = String(noBtn.textContent || "").trim() || "Cancel";
        const csrfTokenValue = <%- JSON.stringify(csrfToken || "") %>;
        let pendingConfirmAction = null;
        let pendingConfirmResolver = null;

        const openConfirm = ({
          title = defaultTitle,
          message = defaultMessage,
          onConfirm = null,
          confirmLabel = defaultYesLabel,
          cancelLabel = defaultNoLabel,
        } = {}) => {
          pendingConfirmAction = typeof onConfirm === "function" ? onConfirm : null;
          if (titleEl instanceof HTMLElement) titleEl.textContent = String(title || defaultTitle).trim() || defaultTitle;
          if (messageEl instanceof HTMLElement) messageEl.textContent = String(message || defaultMessage).trim() || defaultMessage;
          yesBtn.textContent = String(confirmLabel || defaultYesLabel).trim() || defaultYesLabel;
          noBtn.textContent = String(cancelLabel || defaultNoLabel).trim() || defaultNoLabel;
          modal.classList.remove("hidden");
          modal.classList.add("flex");
          window.requestAnimationFrame(() => yesBtn.focus());
        };

        const closeConfirm = ({ confirmed = false } = {}) => {
          const resolver = pendingConfirmResolver;
          pendingConfirmResolver = null;
          pendingConfirmAction = null;
          yesBtn.textContent = defaultYesLabel;
          noBtn.textContent = defaultNoLabel;
          modal.classList.add("hidden");
          modal.classList.remove("flex");
          if (typeof resolver === "function") resolver(Boolean(confirmed));
        };

        const confirmAndRun = () => {
          const action = pendingConfirmAction;
          closeConfirm({ confirmed: true });
          if (typeof action === "function") action();
        };

        const showUiConfirmModal = ({
          title = defaultTitle,
          message = defaultMessage,
          confirmLabel = defaultYesLabel,
          cancelLabel = defaultNoLabel,
        } = {}) => new Promise((resolve) => {
          pendingConfirmResolver = resolve;
          openConfirm({
            title,
            message,
            onConfirm: null,
            confirmLabel,
            cancelLabel,
          });
        });

        window.showUiConfirmModal = showUiConfirmModal;

        const forceCloseBlockingOverlays = () => {
          const selectors = [
            "[data-global-delete-confirm-modal]",
            "[data-ui-error-modal]",
            "#modal-shell",
            "#modal-backdrop",
            "[data-confirm-modal]",
            "[data-gate-pass-modal]",
            "[data-sales-order-picker-modal]",
            "[data-grn-picker-modal]",
            "[data-outward-picker-modal]",
            "[data-sti-transfer-picker-modal]",
          ];
          selectors.forEach((selector) => {
            document.querySelectorAll(selector).forEach((node) => {
              if (!(node instanceof HTMLElement)) return;
              node.classList.add("hidden");
              node.classList.remove("flex");
              if (node.hasAttribute("aria-hidden")) {
                node.setAttribute("aria-hidden", "true");
              }
            });
          });
          document.body.classList.remove("overflow-hidden");
          if (typeof window.closeAllSearchableSelectMenus === "function") {
            window.closeAllSearchableSelectMenus();
          }
        };

        window.erpCloseBlockingOverlays = forceCloseBlockingOverlays;
        window.addEventListener("pageshow", (event) => {
          if (event.persisted) {
            forceCloseBlockingOverlays();
          }
        });

        const submitPostTo = (actionUrl) => {
          const action = String(actionUrl || "").trim();
          if (!action) return;
          const form = document.createElement("form");
          form.method = "POST";
          form.action = action;
          form.style.display = "none";
          form.dataset.globalDeleteConfirmed = "1";
          if (csrfTokenValue) {
            const csrfInput = document.createElement("input");
            csrfInput.type = "hidden";
            csrfInput.name = "_csrf";
            csrfInput.value = csrfTokenValue;
            form.appendChild(csrfInput);
          }
          document.body.appendChild(form);
          form.submit();
        };

        const toText = (value) => String(value || "").replace(/\s+/g, " ").trim();
        const buildDeleteMessage = (...sources) => {
          const label = sources
            .map((src) => {
              if (!(src instanceof HTMLElement)) return "";
              return (
                src.getAttribute("data-confirm-message")
                || src.getAttribute("data-delete-label")
                || src.getAttribute("aria-label")
                || src.textContent
                || ""
              );
            })
            .map(toText)
            .find(Boolean);
          if (!label) return defaultMessage;
          if (label.toLowerCase() === defaultMessage.toLowerCase()) return defaultMessage;
          return `${label}. ${defaultMessage}`;
        };

        const confirmDeleteFormSubmit = (form, message) => {
          if (!(form instanceof HTMLFormElement)) return;
          openConfirm({
            title: defaultTitle,
            message,
            onConfirm: () => {
              form.dataset.globalDeleteConfirmed = "1";
              if (typeof form.requestSubmit === "function") {
                form.requestSubmit();
              } else {
                form.submit();
              }
              window.setTimeout(() => {
                delete form.dataset.globalDeleteConfirmed;
              }, 0);
            },
          });
        };

        yesBtn.addEventListener("click", confirmAndRun);
        noBtn.addEventListener("click", () => closeConfirm({ confirmed: false }));
        modal.addEventListener("click", (event) => {
          if (event.target === modal) closeConfirm({ confirmed: false });
        });
        document.addEventListener("keydown", (event) => {
          if (event.key === "Escape" && modal.classList.contains("flex")) closeConfirm({ confirmed: false });
        });

        document.addEventListener(
          "click",
          (event) => {
            const target = event.target instanceof HTMLElement ? event.target : null;
            if (!target) return;

            const voucherDeleteBtn = target.closest("[data-delete-voucher]");
            if (voucherDeleteBtn instanceof HTMLElement && !voucherDeleteBtn.hasAttribute("disabled")) {
              event.preventDefault();
              event.stopImmediatePropagation();
              const contextForm = voucherDeleteBtn.closest("form");
              const deleteForm =
                (contextForm instanceof HTMLElement
                  ? contextForm.parentElement?.querySelector("[data-delete-voucher-form]")
                  : null)
                || document.querySelector("[data-delete-voucher-form]");
              if (deleteForm instanceof HTMLFormElement) {
                const message = buildDeleteMessage(voucherDeleteBtn, deleteForm);
                confirmDeleteFormSubmit(deleteForm, message);
              }
              return;
            }

            const explicitDeleteActionEl = target.closest("[data-delete-action]");
            if (explicitDeleteActionEl instanceof HTMLElement) {
              if (explicitDeleteActionEl.hasAttribute("data-delete")) return;
              const action = String(explicitDeleteActionEl.getAttribute("data-delete-action") || "").trim();
              if (!action) return;
              const label = String(explicitDeleteActionEl.getAttribute("data-delete-label") || "").trim();
              event.preventDefault();
              event.stopImmediatePropagation();
              openConfirm({
                title: defaultTitle,
                message: buildDeleteMessage(explicitDeleteActionEl) || label || defaultMessage,
                onConfirm: () => submitPostTo(action),
              });
            }
          },
          true,
        );

        document.addEventListener(
          "submit",
          (event) => {
            const form = event.target instanceof HTMLFormElement ? event.target : null;
            if (!form) return;
            if (form.matches("[data-confirm-form]") || form.closest("[data-confirm-modal]")) return;
            if (form.dataset.globalDeleteConfirmed === "1") return;
            const action = String(form.getAttribute("action") || "").toLowerCase();
            const onsubmit = String(form.getAttribute("onsubmit") || "");
            const isDeleteLike =
              form.matches("[data-delete-voucher-form]") ||
              /delete/.test(action) ||
              /confirm\s*\(/i.test(onsubmit);
            if (!isDeleteLike) return;

            event.preventDefault();
            event.stopImmediatePropagation();
            const message = buildDeleteMessage(form);
            confirmDeleteFormSubmit(form, message);
          },
          true,
        );
      })();
    </script>
    <!-- LIVE APPROVAL TOASTS: Real-time approval notifications -->
    <script>
      (function () {
        const path = String(window.location.pathname || "");
        if (!path.startsWith("/vouchers/")) return;
        const hasUiError = <%- JSON.stringify(Boolean(uiError && uiError.message)) %>;
        const hasStickyUiNotice = <%- JSON.stringify(Boolean(uiNotice && uiNotice.message && uiNotice.sticky === true)) %>;
        const shouldPreserveDraft = hasUiError || hasStickyUiNotice;

        const params = new URLSearchParams(window.location.search || "");
        const hasVoucherContext = params.has("voucher_no") || String(params.get("view") || "") === "1";
        if (!hasVoucherContext) return;

        let navType = "";
        try {
          const navEntries = performance.getEntriesByType("navigation");
          navType = String(navEntries?.[0]?.type || "");
        } catch (err) {
          navType = "";
        }

        if (!navType && performance && performance.navigation) {
          const legacyType = Number(performance.navigation.type);
          if (legacyType === 1) navType = "reload";
        }

        if (navType !== "reload") return;
        if (shouldPreserveDraft) return;

        try {
          sessionStorage.removeItem(`voucher_draft:${path}`);
        } catch (err) {
          // ignore
        }
        window.location.replace(`${path}?new=1`);
      })();
    </script>
    <script>
      (function () {
        const path = String(window.location.pathname || "");
        if (!path.startsWith("/vouchers/")) return;

        const form = document.querySelector("[data-voucher-form], [data-sales-voucher-form], [data-purchase-voucher-form]");
        if (!form || !(form instanceof HTMLFormElement)) return;

        const storageKey = `voucher_draft:${path}`;
        const hasUiError = <%- JSON.stringify(Boolean(uiError && uiError.message)) %>;
        const hasStickyUiNotice = <%- JSON.stringify(Boolean(uiNotice && uiNotice.message && uiNotice.sticky === true)) %>;
        const shouldRestoreDraft = hasUiError || hasStickyUiNotice;

        const detectNavigationType = () => {
          let navType = "";
          try {
            const navEntries = performance.getEntriesByType("navigation");
            navType = String(navEntries?.[0]?.type || "");
          } catch (err) {
            navType = "";
          }
          if (!navType && performance && performance.navigation) {
            const legacyType = Number(performance.navigation.type);
            if (legacyType === 1) navType = "reload";
          }
          return navType;
        };

        const setFieldValue = (field, value) => {
          if (!(field instanceof HTMLElement)) return;
          if (field instanceof HTMLInputElement) {
            if (field.type === "checkbox" || field.type === "radio") {
              field.checked = String(field.value || "") === String(value || "");
              return;
            }
            field.value = String(value ?? "");
            return;
          }
          if (field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement) {
            field.value = String(value ?? "");
          }
        };

        const restoreDraft = () => {
          let parsed = null;
          try {
            const raw = sessionStorage.getItem(storageKey);
            parsed = raw ? JSON.parse(raw) : null;
          } catch (err) {
            parsed = null;
          }
          if (!parsed || typeof parsed !== "object") return;
          const { values } = parsed;
          if (!values || typeof values !== "object") return;

          Object.entries(values).forEach(([name, value]) => {
            const fields = Array.from(form.querySelectorAll(`[name="${CSS.escape(name)}"]`));
            if (!fields.length) return;

            if (Array.isArray(value)) {
              if (fields.every((field) => field instanceof HTMLInputElement && (field.type === "checkbox" || field.type === "radio"))) {
                const selected = new Set(value.map((entry) => String(entry ?? "")));
                fields.forEach((field) => {
                  if (field instanceof HTMLInputElement) {
                    field.checked = selected.has(String(field.value || ""));
                  }
                });
              } else if (fields[0] instanceof HTMLSelectElement && fields[0].multiple) {
                const selected = new Set(value.map((entry) => String(entry ?? "")));
                Array.from(fields[0].options).forEach((option) => {
                  option.selected = selected.has(String(option.value || ""));
                });
              } else {
                setFieldValue(fields[0], value[0]);
              }
              return;
            }

            setFieldValue(fields[0], value);
          });

          Array.from(form.querySelectorAll("input, select, textarea")).forEach((field) => {
            field.dispatchEvent(new Event("change", { bubbles: true }));
            field.dispatchEvent(new Event("input", { bubbles: true }));
          });
        };

        const collectDraftValues = () => {
          const values = {};
          const elements = Array.from(form.elements || []);
          elements.forEach((element) => {
            if (!(element instanceof HTMLInputElement || element instanceof HTMLSelectElement || element instanceof HTMLTextAreaElement)) {
              return;
            }
            const name = String(element.name || "").trim();
            if (!name) return;
            if (element instanceof HTMLInputElement && (element.type === "submit" || element.type === "button" || element.type === "file")) {
              return;
            }

            if (element instanceof HTMLInputElement && (element.type === "checkbox" || element.type === "radio")) {
              if (!values[name]) values[name] = [];
              if (element.checked) values[name].push(String(element.value || "on"));
              return;
            }

            if (element instanceof HTMLSelectElement && element.multiple) {
              values[name] = Array.from(element.selectedOptions).map((option) => String(option.value || ""));
              return;
            }

            values[name] = String(element.value ?? "");
          });
          return values;
        };

        const navType = detectNavigationType();
        if (navType === "reload") {
          if (shouldRestoreDraft) {
            restoreDraft();
            return;
          }
          try {
            sessionStorage.removeItem(storageKey);
          } catch (err) {
            // ignore
          }
          return;
        }

        if (shouldRestoreDraft) {
          restoreDraft();
        } else {
          try {
            sessionStorage.removeItem(storageKey);
          } catch (err) {
            // ignore
          }
        }

        form.addEventListener("submit", (event) => {
          if (event.defaultPrevented) return;
          const payload = {
            ts: Date.now(),
            values: collectDraftValues(),
          };
          try {
            sessionStorage.setItem(storageKey, JSON.stringify(payload));
          } catch (err) {
            // ignore
          }
        });
      })();
    </script>
    <script>
      (function () {
        const path = String(window.location.pathname || "");
        if (!path.startsWith("/vouchers/")) return;

        const form = document.querySelector("[data-voucher-form], [data-sales-voucher-form], [data-purchase-voucher-form]");
        if (!(form instanceof HTMLFormElement)) return;
        if (String(form.method || "").toUpperCase() !== "POST") return;
        if (form.dataset.asyncVoucherSubmitBound === "1") return;
        form.dataset.asyncVoucherSubmitBound = "1";

        const genericError = <%- JSON.stringify(String(t("generic_error") )) %>;
        const submitControls = Array.from(
          form.querySelectorAll('button[type="submit"], input[type="submit"]'),
        ).filter(
          (control) =>
            control instanceof HTMLButtonElement || control instanceof HTMLInputElement,
        );
        let isSubmitting = false;

        const setSubmittingState = (submitting) => {
          submitControls.forEach((control) => {
            if (!(control instanceof HTMLButtonElement || control instanceof HTMLInputElement)) return;
            if (submitting) {
              if (!Object.prototype.hasOwnProperty.call(control.dataset, "asyncSubmitOriginalDisabled")) {
                control.dataset.asyncSubmitOriginalDisabled = control.disabled ? "1" : "0";
              }
              control.disabled = true;
              control.setAttribute("aria-busy", "true");
              return;
            }

            control.removeAttribute("aria-busy");
            control.disabled = control.dataset.asyncSubmitOriginalDisabled === "1";
          });
        };

        const extractErrorMessage = async (response) => {
          try {
            const payload = await response.json();
            const message = String(payload?.error || payload?.message || "").trim();
            const details = payload?.details;
            if (details && typeof details === "object") {
              const detailLines = [];
              if (typeof details.detail === "string" && details.detail.trim()) {
                detailLines.push(details.detail.trim());
              }
              if (typeof details.hint === "string" && details.hint.trim()) {
                detailLines.push(details.hint.trim());
              }
              if (typeof details.constraint === "string" && details.constraint.trim()) {
                detailLines.push(`Constraint: ${details.constraint.trim()}`);
              }
              if (detailLines.length) {
                return detailLines.join("\n");
              }
            }
            return message || genericError;
          } catch (err) {
            return genericError;
          }
        };

        form.addEventListener("submit", async (event) => {
          if (event.defaultPrevented) return;
          if (isSubmitting) {
            event.preventDefault();
            return;
          }

          event.preventDefault();
          isSubmitting = true;
          setSubmittingState(true);

          try {
            const formData = new FormData(form);
            const encodedBody = new URLSearchParams();
            formData.forEach((value, key) => {
              if (typeof value === "string") {
                encodedBody.append(key, value);
              }
            });
            const submitter = event.submitter;
            if (
              submitter
              && (submitter instanceof HTMLButtonElement || submitter instanceof HTMLInputElement)
              && String(submitter.name || "").trim()
            ) {
              encodedBody.append(String(submitter.name), String(submitter.value || ""));
            }
            const csrfToken = String(formData.get("_csrf") || "").trim();

            const response = await fetch(form.action || window.location.href, {
              method: "POST",
              body: encodedBody.toString(),
              headers: {
                Accept: "application/json",
                "Content-Type": "application/x-www-form-urlencoded;charset=UTF-8",
                "x-csrf-token": csrfToken,
                "X-Requested-With": "XMLHttpRequest",
              },
              credentials: "same-origin",
            });

            if (!response.ok) {
              const message = await extractErrorMessage(response);
              window.showVoucherError(message);
              return;
            }

            const contentType = String(response.headers.get("content-type") || "").toLowerCase();
            if (contentType.includes("application/json")) {
              const payload = await response.json().catch(() => null);
              if (payload && payload.queuedForApproval && payload.message) {
                // Keep user on the same page and show approval/shortage context in the modal instead of redirecting.
                window.showVoucherError(
                  String(payload.message),
                  String(payload.title || "<%= t('approval_submitted')  %>"),
                );
                return;
              }
              if (payload && payload.redirectUrl) {
                window.location.assign(String(payload.redirectUrl));
                return;
              }
            }

            const nextUrl = String(response.url || "").trim();
            window.location.assign(nextUrl || (form.action || window.location.href));
          } catch (err) {
            window.showVoucherError(genericError);
          } finally {
            isSubmitting = false;
            setSubmittingState(false);
          }
        });
      })();
    </script>
    <script>
      (function () {
        const path = String(window.location.pathname || "");
        if (!path.startsWith("/vouchers/")) return;

        const form = document.querySelector("[data-voucher-form], [data-sales-voucher-form], [data-purchase-voucher-form]");
        if (!(form instanceof HTMLFormElement)) return;

        const DATE_INPUT_SELECTOR = 'input[type="date"], input[type="datetime-local"], input[type="month"], input[type="time"]';
        const pickerSupportedTypes = new Set(["date", "datetime-local", "month", "time"]);

        const tryOpenPicker = (input) => {
          if (!(input instanceof HTMLInputElement)) return;
          if (!pickerSupportedTypes.has(String(input.type || "").toLowerCase())) return;
          if (input.disabled || input.readOnly) return;
          if (typeof input.showPicker !== "function") return;
          try {
            input.showPicker();
          } catch (err) {
            // ignore browser restrictions
          }
        };

        form.querySelectorAll(DATE_INPUT_SELECTOR).forEach((input) => {
          if (!(input instanceof HTMLInputElement)) return;
          if (input.dataset.pickerAutoBound === "1") return;
          input.dataset.pickerAutoBound = "1";
          input.addEventListener("click", () => tryOpenPicker(input));
          input.addEventListener("focus", () => tryOpenPicker(input));
        });
      })();
    </script>
    <script>
      (function () {
        // Live approval event stream and toast notifications
        if (!window.EventSource) return;
        const csrfToken = "<%= csrfToken %>";
        const OWNER_KEY = "approval_live_owner_v1";
        const BROADCAST_KEY = "approval_live_event_v1";
        const DISMISS_KEY = "approval_live_dismissed";
        const OWNER_TTL_MS = 45000;
        const OWNER_HEARTBEAT_MS = 12000;
        const tabId = `${Date.now()}-${Math.random().toString(36).slice(2, 10)}`;
        let source = null;
        let ownerHeartbeat = null;
        let isOwner = false;
        let storageEnabled = true;

        const safeJsonParse = (value) => {
          try {
            return JSON.parse(String(value || ""));
          } catch (err) {
            return null;
          }
        };

        const now = () => Date.now();
        const ownerExpiresAt = () => now() + OWNER_TTL_MS;

        const detectStorage = () => {
          try {
            const key = "__approval_live_probe__";
            localStorage.setItem(key, "1");
            localStorage.removeItem(key);
            return true;
          } catch (err) {
            return false;
          }
        };
        storageEnabled = detectStorage();

        const readOwner = () => {
          if (!storageEnabled) return null;
          return safeJsonParse(localStorage.getItem(OWNER_KEY));
        };

        const writeOwner = (payload) => {
          if (!storageEnabled) return;
          try {
            localStorage.setItem(OWNER_KEY, JSON.stringify(payload));
          } catch (err) {
            // ignore
          }
        };

        const removeOwner = () => {
          if (!storageEnabled) return;
          try {
            const current = readOwner();
            if (current && current.tabId === tabId) {
              localStorage.removeItem(OWNER_KEY);
            }
          } catch (err) {
            // ignore
          }
        };

        const isOwnerAlive = (owner) => {
          if (!owner || !owner.tabId) return false;
          return Number(owner.expiresAt || 0) > now();
        };

        const startSource = () => {
          if (source || !isOwner) return;
          source = new EventSource("/events/approvals");
          source.addEventListener("approval_decision", (event) => {
            try {
              const payload = JSON.parse(event.data);
              const nextCount = getDecisionCount() + 1;
              setDecisionCount(nextCount);
              renderToast(payload);
              if (storageEnabled) {
                localStorage.setItem(
                  BROADCAST_KEY,
                  JSON.stringify({ tabId, ts: now(), payload }),
                );
              }
            } catch (err) {
              // ignore
            }
          });
          source.addEventListener("error", () => {
            // Browser will auto-retry SSE; no manual reconnect needed.
          });
        };

        const stopSource = () => {
          if (!source) return;
          try {
            source.close();
          } catch (err) {
            // ignore
          }
          source = null;
        };

        const startOwnerHeartbeat = () => {
          if (ownerHeartbeat) return;
          ownerHeartbeat = window.setInterval(() => {
            if (!isOwner) return;
            writeOwner({
              tabId,
              expiresAt: ownerExpiresAt(),
              ts: now(),
            });
          }, OWNER_HEARTBEAT_MS);
        };

        const stopOwnerHeartbeat = () => {
          if (!ownerHeartbeat) return;
          clearInterval(ownerHeartbeat);
          ownerHeartbeat = null;
        };

        const becomeOwner = () => {
          if (isOwner) return;
          isOwner = true;
          writeOwner({
            tabId,
            expiresAt: ownerExpiresAt(),
            ts: now(),
          });
          startOwnerHeartbeat();
          startSource();
        };

        const resignOwner = ({ releaseLock = true } = {}) => {
          if (!isOwner && !source) return;
          isOwner = false;
          stopOwnerHeartbeat();
          stopSource();
          if (releaseLock) removeOwner();
        };

        const tryClaimOwner = () => {
          if (document.visibilityState === "hidden") return;
          if (!storageEnabled) {
            // Fallback: no shared storage available, keep SSE only on visible tab.
            becomeOwner();
            return;
          }
          const current = readOwner();
          if (!isOwnerAlive(current) || current.tabId === tabId) {
            becomeOwner();
            return;
          }
          resignOwner({ releaseLock: false });
        };

        const ackApproval = () => {
          try {
            fetch("/events/approvals/ack", {
              method: "POST",
              headers: { "x-csrf-token": csrfToken },
            }).catch(() => {});
          } catch (err) {
            // ignore
          }
        };
        const getDecisionCount = () => Number(sessionStorage.getItem("approval_decision_count") || "0");
        const setDecisionCount = (value) => sessionStorage.setItem("approval_decision_count", String(value));
        const resetDecisionCount = () => setDecisionCount(0);

        const broadcastLiveDismiss = () => {
          try {
            if (!storageEnabled) return;
            localStorage.setItem(DISMISS_KEY, String(Date.now()));
          } catch (err) {
            // ignore
          }
        };
        window.addEventListener("storage", (event) => {
          if (event.key === DISMISS_KEY) {
            document.querySelector("[data-live-approval-toast]")?.remove();
            resetDecisionCount();
            return;
          }
          if (event.key === BROADCAST_KEY) {
            const packet = safeJsonParse(event.newValue);
            if (!packet || packet.tabId === tabId || !packet.payload) return;
            const nextCount = getDecisionCount() + 1;
            setDecisionCount(nextCount);
            renderToast(packet.payload);
            return;
          }
          if (event.key === OWNER_KEY && document.visibilityState !== "hidden") {
            tryClaimOwner();
          }
        });

        const AUTO_DISMISS_MS = 4000;

        const renderToast = (payload) => {
          if (!payload || !payload.message) return;
          const existing = document.querySelector("[data-live-approval-toast]");
          if (existing) existing.remove();
          const wrap = document.createElement("div");
          wrap.className = "fixed right-4 top-4 z-[90] w-[92vw] max-w-sm";
          wrap.setAttribute("data-live-approval-toast", "true");
          const status = String(payload.status || "").toUpperCase();
          const badgeClass = status === "APPROVED" ? "bg-emerald-100 text-emerald-700" : "bg-rose-100 text-rose-700";
          const badgeText = status || "<%= t('status')  %>";
          const count = getDecisionCount();
          const extraCount = count > 1 ? count - 1 : 0;
          const summaryLine = payload.summary ? `<p class="mt-1 text-xs text-slate-500">${payload.summary}</p>` : "";
          const moreLine = extraCount > 0
            ? `<p class="mt-1 text-[10px] uppercase tracking-[0.18em] text-slate-400">+${extraCount} more</p>`
            : "";
          const link = payload.link ? `<a class="mt-2 inline-flex items-center gap-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-accent hover:text-accent/80" href="${payload.link}"><%= t('view')  %> →</a>` : "";
          const requestId = payload.requestId ? `<div class="text-[10px] uppercase tracking-[0.18em] text-slate-400">#${payload.requestId}</div>` : "";
          wrap.innerHTML = `
            <div class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-xl">
              <div class="mt-0.5 rounded-full bg-slate-100 p-2 text-slate-700">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div class="flex-1">
                <div class="flex items-center justify-between gap-2">
                  <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-700"><%= t("notice")  %></div>
                  <span class="rounded-full px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] ${badgeClass}">${badgeText}</span>
                </div>
                ${requestId}
                <p class="mt-1 text-sm text-slate-700"></p>
                ${summaryLine}
                ${moreLine}
                ${link}
                <p class="mt-1 text-[10px] uppercase tracking-[0.18em] text-slate-400"><%= t("dismiss")  %></p>
              </div>
              <button class="text-slate-400 hover:text-slate-600" type="button" aria-label="Close">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>`;
          wrap.querySelector("p.text-sm").textContent = payload.message;
          const closeBtn = wrap.querySelector("button");
          const viewLink = wrap.querySelector("a");
          let dismissed = false;
          let autoDismissTimer = null;
          const dismissToast = ({ acknowledge = true, broadcast = true } = {}) => {
            if (dismissed) return;
            dismissed = true;
            if (autoDismissTimer) {
              clearTimeout(autoDismissTimer);
              autoDismissTimer = null;
            }
            resetDecisionCount();
            if (broadcast) {
              broadcastLiveDismiss();
            }
            if (acknowledge) {
              ackApproval();
            }
            wrap.remove();
          };

          closeBtn.addEventListener("click", () => {
            dismissToast({ acknowledge: true, broadcast: true });
          });
          viewLink?.addEventListener("click", () => {
            dismissToast({ acknowledge: true, broadcast: false });
          });

          autoDismissTimer = setTimeout(() => {
            dismissToast({ acknowledge: true, broadcast: true });
          }, AUTO_DISMISS_MS);

          document.body.appendChild(wrap);
        };

        document.addEventListener("visibilitychange", () => {
          if (document.visibilityState === "hidden") {
            resignOwner({ releaseLock: true });
            return;
          }
          tryClaimOwner();
        });

        window.addEventListener("beforeunload", () => {
          resignOwner({ releaseLock: true });
        });

        tryClaimOwner();
        if (window.location.pathname.startsWith("/administration/approvals")) {
          ackApproval();
        }
      })();
    </script>
    <script>
      (function () {
        const path = String(window.location.pathname || "");
        if (!path.startsWith("/reports/")) return;

        const ALL_VALUE = "__ALL__";
        const REPORT_SUBMIT_MARKER_KEY = `report_submit_marker:${path}`;

        const detectNavigationType = () => {
          let navType = "";
          try {
            const navEntries = performance.getEntriesByType("navigation");
            navType = String(navEntries?.[0]?.type || "");
          } catch (err) {
            navType = "";
          }
          if (!navType && performance && performance.navigation) {
            const legacyType = Number(performance.navigation.type);
            if (legacyType === 1) navType = "reload";
            else if (legacyType === 0) navType = "navigate";
          }
          return navType;
        };

        const readSubmitMarker = () => {
          try {
            const raw = sessionStorage.getItem(REPORT_SUBMIT_MARKER_KEY);
            const ts = Number(raw || 0);
            return Number.isFinite(ts) ? ts : 0;
          } catch (err) {
            return 0;
          }
        };

        const clearSubmitMarker = () => {
          try {
            sessionStorage.removeItem(REPORT_SUBMIT_MARKER_KEY);
          } catch (err) {
            // ignore
          }
        };

        const writeSubmitMarker = () => {
          try {
            sessionStorage.setItem(REPORT_SUBMIT_MARKER_KEY, String(Date.now()));
          } catch (err) {
            // ignore
          }
        };

        const navType = detectNavigationType();
        const submitMarkerAgeMs = Date.now() - readSubmitMarker();
        const isRecentSubmitNavigation = submitMarkerAgeMs >= 0 && submitMarkerAgeMs < 15000;
        const shouldResetOnThisLoad = navType === "reload" && !isRecentSubmitNavigation;

        const normalizeSelectAllState = (select, triggerValue = "", ensureDefault = false) => {
          if (!(select instanceof HTMLSelectElement) || !select.multiple) return;
          const options = Array.from(select.options || []);
          const allOption = options.find((opt) => String(opt.value || "") === ALL_VALUE);
          if (!allOption) return;

          const nonAllOptions = options.filter((opt) => String(opt.value || "") !== ALL_VALUE);

          if (String(triggerValue || "") === ALL_VALUE && allOption.selected) {
            nonAllOptions.forEach((opt) => {
              opt.selected = false;
            });
            return;
          }

          const hasNonAllSelected = nonAllOptions.some((opt) => opt.selected);
          if (hasNonAllSelected) {
            allOption.selected = false;
            return;
          }

          if (ensureDefault) {
            allOption.selected = true;
          }
        };

        const formHasExplicitReportFilters = (form) => {
          if (!(form instanceof HTMLFormElement)) return false;

          const fromDate = form.querySelector('input[name="from_date"]');
          const toDate = form.querySelector('input[name="to_date"]');
          const hasFromDate = fromDate instanceof HTMLInputElement && String(fromDate.value || "").trim() !== "";
          const hasToDate = toDate instanceof HTMLInputElement && String(toDate.value || "").trim() !== "";
          if (hasFromDate || hasToDate) return true;

          const multiSelects = Array.from(form.querySelectorAll("select[multiple]"));
          return multiSelects.some((select) => {
            const options = Array.from(select.options || []);
            if (!options.length) return false;
            const nonAllSelected = options.some(
              (opt) => String(opt.value || "") !== ALL_VALUE && opt.selected,
            );
            return nonAllSelected;
          });
        };

        const bindReportFormDefaults = (form) => {
          if (!(form instanceof HTMLFormElement)) return;
          const multiSelects = Array.from(form.querySelectorAll("select[multiple]"));
          const shouldResetThisForm = shouldResetOnThisLoad && !formHasExplicitReportFilters(form);

          multiSelects.forEach((select) => {
            const options = Array.from(select.options || []);
            const hasAllOption = options.some((opt) => String(opt.value || "") === ALL_VALUE);
            if (!hasAllOption) return;

            if (shouldResetThisForm) {
              options.forEach((opt) => {
                opt.selected = String(opt.value || "") === ALL_VALUE;
              });
            }

            normalizeSelectAllState(select, "", true);

            select.addEventListener("change", (event) => {
              const target = event.target;
              if (!(target instanceof HTMLSelectElement)) return;
              normalizeSelectAllState(target, "", true);
            });
          });

          if (shouldResetThisForm) {
            const fromDate = form.querySelector('input[name="from_date"]');
            const toDate = form.querySelector('input[name="to_date"]');
            if (fromDate instanceof HTMLInputElement) fromDate.value = "";
            if (toDate instanceof HTMLInputElement) toDate.value = "";

            const dateRangeInput = form.querySelector("[data-date-range-input]");
            if (dateRangeInput instanceof HTMLInputElement) dateRangeInput.value = "";
          }

          form.addEventListener("submit", () => {
            multiSelects.forEach((select) => normalizeSelectAllState(select, "", true));
            writeSubmitMarker();
          });
        };

        const reportForms = Array.from(document.querySelectorAll("form"));
        reportForms.forEach((form) => bindReportFormDefaults(form));
        clearSubmitMarker();
      })();
    </script>
    <!-- NAVIGATION DROPDOWNS: Submenu open/close logic -->
    <script>
      (function () {
        const toggles = document.querySelectorAll("[data-submenu-toggle]");
        const wraps = document.querySelectorAll("[data-submenu-wrap]");
        const mediaQuery = window.matchMedia("(min-width: 1024px)");
        const submenuTimeouts = new WeakMap();
        const clearMenuViewportConstraint = (menu) => {
          if (!menu) return;
          menu.classList.remove("nav-scrollable");
          menu.style.maxHeight = "";
          menu.style.overflowX = "";
          menu.style.overflowY = "";
          menu.style.overscrollBehavior = "";
          menu.style.top = "";
          menu.style.bottom = "";
          menu.style.left = "";
          menu.style.right = "";
          menu.style.marginTop = "";
          menu.style.marginBottom = "";
          menu.style.marginLeft = "";
          menu.style.marginRight = "";
        };
        const applyMenuViewportConstraint = (menu) => {
          if (!menu || !mediaQuery.matches) return;
          clearMenuViewportConstraint(menu);
          const viewportTop = 12;
          const viewportBottom = window.innerHeight - 12;
          const viewportLeft = 12;
          const viewportRight = window.innerWidth - 12;
          const forceScrollable = menu.dataset.forceScrollable === "1";
          const wrap = menu.closest("[data-submenu-wrap]");
          const wrapRect = wrap?.getBoundingClientRect();

          if (menu.classList.contains("nav-dropdown")) {
            const initialRect = menu.getBoundingClientRect();
            if (initialRect.right > viewportRight) {
              menu.style.left = "auto";
              menu.style.right = "0";
            } else if (initialRect.left < viewportLeft) {
              menu.style.left = "0";
              menu.style.right = "auto";
            }
          }

          if (menu.classList.contains("nav-submenu")) {
            const initialRect = menu.getBoundingClientRect();
            if (initialRect.right > viewportRight) {
              menu.style.left = "auto";
              menu.style.right = "calc(100% + 0.5rem)";
              menu.style.marginLeft = "0";
              menu.style.marginRight = "0.5rem";
            }
          }

          let rect = menu.getBoundingClientRect();
          if (rect.bottom > viewportBottom && wrapRect) {
            const spaceAbove = Math.max(0, wrapRect.top - viewportTop);
            const spaceBelow = Math.max(0, viewportBottom - wrapRect.bottom);
            if (spaceAbove > spaceBelow) {
              menu.style.top = "auto";
              menu.style.marginTop = "0";
              if (menu.classList.contains("nav-dropdown")) {
                menu.style.bottom = "calc(100% + 0.5rem)";
              } else {
                menu.style.bottom = "0";
              }
            }
            rect = menu.getBoundingClientRect();
          }

          if (menu.classList.contains("nav-submenu")) {
            const hasNestedFlyout = Boolean(menu.querySelector("[data-submenu-wrap] [data-submenu]"));
            const safeTop = Math.max(viewportTop, rect.top);
            const availableHeight = Math.max(180, Math.floor(viewportBottom - safeTop));
            const forcedMaxHeight = Math.max(180, Math.min(220, availableHeight));
            const targetMaxHeight = forceScrollable ? forcedMaxHeight : availableHeight;
            const needsVerticalConstraint = forceScrollable || menu.scrollHeight > targetMaxHeight + 1;
            // Keep flyout chains usable: constraining overflow on a parent submenu clips child submenus.
            if (hasNestedFlyout) {
              menu.style.overflowX = "visible";
              menu.style.overflowY = "visible";
              menu.style.maxHeight = "";
              menu.style.overscrollBehavior = "";
              return;
            }

            menu.style.overflowX = "hidden";
            if (needsVerticalConstraint) {
              menu.classList.add("nav-scrollable");
              menu.style.maxHeight = `${targetMaxHeight}px`;
              menu.style.overflowY = "auto";
              menu.style.overscrollBehavior = "contain";
            }
            return;
          }

          const overflowBottom = rect.bottom - viewportBottom;
          const overflowTop = viewportTop - rect.top;
          if (overflowBottom > 0 || overflowTop > 0) {
            const safeTop = Math.max(viewportTop, rect.top);
            const maxHeight = Math.max(180, Math.floor(viewportBottom - safeTop));
            menu.classList.add("nav-scrollable");
            menu.style.maxHeight = `${maxHeight}px`;
            menu.style.overflowY = "auto";
            menu.style.overscrollBehavior = "contain";
          }
        };

        const closeAll = (except) => {
          document.querySelectorAll("[data-submenu]").forEach((menu) => {
            if (!except) {
              clearMenuViewportConstraint(menu);
              menu.classList.add("hidden");
              return;
            }
            if (menu === except) return;
            if (menu.contains(except)) return;
            if (except.contains(menu)) return;
            clearMenuViewportConstraint(menu);
            menu.classList.add("hidden");
          });
        };

        const setMenuState = (menu, open) => {
          if (!menu) return;
          if (open) {
            menu.classList.remove("hidden");
            requestAnimationFrame(() => applyMenuViewportConstraint(menu));
          } else {
            clearMenuViewportConstraint(menu);
            menu.classList.add("hidden");
          }
        };

        const handleToggleClick = (event) => {
          event.preventDefault();
          event.stopPropagation();
          const toggle = event.currentTarget;
          const key = toggle.getAttribute("data-submenu-toggle");
          const menu = document.querySelector(`[data-submenu="${key}"]`);
          if (!menu) return;
          const willOpen = menu.classList.contains("hidden");
          closeAll(menu);
          setMenuState(menu, willOpen);
        };

        toggles.forEach((toggle) => {
          toggle.addEventListener("click", handleToggleClick);
        });

        wraps.forEach((wrap) => {
          wrap.addEventListener("click", (event) => event.stopPropagation());
        });

        document.querySelectorAll("[data-submenu]").forEach((menu) => {
          menu.addEventListener("click", (event) => event.stopPropagation());
        });

        // --- Dropdown hover/focus logic for robust close on mouse leave ---
        wraps.forEach((wrap) => {
          const key = wrap.querySelector("[data-submenu-toggle]")?.getAttribute("data-submenu-toggle");
          if (!key) return;
          const menu = document.querySelector(`[data-submenu="${key}"]`);
          if (!menu) return;
          let closeTimer = null;
          const clear = () => { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } };
          const scheduleClose = () => {
            clear();
            closeTimer = setTimeout(() => { setMenuState(menu, false); }, 200);
          };
          wrap.addEventListener("mouseenter", clear);
          wrap.addEventListener("mouseleave", scheduleClose);
          menu.addEventListener("mouseenter", clear);
          menu.addEventListener("mouseleave", scheduleClose);
        });

        document.addEventListener("click", () => {
          closeAll();
        });

        mediaQuery.addEventListener("change", () => closeAll());
      })();
    </script>
    <%- include("../partials/report-utils") %>
    <!-- Urdu translation utilities for multilingual support -->
    <%- include("../partials/urdu-translate-utils") %>
  </body>
</html>
