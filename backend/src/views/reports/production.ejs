<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <% const productionReportsPurpose = (() => { const key = "production_reports_purpose_tooltip"; const value = t(key); return value && value !== key ? value : ""; })(); %>
    <div class="flex items-center gap-2">
      <h1 class="text-2xl font-display font-semibold tracking-tight text-ink"><%= t("production_reports") %></h1>
      <% if (productionReportsPurpose) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= productionReportsPurpose %>" aria-label="<%= productionReportsPurpose %>">i</span>
      <% } %>
    </div>
    <p class="mt-1 text-sm text-slate-600"><%= t("reports") %></p>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-3">
      <a href="<%= controlReportPath %>" class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-accent/40 hover:shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500"><%= t("report") %></div>
        <div class="mt-1 text-lg font-semibold text-slate-900"><%= t("production_control_report") %></div>
      </a>
      <a href="<%= plannedConsumptionPath %>" class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-accent/40 hover:shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500"><%= t("report") %></div>
        <div class="mt-1 text-lg font-semibold text-slate-900"><%= t("planned_consumption") %></div>
      </a>
      <a href="<%= departmentWipPath %>" class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-accent/40 hover:shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500"><%= t("report") %></div>
        <div class="mt-1 text-lg font-semibold text-slate-900"><%= (() => { const v = t("department_wip_report"); return v && v !== "department_wip_report" ? v : "Department-wise Pending Production Report"; })() %></div>
      </a>
      <a href="<%= departmentWipLedgerPath %>" class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-accent/40 hover:shadow-sm">
        <div class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-500"><%= t("report") %></div>
        <div class="mt-1 text-lg font-semibold text-slate-900"><%= (() => { const v = t("department_wip_ledger_report"); return v && v !== "department_wip_ledger_report" ? v : "Department WIP Ledger Report"; })() %></div>
      </a>
    </div>
  </section>
</div>
