<%
  const reportLoaded = Boolean(filters?.reportLoaded);
  const detailRows = Array.isArray(reportData?.detailRows) ? reportData.detailRows : [];
  const summaryRows = Array.isArray(reportData?.summaryRows) ? reportData.summaryRows : [];
  const selectedReportType = ["details", "summary"].includes(String(filters?.reportType || "").toLowerCase())
    ? String(filters.reportType).toLowerCase()
    : "details";
  const hasData = selectedReportType === "summary" ? summaryRows.length > 0 : detailRows.length > 0;
  const allMultiOptionValue = "__ALL__";
  const selectedAsOfDate = String(filters?.asOfDate || "");
  const selectedBranchIds = Array.isArray(filters?.branchIds) ? filters.branchIds : [];
  const selectedDepartmentIds = Array.isArray(filters?.departmentIds) ? filters.departmentIds : [];
  const selectedSkuIds = Array.isArray(filters?.skuIds) ? filters.skuIds : [];
  const selectedOrderBy = String(filters?.orderBy || "department").toLowerCase() === "sku"
    ? "sku"
    : "department";
  const branchAllSelected = !selectedBranchIds.length;
  const departmentAllSelected = !selectedDepartmentIds.length;
  const skuAllSelected = !selectedSkuIds.length;
  const includeBranchColumn = Boolean(user?.isAdmin) && selectedBranchIds.length !== 1;
  const reportTitle = (() => {
    const v = t("department_wip_balances_report");
    return v && v !== "department_wip_balances_report" ? v : "Department WIP Balances Report";
  })();
  const reportPurposeTooltip = (() => {
    const v = t("department_wip_balances_report_purpose_tooltip");
    return v && v !== "department_wip_balances_report_purpose_tooltip"
      ? v
      : "Shows current department WIP balance snapshot by SKU and branch as of selected date.";
  })();
  const asOfDateLabel = (() => { const v = t("as_of_date"); return v && v !== "as_of_date" ? v : "As Of Date"; })();
  const articlesLabel = (() => { const v = t("articles"); return v && v !== "articles" ? v : "Articles"; })();
  const orderByLabel = (() => { const v = t("order_by"); return v && v !== "order_by" ? v : "Order By"; })();
  const avgAgingDaysLabel = (() => { const v = t("avg_aging_days"); return v && v !== "avg_aging_days" ? v : "Avg Aging (Days)"; })();
  const maxAgingDaysLabel = (() => { const v = t("max_aging_days"); return v && v !== "max_aging_days" ? v : "Max Aging (Days)"; })();
  const closingPairsLabel = (() => { const v = t("closing_pairs"); return v && v !== "closing_pairs" ? v : "Closing Pairs"; })();
  const closingDozenLabel = (() => { const v = t("closing_dozen"); return v && v !== "closing_dozen" ? v : "Closing Dozen"; })();
  const agingDaysLabel = (() => { const v = t("aging_days"); return v && v !== "aging_days" ? v : "Aging (Days)"; })();
  const skuCountLabel = (() => { const v = t("sku_count"); return v && v !== "sku_count" ? v : "SKU Count"; })();
  const departmentCountLabel = (() => {
    const v = t("department_count");
    return v && v !== "department_count" ? v : "Department Count";
  })();
  const detailTotalsLabelSpan = 6;
  const detailColumnCount = detailTotalsLabelSpan + 2 + (includeBranchColumn ? 1 : 0);
  const formatNumber = (value, decimals = 3) => formatNumberDisplay(value, { decimals, fallback: "0" });
  const summarizeNameSet = (valueSet = new Set()) => {
    const values = Array.from(valueSet.values())
      .map((value) => String(value || "").trim())
      .filter((value) => value && value !== "-")
      .sort((a, b) => a.localeCompare(b));
    if (!values.length) return "-";
    if (values.length <= 2) return values.join(", ");
    return `${values.slice(0, 2).join(", ")} +${values.length - 2}`;
  };
  const detailGroups = (() => {
    const map = new Map();
    detailRows.forEach((row) => {
      const isSkuOrder = selectedOrderBy === "sku";
      const primaryId = isSkuOrder
        ? Number(row?.sku_id || 0)
        : Number(row?.department_id || 0);
      const primaryName = isSkuOrder
        ? String(row?.sku_code || "-")
        : String(row?.department_name || "-");
      const key = primaryId
        ? `${isSkuOrder ? "sku" : "dept"}:${primaryId}`
        : `${isSkuOrder ? "sku" : "dept"}:${primaryName}`;
      const existing = map.get(key) || {
        key,
        primary_label: primaryName,
        rows: [],
        sku_ids: new Set(),
        department_ids: new Set(),
        branch_names: new Set(),
        closing_pairs: 0,
        closing_dozen: 0,
      };
      existing.rows.push(row);
      if (row?.sku_id) existing.sku_ids.add(Number(row.sku_id));
      if (row?.department_id)
        existing.department_ids.add(Number(row.department_id));
      if (String(row?.branch_name || "").trim()) {
        existing.branch_names.add(String(row.branch_name || "").trim());
      }
      existing.closing_pairs += Number(row?.closing_pairs || 0);
      existing.closing_dozen += Number(row?.closing_dozen || 0);
      map.set(key, existing);
    });

    return Array.from(map.values())
      .map((group) => ({
        key: group.key,
        primary_label: group.primary_label,
        rows: [...group.rows].sort((a, b) => {
          const byClosing = Number(b.closing_pairs || 0) - Number(a.closing_pairs || 0);
          if (byClosing) return byClosing;
          const byAging = Number(b.aging_days || 0) - Number(a.aging_days || 0);
          if (byAging) return byAging;
          return String(a.sku_code || "").localeCompare(String(b.sku_code || ""));
        }),
        sku_count: group.sku_ids.size,
        department_count: group.department_ids.size,
        branch_label: summarizeNameSet(group.branch_names),
        closing_pairs: Number(Number(group.closing_pairs || 0).toFixed(3)),
        closing_dozen: Number(Number(group.closing_dozen || 0).toFixed(3)),
      }))
      .sort((a, b) => String(a.primary_label || "").localeCompare(String(b.primary_label || "")));
  })();
  const buildLedgerUrl = (row) => {
    const params = [
      "load_report=1",
      `department_id=${encodeURIComponent(Number(row?.department_id || 0))}`,
      `sku_id=${encodeURIComponent(Number(row?.sku_id || 0))}`,
    ];
    if (selectedAsOfDate) {
      params.push(`to_date=${encodeURIComponent(selectedAsOfDate)}`);
    }
    if (selectedBranchIds.length) {
      selectedBranchIds.forEach((branchId) => {
        params.push(`branch_ids=${encodeURIComponent(Number(branchId || 0))}`);
      });
    }
    return `${ledgerReportPath}?${params.join("&")}`;
  };
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <%- include("../base/partials/report-help-header", {
      title: reportTitle,
      tooltipText: reportPurposeTooltip,
    }) %>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-production-department-wip-balances-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= asOfDateLabel %></label>
          <div class="sm:col-span-9">
            <input
              type="date"
              name="as_of_date"
              value="<%= selectedAsOfDate %>"
              max="9999-12-31"
              class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm"
            >
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("departments") %></label>
          <div class="sm:col-span-9">
            <select name="department_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= departmentAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.departments || []).forEach((department) => { %>
                <option value="<%= department.id %>" <%= selectedDepartmentIds.includes(Number(department.id)) ? "selected" : "" %>><%= department.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("sku") %></label>
          <div class="sm:col-span-9">
            <select name="sku_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= skuAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.skus || []).forEach((sku) => { %>
                <option value="<%= sku.id %>" <%= selectedSkuIds.includes(Number(sku.id)) ? "selected" : "" %>><%= `${sku.sku_code || "-"} - ${sku.article_name || "-"}` %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t("branches") : t("branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchIds.includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= orderByLabel %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'department' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="department" <%= selectedOrderBy === "department" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("department") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'sku' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="sku" <%= selectedOrderBy === "sku" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("sku") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("report_type") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'details' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="details" <%= selectedReportType === "details" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("details") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'summary' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="summary" <%= selectedReportType === "summary" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("summary") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <div class="sm:col-span-3"></div>
          <div class="sm:col-span-9 flex flex-wrap gap-2">
            <button type="submit" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-print-area>
    <div class="flex flex-col gap-3 border-b border-slate-200 px-2 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="text-sm font-semibold text-slate-700"><%= reportTitle %></div>
      <div class="flex items-center gap-2">
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-download-button <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-print-button <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
        <%- include("../base/partials/table-controls", { t, showStatus: false }) %>
      </div>
    </div>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <% if (selectedReportType === "details") { %>
        <div class="relative mt-4 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-330 w-full text-sm tabular-nums" data-table data-report-table>
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="department_name"><%= t("department") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="article_name"><%= articlesLabel %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="sku_code"><%= t("sku") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="product_group_name"><%= t("product_group") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="production_type"><%= t("production_type") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="aging_days"><%= agingDaysLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="closing_pairs"><%= closingPairsLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="closing_dozen"><%= closingDozenLabel %></th>
                <% if (includeBranchColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="branch_name"><%= t("branch") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100" data-table-body>
              <% detailGroups.forEach((group) => { %>
                <tr class="bg-slate-700 text-white" data-row data-active="true">
                  <td colspan="<%= detailColumnCount %>" class="px-3 py-1.5">
                    <div class="flex flex-wrap items-center gap-2">
                      <% if (selectedOrderBy === "sku") { %>
                        <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= t("sku") %>: <%= group.primary_label || "-" %></span>
                        <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= departmentCountLabel %>: <%= Number(group.department_count || 0) %></span>
                      <% } else { %>
                        <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= t("department") %>: <%= group.primary_label || "-" %></span>
                        <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= skuCountLabel %>: <%= Number(group.sku_count || 0) %></span>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% (group.rows || []).forEach((row) => { %>
                  <tr class="odd:bg-slate-50 even:bg-white hover:bg-slate-100" data-row data-active="true">
                    <td class="px-3 py-2"><%= row.department_name || "-" %></td>
                    <td class="px-3 py-2"><%= row.article_name || "-" %></td>
                    <td class="px-3 py-2">
                      <a href="<%= buildLedgerUrl(row) %>" class="font-semibold text-accent hover:underline"><%= row.sku_code || "-" %></a>
                    </td>
                    <td class="px-3 py-2"><%= row.product_group_name || "-" %></td>
                    <td class="px-3 py-2"><%= row.production_type || "-" %></td>
                    <td class="px-3 py-2 text-right"><%= Number(row.aging_days || 0) %></td>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatNumber(row.closing_pairs || 0, 3) %></td>
                    <td class="px-3 py-2 text-right"><%= formatNumber(row.closing_dozen || 0, 3) %></td>
                    <% if (includeBranchColumn) { %>
                      <td class="px-3 py-2"><%= row.branch_name || "-" %></td>
                    <% } %>
                  </tr>
                <% }) %>
                <tr class="bg-accent text-white" data-row data-active="true">
                  <td colspan="<%= detailTotalsLabelSpan %>" class="px-3 py-2">
                    <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 text-[11px] font-extrabold uppercase tracking-[0.08em]">
                      <span><%= t("total") %></span>
                    </div>
                  </td>
                  <td class="px-3 py-2 text-right font-extrabold tabular-nums"><%= formatNumber(group.closing_pairs || 0, 3) %></td>
                  <td class="px-3 py-2 text-right font-extrabold tabular-nums"><%= formatNumber(group.closing_dozen || 0, 3) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"></td>
                  <% } %>
                </tr>
              <% }) %>
              <tr class="bg-slate-800 text-white" data-row data-active="true" data-report-grand-total>
                <td colspan="6" class="px-3 py-3 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                <td class="px-3 py-3 text-right font-black tabular-nums text-emerald-100"><%= formatNumber(reportData?.totals?.closingPairs || 0, 3) %></td>
                <td class="px-3 py-3 text-right font-extrabold tabular-nums"><%= formatNumber(reportData?.totals?.closingDozen || 0, 3) %></td>
                <% if (includeBranchColumn) { %>
                  <td class="px-3 py-3"></td>
                <% } %>
              </tr>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="relative mt-4 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-245 w-full text-sm tabular-nums" data-table data-report-table>
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="department_name"><%= selectedOrderBy === "sku" ? t("sku") : t("department") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="sku_count"><%= selectedOrderBy === "sku" ? departmentCountLabel : skuCountLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="avg_aging_days"><%= avgAgingDaysLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="max_aging_days"><%= maxAgingDaysLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="closing_pairs"><%= closingPairsLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="closing_dozen"><%= closingDozenLabel %></th>
                <% if (includeBranchColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="branch_label"><%= t("branches") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100" data-table-body>
              <% summaryRows.forEach((row) => { %>
                <tr class="bg-slate-200/50 text-slate-700" data-row data-active="true">
                  <td class="px-3 py-2"><%= selectedOrderBy === "sku" ? (row.sku_code || "-") : (row.department_name || "-") %></td>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= selectedOrderBy === "sku" ? Number(row.department_count || 0) : Number(row.sku_count || 0) %></td>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= formatNumber(row.avg_aging_days || 0, 2) %></td>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= Number(row.max_aging_days || 0) %></td>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= formatNumber(row.closing_pairs || 0, 3) %></td>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= formatNumber(row.closing_dozen || 0, 3) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"><%= row.branch_label || "-" %></td>
                  <% } %>
                </tr>
              <% }) %>
              <tr class="bg-rose-700 text-white" data-row data-active="true" data-report-grand-total>
                <td colspan="4" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                <td class="px-3 py-2 text-right font-black tabular-nums text-emerald-100"><%= formatNumber(reportData?.totals?.closingPairs || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-extrabold tabular-nums"><%= formatNumber(reportData?.totals?.closingDozen || 0, 3) %></td>
                <% if (includeBranchColumn) { %>
                  <td class="px-3 py-2 text-left"><%= selectedOrderBy === "sku" ? Number(reportData?.totals?.skuCount || 0) : Number(reportData?.totals?.departmentCount || 0) %> <%= selectedOrderBy === "sku" ? t("sku") : t("departments") %></td>
                <% } %>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>
      <%- include("../base/partials/table-footer", { t }) %>
    <% } %>
  </section>
</div>

<script>
  (function () {
    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }
  })();
</script>