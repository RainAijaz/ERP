<%
  const reportLoaded = Boolean(filters?.reportLoaded);
  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const groups = Array.isArray(reportData?.groups) ? reportData.groups : [];
  const summaryRows = Array.isArray(reportData?.summaryRows) ? reportData.summaryRows : [];
  const selectedOrderBy = ["voucher", "sku", "department"].includes(String(filters?.orderBy || "").toLowerCase())
    ? String(filters.orderBy).toLowerCase()
    : "voucher";
  const selectedReportType = ["details", "summary"].includes(String(filters?.reportType || "").toLowerCase())
    ? String(filters.reportType).toLowerCase()
    : "details";
  const hasData = selectedReportType === "summary" ? summaryRows.length > 0 : groups.length > 0;
  const allMultiOptionValue = "__ALL__";
  const selectedBranchIds = Array.isArray(filters?.branchIds) ? filters.branchIds : [];
  const selectedDepartmentIds = Array.isArray(filters?.departmentIds) ? filters.departmentIds : [];
  const selectedLabourIds = Array.isArray(filters?.labourIds) ? filters.labourIds : [];
  const selectedProductGroupIds = Array.isArray(filters?.productGroupIds) ? filters.productGroupIds : [];
  const selectedProductSubgroupIds = Array.isArray(filters?.productSubgroupIds) ? filters.productSubgroupIds : [];
  const selectedArticleIds = Array.isArray(filters?.articleIds) ? filters.articleIds : [];
  const selectedProductionType = String(filters?.productionType || "ALL").toUpperCase();
  const selectedSkuUnit = ["ALL", "PAIR", "DZN"].includes(String(filters?.skuUnit || "").toUpperCase())
    ? String(filters?.skuUnit || "").toUpperCase()
    : "ALL";
  const selectedStageScope = String(filters?.stageScope || "ALL").toUpperCase() === "FINAL_ONLY" ? "FINAL_ONLY" : "ALL";
  const branchAllSelected = !selectedBranchIds.length;
  const departmentAllSelected = !selectedDepartmentIds.length;
  const labourAllSelected = !selectedLabourIds.length;
  const groupAllSelected = !selectedProductGroupIds.length;
  const subgroupAllSelected = !selectedProductSubgroupIds.length;
  const articleAllSelected = !selectedArticleIds.length;
  const summaryGroupLabel = selectedOrderBy === "sku"
    ? t("sku")
    : selectedOrderBy === "department"
      ? t("department")
      : t("voucher_no");
  const showVoucherColumn = selectedOrderBy !== "voucher";
  const showSkuColumn = selectedOrderBy !== "sku";
  const showDepartmentColumn = selectedOrderBy === "sku";
  const showLabourColumn = selectedOrderBy === "sku" || selectedOrderBy === "department";
  const showStageColumn = selectedOrderBy === "sku";
  const showProductionTypeColumn = selectedOrderBy !== "sku";
  const showProductGroupColumn = selectedOrderBy !== "sku";
  const showSkuUnitColumn = true;
  const includeBranchColumn = Boolean(user?.isAdmin) && selectedBranchIds.length !== 1;
  const detailTotalsLabelSpan = 1
    + (showVoucherColumn ? 1 : 0)
    + (showSkuColumn ? 1 : 0)
    + (showDepartmentColumn ? 1 : 0)
    + (showLabourColumn ? 1 : 0)
    + (showStageColumn ? 1 : 0)
    + (showProductionTypeColumn ? 1 : 0)
    + (showSkuUnitColumn ? 1 : 0)
    + (showProductGroupColumn ? 1 : 0);
  const detailColumnCount = detailTotalsLabelSpan + 1 + (includeBranchColumn ? 1 : 0);
  const dozenShortLabel = (() => { const value = t("dozen"); return value && value !== "dozen" ? value : "Dozen"; })();
  const pairsShortLabel = (() => { const value = t("pairs"); return value && value !== "pairs" ? value : "Pairs"; })();
  const articlesLabel = (() => { const value = t("articles"); return value && value !== "articles" ? value : "Articles"; })();
  const productionUnitLabel = (() => { const value = t("production_unit"); return value && value !== "production_unit" ? value : "Production Unit"; })();
  const stageScopeLabel = (() => { const value = t("stage_scope"); return value && value !== "stage_scope" ? value : "Stage Scope"; })();
  const finalStageOnlyLabel = (() => { const value = t("final_stage_only"); return value && value !== "final_stage_only" ? value : "Final Stage Only"; })();
  const advancedFiltersLabel = (() => { const value = t("advanced_filters"); return value && value !== "advanced_filters" ? value : "Advanced Filters"; })();
  const advancedFilterEntries = [
    selectedProductGroupIds.length ? t("product_groups") : "",
    selectedProductSubgroupIds.length ? t("product_subgroups") : "",
    selectedArticleIds.length ? articlesLabel : "",
    selectedLabourIds.length ? t("labours") : "",
    selectedDepartmentIds.length ? t("departments") : "",
    selectedProductionType !== "ALL" ? t("production_type") : "",
    selectedSkuUnit !== "ALL" ? productionUnitLabel : "",
  ].filter(Boolean);
  const advancedFilterCount = advancedFilterEntries.length;
  const advancedFilterSummary = advancedFilterEntries.join(", ");
  const formatDate = (value) => formatDateDisplay(value, "-");
  const formatNumber = (value, decimals = 3) => formatNumberDisplay(value, { decimals, fallback: "0" });
  const formatSkuUnit = (value) => {
    const normalized = String(value || "").trim().toUpperCase();
    if (normalized === "DZN") return t("unit_dozen");
    if (normalized === "PAIR") return t("unit_pair");
    return "-";
  };
  const formatDateRangeLabel = (fromDate, toDate) => {
    const from = String(fromDate || "").trim();
    const to = String(toDate || "").trim();
    if (!from && !to) return "-";
    if (!from) return formatDate(to);
    if (!to) return formatDate(from);
    if (from === to) return formatDate(from);
    return `${formatDate(from)} - ${formatDate(to)}`;
  };
  const reportPurposeTooltip = (() => {
    const key = "production_control_report_purpose_tooltip";
    const value = t(key);
    return value && value !== key ? value : "";
  })();
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= t("production_control_report") %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-production-control-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-end">
          <button
            type="button"
            class="relative inline-flex h-10 w-10 items-center justify-center self-end rounded-lg border border-slate-300 bg-white text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
            data-advanced-filter-toggle
            aria-expanded="false"
            aria-label="<%= advancedFiltersLabel %>"
            title="<%= advancedFiltersLabel %>"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M3 5h14M6 10h8M8 15h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
            <% if (advancedFilterCount > 0) { %>
              <span class="absolute -right-1.5 -top-1.5 inline-flex min-w-[1.1rem] items-center justify-center rounded-full bg-accent px-1 py-0.5 text-[10px] font-bold text-white"><%= advancedFilterCount %></span>
            <% } %>
          </button>
          <% if (advancedFilterCount > 0) { %>
            <div class="text-right text-xs font-medium text-slate-600 sm:max-w-[32rem]">
              <span class="font-semibold text-slate-700"><%= advancedFiltersLabel %>:</span>
              <span><%= advancedFilterSummary %></span>
            </div>
          <% } %>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("date_range") %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input type="text" readonly value="<%= `${filters?.fromDate || ''} - ${filters?.toDate || ''}` %>" data-date-range-input class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm">
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div>
                    </div>
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div>
                    </div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 xl:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <span><%= t("weekday_sun_short") %></span><span><%= t("weekday_mon_short") %></span><span><%= t("weekday_tue_short") %></span><span><%= t("weekday_wed_short") %></span><span><%= t("weekday_thu_short") %></span><span><%= t("weekday_fri_short") %></span><span><%= t("weekday_sat_short") %></span>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden xl:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <span><%= t("weekday_sun_short") %></span><span><%= t("weekday_mon_short") %></span><span><%= t("weekday_tue_short") %></span><span><%= t("weekday_wed_short") %></span><span><%= t("weekday_thu_short") %></span><span><%= t("weekday_fri_short") %></span><span><%= t("weekday_sat_short") %></span>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2">
                  <button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button>
                  <button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button>
                </div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= filters?.fromDate || '' %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= filters?.toDate || '' %>" data-to-date-hidden>
          </div>
        </div>

        <div class="hidden space-y-3 rounded-2xl border border-slate-200/80 bg-white/70 p-3" data-advanced-filter-panel>
          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("product_groups") %></label>
            <div class="sm:col-span-9">
              <select name="product_group_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= groupAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.productGroups || []).forEach((group) => { %>
                  <option value="<%= group.id %>" <%= selectedProductGroupIds.includes(Number(group.id)) ? "selected" : "" %>><%= group.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("product_subgroups") %></label>
            <div class="sm:col-span-9">
              <select name="product_subgroup_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= subgroupAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.productSubgroups || []).forEach((subgroup) => { %>
                  <option value="<%= subgroup.id %>" <%= selectedProductSubgroupIds.includes(Number(subgroup.id)) ? "selected" : "" %>><%= subgroup.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= articlesLabel %></label>
            <div class="sm:col-span-9">
              <select name="article_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= articleAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.articles || []).forEach((article) => { %>
                  <option value="<%= article.id %>" <%= selectedArticleIds.includes(Number(article.id)) ? "selected" : "" %>><%= article.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("labours") %></label>
            <div class="sm:col-span-9">
              <select name="labour_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= labourAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.labours || []).forEach((labour) => { %>
                  <option value="<%= labour.id %>" <%= selectedLabourIds.includes(Number(labour.id)) ? "selected" : "" %>><%= labour.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("departments") %></label>
            <div class="sm:col-span-9">
              <select name="department_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= departmentAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.departments || []).forEach((department) => { %>
                  <option value="<%= department.id %>" <%= selectedDepartmentIds.includes(Number(department.id)) ? "selected" : "" %>><%= department.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("production_type") %></label>
            <div class="sm:col-span-9">
              <select name="production_type" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <% (options?.productionTypes || []).forEach((option) => { %>
                  <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === selectedProductionType ? "selected" : "" %>><%= t(option.labelKey) %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= productionUnitLabel %></label>
            <div class="sm:col-span-9">
              <select name="sku_unit" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <% (options?.skuUnits || []).forEach((option) => { %>
                  <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === selectedSkuUnit ? "selected" : "" %>><%= t(option.labelKey) %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= stageScopeLabel %></label>
          <div class="sm:col-span-9">
            <select name="stage_scope" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <% (options?.stageScopes || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === selectedStageScope ? "selected" : "" %>><%= option.labelKey === "final_stage_only" ? finalStageOnlyLabel : t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t("branches") : t("branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchIds.includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("order_by") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'voucher' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="voucher" <%= selectedOrderBy === "voucher" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("voucher_no") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'sku' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="sku" <%= selectedOrderBy === "sku" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("sku") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'department' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="department" <%= selectedOrderBy === "department" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("department") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("report_type") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'details' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="details" <%= selectedReportType === "details" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("details") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'summary' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="summary" <%= selectedReportType === "summary" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("summary") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <div class="sm:col-span-3"></div>
          <div class="sm:col-span-9 flex flex-wrap gap-2">
            <button type="submit" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-print-area>
    <div class="flex flex-col gap-3 border-b border-slate-200 px-2 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="text-sm font-semibold text-slate-700"><%= t("production_control_report") %></div>
      <div class="flex items-center gap-2">
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-download-button <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-print-button <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
        <%- include("../base/partials/table-controls", { t, showStatus: false }) %>
      </div>
    </div>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <% if (selectedReportType === "details") { %>
        <div class="relative mt-4 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[1120px] w-full text-sm tabular-nums" data-table data-report-table>
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="date"><%= t("date") %></th>
                <% if (showVoucherColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="voucher_no"><%= t("voucher_no") %></th>
                <% } %>
                <% if (showSkuColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="sku_code"><%= t("sku") %></th>
                <% } %>
                <% if (showDepartmentColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="department_name"><%= t("department") %></th>
                <% } %>
                <% if (showLabourColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="labour_name"><%= t("labour") %></th>
                <% } %>
                <% if (showStageColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="stage_name"><%= t("production_stages") %></th>
                <% } %>
                <% if (showProductionTypeColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="production_type"><%= t("production_type") %></th>
                <% } %>
                <% if (showSkuUnitColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="sku_unit"><%= productionUnitLabel %></th>
                <% } %>
                <% if (showProductGroupColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="product_group_name"><%= t("product_group") %></th>
                <% } %>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="qty"><%= t("quantity") %></th>
                <% if (includeBranchColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="branch_name"><%= t("branch") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100" data-table-body>
              <% groups.forEach((group) => { %>
                <tr class="bg-slate-700 text-white" data-row data-active="true">
                  <td colspan="<%= detailColumnCount %>" class="px-3 py-1.5">
                    <div class="flex flex-wrap items-center gap-2">
                      <% if (selectedOrderBy === "voucher") { %>
                        <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white">VR. NO. <%= group.label || "-" %></span>
                      <% } else { %>
                        <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= summaryGroupLabel %>: <%= group.label || "-" %></span>
                      <% } %>
                      <% if (selectedOrderBy === "voucher") { %>
                        <% if (String(group.department_label || "").trim() && group.department_label !== "-") { %>
                          <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= t("department") %>: <%= group.department_label %></span>
                        <% } %>
                        <% if (String(group.labour_label || "").trim() && group.labour_label !== "-") { %>
                          <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= t("labour") %>: <%= group.labour_label %></span>
                        <% } %>
                      <% } else if (selectedOrderBy === "sku") { %>
                        <% if (String(group.product_group_label || "").trim() && group.product_group_label !== "-") { %>
                          <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= t("product_group") %>: <%= group.product_group_label %></span>
                        <% } %>
                        <% if (String(group.production_type_label || "").trim() && group.production_type_label !== "-") { %>
                          <span class="inline-flex items-center rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= t("production_type") %>: <%= group.production_type_label %></span>
                        <% } %>
                      <% } %>
                    </div>
                  </td>
                </tr>
                <% (group.rows || []).forEach((row) => { %>
                  <tr class="bg-white odd:bg-slate-50 even:bg-white hover:bg-slate-100" data-row data-active="true">
                    <td class="px-3 py-2"><%= formatDate(row.date) %></td>
                    <% if (showVoucherColumn) { %>
                      <td class="px-3 py-2"><%= row.voucher_no || "-" %></td>
                    <% } %>
                    <% if (showSkuColumn) { %>
                      <td class="px-3 py-2"><%= row.sku_code || "-" %></td>
                    <% } %>
                    <% if (showDepartmentColumn) { %>
                      <td class="px-3 py-2"><%= row.department_name || "-" %></td>
                    <% } %>
                    <% if (showLabourColumn) { %>
                      <td class="px-3 py-2"><%= row.labour_name || "-" %></td>
                    <% } %>
                    <% if (showStageColumn) { %>
                      <td class="px-3 py-2"><%= row.stage_name || "-" %></td>
                    <% } %>
                    <% if (showProductionTypeColumn) { %>
                      <td class="px-3 py-2"><%= row.production_type || "-" %></td>
                    <% } %>
                    <% if (showSkuUnitColumn) { %>
                      <td class="px-3 py-2"><%= formatSkuUnit(row.sku_unit) %></td>
                    <% } %>
                    <% if (showProductGroupColumn) { %>
                      <td class="px-3 py-2"><%= row.product_group_name || "-" %></td>
                    <% } %>
                    <td class="px-3 py-2 text-right"><%= formatNumber(row.qty || 0, 3) %></td>
                    <% if (includeBranchColumn) { %>
                      <td class="px-3 py-2"><%= row.branch_name || "-" %></td>
                    <% } %>
                  </tr>
                <% }) %>
                <tr class="bg-accent text-white">
                  <td colspan="<%= detailTotalsLabelSpan %>" class="px-3 py-2">
                    <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 text-[11px] font-extrabold uppercase tracking-[0.08em]">
                      <span><%= t("total") %></span>
                      <span><%= dozenShortLabel %>: <span class="tabular-nums"><%= formatNumber(group.packed_qty || 0, 3) %></span></span>
                      <span><%= pairsShortLabel %>: <span class="tabular-nums"><%= formatNumber(group.loose_qty || 0, 3) %></span></span>
                    </div>
                  </td>
                  <td class="px-3 py-2 text-right font-extrabold tabular-nums"><%= formatNumber(group.qty || 0, 3) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"></td>
                  <% } %>
                </tr>
              <% }) %>
              <tr class="bg-slate-800 text-white" data-row data-active="true" data-report-grand-total>
                <td colspan="<%= detailTotalsLabelSpan %>" class="px-3 py-3">
                  <div class="flex flex-wrap items-center justify-end gap-x-4 gap-y-1 text-[11px] font-extrabold uppercase tracking-[0.08em]">
                    <span><%= t("grand_total") %></span>
                    <span><%= dozenShortLabel %>: <span class="tabular-nums"><%= formatNumber(reportData?.totals?.packedQty || 0, 3) %></span></span>
                    <span><%= pairsShortLabel %>: <span class="tabular-nums"><%= formatNumber(reportData?.totals?.looseQty || 0, 3) %></span></span>
                  </div>
                </td>
                <td class="px-3 py-3 text-right font-black tabular-nums text-emerald-100"><%= formatNumber(reportData?.totals?.qty || 0, 3) %></td>
                <% if (includeBranchColumn) { %>
                  <td class="px-3 py-3"></td>
                <% } %>
              </tr>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="relative mt-4 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[1080px] w-full text-sm tabular-nums" data-table data-report-table>
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="group_label"><%= summaryGroupLabel %></th>
                <% if (selectedOrderBy === "voucher") { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="date_from"><%= t("date") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="department_label"><%= t("department") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="labour_label"><%= t("labour") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="production_type_label"><%= t("production_type") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="unit_label"><%= productionUnitLabel %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="product_group_label"><%= t("product_group") %></th>
                <% } else if (selectedOrderBy === "sku") { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="product_group_label"><%= t("product_group") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="production_type_label"><%= t("production_type") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="department_label"><%= t("department") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="labour_label"><%= t("labour") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="unit_label"><%= productionUnitLabel %></th>
                <% } else { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="sku_label"><%= t("sku") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="labour_label"><%= t("labour") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="production_type_label"><%= t("production_type") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="unit_label"><%= productionUnitLabel %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="product_group_label"><%= t("product_group") %></th>
                <% } %>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="packed_qty"><%= dozenShortLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="loose_qty"><%= pairsShortLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="qty"><%= t("quantity") %></th>
                <% if (includeBranchColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="branch_label"><%= t("branches") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100" data-table-body>
              <% summaryRows.forEach((row) => { %>
                <tr class="bg-slate-200/50 text-slate-700" data-row data-active="true">
                  <td class="px-3 py-2"><%= row.group_label || "-" %></td>
                  <% if (selectedOrderBy === "voucher") { %>
                    <td class="px-3 py-2"><%= formatDateRangeLabel(row.date_from, row.date_to) %></td>
                    <td class="px-3 py-2"><%= row.department_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.labour_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.production_type_label || "-" %></td>
                    <td class="px-3 py-2"><%= formatSkuUnit(row.unit_label) !== "-" ? formatSkuUnit(row.unit_label) : (row.unit_label || "-") %></td>
                    <td class="px-3 py-2"><%= row.product_group_label || "-" %></td>
                  <% } else if (selectedOrderBy === "sku") { %>
                    <td class="px-3 py-2"><%= row.product_group_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.production_type_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.department_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.labour_label || "-" %></td>
                    <td class="px-3 py-2"><%= formatSkuUnit(row.unit_label) !== "-" ? formatSkuUnit(row.unit_label) : (row.unit_label || "-") %></td>
                  <% } else { %>
                    <td class="px-3 py-2"><%= row.sku_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.labour_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.production_type_label || "-" %></td>
                    <td class="px-3 py-2"><%= formatSkuUnit(row.unit_label) !== "-" ? formatSkuUnit(row.unit_label) : (row.unit_label || "-") %></td>
                    <td class="px-3 py-2"><%= row.product_group_label || "-" %></td>
                  <% } %>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= formatNumber(row.packed_qty || 0, 3) %></td>
                  <td class="px-3 py-2 text-right font-semibold tabular-nums"><%= formatNumber(row.loose_qty || 0, 3) %></td>
                  <td class="px-3 py-2 text-right"><%= formatNumber(row.qty || 0, 3) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"><%= row.branch_label || "-" %></td>
                  <% } %>
                </tr>
              <% }) %>
              <tr class="bg-rose-700 text-white" data-row data-active="true" data-report-grand-total>
                <% if (selectedOrderBy === "voucher") { %>
                  <td colspan="7" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                <% } else { %>
                  <td colspan="6" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                <% } %>
                <td class="px-3 py-2 text-right font-extrabold tabular-nums"><%= formatNumber(reportData?.totals?.packedQty || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-extrabold tabular-nums"><%= formatNumber(reportData?.totals?.looseQty || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-black tabular-nums text-emerald-100"><%= formatNumber(reportData?.totals?.qty || 0, 3) %></td>
                <% if (includeBranchColumn) { %>
                  <td class="px-3 py-2 text-left"></td>
                <% } %>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>
      <%- include("../base/partials/table-footer", { t }) %>
    <% } %>
  </section>
</div>

<script><%- include("../base/partials/date-range-picker.js") %></script>

<script><%- include("../base/partials/advanced-filter-toggle.js") %></script>
<script>
  (function () {
    const form = document.querySelector("[data-production-control-filter-form]");
    if (!form) return;

    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }
    if (typeof window.initReportDateRangePicker === "function") {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
        selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>,
      });
    }
    if (typeof window.initAdvancedFilterToggle === "function") {
      window.initAdvancedFilterToggle({ root: form });
    }
  })();
</script>
