<%
  const tt = (key, fallback) => {
    const value = typeof t === "function" ? t(key) : "";
    return value && value !== key ? value : fallback;
  };
  const ttTitle = (key) => {
    const value = typeof t === "function" ? t(key) : "";
    return value && value !== key ? value : "";
  };

  const reportLoaded = Boolean(filters?.reportLoaded);
  const fromDate = String(filters?.from || "");
  const toDate = String(filters?.to || "");
  const stockTypeFilter = String(filters?.stockTypeFilter || "FG").toUpperCase();
  const isFinished = stockTypeFilter === "FG";
  const stockStatus =
    String(filters?.stockStatus || "PACKED").toUpperCase() === "LOOSE"
      ? "LOOSE"
      : "PACKED";
  const selectedUnitId = Number(filters?.unitId || 0) || null;
  const selectedUnitLabel = String(filters?.unitLabel || "").trim();
  const rateType = String(filters?.rateType || "SALE").toUpperCase();
  const viewType = String(filters?.viewType || "summary").toLowerCase();
  const isDetails = viewType === "details";
  const minClosingQty = Number(filters?.minClosingQty || 0);
  const deadStockOnly = Boolean(filters?.deadStockOnly);
  const sortBy = String(filters?.sortBy || "CLOSING_QTY_DESC").toUpperCase();
  const allMultiOptionValue = "__ALL__";
  const canViewValues = Boolean(canViewCostFields);

  const selectedBranchIds = Array.isArray(filters?.branchIds) ? filters.branchIds : [];
  const selectedGroupIds = Array.isArray(filters?.productGroupIds) ? filters.productGroupIds : [];
  const selectedSubgroupIds = Array.isArray(filters?.productSubgroupIds) ? filters.productSubgroupIds : [];

  const branchAllSelected = !selectedBranchIds.length;
  const groupAllSelected = !selectedGroupIds.length;
  const subgroupAllSelected = !selectedSubgroupIds.length;

  const unitOptions = Array.isArray(options?.unitOptions) ? options.unitOptions : [];

  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const totals = reportData?.totals || {
    totalSkus: 0,
    totalClosingQty: 0,
    totalClosingValue: 0,
    totalQtySold: 0,
    deadStockSkuCount: 0,
    deadStockValue: 0,
  };
  const hasData = rows.length > 0;

  const formatQty = (value) => formatNumberDisplay(value, { decimals: 3, fallback: "0" });
  const formatMoney = (value) => formatNumberDisplay(value, { decimals: 2, fallback: "0" });
  const naLabel = tt("not_applicable_short", "N/A");
  const qtySuffix = selectedUnitLabel ? ` (${selectedUnitLabel})` : "";

  const statusOf = (row) => {
    if (row.isDeadStock) return { key: "dead", labelKey: "stock_status_dead", fallback: "Dead", tone: "bg-rose-100 text-rose-700 border-rose-200" };
    const ratio = row.turnoverRatio;
    if (ratio === null || ratio < 0.25) return { key: "slow", labelKey: "stock_status_slow", fallback: "Slow Moving", tone: "bg-amber-100 text-amber-700 border-amber-200" };
    return { key: "healthy", labelKey: "stock_status_healthy", fallback: "Healthy", tone: "bg-emerald-100 text-emerald-700 border-emerald-200" };
  };

  const weekdayShortLabels = [
    t("weekday_sun_short"),
    t("weekday_mon_short"),
    t("weekday_tue_short"),
    t("weekday_wed_short"),
    t("weekday_thu_short"),
    t("weekday_fri_short"),
    t("weekday_sat_short"),
  ];

  const reportPurposeTooltip = (() => {
    const key = "dead_stock_report_purpose_tooltip";
    const value = t(key);
    return value && value !== key ? value : "";
  })();

  const descriptorColspan = 3 + (isDetails ? 1 : 0);
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= tt("dead_stock_report", "Slow-Moving / Dead Stock Report") %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>

    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= tt("date_filters_auto_corrected", "Some date filters were invalid and have been reset.") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-dead-stock-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("date_range", "Date Range") %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input type="text" readonly value="<%= `${fromDate} - ${toDate}` %>" data-date-range-input class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm">
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div></div>
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div></div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-52.5 rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden sm:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-52.5 rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2"><button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button><button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button></div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= fromDate %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= toDate %>" data-to-date-hidden>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("stock_type", "Stock Type") %></label>
          <div class="sm:col-span-9">
            <select name="stock_type_filter" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <% (options?.stockTypeFilters || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === stockTypeFilter ? "selected" : "" %>><%= t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= isFinished ? '' : 'hidden' %>" data-packaging-filter-row>
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("packaging", "Packaging") %></label>
          <div class="sm:col-span-9">
            <select name="stock_status" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" <%= isFinished ? "" : "disabled" %>>
              <% (options?.stockStatuses || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === stockStatus ? "selected" : "" %>><%= t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= isFinished ? 'hidden' : '' %>" data-sfg-unit-filter-row>
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("unit", "Unit") %></label>
          <div class="sm:col-span-9">
            <select name="unit_id" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" <%= isFinished ? "disabled" : "" %>>
              <% unitOptions.forEach((unit) => { %>
                <option value="<%= unit.id %>" data-unit-code="<%= unit.code || '' %>" <%= selectedUnitId === Number(unit.id) ? "selected" : "" %>><%= unit.code || unit.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("product_groups", "Product Groups") %></label>
          <div class="sm:col-span-9">
            <select name="product_group_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= groupAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.productGroups || []).forEach((group) => { %>
                <option value="<%= group.id %>" <%= selectedGroupIds.includes(Number(group.id)) ? "selected" : "" %>><%= group.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("product_subgroups", "Product Sub-Groups") %></label>
          <div class="sm:col-span-9">
            <select name="product_subgroup_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= subgroupAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.productSubgroups || []).forEach((subgroup) => { %>
                <option value="<%= subgroup.id %>" <%= selectedSubgroupIds.includes(Number(subgroup.id)) ? "selected" : "" %>><%= subgroup.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? tt("branches", "Branches") : tt("branch", "Branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchIds.includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
              <input type="hidden" name="branch_ids" value="<%= branchId || '' %>">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("report_type", "Report Type") %></label>
          <div class="sm:col-span-9 flex flex-wrap gap-4 rounded-xl bg-white/60 p-2">
            <% (options?.viewFilters || []).forEach((option) => { const selected = String(option.value || '').toLowerCase() === viewType; %>
              <label class="inline-flex items-center gap-2 text-sm <%= selected ? 'font-semibold text-accent' : 'text-slate-700' %>">
                <input type="radio" name="view_filter" value="<%= option.value %>" <%= selected ? "checked" : "" %>>
                <span><%= t(option.labelKey) %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("sort_by", "Sort By") %></label>
          <div class="sm:col-span-9 flex flex-wrap gap-4 rounded-xl bg-white/60 p-2">
            <% (options?.sortByOptions || []).forEach((option) => { const selected = String(option.value || '').toUpperCase() === sortBy; %>
              <label class="inline-flex items-center gap-2 text-sm <%= selected ? 'font-semibold text-accent' : 'text-slate-700' %>">
                <input type="radio" name="sort_by" value="<%= option.value %>" <%= selected ? "checked" : "" %>>
                <span><%= t(option.labelKey) %></span>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("min_closing_qty", "Minimum Closing Qty") %></label>
          <div class="sm:col-span-9">
            <input type="number" min="0" step="0.001" name="min_closing_qty" value="<%= minClosingQty || 0 %>" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("dead_stock_only", "Dead Stock Only") %></label>
          <div class="sm:col-span-9 flex items-center">
            <label class="inline-flex items-center gap-2 text-sm text-slate-700">
              <input type="checkbox" name="dead_stock_only" value="1" <%= deadStockOnly ? "checked" : "" %>>
              <span><%= tt("no_sales_in_period", "No sales in period") %></span>
            </label>
          </div>
        </div>

        <% if (canViewValues) { %>
          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= isFinished ? '' : 'hidden' %>" data-rate-type-filter-row>
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("rate_type", "Value Basis") %></label>
            <div class="sm:col-span-9 flex flex-wrap gap-4 rounded-xl bg-white/60 p-2">
              <% (options?.rateTypes || []).forEach((option) => { const selected = String(option.value || '').toUpperCase() === rateType; %>
                <label class="inline-flex items-center gap-2 text-sm <%= selected ? 'font-semibold text-accent' : 'text-slate-700' %>">
                  <input type="radio" name="rate_type" value="<%= option.value %>" <%= selected ? "checked" : "" %> <%= isFinished ? "" : "disabled" %>>
                  <span><%= t(option.labelKey) %></span>
                </label>
              <% }) %>
            </div>
          </div>
        <% } %>

        <div class="grid grid-cols-1 items-center gap-2 pt-1 sm:grid-cols-12">
          <div class="sm:col-start-4 sm:col-span-9 flex items-center gap-2">
            <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-report-print-area>
    <div class="flex items-center justify-end gap-2" data-report-controls>
      <button type="button" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-slate-700 disabled:opacity-40" data-print-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
      <button type="button" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" data-download-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
    </div>

    <% if (reportLoaded) { %>
      <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2 xl:grid-cols-6">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-slate-600"><%= tt("total_skus", "Total SKUs") %></div><div class="mt-1 text-base font-semibold text-slate-900"><%= totals.totalSkus || 0 %></div></div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-slate-600"><%= `${tt("closing_qty", "Closing Qty")}${qtySuffix}` %></div><div class="mt-1 text-base font-semibold text-slate-900"><%= formatQty(totals.totalClosingQty) %></div></div>
        <% if (canViewValues) { %>
          <div class="rounded-xl border border-slate-200 bg-slate-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-slate-600"><%= tt("closing_value", "Closing Value") %></div><div class="mt-1 text-base font-semibold text-slate-900"><%= formatMoney(totals.totalClosingValue) %></div></div>
        <% } %>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-emerald-700"><%= `${tt("qty_sold_period", "Qty Sold (Period)")}${qtySuffix}` %></div><div class="mt-1 text-base font-semibold text-emerald-900"><%= formatQty(totals.totalQtySold) %></div></div>
        <div class="rounded-xl border border-rose-200 bg-rose-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-rose-700"><%= tt("dead_stock_sku_count", "Dead Stock SKUs") %></div><div class="mt-1 text-base font-semibold text-rose-900"><%= totals.deadStockSkuCount || 0 %></div></div>
        <% if (canViewValues) { %>
          <div class="rounded-xl border border-rose-200 bg-rose-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-rose-700"><%= tt("dead_stock_value", "Dead Stock Value") %></div><div class="mt-1 text-base font-semibold text-rose-900"><%= formatMoney(totals.deadStockValue) %></div></div>
        <% } %>
      </div>
    <% } %>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= tt("load_report_to_view", "Load report to view") %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= tt("no_entries", "No entries") %></div>
    <% } else { %>
      <div class="relative mt-3 overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-[1180px] w-full text-sm tabular-nums" data-report-table data-export-title="<%= tt('dead_stock_report', 'Slow-Moving / Dead Stock Report') %>">
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("article", "Article") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("sku", "SKU") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("group", "Group") %></th>
              <% if (isDetails) { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("branch", "Branch") %></th>
              <% } %>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= `${tt("closing_qty", "Closing Qty")}${qtySuffix}` %></th>
              <% if (canViewValues) { %>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("closing_value", "Closing Value") %></th>
              <% } %>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= `${tt("qty_sold_period", "Qty Sold (Period)")}${qtySuffix}` %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em] cursor-help" title="<%= ttTitle('turnover_ratio_tooltip') %>"><%= tt("turnover_ratio", "Turnover Ratio") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em] cursor-help" title="<%= ttTitle('days_of_stock_cover_tooltip') %>"><%= tt("days_of_stock_cover", "Days of Stock Cover") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("status", "Status") %></th>
            </tr>
          </thead>
          <tbody data-table-body>
            <% rows.forEach((row) => { const status = statusOf(row); %>
              <tr class="odd:bg-slate-50 even:bg-white hover:bg-slate-100" data-row data-active="true" data-report-entry>
                <td class="px-3 py-2 font-medium text-slate-800"><%= row.article_name || "-" %></td>
                <td class="px-3 py-2"><%= row.sku_code || "-" %></td>
                <td class="px-3 py-2"><%= row.group_name || "-" %></td>
                <% if (isDetails) { %>
                  <td class="px-3 py-2"><%= row.branch_name || "-" %></td>
                <% } %>
                <td class="px-3 py-2 text-right font-semibold"><%= formatQty(row.closingQty) %></td>
                <% if (canViewValues) { %>
                  <td class="px-3 py-2 text-right"><%= formatMoney(row.closingValue) %></td>
                <% } %>
                <td class="px-3 py-2 text-right"><%= formatQty(row.qtySold) %></td>
                <td class="px-3 py-2 text-right"><%= row.turnoverRatio === null ? naLabel : formatQty(row.turnoverRatio) %></td>
                <td class="px-3 py-2 text-right"><%= row.daysOfStockCover === null ? naLabel : formatQty(row.daysOfStockCover) %></td>
                <td class="px-3 py-2">
                  <span class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold <%= status.tone %>"><%= tt(status.labelKey, status.fallback) %></span>
                </td>
              </tr>
            <% }) %>
            <tr class="bg-rose-700 text-white">
              <td colspan="<%= descriptorColspan %>" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(totals.totalClosingQty) %></td>
              <% if (canViewValues) { %>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatMoney(totals.totalClosingValue) %></td>
              <% } %>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(totals.totalQtySold) %></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2"></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</div>

<script><%- include("../base/partials/date-range-picker.js") %></script>
<script>
  (function () {
    const form = document.querySelector("[data-dead-stock-filter-form]");
    if (!form) return;

    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }

    if (typeof window.initReportDateRangePicker === "function") {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
        selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>,
      });
    }

    const allMultiValue = <%- JSON.stringify(allMultiOptionValue) %>;
    const allMultiSelects = Array.from(form.querySelectorAll('select[data-all-multi-select="true"]'));

    const setPrevSelectionState = (select) => {
      const opts = Array.from(select?.options || []);
      const selectedValues = opts.filter((option) => option.selected).map((option) => option.value);
      const hasAll = selectedValues.includes(allMultiValue);
      if (select) select.dataset.prevHasAll = hasAll ? "1" : "0";
    };

    const normalizeAllSelection = (select, useIntent = false) => {
      if (!select) return;
      const opts = Array.from(select.options || []);
      const allOption = opts.find((option) => option.value === allMultiValue);
      if (!allOption) return;

      const selectedValues = opts.filter((option) => option.selected).map((option) => option.value);
      const hasSpecific = selectedValues.some((value) => value !== allMultiValue);
      const hasAll = selectedValues.includes(allMultiValue);
      const prevHasAll = String(select.dataset.prevHasAll || "0") === "1";

      if (hasSpecific && hasAll) {
        if (useIntent && prevHasAll) {
          allOption.selected = false;
        } else {
          opts.forEach((option) => {
            if (option.value !== allMultiValue) option.selected = false;
          });
          allOption.selected = true;
        }
      } else if (!hasSpecific && !hasAll) {
        allOption.selected = true;
      }

      setPrevSelectionState(select);
    };

    allMultiSelects.forEach((select) => {
      normalizeAllSelection(select);
      setPrevSelectionState(select);
      select.addEventListener("focus", () => setPrevSelectionState(select));
      select.addEventListener("change", () => normalizeAllSelection(select, true));
    });

    form.addEventListener("submit", () => {
      allMultiSelects.forEach((select) => normalizeAllSelection(select));
    });

    const stockTypeSelect = form.querySelector('select[name="stock_type_filter"]');
    const packagingRow = form.querySelector("[data-packaging-filter-row]");
    const packagingSelect = form.querySelector('select[name="stock_status"]');
    const sfgUnitRow = form.querySelector("[data-sfg-unit-filter-row]");
    const sfgUnitSelect = form.querySelector('select[name="unit_id"]');
    const rateTypeRow = form.querySelector("[data-rate-type-filter-row]");
    const rateTypeRadios = Array.from(form.querySelectorAll('input[name="rate_type"]'));

    const pickSfgDefaultUnitValue = () => {
      if (!sfgUnitSelect) return "";
      const opts = Array.from(sfgUnitSelect.options || []);
      if (!opts.length) return "";
      const dozenOption = opts.find((option) => {
        const code = String(option.getAttribute("data-unit-code") || "").trim().toUpperCase();
        const label = String(option.textContent || "").trim().toUpperCase();
        return code === "DZN" || code === "DOZEN" || label === "DZN" || label === "DOZEN";
      });
      return String((dozenOption || opts[0])?.value || "");
    };

    const syncStockTypePresentation = () => {
      if (!stockTypeSelect) return;
      const isFinishedNow = String(stockTypeSelect.value || "").toUpperCase() === "FG";

      if (packagingRow) packagingRow.classList.toggle("hidden", !isFinishedNow);
      if (packagingSelect) packagingSelect.disabled = !isFinishedNow;

      if (sfgUnitRow) sfgUnitRow.classList.toggle("hidden", isFinishedNow);
      if (sfgUnitSelect) {
        sfgUnitSelect.disabled = isFinishedNow;
        if (!isFinishedNow) {
          const opts = Array.from(sfgUnitSelect.options || []);
          const selectedValue = String(sfgUnitSelect.value || "");
          const hasSelected = opts.some((option) => String(option.value || "") === selectedValue);
          if (!hasSelected || !selectedValue) sfgUnitSelect.value = pickSfgDefaultUnitValue();
        }
      }

      if (rateTypeRow) rateTypeRow.classList.toggle("hidden", !isFinishedNow);
      rateTypeRadios.forEach((radio) => { radio.disabled = !isFinishedNow; });

      if (typeof window.initSearchableSelects === "function") {
        window.initSearchableSelects();
      }
    };

    stockTypeSelect?.addEventListener("change", syncStockTypePresentation);
    syncStockTypePresentation();
  })();
</script>
