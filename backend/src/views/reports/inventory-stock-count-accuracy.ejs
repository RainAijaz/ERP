<%
  const tt = (key, fallback) => {
    const value = typeof t === "function" ? t(key) : "";
    return value && value !== key ? value : fallback;
  };

  const reportLoaded = Boolean(filters?.reportLoaded);
  const fromDate = String(filters?.from || "");
  const toDate = String(filters?.to || "");
  const periodGrain = String(filters?.periodGrain || "month").toLowerCase();
  const categoryFilter = String(filters?.category || "ALL").toUpperCase();
  const allMultiOptionValue = "__ALL__";

  const selectedBranchIds = Array.isArray(filters?.branchIds) ? filters.branchIds : [];
  const branchAllSelected = !selectedBranchIds.length;

  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const chart = reportData?.chart || { labels: [], qtyAccuracy: [], costAccuracy: [], costDifference: [] };
  const totals = reportData?.totals || {
    linesCounted: 0,
    costDifference: 0,
    qtyAccuracyPct: 100,
    costAccuracyPct: 100,
  };
  const hasData = rows.length > 0;

  const formatQty = (value) => formatNumberDisplay(value, { decimals: 3, fallback: "0" });
  const formatMoney = (value) => formatNumberDisplay(value, { decimals: 2, fallback: "0" });
  const formatPct = (value) => `${formatNumberDisplay(value, { decimals: 1, fallback: "0" })}%`;

  const accuracyTone = (pct) => {
    const value = Number(pct || 0);
    if (value >= 98) return "bg-emerald-100 text-emerald-700 border-emerald-200";
    if (value >= 90) return "bg-amber-100 text-amber-700 border-amber-200";
    return "bg-rose-100 text-rose-700 border-rose-200";
  };

  const weekdayShortLabels = [
    t("weekday_sun_short"),
    t("weekday_mon_short"),
    t("weekday_tue_short"),
    t("weekday_wed_short"),
    t("weekday_thu_short"),
    t("weekday_fri_short"),
    t("weekday_sat_short"),
  ];

  const reportPurposeTooltip = (() => {
    const key = "stock_count_accuracy_report_purpose_tooltip";
    const value = t(key);
    return value && value !== key ? value : "";
  })();
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= tt("stock_count_accuracy_report", "Stock Count Accuracy Report") %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>

    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= tt("date_filters_auto_corrected", "Some date filters were invalid and have been reset.") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-accuracy-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("date_range", "Date Range") %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input type="text" readonly value="<%= `${fromDate} - ${toDate}` %>" data-date-range-input class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm">
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div></div>
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div></div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-52.5 rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden sm:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-52.5 rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2"><button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button><button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button></div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= fromDate %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= toDate %>" data-to-date-hidden>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("period_grain", "Period Grain") %></label>
          <div class="sm:col-span-9">
            <select name="period_grain" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <% (options?.periodGrains || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toLowerCase() === periodGrain ? "selected" : "" %>><%= t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("category", "Category") %></label>
          <div class="sm:col-span-9">
            <select name="category_filter" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <% (options?.categoryFilters || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === categoryFilter ? "selected" : "" %>><%= t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? tt("branches", "Branches") : tt("branch", "Branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchIds.includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
              <input type="hidden" name="branch_ids" value="<%= branchId || '' %>">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-center gap-2 pt-1 sm:grid-cols-12">
          <div class="sm:col-start-4 sm:col-span-9 flex items-center gap-2">
            <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-report-print-area>
    <div class="flex items-center justify-end gap-2" data-report-controls>
      <button type="button" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-slate-700 disabled:opacity-40" data-print-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
      <button type="button" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" data-download-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
    </div>

    <% if (reportLoaded && hasData) { %>
      <div class="mt-3 grid grid-cols-1 gap-2 sm:grid-cols-2 xl:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-slate-600"><%= tt("lines_counted", "Lines Counted") %></div><div class="mt-1 text-base font-semibold text-slate-900"><%= totals.linesCounted || 0 %></div></div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-emerald-700"><%= tt("quantity_accuracy", "Quantity Accuracy") %></div><div class="mt-1 text-base font-semibold text-emerald-900"><%= formatPct(totals.qtyAccuracyPct) %></div></div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-emerald-700"><%= tt("cost_accuracy", "Cost Accuracy") %></div><div class="mt-1 text-base font-semibold text-emerald-900"><%= formatPct(totals.costAccuracyPct) %></div></div>
        <div class="rounded-xl border border-rose-200 bg-rose-50 p-2.5"><div class="text-[10px] uppercase font-semibold tracking-[0.08em] text-rose-700"><%= tt("total_cost_difference", "Total Cost Difference") %></div><div class="mt-1 text-base font-semibold text-rose-900"><%= formatMoney(totals.costDifference) %></div></div>
      </div>
    <% } %>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= tt("load_report_to_view", "Load report to view") %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= tt("no_entries", "No entries") %></div>
    <% } else { %>
      <div class="mt-3 rounded-2xl border border-slate-200 p-3">
        <div class="mb-2 text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= tt("accuracy_trend", "Accuracy Trend") %></div>
        <div class="relative w-full" style="min-height:280px;">
          <canvas data-accuracy-chart class="hidden w-full" style="max-height:340px;"></canvas>
          <svg data-accuracy-chart-fallback viewBox="0 0 720 300" preserveAspectRatio="xMidYMid meet" class="w-full" style="max-height:340px;"></svg>
        </div>
        <div class="mt-2 flex flex-wrap items-center gap-4 text-[11px] font-semibold text-slate-600">
          <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-full" style="background:#0f766e;"></span><%= tt("quantity_accuracy", "Quantity Accuracy") %> (%)</span>
          <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-2.5 rounded-full" style="background:#7c3aed;"></span><%= tt("cost_accuracy", "Cost Accuracy") %> (%)</span>
          <span class="inline-flex items-center gap-1.5"><span class="inline-block h-2.5 w-3.5 rounded-sm" style="background:rgba(244,63,94,0.35);"></span><%= tt("total_cost_difference", "Total Cost Difference") %></span>
        </div>
      </div>

      <div class="relative mt-3 overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-[960px] w-full text-sm tabular-nums" data-report-table data-export-title="<%= tt('stock_count_accuracy_report', 'Stock Count Accuracy Report') %>">
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("period", "Period") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("category", "Category") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("lines_counted", "Lines Counted") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("system_qty", "System Qty") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("unit_difference", "Unit Difference") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("quantity_accuracy", "Quantity Accuracy") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("cost_difference", "Cost Difference") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("cost_accuracy", "Cost Accuracy") %></th>
            </tr>
          </thead>
          <tbody data-table-body>
            <% rows.forEach((row) => { const unitLabel = tt(row.unitLabelKey, row.unitLabelKey === "dozens" ? "dozens" : "units"); %>
              <tr class="odd:bg-slate-50 even:bg-white hover:bg-slate-100" data-row data-active="true" data-report-entry>
                <td class="px-3 py-2 font-medium text-slate-800"><%= row.periodLabel %></td>
                <td class="px-3 py-2"><%= tt(row.categoryLabelKey, row.category) %></td>
                <td class="px-3 py-2 text-right"><%= formatQty(row.systemQtyDisplay) %> <span class="text-[10px] text-slate-500"><%= unitLabel %></span></td>
                <td class="px-3 py-2 text-right font-semibold"><%= formatQty(row.unitDiffDisplay) %> <span class="text-[10px] text-slate-500"><%= unitLabel %></span></td>
                <td class="px-3 py-2 text-right"><span class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold <%= accuracyTone(row.qtyAccuracyPct) %>"><%= formatPct(row.qtyAccuracyPct) %></span></td>
                <td class="px-3 py-2 text-right"><%= formatMoney(row.costDifference) %></td>
                <td class="px-3 py-2 text-right"><span class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold <%= accuracyTone(row.costAccuracyPct) %>"><%= formatPct(row.costAccuracyPct) %></span></td>
              </tr>
            <% }) %>
            <tr class="bg-slate-800 text-white" data-report-grand-total>
              <td colspan="2" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= totals.linesCounted || 0 %></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatPct(totals.qtyAccuracyPct) %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatMoney(totals.costDifference) %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatPct(totals.costAccuracyPct) %></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</div>

<script><%- include("../base/partials/date-range-picker.js") %></script>
<script>
  (function () {
    const form = document.querySelector("[data-accuracy-filter-form]");
    if (form) {
      if (typeof window.initSearchableSelects === "function") {
        window.initSearchableSelects();
      }
      if (typeof window.initReportDateRangePicker === "function") {
        window.initReportDateRangePicker({
          root: form,
          invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
          selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>,
        });
      }

      const allMultiValue = <%- JSON.stringify(allMultiOptionValue) %>;
      const allMultiSelects = Array.from(form.querySelectorAll('select[data-all-multi-select="true"]'));

      const normalizeAllSelection = (select) => {
        if (!select) return;
        const opts = Array.from(select.options || []);
        const allOption = opts.find((option) => option.value === allMultiValue);
        if (!allOption) return;
        const selectedValues = opts.filter((option) => option.selected).map((option) => option.value);
        const hasSpecific = selectedValues.some((value) => value !== allMultiValue);
        const hasAll = selectedValues.includes(allMultiValue);
        if (hasSpecific && hasAll) {
          allOption.selected = false;
        } else if (!hasSpecific && !hasAll) {
          allOption.selected = true;
        }
      };

      allMultiSelects.forEach((select) => {
        normalizeAllSelection(select);
        select.addEventListener("change", () => normalizeAllSelection(select));
      });
      form.addEventListener("submit", () => {
        allMultiSelects.forEach((select) => normalizeAllSelection(select));
      });
    }

    const chartData = <%- JSON.stringify(chart) %>;
    const labels = Array.isArray(chartData.labels) ? chartData.labels : [];
    if (!labels.length) return;

    const qtySeries = (chartData.qtyAccuracy || []).map((value) => Number(value || 0));
    const costSeries = (chartData.costAccuracy || []).map((value) => Number(value || 0));
    const costDiffSeries = (chartData.costDifference || []).map((value) => Number(value || 0));

    const canvas = document.querySelector("[data-accuracy-chart]");
    const fallback = document.querySelector("[data-accuracy-chart-fallback]");

    const renderSvgFallback = () => {
      if (!fallback) return;
      if (canvas) canvas.classList.add("hidden");
      fallback.classList.remove("hidden");

      const width = 720;
      const height = 300;
      const padX = 44;
      const padY = 28;
      const innerW = width - padX * 2;
      const innerH = height - padY * 2;
      const stepX = labels.length > 1 ? innerW / (labels.length - 1) : 0;
      const xAt = (idx) => padX + (labels.length > 1 ? stepX * idx : innerW / 2);
      const yAt = (pct) => padY + innerH - (Math.max(0, Math.min(100, pct)) / 100) * innerH;

      const grid = [0, 25, 50, 75, 100]
        .map((pct) => {
          const y = yAt(pct).toFixed(2);
          return `<line x1="${padX}" y1="${y}" x2="${(width - padX).toFixed(2)}" y2="${y}" stroke="#e2e8f0" stroke-width="1"></line>` +
            `<text x="${(padX - 6).toFixed(2)}" y="${(Number(y) + 3).toFixed(2)}" text-anchor="end" font-size="9" fill="#94a3b8">${pct}%</text>`;
        })
        .join("");

      const pathFor = (series, color, dash) => {
        if (!series.length) return "";
        const d = series
          .map((value, idx) => `${idx === 0 ? "M" : "L"} ${xAt(idx).toFixed(2)} ${yAt(value).toFixed(2)}`)
          .join(" ");
        const dots = series
          .map((value, idx) => `<circle cx="${xAt(idx).toFixed(2)}" cy="${yAt(value).toFixed(2)}" r="2.5" fill="${color}"></circle>`)
          .join("");
        return `<path d="${d}" fill="none" stroke="${color}" stroke-width="2.4"${dash ? ` stroke-dasharray="${dash}"` : ""}></path>${dots}`;
      };

      const xLabels = labels
        .map((label, idx) => {
          if (labels.length > 12 && idx % Math.ceil(labels.length / 12) !== 0) return "";
          return `<text x="${xAt(idx).toFixed(2)}" y="${(height - 8).toFixed(2)}" text-anchor="middle" font-size="8" fill="#64748b">${String(label).replace(/[<>&]/g, "")}</text>`;
        })
        .join("");

      fallback.innerHTML =
        `<rect x="0" y="0" width="${width}" height="${height}" fill="#ffffff"></rect>` +
        grid +
        pathFor(qtySeries, "#0f766e", "") +
        pathFor(costSeries, "#7c3aed", "5 4") +
        xLabels;
    };

    const loadChartJs = () => {
      if (window.Chart) return Promise.resolve(window.Chart);
      if (window.__stockCountAccuracyChartJsPromise) return window.__stockCountAccuracyChartJsPromise;
      window.__stockCountAccuracyChartJsPromise = new Promise((resolve, reject) => {
        const script = document.createElement("script");
        script.src = "/vendor/chart.umd.min.js";
        script.async = true;
        script.onload = () => (window.Chart ? resolve(window.Chart) : reject(new Error("Chart.js missing")));
        script.onerror = () => reject(new Error("Failed to load Chart.js"));
        document.head.appendChild(script);
      });
      return window.__stockCountAccuracyChartJsPromise;
    };

    const renderChartJs = async () => {
      if (!canvas) {
        renderSvgFallback();
        return;
      }
      let ChartJs;
      try {
        ChartJs = await loadChartJs();
      } catch (err) {
        renderSvgFallback();
        return;
      }
      if (!ChartJs) {
        renderSvgFallback();
        return;
      }
      if (fallback) fallback.classList.add("hidden");
      canvas.classList.remove("hidden");
      if (canvas._accuracyChart && typeof canvas._accuracyChart.destroy === "function") {
        canvas._accuracyChart.destroy();
      }
      const ctx = canvas.getContext("2d");
      canvas._accuracyChart = new ChartJs(ctx, {
        type: "bar",
        data: {
          labels,
          datasets: [
            {
              type: "bar",
              label: <%- JSON.stringify(tt("total_cost_difference", "Total Cost Difference")) %>,
              data: costDiffSeries,
              yAxisID: "yCost",
              backgroundColor: "rgba(244, 63, 94, 0.30)",
              borderColor: "rgba(244, 63, 94, 0.55)",
              borderWidth: 1,
              barPercentage: 0.6,
              categoryPercentage: 0.7,
              order: 3,
            },
            {
              type: "line",
              label: <%- JSON.stringify(tt("quantity_accuracy", "Quantity Accuracy") + " (%)") %>,
              data: qtySeries,
              yAxisID: "yPct",
              borderColor: "#0f766e",
              backgroundColor: "#0f766e",
              borderWidth: 2.5,
              pointRadius: 3,
              pointHoverRadius: 5,
              tension: 0.25,
              order: 1,
            },
            {
              type: "line",
              label: <%- JSON.stringify(tt("cost_accuracy", "Cost Accuracy") + " (%)") %>,
              data: costSeries,
              yAxisID: "yPct",
              borderColor: "#7c3aed",
              backgroundColor: "#7c3aed",
              borderWidth: 2.5,
              borderDash: [5, 4],
              pointRadius: 3,
              pointHoverRadius: 5,
              tension: 0.25,
              order: 2,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: "index", intersect: false },
          plugins: { legend: { display: false } },
          scales: {
            yPct: {
              type: "linear",
              position: "left",
              min: 0,
              max: 100,
              title: { display: true, text: "%" },
              ticks: { callback: (value) => `${value}%` },
            },
            yCost: {
              type: "linear",
              position: "right",
              beginAtZero: true,
              grid: { drawOnChartArea: false },
            },
          },
        },
      });
    };

    renderChartJs();
  })();
</script>
