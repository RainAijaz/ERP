<%
  const reportLoaded = Boolean(filters?.reportLoaded);
  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const purchaseCategory = String(filters?.purchaseCategory || "all").toLowerCase();
  const allMultiOptionValue = "__ALL__";
  const partyAllSelected = !Array.isArray(filters?.supplierIds) || filters.supplierIds.length === 0;
  const branchAllSelected = !Array.isArray(filters?.branchIds) || filters.branchIds.length === 0;
  const formatDate = (value) => formatDateDisplay(value, "-");
  const formatNumber = (value, digits = 3) => formatNumberDisplay(value, { decimals: digits, fallback: "0" });
  const resolveSupplierName = (row) => {
    if (locale === "ur") return String(row?.supplier_name_ur || row?.supplier_name || "-");
    return String(row?.supplier_name || "-");
  };
  const resolveItemName = (row) => {
    if (locale === "ur") return String(row?.item_name_ur || row?.item_name || "-");
    return String(row?.item_name || "-");
  };
  const categoryLabel = (value) => {
    const v = String(value || "").toUpperCase();
    if (v === "ASSET") return t("asset");
    return t("raw_material");
  };
  const daysPendingTone = (days) => {
    const n = Number(days || 0);
    if (n > 30) return "text-rose-700 font-extrabold";
    if (n > 15) return "text-amber-700 font-bold";
    return "text-slate-700";
  };
  const reportPurposeTooltip = (() => {
    const key = "pending_grn_report_purpose_tooltip";
    const value = t(key);
    return value && value !== key ? value : "";
  })();
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= t('pending_grn_report') %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t('date_filters_auto_corrected') %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-4xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-pending-grn-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('date_range') %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input
                type="text"
                readonly
                value="<%= `${filters?.from || ''} - ${filters?.to || ''}` %>"
                placeholder="<%= t('all') %>"
                data-date-range-input
                class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm"
              >
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div>
                    </div>
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div>
                    </div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <% [t('weekday_sun_short'), t('weekday_mon_short'), t('weekday_tue_short'), t('weekday_wed_short'), t('weekday_thu_short'), t('weekday_fri_short'), t('weekday_sat_short')].forEach((weekdayLabel) => { %>
                            <span><%= weekdayLabel %></span>
                          <% }) %>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden sm:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <% [t('weekday_sun_short'), t('weekday_mon_short'), t('weekday_tue_short'), t('weekday_wed_short'), t('weekday_thu_short'), t('weekday_fri_short'), t('weekday_sat_short')].forEach((weekdayLabel) => { %>
                            <span><%= weekdayLabel %></span>
                          <% }) %>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2">
                  <button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button>
                  <button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button>
                </div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= filters?.from || '' %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= filters?.to || '' %>" data-to-date-hidden>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('party_name') %></label>
          <div class="sm:col-span-9">
            <select name="party_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= partyAllSelected ? "selected" : "" %>><%= t('all') %></option>
              <% (options?.suppliers || []).forEach((supplier) => { %>
                <option value="<%= supplier.id %>" <%= (filters?.supplierIds || []).includes(Number(supplier.id)) ? "selected" : "" %>><%= locale === 'ur' ? (supplier.name_ur || supplier.name) : supplier.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t('branches') : t('branch') %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t('all') %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= (filters?.branchIds || []).includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
              <input type="hidden" name="branch_ids" value="<%= branchId || '' %>">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('category') %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseCategory === 'all' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_category" value="all" <%= purchaseCategory === "all" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('all') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseCategory === 'raw_material' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_category" value="raw_material" <%= purchaseCategory === "raw_material" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('raw_material') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseCategory === 'asset' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_category" value="asset" <%= purchaseCategory === "asset" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('asset') %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-center gap-2 pt-1 sm:grid-cols-12">
          <div class="sm:col-start-4 sm:col-span-9 flex items-center gap-2">
            <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t('load') %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 max-lg:py-2.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t('cancel') %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-print-area>
    <div class="px-1 pt-1 text-center text-xl font-display font-semibold uppercase tracking-[0.35em] text-slate-900" data-print-header>
      <%= t('brand') %>
    </div>

    <div class="flex flex-col gap-3 border-b border-slate-200 px-2 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="text-sm font-semibold text-slate-700"><%= t('pending_grn_report') %></div>
      <div class="flex items-center gap-2">
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-download-button <%= reportLoaded && rows.length ? '' : 'disabled' %>>
          <%= t('download') %>
        </button>
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-print-button <%= reportLoaded && rows.length ? '' : 'disabled' %>>
          <%= t('print') %>
        </button>
        <%- include("../../base/partials/table-controls", { t, showStatus: false }) %>
      </div>
    </div>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t('load_report_to_view') %></div>
    <% } else if (!rows.length) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t('no_entries') %></div>
    <% } else { %>
      <div class="mt-3 rounded-xl border border-slate-200 bg-slate-50/60 px-3 py-2 text-xs font-semibold text-slate-600">
        <%= t('pending_grn_report_quantity_only_note') %>
      </div>
      <div class="relative mt-3 overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-[1440px] w-full text-sm tabular-nums" data-table data-report-table>
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="__sr">SR.NO</th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="grn_voucher_no"><%= t('voucher_no') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="grn_voucher_date"><%= t('date') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="branch_name"><%= t('branch') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="supplier_name"><%= t('party_name') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="purchase_category"><%= t('category') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="item_code"><%= t('code') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="item_name"><%= t('item_name') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('unit') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="qty"><%= t('grn_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="allocated_qty"><%= t('billed_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="open_qty"><%= t('pending_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]" data-sort-key="days_pending"><%= t('days_pending') %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('reference_no') %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" data-table-body>
            <% rows.forEach((row, rowIndex) => { %>
              <tr class="bg-white odd:bg-slate-50/30" data-row data-active="true">
                <td class="px-3 py-2" data-sort-value="<%= rowIndex + 1 %>"><%= rowIndex + 1 %></td>
                <td class="px-3 py-2"><%= row.grn_voucher_no %></td>
                <td class="px-3 py-2"><%= formatDate(row.grn_voucher_date) %></td>
                <td class="px-3 py-2"><%= row.branch_name || '-' %></td>
                <td class="px-3 py-2"><%= resolveSupplierName(row) %></td>
                <td class="px-3 py-2"><%= categoryLabel(row.purchase_category) %></td>
                <td class="px-3 py-2"><%= row.item_code || '-' %></td>
                <td class="px-3 py-2">
                  <%= resolveItemName(row) %>
                  <% const itemAttrs = [row.color_name, row.size_name].filter(Boolean); %>
                  <% if (itemAttrs.length) { %>
                    <span class="ml-1 text-xs text-slate-500">(<%= itemAttrs.join(" / ") %>)</span>
                  <% } %>
                </td>
                <td class="px-3 py-2"><%= row.uom_code || '-' %></td>
                <td class="px-3 py-2 text-right font-semibold" data-sort-value="<%= Number(row.qty || 0) %>"><%= formatNumber(row.qty, 3) %></td>
                <td class="px-3 py-2 text-right font-semibold" data-sort-value="<%= Number(row.allocated_qty || 0) %>"><%= formatNumber(row.allocated_qty, 3) %></td>
                <td class="px-3 py-2 text-right font-extrabold text-accent" data-sort-value="<%= Number(row.open_qty || 0) %>"><%= formatNumber(row.open_qty, 3) %></td>
                <td class="px-3 py-2 text-right <%= daysPendingTone(row.days_pending) %>" data-sort-value="<%= Number(row.days_pending || 0) %>"><%= Number(row.days_pending || 0) %></td>
                <td class="px-3 py-2"><%= row.grn_reference_no || '-' %></td>
              </tr>
            <% }) %>
            <tr class="border-t border-slate-200 bg-slate-100">
              <td colspan="9" class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em] text-slate-700"><%= `${t('total')} (${rows.length} ${t('lines')} / ${reportData?.grnVoucherCount || 0} ${t('vouchers')})` %></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2 text-right font-extrabold text-slate-900" data-sort-value="<%= Number(reportData?.totalOpenQty || 0) %>"><%= formatNumber(reportData?.totalOpenQty || 0, 3) %></td>
              <td class="px-3 py-2"></td>
              <td class="px-3 py-2"></td>
            </tr>
          </tbody>
        </table>
      </div>
      <%- include("../../base/partials/table-footer", { t }) %>
    <% } %>
  </section>
</div>

<script><%- include("../../base/partials/date-range-picker.js") %></script>
<script>
  (function () {
    const form = document.querySelector("[data-pending-grn-filter-form]");
    if (!form) return;

    if (typeof window.initReportDateRangePicker === "function") {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
        selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>,
      });
    }

    const allMultiValue = <%- JSON.stringify(allMultiOptionValue) %>;
    const allMultiSelects = Array.from(form.querySelectorAll('select[data-all-multi-select="true"]'));
    const setPrevSelectionState = (select) => {
      const opts = Array.from(select?.options || []);
      const selectedValues = opts.filter((option) => option.selected).map((option) => option.value);
      const hasAll = selectedValues.includes(allMultiValue);
      if (select) select.dataset.prevHasAll = hasAll ? "1" : "0";
    };
    const normalizeAllSelection = (select) => {
      if (!select) return;
      const opts = Array.from(select.options || []);
      const allOption = opts.find((option) => option.value === allMultiValue);
      if (!allOption) return;

      const selectedValues = opts.filter((option) => option.selected).map((option) => option.value);
      const hasSpecific = selectedValues.some((value) => value !== allMultiValue);
      const hasAll = selectedValues.includes(allMultiValue);
      const prevHasAll = String(select.dataset.prevHasAll || "0") === "1";

      if (hasSpecific && hasAll) {
        if (prevHasAll) {
          allOption.selected = false;
        } else {
          opts.forEach((option) => {
            if (option.value !== allMultiValue) option.selected = false;
          });
          allOption.selected = true;
        }
      } else if (!hasSpecific && !hasAll) {
        allOption.selected = true;
      }

      setPrevSelectionState(select);
    };

    allMultiSelects.forEach((select) => normalizeAllSelection(select));

    form.addEventListener("submit", () => {
      allMultiSelects.forEach((select) => normalizeAllSelection(select));
    });

    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }
  })();
</script>

<%- include("../../base/partials/basic-info-utils", {
  t,
  page: { titleKey: "pending_grn_report", autoCodeFromName: false },
  basePath: reportPath,
  modalOpen: false,
  modalMode: "add"
}) %>
