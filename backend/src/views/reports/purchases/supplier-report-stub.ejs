<div class="mx-auto w-full max-w-5xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-lg">
    <% const reportPurposeTooltip = (() => { const key = `${String(reportTitleKey || "").trim()}_purpose_tooltip`; const value = t(key); return value && value !== key ? value : ""; })(); %>
    <div class="flex items-center gap-2">
      <h1 class="text-2xl font-display text-ink"><%= t(reportTitleKey) %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>
    <p class="mt-2 text-sm text-muted"><%= t(reportDescriptionKey) %></p>
  </section>
</div>
