            <tr class="border-t border-slate-200 bg-slate-100">
              <td colspan="6" class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em] text-slate-700"><%= t('total') %></td>
              <td class="px-3 py-2 text-right font-semibold text-slate-900"><%= formatNumber(totals.qty || 0, 3) %></td>
              <td class="px-3 py-2 text-right font-semibold text-slate-900"><%= formatNumber(totals.debit || 0, 2) %></td>
              <td class="px-3 py-2 text-right font-semibold text-slate-900"><%= formatNumber(totals.credit || 0, 2) %></td>
              <td class="px-3 py-2 text-right font-semibold text-slate-900"><%= formatNumber(totals.closingBalance || 0, 2) %></td>
              <% if (includeBranchColumn) { %>
                <td class="px-3 py-2"></td>
              <% } %>
            </tr>
          </tbody>
        </table>
      </div>
      <%- include("../../base/partials/table-footer", { t }) %>
    <% } %>
  </section>
</div>

<%- include("../../base/partials/basic-info-utils", {
  t,
  page: { titleKey: "supplier_ledger_report", autoCodeFromName: false },
  basePath: reportPath,
  modalOpen: false,
  modalMode: "add"
}) %>

<script><%- include("../../base/partials/date-range-picker.js") %></script>
<script><%- include("../../base/partials/searchable-select.js") %></script>
<script>
  (function () {
    const form = document.querySelector('[data-supplier-ledger-form]');
    if (!form) return;

    if (typeof window.initSearchableSelects === 'function') {
      window.initSearchableSelects();
    }

    if (typeof window.initReportDateRangePicker === 'function') {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t('invalid_date_range')) %>,
        selectDateRangeText: <%- JSON.stringify(t('select_date_range')) %>,
      });
    }

    const partySelect = document.querySelector('[data-supplier-party]');
    const codeInput = document.querySelector('[data-supplier-code]');
    if (partySelect && codeInput) {
      const syncCode = () => {
        const selectedOption = partySelect.options[partySelect.selectedIndex];
        codeInput.value = selectedOption ? String(selectedOption.getAttribute('data-code') || '') : '';
      };
      partySelect.addEventListener('change', syncCode);
      syncCode();
    }

    const roots = Array.from(document.querySelectorAll('[data-multi-select]'));
    if (!roots.length) return;

    let openRoot = null;
    const closeAll = () => {
      roots.forEach((root) => {
        root.querySelector('[data-multi-panel]')?.classList.add('hidden');
      });
      openRoot = null;
    };

    roots.forEach((root) => {
      const trigger = root.querySelector('[data-multi-trigger]');
      const panel = root.querySelector('[data-multi-panel]');
      const hidden = root.querySelector('[data-multi-hidden]');
      const checkboxes = Array.from(root.querySelectorAll('input[type="checkbox"]'));
      const allValue = String(root.dataset.multiAllValue || '').trim();
      const autoAll = String(root.dataset.multiAutoAll || '').trim() === '1';
      if (!trigger || !panel || !hidden) return;

      const getAllCheckbox = () => {
        if (!allValue) return null;
        return checkboxes.find((cb) => String(cb.value || '').trim() === allValue) || null;
      };

      const normalizeSelection = (changedCheckbox) => {
        const allCheckbox = getAllCheckbox();
        if (!allCheckbox) return;

        const nonAllCheckboxes = checkboxes.filter((cb) => cb !== allCheckbox);
        if (changedCheckbox === allCheckbox && allCheckbox.checked) {
          nonAllCheckboxes.forEach((cb) => {
            cb.checked = false;
          });
          return;
        }

        if (changedCheckbox && changedCheckbox !== allCheckbox && changedCheckbox.checked) {
          allCheckbox.checked = false;
        }

        const checkedNonAll = nonAllCheckboxes.filter((cb) => cb.checked);
        if (!checkedNonAll.length && autoAll) {
          allCheckbox.checked = true;
          return;
        }

        if (checkedNonAll.length && allCheckbox.checked) {
          allCheckbox.checked = false;
        }
      };

      const refresh = () => {
        const selected = checkboxes.filter((cb) => cb.checked);
        const selectedValues = selected
          .map((cb) => String(cb.value || '').trim())
          .filter((value) => Boolean(value) && value !== allValue);
        hidden.value = selectedValues.join(',');

        if (!selectedValues.length) {
          trigger.textContent = String(root.dataset.placeholder || '');
          return;
        }
        if (selectedValues.length === 1) {
          const selectedCheckbox = selected.find((cb) => String(cb.value || '').trim() === selectedValues[0]);
          const label = selectedCheckbox?.closest('label')?.querySelector('span')?.textContent || selectedValues[0];
          trigger.textContent = label;
          return;
        }

        trigger.textContent = `${selectedValues.length} <%= t('selected') || 'selected' %>`;
      };

      normalizeSelection(null);
      refresh();

      checkboxes.forEach((cb) => {
        cb.addEventListener('change', () => {
          normalizeSelection(cb);
          refresh();
        });
      });

      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        const wasHidden = panel.classList.contains('hidden');
        closeAll();
        if (wasHidden) {
          panel.classList.remove('hidden');
          openRoot = root;
        }
      });
    });

    document.addEventListener('click', (event) => {
      if (!openRoot) return;
      if (openRoot.contains(event.target)) return;
      closeAll();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeAll();
    });
  })();
</script>
