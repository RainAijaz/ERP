            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </section>
</div>

<script><%- include("../base/partials/date-range-picker.js") %></script>

<script>
  (function () {
    const form = document.querySelector("[data-stock-transfer-filter-form]");
    if (!form) return;

    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }

    if (typeof window.initReportDateRangePicker === "function") {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
        selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>,
      });
    }

    const advancedToggleButton = form.querySelector("[data-advanced-filter-toggle]");
    const advancedFilterPanel = form.querySelector("[data-advanced-filter-panel]");
    const allMultiValue = <%- JSON.stringify(allMultiOptionValue) %>;

    const setAdvancedPanelOpen = (isOpen) => {
      if (!advancedFilterPanel) return;
      const nextOpen = Boolean(isOpen);
      advancedFilterPanel.classList.toggle("hidden", !nextOpen);
      if (advancedToggleButton) {
        advancedToggleButton.setAttribute("aria-expanded", nextOpen ? "true" : "false");
      }
      if (nextOpen && typeof window.initSearchableSelects === "function") {
        window.initSearchableSelects();
      }
    };

    advancedToggleButton?.addEventListener("click", () => {
      const currentlyOpen =
        advancedToggleButton.getAttribute("aria-expanded") === "true";
      setAdvancedPanelOpen(!currentlyOpen);
    });

    const allMultiSelects = Array.from(
      form.querySelectorAll('select[data-all-multi-select="true"]'),
    );

    const setPrevSelectionState = (select) => {
      const options = Array.from(select?.options || []);
      const selectedValues = options
        .filter((option) => option.selected)
        .map((option) => option.value);
      const hasAll = selectedValues.includes(allMultiValue);
      if (select) select.dataset.prevHasAll = hasAll ? "1" : "0";
    };

    const normalizeAllSelection = (select, useIntent = false) => {
      if (!select) return;
      const options = Array.from(select.options || []);
      const allOption = options.find((option) => option.value === allMultiValue);
      if (!allOption) return;

      const selectedValues = options
        .filter((option) => option.selected)
        .map((option) => option.value);
      const hasSpecific = selectedValues.some((value) => value !== allMultiValue);
      const hasAll = selectedValues.includes(allMultiValue);
      const prevHasAll = String(select.dataset.prevHasAll || "0") === "1";

      if (hasSpecific && hasAll) {
        if (useIntent && prevHasAll) {
          allOption.selected = false;
        } else {
          options.forEach((option) => {
            if (option.value !== allMultiValue) option.selected = false;
          });
          allOption.selected = true;
        }
      } else if (!hasSpecific && !hasAll) {
        allOption.selected = true;
      }

      setPrevSelectionState(select);
    };

    allMultiSelects.forEach((select) => {
      normalizeAllSelection(select);
      setPrevSelectionState(select);
      select.addEventListener("focus", () => setPrevSelectionState(select));
      select.addEventListener("change", () => normalizeAllSelection(select, true));
    });

    const stockTypeSelect = form.querySelector("[data-stock-type-select]");
    const stockStatusRow = form.querySelector("[data-stock-status-row]");
    const stockStatusSelect = form.querySelector("[data-stock-status-select]");
    const groupSelect = form.querySelector("[data-group-select]");
    const subgroupSelect = form.querySelector("[data-subgroup-select]");
    const articleSelect = form.querySelector("[data-article-select]");
    const articleFilterRow = form.querySelector("[data-article-filter-row]");
    const stockItemSelect = form.querySelector("[data-stock-item-select]");
    const stockItemLabel = form.querySelector("[data-stock-item-label]");

    const allLabel = <%- JSON.stringify(t("all")) %>;
    const skuLabel = <%- JSON.stringify(tt("sku", "SKU")) %>;
    const rawMaterialLabel = <%- JSON.stringify(tt("raw_material", "Raw Material")) %>;
    const productGroupsByType = <%- JSON.stringify(productGroupsByType) %>;
    const productSubgroupsByType = <%- JSON.stringify(productSubgroupsByType) %>;
    const articlesByType = <%- JSON.stringify(articlesByType) %>;
    const stockItemsByType = <%- JSON.stringify(stockItemsByType) %>;

    const populateMultiSelectWithAll = ({ select, rows, labelKey }) => {
      if (!select) return;
      const previousSelection = new Set(
        Array.from(select.options || [])
          .filter((option) => option.selected && option.value !== allMultiValue)
          .map((option) => String(option.value || "")),
      );

      select.innerHTML = "";

      const allOption = document.createElement("option");
      allOption.value = allMultiValue;
      allOption.textContent = String(allLabel || "All");
      select.appendChild(allOption);

      const normalizedRows = Array.isArray(rows) ? rows : [];
      normalizedRows.forEach((row) => {
        const option = document.createElement("option");
        option.value = String(row?.id || "");
        option.textContent = String(row?.[labelKey] || "").trim() || "-";
        if (previousSelection.has(option.value)) option.selected = true;
        select.appendChild(option);
      });

      const hasSpecificSelection = Array.from(select.options || []).some(
        (option) => option.value !== allMultiValue && option.selected,
      );
      allOption.selected = !hasSpecificSelection;
      setPrevSelectionState(select);
      select.dispatchEvent(new Event("change", { bubbles: true }));
    };

    const syncStockTypePresentation = () => {
      if (!stockTypeSelect) return;
      const currentStockType = String(stockTypeSelect.value || "").toUpperCase();
      const isFinished = currentStockType === "FG";
      const isRawMaterial = currentStockType === "RM";

      if (stockStatusRow) stockStatusRow.classList.toggle("hidden", !isFinished);
      if (stockStatusSelect) {
        stockStatusSelect.disabled = !isFinished;
        if (!isFinished) {
          stockStatusSelect.value = "ALL";
          stockStatusSelect.dispatchEvent(new Event("change", { bubbles: true }));
        }
      }

      populateMultiSelectWithAll({
        select: groupSelect,
        rows: productGroupsByType[currentStockType] || [],
        labelKey: "name",
      });
      populateMultiSelectWithAll({
        select: subgroupSelect,
        rows: productSubgroupsByType[currentStockType] || [],
        labelKey: "name",
      });
      populateMultiSelectWithAll({
        select: articleSelect,
        rows: isRawMaterial ? [] : articlesByType[currentStockType] || [],
        labelKey: "name",
      });
      populateMultiSelectWithAll({
        select: stockItemSelect,
        rows: stockItemsByType[currentStockType] || [],
        labelKey: "label",
      });

      if (articleFilterRow) articleFilterRow.classList.toggle("hidden", isRawMaterial);
      if (articleSelect) articleSelect.disabled = isRawMaterial;
      if (stockItemLabel) {
        stockItemLabel.textContent = isRawMaterial ? rawMaterialLabel : skuLabel;
      }

      if (typeof window.initSearchableSelects === "function") {
        window.initSearchableSelects();
      }
    };

    stockTypeSelect?.addEventListener("change", syncStockTypePresentation);
    syncStockTypePresentation();

    form.addEventListener("submit", () => {
      allMultiSelects.forEach((select) => normalizeAllSelection(select));
    });
  })();
</script>
