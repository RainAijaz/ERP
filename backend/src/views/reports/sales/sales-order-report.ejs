<%
  const reportLoaded = Boolean(filters?.reportLoaded);
  const selectedFrom = String(filters?.from || "");
  const selectedTo = String(filters?.to || "");
  const selectedPartyId = Number(filters?.partyId || 0) || null;
  const selectedProductGroupId = Number(filters?.productGroupId || 0) || null;
  const selectedBranchIds = Array.isArray(filters?.branchIds)
    ? filters.branchIds.map((id) => Number(id)).filter((id) => Number.isInteger(id) && id > 0)
    : [];
  const selectedReportType = ["pending", "closed", "complete"].includes(String(filters?.reportType || "").toLowerCase())
    ? String(filters.reportType).toLowerCase()
    : "pending";
  const selectedOrderBy = ["party", "voucher", "article"].includes(String(filters?.orderBy || "").toLowerCase())
    ? String(filters.orderBy).toLowerCase()
    : "party";
  const selectedDisplayType = ["details", "summary"].includes(String(filters?.displayType || "").toLowerCase())
    ? String(filters.displayType).toLowerCase()
    : "details";

  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const groups = Array.isArray(reportData?.groups) ? reportData.groups : [];
  const summaryRows = Array.isArray(reportData?.summaryRows) ? reportData.summaryRows : [];
  const totals = reportData?.totals || { orderedQty: 0, deliveredQty: 0, remainingQty: 0 };
  const includeBranchColumn = Boolean(reportData?.includeBranchColumn);
  const hasData = selectedDisplayType === "summary" ? summaryRows.length > 0 : groups.length > 0;
  const customerOptions = Array.isArray(options?.customers) ? options.customers : [];
  const productGroupOptions = Array.isArray(options?.productGroups) ? options.productGroups : [];

  const dateRangeLabel = (() => {
    const value = typeof t === "function" ? t("date_range") : "";
    return value || "Date Range";
  })();

  const productGroupLabel = (() => {
    const value = typeof t === "function" ? t("product_group") : "";
    return value && value !== "product_group" ? value : "Product Group";
  })();

  const completeDateLabel = (() => {
    const value = typeof t === "function" ? t("complete_date") : "";
    if (value && value !== "complete_date") return value;
    const closeValue = typeof t === "function" ? t("close_date") : "";
    return closeValue && closeValue !== "close_date" ? closeValue : "Complete Date";
  })();

  const weekdayShortLabels = [
    t("weekday_sun_short"),
    t("weekday_mon_short"),
    t("weekday_tue_short"),
    t("weekday_wed_short"),
    t("weekday_thu_short"),
    t("weekday_fri_short"),
    t("weekday_sat_short"),
  ];

  const formatDate = (value) => {
    return formatDateDisplay(value, "-");
  };

  const formatNumber = (value, digits = 3) => {
    return formatNumberDisplay(value, { decimals: digits, fallback: "0" });
  };

  const resolveCustomerName = (customer) => {
    if (!customer) return "-";
    if (locale === "ur") return String(customer.name_ur || customer.name || "-");
    return String(customer.name || "-");
  };

  const resolveRowCustomerName = (row) => {
    if (!row) return "-";
    if (locale === "ur") return String(row.customer_name_ur || row.customer_name_en || "-");
    return String(row.customer_name_en || row.customer_name_ur || "-");
  };

  const hiddenGroupedColumnCount = 1;
  const detailColumnCount = (includeBranchColumn ? 10 : 9) + (selectedReportType === "complete" ? 1 : 0) - hiddenGroupedColumnCount;
  const detailTotalsLabelSpan = (selectedReportType === "complete" ? 6 : 5) - hiddenGroupedColumnCount;
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= t("sales_order_report") %></h1>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-sales-order-report-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= dateRangeLabel %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input
                type="text"
                readonly
                value=""
                data-date-range-input
                class="h-10 w-full cursor-pointer rounded-xl border border-slate-300 bg-white px-3 pr-10 text-sm"
              >
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div>
                    </div>
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div>
                    </div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 xl:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-52.5 rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <% weekdayShortLabels.forEach((weekdayLabel) => { %>
                            <span><%= weekdayLabel %></span>
                          <% }) %>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden xl:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-52.5 rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <% weekdayShortLabels.forEach((weekdayLabel) => { %>
                            <span><%= weekdayLabel %></span>
                          <% }) %>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2">
                  <button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button>
                  <button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button>
                </div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= selectedFrom %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= selectedTo %>" data-to-date-hidden>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('party_name') %></label>
          <div class="sm:col-span-9">
            <select name="party_id" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
              <option value=""><%= t('all') %></option>
              <% customerOptions.forEach((customer) => { %>
                <option value="<%= customer.id %>" <%= selectedPartyId === Number(customer.id) ? 'selected' : '' %>><%= resolveCustomerName(customer) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= productGroupLabel %></label>
          <div class="sm:col-span-9">
            <select name="product_group_id" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
              <option value=""><%= t('all') %></option>
              <% productGroupOptions.forEach((group) => { %>
                <option value="<%= group.id %>" <%= selectedProductGroupId === Number(group.id) ? 'selected' : '' %>><%= group.name || '-' %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t('branches') : t('branch') %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <div class="relative" data-multi-select data-name="branch_ids" data-placeholder="<%= `${t('all')} ${t('branches')}` %>" data-multi-all-value="__ALL__" data-multi-auto-all="1">
                <button type="button" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 pr-10 text-left text-sm text-slate-700" data-multi-trigger></button>
                <span class="pointer-events-none absolute inset-y-0 right-3 inline-flex items-center text-slate-500">
                  <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </span>
                <div class="absolute left-0 right-0 top-[calc(100%+0.35rem)] z-50 hidden rounded-xl border border-slate-200 bg-white p-2 shadow-xl" data-multi-panel>
                  <div class="max-h-52 overflow-auto pr-1" data-multi-options>
                    <label class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm font-semibold text-slate-700 hover:bg-slate-50">
                      <input type="checkbox" value="__ALL__" <%= selectedBranchIds.length ? '' : 'checked' %>>
                      <span><%= `${t('all')} ${t('branches')}` %></span>
                    </label>
                    <% (options?.branches || []).forEach((branch) => { %>
                      <label class="flex items-center gap-2 rounded-lg px-2 py-1.5 text-sm text-slate-700 hover:bg-slate-50">
                        <input type="checkbox" value="<%= branch.id %>" <%= selectedBranchIds.includes(Number(branch.id)) ? 'checked' : '' %>>
                        <span><%= branch.name %></span>
                      </label>
                    <% }) %>
                  </div>
                </div>
                <input type="hidden" name="branch_ids" value="<%= selectedBranchIds.join(',') %>" data-multi-hidden>
              </div>
            <% } else { %>
              <input type="text" readonly class="h-10 w-full rounded-xl border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700" value="<%= (options?.branches || [])[0]?.name || branchId %>">
              <input type="hidden" name="branch_ids" value="<%= branchId || '' %>">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('order_by') %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'party' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="party" <%= selectedOrderBy === 'party' ? 'checked' : '' %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('party_name') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'voucher' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="voucher" <%= selectedOrderBy === 'voucher' ? 'checked' : '' %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('voucher_no') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedOrderBy === 'article' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="article" <%= selectedOrderBy === 'article' ? 'checked' : '' %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('article') %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('status') %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'pending' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="pending" class="h-4 w-4 border-slate-300 text-accent focus:ring-accent" <%= selectedReportType === 'pending' ? 'checked' : '' %>>
                <span><%= t('pending') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'closed' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="closed" class="h-4 w-4 border-slate-300 text-accent focus:ring-accent" <%= selectedReportType === 'closed' ? 'checked' : '' %>>
                <span><%= t('closed') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedReportType === 'complete' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="complete" class="h-4 w-4 border-slate-300 text-accent focus:ring-accent" <%= selectedReportType === 'complete' ? 'checked' : '' %>>
                <span><%= t('complete') %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t('report_type') %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedDisplayType === 'details' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="display_type" value="details" <%= selectedDisplayType === 'details' ? 'checked' : '' %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('details') %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= selectedDisplayType === 'summary' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="display_type" value="summary" <%= selectedDisplayType === 'summary' ? 'checked' : '' %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t('summary') %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-center gap-2 pt-1 sm:grid-cols-12">
          <div class="sm:col-start-4 sm:col-span-9 flex items-center gap-2">
            <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t('load') %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t('cancel') %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-print-area>
    <div class="px-1 pt-1 text-center text-xl font-display font-semibold uppercase tracking-[0.35em] text-slate-900" data-print-header>
      <%= t('brand') %>
    </div>

    <div class="flex flex-col gap-3 border-b border-slate-200 px-2 py-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="text-sm font-semibold text-slate-700"><%= t('sales_order_report') %></div>
      <div class="flex items-center gap-2">
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-download-button <%= reportLoaded && hasData ? '' : 'disabled' %>>
          <%= t('download') %>
        </button>
        <button class="cursor-pointer rounded-full border border-slate-200 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800 disabled:cursor-not-allowed disabled:opacity-40" type="button" data-print-button <%= reportLoaded && hasData ? '' : 'disabled' %>>
          <%= t('print') %>
        </button>
        <%- include("../../base/partials/table-controls", { t, showStatus: false }) %>
      </div>
    </div>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t('load_report_to_view') %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t('no_entries') %></div>
    <% } else if (selectedDisplayType === "details") { %>
      <div class="relative mt-4 overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-[1120px] w-full text-sm tabular-nums" data-table data-report-table>
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <% if (selectedOrderBy === "party") { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('sales_order') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('date') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('product') === 'product' ? t('products') : t('product') %></th>
              <% } else if (selectedOrderBy === "voucher") { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('date') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('customer_name') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('product') === 'product' ? t('products') : t('product') %></th>
              <% } else { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('customer_name') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('sales_order') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('date') %></th>
              <% } %>
              <% if (selectedReportType === "complete") { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= completeDateLabel %></th>
              <% } %>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('unit') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('ordered_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('delivered_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('remaining_qty') %></th>
              <% if (includeBranchColumn) { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('branch') %></th>
              <% } %>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('action') %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" data-table-body>
            <% groups.forEach((group) => { %>
              <tr class="bg-slate-700 text-white" data-row data-active="true">
                <td colspan="<%= detailColumnCount %>" class="px-3 py-2">
                  <div class="flex flex-wrap items-center gap-2">
                    <button type="button" class="inline-flex h-7 w-7 items-center justify-center rounded-md border border-white/30 bg-white/10 text-white" data-group-toggle="<%= group.key %>" aria-expanded="true">
                      <svg class="h-4 w-4 transition-transform" style="transform: rotate(180deg);" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" data-group-icon="<%= group.key %>">
                        <path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                    <span class="rounded-md border border-white/40 bg-white/20 px-2 py-0.5 text-xs font-semibold text-white"><%= group.label || '-' %></span>
                    <% if (selectedOrderBy === "voucher" && group.close_date) { %>
                      <span class="rounded-md border border-white/20 bg-transparent px-2 py-0.5 text-xs font-semibold text-slate-100"><%= `${t('close_date')}: ${formatDate(group.close_date)}` %></span>
                    <% } %>
                  </div>
                </td>
              </tr>
              <% (group.lines || []).forEach((row) => { %>
                <tr class="bg-white odd:bg-slate-50/30" data-group-line="<%= group.key %>" data-row data-active="true">
                  <% if (selectedOrderBy === "party") { %>
                    <td class="px-3 py-2"><%= row.sales_order_no || '-' %></td>
                    <td class="px-3 py-2"><%= formatDate(row.sales_order_date) %></td>
                    <td class="px-3 py-2"><%= row.product_name || '-' %></td>
                  <% } else if (selectedOrderBy === "voucher") { %>
                    <td class="px-3 py-2"><%= formatDate(row.sales_order_date) %></td>
                    <td class="px-3 py-2"><%= resolveRowCustomerName(row) %></td>
                    <td class="px-3 py-2"><%= row.product_name || '-' %></td>
                  <% } else { %>
                    <td class="px-3 py-2"><%= resolveRowCustomerName(row) %></td>
                    <td class="px-3 py-2"><%= row.sales_order_no || '-' %></td>
                    <td class="px-3 py-2"><%= formatDate(row.sales_order_date) %></td>
                  <% } %>
                  <% if (selectedReportType === "complete") { %>
                    <td class="px-3 py-2"><%= formatDate(row.close_date) %></td>
                  <% } %>
                  <td class="px-3 py-2"><%= row.unit_name || '-' %></td>
                  <td class="px-3 py-2 text-right"><%= formatNumber(row.ordered_qty || 0, 3) %></td>
                  <td class="px-3 py-2 text-right"><%= formatNumber(row.delivered_qty || 0, 3) %></td>
                  <td class="px-3 py-2 text-right"><%= formatNumber(row.remaining_qty || 0, 3) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"><%= row.branch_name || '-' %></td>
                  <% } %>
                  <td class="px-3 py-2"><a class="text-accent hover:underline" href="<%= row.action_link %>"><%= t('view') %></a></td>
                </tr>
              <% }) %>
              <tr class="bg-accent text-white" data-group-line="<%= group.key %>">
                <td colspan="<%= detailTotalsLabelSpan %>" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t('total') %></td>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(group.total_ordered_qty || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(group.total_delivered_qty || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(group.total_remaining_qty || 0, 3) %></td>
                <% if (includeBranchColumn) { %>
                  <td class="px-3 py-2"></td>
                <% } %>
                <td class="px-3 py-2"></td>
              </tr>
            <% }) %>
            <tr class="bg-rose-700 text-white">
              <td colspan="<%= detailTotalsLabelSpan %>" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t('grand_total') %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(totals.orderedQty || 0, 3) %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(totals.deliveredQty || 0, 3) %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(totals.remainingQty || 0, 3) %></td>
              <% if (includeBranchColumn) { %>
                <td class="px-3 py-2"></td>
              <% } %>
              <td class="px-3 py-2"></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="relative mt-4 overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-[980px] w-full text-sm tabular-nums" data-table data-report-table>
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <% if (selectedOrderBy === "party") { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('group') %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('sales_order') %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('article') %></th>
              <% } else if (selectedOrderBy === "voucher") { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('group') %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('date') %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('article') %></th>
              <% } else { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t('group') %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('sales_order') %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('customer_name') %></th>
              <% } %>
              <% if (selectedReportType === "complete") { %>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= completeDateLabel %></th>
              <% } %>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('ordered_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('delivered_qty') %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t('remaining_qty') %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" data-table-body>
            <% summaryRows.forEach((row) => { %>
              <tr class="bg-white odd:bg-slate-50/30" data-row data-active="true">
                <% if (selectedOrderBy === "party") { %>
                  <td class="px-3 py-2 font-semibold"><%= row.group_label || '-' %></td>
                  <td class="px-3 py-2 text-right"><%= row.order_count || 0 %></td>
                  <td class="px-3 py-2 text-right"><%= row.article_count || 0 %></td>
                <% } else if (selectedOrderBy === "voucher") { %>
                  <td class="px-3 py-2 font-semibold"><%= row.group_label || '-' %></td>
                  <td class="px-3 py-2"><%= formatDate(row.sales_order_date) %></td>
                  <td class="px-3 py-2 text-right"><%= row.article_count || 0 %></td>
                <% } else { %>
                  <td class="px-3 py-2 font-semibold"><%= row.group_label || '-' %></td>
                  <td class="px-3 py-2 text-right"><%= row.order_count || 0 %></td>
                  <td class="px-3 py-2 text-right"><%= row.customer_count || 0 %></td>
                <% } %>
                <% if (selectedReportType === "complete") { %>
                  <td class="px-3 py-2"><%= formatDate(row.latest_complete_date || row.close_date) %></td>
                <% } %>
                <td class="px-3 py-2 text-right font-semibold"><%= formatNumber(row.total_ordered_qty || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-semibold"><%= formatNumber(row.total_delivered_qty || 0, 3) %></td>
                <td class="px-3 py-2 text-right font-semibold"><%= formatNumber(row.total_remaining_qty || 0, 3) %></td>
              </tr>
            <% }) %>
            <tr class="bg-rose-700 text-white">
              <td colspan="3" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t('grand_total') %></td>
              <% if (selectedReportType === "complete") { %>
                <td class="px-3 py-2"></td>
              <% } %>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(totals.orderedQty || 0, 3) %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(totals.deliveredQty || 0, 3) %></td>
              <td class="px-3 py-2 text-right font-extrabold"><%= formatNumber(totals.remainingQty || 0, 3) %></td>
            </tr>
          </tbody>
        </table>
      </div>
    <% } %>
    <% if (reportLoaded && hasData) { %>
      <%- include("../../base/partials/table-footer", { t }) %>
    <% } %>
  </section>
</div>

<%- include("../../base/partials/basic-info-utils", {
  t,
  page: { titleKey: "sales_order_report", autoCodeFromName: false },
  basePath: reportPath,
  modalOpen: false,
  modalMode: "add"
}) %>

<script><%- include("../../base/partials/date-range-picker.js") %></script>
<script><%- include("../../base/partials/searchable-select.js") %></script>
<script>
  (function () {
    const form = document.querySelector('[data-sales-order-report-form]');
    if (!form) return;

    if (typeof window.initSearchableSelects === 'function') {
      window.initSearchableSelects();
    }

    if (typeof window.initReportDateRangePicker === 'function') {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t('invalid_date_range')) %>,
        selectDateRangeText: <%- JSON.stringify(t('select_date_range')) %>,
      });
    }

    if (typeof window.initDataMultiSelects === 'function') {
      window.initDataMultiSelects(form);
    }

    document.querySelectorAll('[data-group-toggle]').forEach((toggle) => {
      toggle.addEventListener('click', () => {
        const key = String(toggle.getAttribute('data-group-toggle') || '').trim();
        if (!key) return;
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        const nextExpanded = !expanded;
        toggle.setAttribute('aria-expanded', nextExpanded ? 'true' : 'false');
        const icon = document.querySelector(`[data-group-icon="${key}"]`);
        if (icon) {
          icon.style.transform = nextExpanded ? 'rotate(180deg)' : 'rotate(0deg)';
        }
        document.querySelectorAll(`[data-group-line="${key}"]`).forEach((row) => {
          row.classList.toggle('hidden', !nextExpanded);
        });
      });
    });
  })();
</script>
