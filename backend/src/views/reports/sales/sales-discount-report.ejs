<%
const reportLoaded = Boolean(filters?.reportLoaded);
const selectedFrom = String(filters?.from || "");
const selectedTo = String(filters?.to || "");
const selectedBranchIds = Array.isArray(filters?.branchIds) ? filters.branchIds.map((id) => Number(id)).filter((id) => Number.isInteger(id) && id > 0) : [];
const selectedBranchToken = selectedBranchIds.length === 1 ? String(selectedBranchIds[0]) : "__ALL__";
const selectedSalesmanId = Number(filters?.salesmanId || 0) || null;
const selectedPartyId = Number(filters?.partyId || 0) || null;
const selectedProductGroupId = Number(filters?.productGroupId || 0) || null;
const selectedMinDiscountAmount = Number(filters?.minDiscountAmount || 0);
const selectedHighDiscountPct = Number(filters?.highDiscountPct || 10);
const kpis = reportData?.kpis || {};
const trendRows = Array.isArray(reportData?.trendRows) ? reportData.trendRows : [];
const salesmanRows = Array.isArray(reportData?.salesmanRows) ? reportData.salesmanRows : [];
const customerRows = Array.isArray(reportData?.customerRows) ? reportData.customerRows : [];
const itemRows = Array.isArray(reportData?.itemRows) ? reportData.itemRows : [];
const alertRows = Array.isArray(reportData?.alertRows) ? reportData.alertRows : [];
const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
const includeBranchColumn = Boolean(reportData?.includeBranchColumn);
const hasData = rows.length > 0;
const branchOptions = Array.isArray(options?.branches) ? options.branches : [];
const salesmanOptions = Array.isArray(options?.salesmen) ? options.salesmen : [];
const customerOptions = Array.isArray(options?.customers) ? options.customers : [];
const productGroupOptions = Array.isArray(options?.productGroups) ? options.productGroups : [];
const dateRangeLabel = (() => {
  const v = typeof t === "function" ? t("date_range") : "";
  return v || "Date Range";
})();
const productGroupLabel = (() => {
  const v = typeof t === "function" ? t("product_group") : "";
  if (v && v !== "product_group") return v;
  const alt = typeof t === "function" ? t("product_groups") : "";
  return alt && alt !== "product_groups" ? alt : "Product Group";
})();
const averagePairDiscountLabel = (() => {
  const v = typeof t === "function" ? t("average_pair_discount") : "";
  return v && v !== "average_pair_discount" ? v : "Average Pair Discount";
})();
const averageDozenDiscountLabel = (() => {
  const v = typeof t === "function" ? t("average_dozen_discount") : "";
  return v && v !== "average_dozen_discount" ? v : "Average Dozen Discount";
})();
const allLabel = typeof t === "function" ? t("all") : "All";
const weekdayShortLabels = [t("weekday_sun_short"), t("weekday_mon_short"), t("weekday_tue_short"), t("weekday_wed_short"), t("weekday_thu_short"), t("weekday_fri_short"), t("weekday_sat_short")];
const formatDate = (value) => formatDateDisplay(value, "-");
const formatAmount = (value) => formatNumberDisplay(value, { decimals: 2, fallback: "0" });
const formatPct = (value) => `${formatNumberDisplay(value, { decimals: 2, fallback: "0" })}%`;
const formatQty = (value) => formatNumberDisplay(value, { decimals: 3, fallback: "0" });
const resolveCustomerOptionName = (customer) => { if (!customer) return "-"; if (locale === "ur") return String(customer.name_ur || customer.name || "-"); return String(customer.name || customer.name_ur || "-"); };
const resolveRowCustomerName = (row) => {
  if (!row) return t("walk_in_customer");
  if (row.customer_party_id) return locale === "ur" ? String(row.customer_name_ur || row.customer_name_en || t("walk_in_customer")) : String(row.customer_name_en || row.customer_name_ur || t("walk_in_customer"));
  return String(row.walk_in_customer_name || t("walk_in_customer"));
};
const paymentTypeLabel = (value) => String(value || "").trim().toUpperCase() === "CASH" ? t("cash_sale") : String(value || "").trim().toUpperCase() === "CREDIT" ? t("credit_sale") : "-";
const saleModeLabel = (value) => String(value || "").trim().toUpperCase() === "DIRECT" ? t("sale_mode_direct") : String(value || "").trim().toUpperCase() === "FROM_SO" ? t("sale_mode_from_so") : "-";
const highestDiscountVoucher = kpis?.highestDiscountVoucher || null;
const reportPurposeTooltip = (() => {
  const key = "sales_discount_report_purpose_tooltip";
  const value = t(key);
  return value && value !== key ? value : "";
})();
%>
<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= t("sales_discount_report") %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>
    <% if (filters?.invalidFilterInput) { %><div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div><% } %>
    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-sales-discount-report-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">
      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= dateRangeLabel %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input type="text" readonly value="<%= `${selectedFrom} - ${selectedTo}` %>" data-date-range-input class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm">
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div></div>
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div></div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 xl:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden xl:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2"><button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button><button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button></div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= selectedFrom %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= selectedTo %>" data-to-date-hidden>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("salesman") %></label>
          <div class="sm:col-span-9">
            <select name="salesman_employee_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
              <option value=""><%= `${allLabel} ${t("salesman")}` %></option>
              <% salesmanOptions.forEach((salesman) => { %>
                <option value="<%= salesman.id %>" <%= selectedSalesmanId === Number(salesman.id) ? "selected" : "" %>><%= salesman.name || salesman.code || '-' %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("customer_name") %></label>
          <div class="sm:col-span-9">
            <select name="party_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
              <option value=""><%= `${allLabel} ${t("customer_name")}` %></option>
              <% customerOptions.forEach((customer) => { %>
                <option value="<%= customer.id %>" <%= selectedPartyId === Number(customer.id) ? "selected" : "" %>><%= resolveCustomerOptionName(customer) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= productGroupLabel %></label>
          <div class="sm:col-span-9">
            <select name="product_group_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
              <option value=""><%= `${allLabel} ${productGroupLabel}` %></option>
              <% productGroupOptions.forEach((group) => { %>
                <option value="<%= group.id %>" <%= selectedProductGroupId === Number(group.id) ? "selected" : "" %>><%= group.name || '-' %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t("branches") : t("branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value="__ALL__" <%= selectedBranchToken === "__ALL__" ? "selected" : "" %>><%= `${allLabel} ${t("branches")}` %></option>
                <% branchOptions.forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchToken === String(branch.id) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700" value="<%= branchOptions[0]?.name || branchId || '-' %>">
              <input type="hidden" name="branch_ids" value="<%= branchId || '' %>">
            <% } %>
          </div>
        </div>

      </div>
      <div class="mt-4 flex flex-wrap items-center gap-2"><button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button><a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a></div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <% if (!reportLoaded) { %><div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!hasData) { %><div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-slate-50/70 p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500"><%= t("gross_sales_before_discount") %></div><div class="mt-2 text-2xl font-semibold text-slate-900"><%= formatAmount(kpis.grossSalesBeforeDiscount || 0) %></div><div class="mt-1 text-xs text-slate-500"><%= `${t("voucher_count")}: ${Number(kpis.voucherCount || 0)}` %></div></div>
        <div class="rounded-2xl border border-rose-200 bg-rose-50/70 p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-rose-600"><%= t("total_discount") %></div><div class="mt-2 text-2xl font-semibold text-rose-700"><%= formatAmount(kpis.totalDiscount || 0) %></div><div class="mt-1 text-xs text-rose-600"><%= `${t("discount_pct_of_gross_sales")}: ${formatPct(kpis.discountPctOfGrossSales || 0)}` %></div></div>
        <div class="rounded-2xl border border-emerald-200 bg-emerald-50/70 p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-emerald-700"><%= t("net_sales_after_discount") %></div><div class="mt-2 text-2xl font-semibold text-emerald-800"><%= formatAmount(kpis.netSalesAfterDiscount || 0) %></div><div class="mt-1 text-xs text-emerald-700"><%= `${t("discounted_vouchers")}: ${Number(kpis.discountedVoucherCount || 0)}` %></div></div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500"><%= averagePairDiscountLabel %></div><div class="mt-2 text-2xl font-semibold text-slate-900"><%= formatAmount(kpis.averagePairDiscount || 0) %></div><div class="mt-1 text-xs text-slate-500"><%= `${t("line_discount_total")}: ${formatAmount(kpis.lineDiscountTotal || 0)}` %></div></div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500"><%= averageDozenDiscountLabel %></div><div class="mt-2 text-2xl font-semibold text-slate-900"><%= formatAmount(kpis.averageDozenDiscount || 0) %></div><div class="mt-1 text-xs text-slate-500"><%= `${t("extra_discount")}: ${formatAmount(kpis.extraDiscountTotal || 0)}` %></div></div>
        <div class="rounded-2xl border border-rose-200 bg-rose-50/70 p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-rose-600"><%= t("policy_breach_count") %></div><div class="mt-2 text-2xl font-semibold text-rose-700"><%= Number(kpis.policyBreachedVoucherCount || 0) %></div><div class="mt-1 text-xs text-rose-600"><%= `${t("policy_excess_discount")}: ${formatAmount(kpis.policyExcessDiscountTotal || 0)}` %></div></div>
        <div class="rounded-2xl border border-slate-200 bg-white p-4"><div class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-500"><%= t("highest_discount_voucher") %></div><% if (highestDiscountVoucher) { %><div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-700"><span class="rounded-full bg-slate-100 px-2.5 py-1 font-semibold text-slate-800">VR. NO. <%= highestDiscountVoucher.voucher_no || "-" %></span><span><%= resolveRowCustomerName(highestDiscountVoucher) %></span><span class="font-semibold text-rose-700"><%= formatAmount(highestDiscountVoucher.total_discount || 0) %></span><a href="<%= highestDiscountVoucher.action_link %>" class="font-semibold text-accent hover:underline"><%= t("view") %></a></div><% } else { %><div class="mt-2 text-sm text-slate-500"><%= t("no_entries") %></div><% } %></div>
      </div>

      <div class="mt-4 grid grid-cols-1 gap-4 xl:grid-cols-2">
        <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"><h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700"><%= t("daily_discount_trend") %></h2><div class="mt-3 space-y-2"><% if (!trendRows.length) { %><div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-6 text-center text-sm text-slate-500"><%= t("no_entries") %></div><% } %><% trendRows.forEach((row) => { %><div class="rounded-xl border border-slate-200 bg-slate-50/50 p-3"><div class="flex items-center justify-between gap-2 text-sm"><span class="font-semibold text-slate-800"><%= formatDate(row.voucher_date) %></span><span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-500"><%= `${row.voucher_count} ${t("voucher_count")}` %></span></div><div class="mt-2 h-2 overflow-hidden rounded-full bg-slate-200"><div class="h-full rounded-full bg-accent" style="width:<%= Math.max(0, Math.min(100, Number(row.bar_pct || 0))) %>%"></div></div><div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-slate-600"><span><%= `${t("gross_amount")}: ${formatAmount(row.gross_sales_before_discount || 0)}` %></span><span><%= `${t("total_discount")}: ${formatAmount(row.total_discount || 0)}` %></span><span><%= `${t("discount_pct")}: ${formatPct(row.discount_pct || 0)}` %></span></div></div><% }) %></div></section>
        <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"><h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700"><%= t("high_discount_alerts") %></h2><div class="mt-3 space-y-2"><% if (!alertRows.length) { %><div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-6 text-center text-sm text-slate-500"><%= t("no_entries") %></div><% } %><% alertRows.forEach((row) => { %><div class="rounded-xl border border-rose-200 bg-rose-50/70 p-3"><div class="flex flex-wrap items-center justify-between gap-2"><div class="flex flex-wrap items-center gap-2"><span class="rounded-full bg-white px-2.5 py-1 text-xs font-semibold text-rose-700">VR. NO. <%= row.voucher_no || "-" %></span><span class="text-sm font-semibold text-slate-800"><%= resolveRowCustomerName(row) %></span><% if (row.policy_exceeded) { %><span class="rounded-full bg-rose-100 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-rose-700"><%= t("policy_limit_exceeded") %></span><% } %></div><a href="<%= row.action_link %>" class="text-xs font-semibold uppercase tracking-[0.08em] text-accent hover:underline"><%= t("view") %></a></div><div class="mt-2 flex flex-wrap items-center gap-3 text-xs text-slate-700"><span><%= `${t("total_discount")}: ${formatAmount(row.total_discount || 0)}` %></span><span><%= `${t("discount_pct")}: ${formatPct(row.discount_pct || 0)}` %></span><span><%= `${t("salesman")}: ${row.salesman_name || "-"}` %></span><% if (row.policy_exceeded) { %><span><%= `${t("policy_excess_discount")}: ${formatAmount(row.policy_excess_discount_total || 0)}` %></span><% } %></div></div><% }) %></div></section>
      </div>

      <div class="mt-4 grid grid-cols-1 gap-4 xl:grid-cols-3">
        <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"><h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700"><%= t("top_salesmen_by_discount") %></h2><div class="mt-3 overflow-x-auto"><table class="min-w-[640px] w-full text-sm"><thead class="bg-slate-100 text-slate-700"><tr><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("salesman") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Qty Sold (Dozen)</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Avg Pair Discount</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Avg Dozen Discount</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("discount_pct") %></th></tr></thead><tbody class="divide-y divide-slate-100"><% if (!salesmanRows.length) { %><tr><td colspan="5" class="px-3 py-6 text-center text-sm text-slate-500"><%= t("no_entries") %></td></tr><% } %><% salesmanRows.forEach((row) => { %><tr class="odd:bg-slate-50/40"><td class="px-3 py-2 font-medium text-slate-800"><%= row.salesman_name || "-" %></td><td class="px-3 py-2 text-right"><%= formatQty(row.total_dozen_qty || 0) %></td><td class="px-3 py-2 text-right font-semibold text-rose-700"><%= formatAmount(row.average_pair_discount || 0) %></td><td class="px-3 py-2 text-right font-semibold text-slate-800"><%= formatAmount(row.average_dozen_discount || 0) %></td><td class="px-3 py-2 text-right"><%= formatPct(row.discount_pct || 0) %></td></tr><% }) %></tbody></table></div></section>
        <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"><h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700"><%= t("top_customers_by_discount") %></h2><div class="mt-3 overflow-x-auto"><table class="min-w-[680px] w-full text-sm"><thead class="bg-slate-100 text-slate-700"><tr><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("customer_name") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Qty Sold (Dozen)</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Avg Pair Discount</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Avg Dozen Discount</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("discount_pct") %></th></tr></thead><tbody class="divide-y divide-slate-100"><% if (!customerRows.length) { %><tr><td colspan="5" class="px-3 py-6 text-center text-sm text-slate-500"><%= t("no_entries") %></td></tr><% } %><% customerRows.forEach((row) => { %><tr class="odd:bg-slate-50/40"><td class="px-3 py-2 font-medium text-slate-800"><%= resolveRowCustomerName(row) %></td><td class="px-3 py-2 text-right"><%= formatQty(row.total_dozen_qty || 0) %></td><td class="px-3 py-2 text-right font-semibold text-rose-700"><%= formatAmount(row.average_pair_discount || 0) %></td><td class="px-3 py-2 text-right font-semibold text-slate-800"><%= formatAmount(row.average_dozen_discount || 0) %></td><td class="px-3 py-2 text-right"><%= formatPct(row.discount_pct || 0) %></td></tr><% }) %></tbody></table></div></section>
        <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm"><h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700"><%= t("top_items_by_discount") %></h2><div class="mt-3 overflow-x-auto"><table class="min-w-[600px] w-full text-sm"><thead class="bg-slate-100 text-slate-700"><tr><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("article") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Qty Sold (Dozen)</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Avg Pair Discount</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Avg Dozen Discount</th></tr></thead><tbody class="divide-y divide-slate-100"><% if (!itemRows.length) { %><tr><td colspan="4" class="px-3 py-6 text-center text-sm text-slate-500"><%= t("no_entries") %></td></tr><% } %><% itemRows.forEach((row) => { %><tr class="odd:bg-slate-50/40"><td class="px-3 py-2 font-medium text-slate-800"><%= row.item_label || "-" %></td><td class="px-3 py-2 text-right"><%= formatQty(row.total_dozen_qty || 0) %></td><td class="px-3 py-2 text-right font-semibold text-rose-700"><%= formatAmount(row.average_pair_discount || 0) %></td><td class="px-3 py-2 text-right font-semibold text-slate-800"><%= formatAmount(row.average_dozen_discount || 0) %></td></tr><% }) %></tbody></table></div></section>
      </div>

      <section class="mt-4 rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
        <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-slate-700"><%= t("voucher_discount_details") %></h2>
        <div class="mt-3 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[1320px] w-full text-sm tabular-nums"><thead class="bg-slate-100 text-slate-700"><tr><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("date") %></th><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("voucher_no") %></th><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("customer_name") %></th><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("salesman") %></th><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("payment_type") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Dozen Qty</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("gross_amount") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("total_discount") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]">Exceeded Discount Amount</th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("discount_pct") %></th><th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("net_amount") %></th><% if (includeBranchColumn) { %><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("branch") %></th><% } %><th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("action") %></th></tr></thead><tbody class="divide-y divide-slate-100"><% rows.forEach((row) => { %><tr class="<%= row.policy_exceeded ? 'bg-rose-50/70' : 'odd:bg-slate-50/30' %>"><td class="px-3 py-2"><%= formatDate(row.voucher_date) %></td><td class="px-3 py-2 font-semibold text-slate-800"><%= row.voucher_no || "-" %></td><td class="px-3 py-2"><%= resolveRowCustomerName(row) %></td><td class="px-3 py-2"><%= row.salesman_name || "-" %></td><td class="px-3 py-2"><%= paymentTypeLabel(row.payment_type) %></td><td class="px-3 py-2 text-right"><%= formatQty(row.total_dozen_qty || 0) %></td><td class="px-3 py-2 text-right"><%= formatAmount(row.gross_sales_before_discount || 0) %></td><td class="px-3 py-2 text-right font-semibold text-rose-700"><%= formatAmount(row.total_discount || 0) %></td><td class="px-3 py-2 text-right <%= Number(row.policy_excess_discount_total || 0) > 0 ? 'font-semibold text-rose-700' : 'text-slate-600' %>"><%= formatAmount(row.policy_excess_discount_total || 0) %></td><td class="px-3 py-2 text-right"><%= formatPct(row.discount_pct || 0) %></td><td class="px-3 py-2 text-right font-semibold text-emerald-700"><%= formatAmount(row.net_sales_after_discount || 0) %></td><% if (includeBranchColumn) { %><td class="px-3 py-2"><%= row.branch_name || "-" %></td><% } %><td class="px-3 py-2"><a href="<%= row.action_link %>" class="font-semibold text-accent hover:underline"><%= t("view") %></a></td></tr><% }) %><tr class="bg-rose-700 text-white"><td colspan="5" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td><td class="px-3 py-2 text-right font-extrabold"><%= formatQty(kpis.totalDozenQty || 0) %></td><td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(kpis.grossSalesBeforeDiscount || 0) %></td><td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(kpis.totalDiscount || 0) %></td><td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(kpis.totalExceededDiscountAmount || 0) %></td><td class="px-3 py-2 text-right font-extrabold"><%= formatPct(kpis.discountPctOfGrossSales || 0) %></td><td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(kpis.netSalesAfterDiscount || 0) %></td><% if (includeBranchColumn) { %><td class="px-3 py-2"></td><% } %><td class="px-3 py-2"></td></tr></tbody></table>
        </div>
      </section>
    <% } %>
  </section>
</div>
<script><%- include("../../base/partials/date-range-picker.js") %></script>

<script>(function(){ if (typeof window.initSearchableSelects === "function") window.initSearchableSelects(); const form = document.querySelector("[data-sales-discount-report-filter-form]"); if (form && typeof window.initReportDateRangePicker === "function") window.initReportDateRangePicker({ root: form, invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>, selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %> }); })();</script>

