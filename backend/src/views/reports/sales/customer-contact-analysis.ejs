<%
const reportLoaded = Boolean(filters?.reportLoaded);
const selectedFrom = String(filters?.from || "");
const selectedTo = String(filters?.to || "");
const selectedBranchId = Number(filters?.branchId || 0) || null;
const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
const totals = reportData?.totals || {
  contactCount: 0,
  voucherCount: 0,
  totalBillAmount: 0,
  highestBill: 0,
};
const branches = Array.isArray(options?.branches) ? options.branches : [];
const hasData = rows.length > 0;
const downloadName = "customer-contact-analysis.csv";
const dateRangeLabel = (() => {
  const v = typeof t === "function" ? t("date_range") : "";
  return v || "Date Range";
})();
const weekdayShortLabels = [
  t("weekday_sun_short"),
  t("weekday_mon_short"),
  t("weekday_tue_short"),
  t("weekday_wed_short"),
  t("weekday_thu_short"),
  t("weekday_fri_short"),
  t("weekday_sat_short"),
];
const formatMoney = (value) => {
  const num = Number(value || 0);
  return Number.isFinite(num)
    ? num.toLocaleString(undefined, {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      })
    : "0.00";
};
const formatDate = (value) => formatDateDisplay(value, "-");
const paymentTypeLabel = (value) =>
  String(value || "").trim().toUpperCase() === "CASH"
    ? t("cash_sale")
    : String(value || "").trim().toUpperCase() === "CREDIT"
      ? t("credit_sale")
      : "-";
const paymentTypeTone = (value) =>
  String(value || "").trim().toUpperCase() === "CASH"
    ? "border-emerald-200 bg-emerald-50 text-emerald-700"
    : String(value || "").trim().toUpperCase() === "CREDIT"
      ? "border-amber-200 bg-amber-50 text-amber-700"
      : "border-slate-200 bg-slate-50 text-slate-700";
const voucherStatusLabel = (value) => {
  const normalized = String(value || "").trim().toUpperCase();
  if (normalized === "APPROVED") return t("approved");
  if (normalized === "PENDING") return t("pending");
  if (normalized === "REJECTED") return t("rejected");
  return normalized || "-";
};
const voucherStatusTone = (value) => {
  const normalized = String(value || "").trim().toUpperCase();
  if (normalized === "APPROVED") return "border-emerald-200 bg-emerald-50 text-emerald-700";
  if (normalized === "PENDING") return "border-amber-200 bg-amber-50 text-amber-700";
  if (normalized === "REJECTED") return "border-rose-200 bg-rose-50 text-rose-700";
  return "border-slate-200 bg-slate-50 text-slate-700";
};
%>
<div class="mx-auto w-full max-w-none space-y-6 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex flex-col gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= t("customer_contact_analysis") %></h1>
      <p class="text-sm text-slate-500"><%= t("customer_reports") %></p>
    </div>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div>
    <% } %>
    <form method="post" action="<%= reportPath %>" class="mt-4 grid grid-cols-1 gap-3 rounded-2xl border border-slate-200 bg-slate-50/70 p-4 lg:grid-cols-12" data-contact-analysis-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="lg:col-span-8">
        <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.08em] text-slate-500"><%= dateRangeLabel %></label>
        <div class="relative" data-date-range-wrap>
          <input type="text" readonly value="<%= `${selectedFrom} - ${selectedTo}` %>" data-date-range-input class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm text-slate-700">
          <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </button>
          <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
            <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
              <div class="space-y-1.5">
                <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div></div>
                <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div></div>
              </div>
              <div>
                <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                <div class="grid grid-cols-1 gap-3 xl:grid-cols-[1fr_auto_1fr]">
                  <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                    <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button></div>
                    <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                    <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                  </div>
                  <div class="hidden xl:block w-px bg-slate-200 self-stretch"></div>
                  <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                    <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button></div>
                    <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                    <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                  </div>
                </div>
              </div>
            </div>
            <div class="mt-1.5 flex items-center justify-end gap-2"><button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button><button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button></div>
          </div>
        </div>
        <input type="hidden" name="from_date" value="<%= selectedFrom %>" data-from-date-hidden>
        <input type="hidden" name="to_date" value="<%= selectedTo %>" data-to-date-hidden>
      </div>

      <div class="lg:col-span-4">
        <label class="mb-1 block text-xs font-semibold uppercase tracking-[0.08em] text-slate-500"><%= user?.isAdmin ? t("branches") : t("branch") %></label>
        <% if (user?.isAdmin) { %>
          <select name="branch_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm text-slate-700">
            <option value=""><%= t("all") %></option>
            <% branches.forEach((branch) => { %>
              <option value="<%= branch.id %>" <%= selectedBranchId === Number(branch.id) ? "selected" : "" %>><%= branch.name %></option>
            <% }) %>
          </select>
        <% } else { %>
          <input type="text" readonly value="<%= branches[0]?.name || branchId || '-' %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
        <% } %>
      </div>

      <div class="lg:col-span-12 flex flex-wrap items-center gap-2">
        <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
        <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white/95 shadow-md" data-contact-analysis-area>
    <div class="border-b border-slate-200 px-5 py-4">
      <div class="mb-3 flex items-center justify-end gap-2" data-report-controls>
        <button type="button" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 disabled:opacity-40" data-print-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
        <button type="button" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" data-download-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
      </div>
      <div class="flex flex-col gap-3 lg:flex-row lg:items-end lg:justify-between">
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t("customer_contact_analysis") %></div>
            <div class="mt-1 text-2xl font-display font-semibold text-slate-900"><%= totals.contactCount || 0 %></div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t("bill_count") %></div>
            <div class="mt-1 text-2xl font-display font-semibold text-slate-900"><%= totals.voucherCount || 0 %></div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t("total_bill_amount") %></div>
            <div class="mt-1 text-2xl font-display font-semibold text-slate-900"><%= formatMoney(totals.totalBillAmount || 0) %></div>
          </div>
          <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
            <div class="text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t("highest_bill") %></div>
            <div class="mt-1 text-2xl font-display font-semibold text-slate-900"><%= formatMoney(totals.highestBill || 0) %></div>
          </div>
        </div>
        <div><%- include("../../base/partials/table-controls", { t, showStatus: false }) %></div>
      </div>
    </div>

    <% if (!reportLoaded) { %>
      <div class="px-5 py-10 text-center text-xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!hasData) { %>
      <div class="px-5 py-10 text-center text-xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="min-w-[1240px] w-full text-sm" data-contact-table>
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-widest text-slate-500">
            <tr>
              <th class="px-4 py-3 text-left">SR.NO</th>
              <th class="px-4 py-3 text-left"><%= t("primary_customer_name") %></th>
              <th class="px-4 py-3 text-right"><%= t("total_bill_amount") %></th>
              <th class="px-4 py-3 text-right"><%= t("highest_bill") %></th>
              <th class="px-4 py-3 text-right"><%= t("bill_count") %></th>
              <th class="px-4 py-3 text-left"><%= t("last_purchase_date") %></th>
              <th class="px-4 py-3 text-left"><%= t("product_groups") %></th>
              <th class="px-4 py-3 text-center"><%= t("details") %></th>
              <th class="px-4 py-3 text-left"><%= t("phone_number") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100" data-contact-table-body>
            <% rows.forEach((row, idx) => { %>
              <tr class="bg-white hover:bg-slate-50" data-row data-active="true" data-contact-row data-contact-key="<%= row.phone_key %>">
                <td class="px-4 py-3 text-slate-700"><%= idx + 1 %></td>
                <td class="px-4 py-3 text-slate-700"><%= row.primary_customer_name || "-" %></td>
                <td class="px-4 py-3 text-right font-semibold tabular-nums text-slate-900"><%= formatMoney(row.total_bill_amount || 0) %></td>
                <td class="px-4 py-3 text-right font-semibold tabular-nums text-slate-700"><%= formatMoney(row.highest_bill || 0) %></td>
                <td class="px-4 py-3 text-right font-semibold text-slate-700"><%= row.bill_count || 0 %></td>
                <td class="px-4 py-3 text-slate-700"><%= formatDate(row.last_purchase_date) %></td>
                <td class="px-4 py-3 text-slate-700">
                  <div class="flex flex-wrap gap-1.5">
                    <% if (Array.isArray(row.product_groups_bought) && row.product_groups_bought.length) { %>
                      <% row.product_groups_bought.forEach((groupName) => { %>
                        <span class="inline-flex rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 text-[11px] font-semibold text-slate-700"><%= groupName %></span>
                      <% }) %>
                    <% } else { %>
                      <span class="text-slate-400"><%= t("none") %></span>
                    <% } %>
                  </div>
                </td>
                <td class="px-4 py-3 text-center">
                  <button type="button" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-700 shadow-sm" data-contact-toggle data-contact-key="<%= row.phone_key %>" aria-expanded="false">
                    <span><%= t("details") %></span>
                    <span class="ml-1 rounded-full bg-slate-100 px-1.5 py-0.5 text-[10px] text-slate-600"><%= Array.isArray(row.invoices) ? row.invoices.length : 0 %></span>
                  </button>
                </td>
                <td class="px-4 py-3 font-semibold text-slate-900"><%= row.phone_number || "-" %></td>
              </tr>
              <tr class="hidden bg-slate-50/70" data-contact-detail-row data-contact-key="<%= row.phone_key %>">
                <td colspan="9" class="px-4 py-4">
                  <div class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
                    <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
                      <div class="text-sm font-semibold text-slate-800"><%= t("invoice") %> <%= t("details") %></div>
                      <div class="text-xs font-medium text-slate-500"><%= row.phone_number || "-" %></div>
                    </div>
                    <div class="overflow-x-auto rounded-xl border border-slate-200">
                      <table class="min-w-[960px] w-full text-xs">
                        <thead class="bg-slate-50 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-500">
                          <tr>
                            <th class="px-3 py-2 text-left"><%= t("invoice") %></th>
                            <th class="px-3 py-2 text-left"><%= t("date") %></th>
                            <th class="px-3 py-2 text-left"><%= t("bill_number") %></th>
                            <th class="px-3 py-2 text-left"><%= t("party_name") %></th>
                            <th class="px-3 py-2 text-left"><%= t("branch") %></th>
                            <th class="px-3 py-2 text-left"><%= t("sales_type") %></th>
                            <th class="px-3 py-2 text-left"><%= t("status") %></th>
                            <th class="px-3 py-2 text-right"><%= t("total_bill_amount") %></th>
                            <th class="px-3 py-2 text-left"><%= t("product_groups") %></th>
                            <th class="px-3 py-2 text-center"><%= t("view") %></th>
                          </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                          <% if (!Array.isArray(row.invoices) || !row.invoices.length) { %>
                            <tr>
                              <td colspan="10" class="px-3 py-6 text-center text-slate-500"><%= t("no_entries") %></td>
                            </tr>
                          <% } else { %>
                            <% row.invoices.forEach((invoice) => { %>
                              <tr class="bg-white">
                                <td class="px-3 py-2 font-semibold text-slate-800"><%= invoice.voucher_no || "-" %></td>
                                <td class="px-3 py-2 text-slate-700"><%= formatDate(invoice.voucher_date) %></td>
                                <td class="px-3 py-2 text-slate-700"><%= invoice.bill_number || "-" %></td>
                                <td class="px-3 py-2 text-slate-700"><%= invoice.customer_name || "-" %></td>
                                <td class="px-3 py-2 text-slate-700"><%= invoice.branch_name || "-" %></td>
                                <td class="px-3 py-2">
                                  <span class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold <%= paymentTypeTone(invoice.payment_type) %>"><%= paymentTypeLabel(invoice.payment_type) %></span>
                                </td>
                                <td class="px-3 py-2">
                                  <span class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold <%= voucherStatusTone(invoice.voucher_status) %>"><%= voucherStatusLabel(invoice.voucher_status) %></span>
                                </td>
                                <td class="px-3 py-2 text-right font-semibold tabular-nums text-slate-900"><%= formatMoney(invoice.bill_amount || 0) %></td>
                                <td class="px-3 py-2 text-slate-700">
                                  <% if (Array.isArray(invoice.product_groups) && invoice.product_groups.length) { %>
                                    <%= invoice.product_groups.join(", ") %>
                                  <% } else { %>
                                    <%= t("none") %>
                                  <% } %>
                                </td>
                                <td class="px-3 py-2 text-center">
                                  <a href="<%= invoice.action_link %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-2 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-700"><%= t("view") %></a>
                                </td>
                              </tr>
                            <% }) %>
                          <% } %>
                        </tbody>
                      </table>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <%- include("../../base/partials/table-footer", { t }) %>
  </section>
</div>

<script><%- include("../../base/partials/date-range-picker.js") %></script>
<script>
(() => {
  const form = document.querySelector("[data-contact-analysis-form]");
  if (form && typeof window.initReportDateRangePicker === "function") {
    window.initReportDateRangePicker({
      root: form,
      invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
      selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>
    });
  }

  document.querySelector("[data-print-report]")?.addEventListener("click", () => window.print());
  document.querySelector("[data-download-report]")?.addEventListener("click", () => {
    const table = document.querySelector("[data-contact-table]");
    if (!table) return;
    const headerRows = Array.from(table.querySelectorAll("thead tr"));
    const bodyRows = Array.from(table.querySelectorAll("tbody tr[data-contact-row]"))
      .filter((tr) => !tr.classList.contains("hidden"));
    const csv = [...headerRows, ...bodyRows]
      .map((tr) =>
        Array.from(tr.querySelectorAll("th,td"))
          .map((cell) => `"${String(cell.textContent || "").replace(/\s+/g, " ").trim().replace(/"/g, '""')}"`)
          .join(","),
      )
      .join("\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = <%- JSON.stringify(downloadName) %>;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(link.href);
  });

  const tableBody = document.querySelector("[data-contact-table-body]");
  const searchInput = document.querySelector("[data-search-input]");
  const pageSizeSelect = document.querySelector("[data-page-size]");
  const prevButton = document.querySelector("[data-prev-page]");
  const nextButton = document.querySelector("[data-next-page]");
  const pageIndicator = document.querySelector("[data-page-indicator]");
  const showingCount = document.querySelector("[data-showing-count]");

  if (!tableBody) return;

  const getMainRows = () => Array.from(tableBody.querySelectorAll("tr[data-contact-row]"));
  let currentPage = 1;

  const closeHiddenDetails = () => {
    Array.from(tableBody.querySelectorAll("tr[data-contact-detail-row]")).forEach((detailRow) => {
      const key = detailRow.getAttribute("data-contact-key");
      const mainRow = tableBody.querySelector(`tr[data-contact-row][data-contact-key="${key}"]`);
      if (!mainRow || mainRow.classList.contains("hidden")) {
        detailRow.classList.add("hidden");
        const toggle = document.querySelector(`[data-contact-toggle][data-contact-key="${key}"]`);
        if (toggle) toggle.setAttribute("aria-expanded", "false");
      }
    });
  };

  const applyTableState = () => {
    const pageSizeValue = pageSizeSelect?.value || "10";
    const pageSize = pageSizeValue === "all" ? Number.MAX_SAFE_INTEGER : Math.max(1, Number(pageSizeValue || 10));
    const query = String(searchInput?.value || "").trim().toLowerCase();
    const allRows = getMainRows();
    const filteredRows = allRows.filter((row) => {
      if (!query) return true;
      return String(row.textContent || "").toLowerCase().includes(query);
    });

    const totalPages = Math.max(1, Math.ceil(filteredRows.length / pageSize));
    if (currentPage > totalPages) currentPage = totalPages;

    allRows.forEach((row) => row.classList.add("hidden"));
    const start = (currentPage - 1) * pageSize;
    filteredRows.slice(start, start + pageSize).forEach((row) => row.classList.remove("hidden"));

    closeHiddenDetails();

    if (showingCount) {
      const end = filteredRows.length ? Math.min(filteredRows.length, start + pageSize) : 0;
      showingCount.textContent = `<%= t("showing") %> ${filteredRows.length ? start + 1 : 0}-${end} / ${filteredRows.length}`;
    }
    if (pageIndicator) pageIndicator.textContent = String(currentPage);
    if (prevButton) prevButton.disabled = currentPage <= 1;
    if (nextButton) nextButton.disabled = currentPage >= totalPages;
  };

  searchInput?.addEventListener("input", () => {
    currentPage = 1;
    applyTableState();
  });

  pageSizeSelect?.addEventListener("change", () => {
    currentPage = 1;
    applyTableState();
  });

  prevButton?.addEventListener("click", () => {
    if (currentPage <= 1) return;
    currentPage -= 1;
    applyTableState();
  });

  nextButton?.addEventListener("click", () => {
    currentPage += 1;
    applyTableState();
  });

  document.querySelectorAll("[data-contact-toggle]").forEach((button) => {
    button.addEventListener("click", () => {
      const key = button.getAttribute("data-contact-key");
      if (!key) return;
      const mainRow = tableBody.querySelector(`tr[data-contact-row][data-contact-key="${key}"]`);
      const detailRow = tableBody.querySelector(`tr[data-contact-detail-row][data-contact-key="${key}"]`);
      if (!mainRow || !detailRow || mainRow.classList.contains("hidden")) return;
      const expanded = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", expanded ? "false" : "true");
      detailRow.classList.toggle("hidden", expanded);
    });
  });

  applyTableState();
})();
</script>
