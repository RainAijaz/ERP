<%
const reportLoaded = Boolean(filters?.reportLoaded);
const selectedFrom = String(filters?.from || "");
const selectedTo = String(filters?.to || "");
const selectedPartyId = Number(filters?.partyId || 0) || null;
const selectedGroupId = Number(filters?.groupId || 0) || null;
const selectedSubgroupId = Number(filters?.subgroupId || 0) || null;
const selectedCategoryId = Number(filters?.categoryId || 0) || null;
const selectedReturnReasonId = Number(filters?.returnReasonId || 0) || null;
const selectedSalesmanId = Number(filters?.salesmanId || 0) || null;
const selectedReceiveIntoAccountId = Number(filters?.receiveIntoAccountId || 0) || null;
const selectedBranchId = Number(filters?.branchId || 0) || null;
const selectedVoucherStatus = ["all", "approved", "pending"].includes(String(filters?.voucherStatus || "").toLowerCase()) ? String(filters.voucherStatus).toLowerCase() : "all";
const rawSelectedOrderBy = String(filters?.orderBy || "").toLowerCase();
const normalizedSelectedOrderBy = rawSelectedOrderBy === "party" ? "payment_account" : rawSelectedOrderBy;
const selectedOrderBy = ["payment_account", "voucher", "article"].includes(normalizedSelectedOrderBy) ? normalizedSelectedOrderBy : "payment_account";
const selectedSaleType = ["all", "cash", "credit"].includes(String(filters?.saleType || "").toLowerCase()) ? String(filters.saleType).toLowerCase() : "all";
const selectedReportType = ["details", "summary"].includes(String(filters?.reportType || "").toLowerCase()) ? String(filters.reportType).toLowerCase() : "details";
const groups = Array.isArray(reportData?.groups) ? reportData.groups : [];
const summaryRows = Array.isArray(reportData?.summaryRows) ? reportData.summaryRows : [];
const totals = reportData?.totals || { qty: 0, packedQty: 0, looseQty: 0, grossAmount: 0, discountAmount: 0, netAmount: 0, effectivePairDiscount: 0 };
const includeBranchColumn = Boolean(reportData?.includeBranchColumn);
const hasData = selectedReportType === "summary" ? summaryRows.length > 0 : groups.length > 0;
const customerOptions = Array.isArray(options?.customers) ? options.customers : [];
const groupOptions = Array.isArray(options?.groups) ? options.groups : [];
const subgroupOptions = Array.isArray(options?.subgroups) ? options.subgroups : [];
const categoryOptions = Array.isArray(options?.categories) ? options.categories : [];
const returnReasonOptions = Array.isArray(options?.returnReasons) ? options.returnReasons : [];
const salesmanOptions = Array.isArray(options?.salesmen) ? options.salesmen : [];
const receiveAccountOptions = Array.isArray(options?.receiveAccounts) ? options.receiveAccounts : [];
const branchOptions = Array.isArray(options?.branches) ? options.branches : [];
const showReturnReasonFilter = Boolean(returnReasonFilter);
const showReceiveAccountFilter = !showReturnReasonFilter;
const pageTitle = (() => {
  if (typeof reportTitle === "string" && reportTitle.trim()) return reportTitle.trim();
  const v = typeof t === "function" ? t("sales_report") : "";
  return v && v !== "sales_report" ? v : "Sales Report";
})();
const downloadName = (() => {
  if (typeof downloadFileName === "string" && downloadFileName.trim()) return downloadFileName.trim();
  return "sales-report.csv";
})();
const dateRangeLabel = (() => {
  const v = typeof t === "function" ? t("date_range") : "";
  return v || "Date Range";
})();
const articleGroupLabel = (() => { const v = typeof t === "function" ? t("product_group") : ""; return v && v !== "product_group" ? v : "Article Group"; })();
const articleSubgroupLabel = (() => { const v = typeof t === "function" ? t("sub_group") : ""; if (v && v !== "sub_group") return v; const alt = typeof t === "function" ? t("product_subgroups") : ""; return alt && alt !== "product_subgroups" ? alt : "Article Subgroup"; })();
const articleCategoryLabel = (() => { const v = typeof t === "function" ? t("category") : ""; return v && v !== "category" ? v : "Article Category"; })();
const returnReasonLabel = (() => { const v = typeof t === "function" ? t("return_reason") : ""; return v && v !== "return_reason" ? v : "Return Reason"; })();
const salesTypeLabel = (() => { const v = typeof t === "function" ? t("sales_type") : ""; return v && v !== "sales_type" ? v : "Sales Type"; })();
const totalDozenSoldLabel = (() => { const v = typeof t === "function" ? t("total_dozen_sold") : ""; return v && v !== "total_dozen_sold" ? v : "Total Dozen Sold"; })();
const totalPairsSoldLabel = (() => { const v = typeof t === "function" ? t("total_pairs_sold") : ""; return v && v !== "total_pairs_sold" ? v : "Total Pairs Sold"; })();
const dozenShortLabel = (() => { const v = typeof t === "function" ? t("dozen") : ""; return v && v !== "dozen" ? v : "Dozen"; })();
const pairsShortLabel = (() => { const v = typeof t === "function" ? t("pairs") : ""; return v && v !== "pairs" ? v : "Pairs"; })();
const saleReturnLabel = (() => { const v = typeof t === "function" ? t("sale_return_report") : ""; const text = v && v !== "sale_return_report" ? v : "Sale Return"; return String(text).replace(/\s+Report$/i, ""); })();
const pairRateLabel = (() => { const v = typeof t === "function" ? t("pair_rate") : ""; return v && v !== "pair_rate" ? v : "Pair Rate"; })();
const pairDiscountLabel = (() => { const v = typeof t === "function" ? t("pair_discount") : ""; return v && v !== "pair_discount" ? v : "Pair Discount"; })();
const totalDiscountLabel = (() => { const v = typeof t === "function" ? t("total_discount") : ""; return v && v !== "total_discount" ? v : "Total Discount"; })();
const paymentAccountLabel = (() => { const v = typeof t === "function" ? t("payment_account") : ""; return v && v !== "payment_account" ? v : "Payment Account"; })();
const invoiceLabel = (() => { const v = typeof t === "function" ? t("invoice") : ""; return v && v !== "invoice" ? v : "Invoice"; })();
const allLabel = typeof t === "function" ? t("all") : "All";
const weekdayShortLabels = [t("weekday_sun_short"), t("weekday_mon_short"), t("weekday_tue_short"), t("weekday_wed_short"), t("weekday_thu_short"), t("weekday_fri_short"), t("weekday_sat_short")];
const formatDate = (value) => formatDateDisplay(value, "-");
const formatQty = (value) => formatNumberDisplay(value, { decimals: 3, fallback: "0" });
const formatMoney = (value, digits = 2) => formatNumberDisplay(value, { decimals: digits, fallback: "0" });
const resolveCustomerOptionName = (customer) => { if (!customer) return "-"; if (locale === "ur") return String(customer.name_ur || customer.name || "-"); return String(customer.name || customer.name_ur || "-"); };
const resolveRowCustomerName = (row) => { if (!row) return "-"; if (row.customer_party_id) { if (locale === "ur") return String(row.customer_name_ur || row.customer_name_en || "-"); return String(row.customer_name_en || row.customer_name_ur || "-"); } return String(row.walk_in_customer_name || "-"); };
const rowStatusLabel = (value) => String(value || "").trim().toUpperCase() === "LOOSE" ? (t("loose") === "loose" ? "Loose" : t("loose")) : (t("packed") === "packed" ? "Packed" : t("packed"));
const rowStatusTone = (value) => String(value || "").trim().toUpperCase() === "LOOSE" ? "border-amber-300 bg-amber-50 text-amber-800" : "border-slate-300 bg-slate-100 text-slate-700";
const paymentTypeLabel = (value) => String(value || "").trim().toUpperCase() === "CASH" ? t("cash_sale") : String(value || "").trim().toUpperCase() === "CREDIT" ? t("credit_sale") : "-";
const paymentTypeTone = (value) => String(value || "").trim().toUpperCase() === "CASH" ? "border-emerald-300 bg-emerald-50 text-emerald-700" : String(value || "").trim().toUpperCase() === "CREDIT" ? "border-amber-300 bg-amber-50 text-amber-700" : "border-slate-300 bg-slate-50 text-slate-700";
const voucherStatusLabel = (value) => { const normalized = String(value || "").trim().toUpperCase(); if (normalized === "APPROVED") return t("approved") === "approved" ? "Approved" : t("approved"); if (normalized === "PENDING") return t("pending") === "pending" ? "Pending" : t("pending"); if (normalized === "REJECTED") return t("rejected") === "rejected" ? "Rejected" : t("rejected"); return normalized || "-"; };
const voucherStatusTone = (value) => { const normalized = String(value || "").trim().toUpperCase(); if (normalized === "APPROVED") return "border-emerald-300 bg-emerald-50 text-emerald-700"; if (normalized === "PENDING") return "border-amber-300 bg-amber-50 text-amber-700"; if (normalized === "REJECTED") return "border-rose-300 bg-rose-50 text-rose-700"; return "border-slate-300 bg-slate-50 text-slate-700"; };
const remainingTone = (value) => Number(value || 0) > 0 ? "border-amber-300 bg-amber-50 text-amber-700" : "border-emerald-300 bg-emerald-50 text-emerald-700";
const advancedFilterEntries = [
  selectedPartyId ? t("party_name") : "",
  selectedGroupId ? articleGroupLabel : "",
  selectedSubgroupId ? articleSubgroupLabel : "",
  selectedCategoryId ? articleCategoryLabel : "",
  selectedSalesmanId ? t("salesman") : "",
  selectedVoucherStatus !== "all" ? t("status") : "",
  showReceiveAccountFilter && selectedReceiveIntoAccountId ? t("receive_into_account") : "",
  showReturnReasonFilter && selectedReturnReasonId ? returnReasonLabel : "",
].filter(Boolean);
const advancedFilterCount = advancedFilterEntries.length;
const advancedFilterSummary = advancedFilterEntries.join(", ");
const detailStaticColumnCount = 1
  + (selectedOrderBy !== "voucher" ? 2 : 0)
  + (selectedOrderBy !== "voucher" ? 1 : 0)
  + (selectedOrderBy !== "article" ? 1 : 0)
  + 1
  + (selectedOrderBy !== "voucher" ? 1 : 0)
  + 1
  + (showReturnReasonFilter ? 1 : 0);
const detailTotalsLabelSpan = detailStaticColumnCount;
const detailMetricColumnCount = 5 + (selectedOrderBy === "voucher" ? 1 : 0);
const detailColumnCount = detailStaticColumnCount + detailMetricColumnCount + (includeBranchColumn ? 1 : 0);
const distinctCount = (rows, key) => { const values = new Set(); (rows || []).forEach((row) => { const value = row?.[key]; if (value !== null && value !== undefined && String(value).trim() !== "") values.add(String(value)); }); return values.size; };
%>
<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= pageTitle %></h1>
    <% if (filters?.invalidFilterInput) { %><div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div><% } %>
    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-sales-report-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">
      <div class="space-y-3">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-end">
          <button
            type="button"
            class="relative inline-flex h-10 w-10 items-center justify-center self-end rounded-lg border border-slate-300 bg-white text-slate-700 transition hover:border-slate-400 hover:bg-slate-50"
            data-advanced-filter-toggle
            aria-expanded="false"
            aria-label="<%= t('advanced_filters') !== 'advanced_filters' ? t('advanced_filters') : 'Advanced Filters' %>"
            title="<%= t('advanced_filters') !== 'advanced_filters' ? t('advanced_filters') : 'Advanced Filters' %>"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M3 5h14M6 10h8M8 15h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
            <% if (advancedFilterCount > 0) { %>
              <span class="absolute -right-1.5 -top-1.5 inline-flex min-w-[1.1rem] items-center justify-center rounded-full bg-accent px-1 py-0.5 text-[10px] font-bold text-white"><%= advancedFilterCount %></span>
            <% } %>
          </button>
          <% if (advancedFilterCount > 0) { %>
            <div class="text-right text-xs font-medium text-slate-600 sm:max-w-[32rem]">
              <span class="font-semibold text-slate-700"><%= t("advanced_filters") !== "advanced_filters" ? t("advanced_filters") : "Advanced Filters" %>:</span>
              <span><%= advancedFilterSummary %></span>
            </div>
          <% } %>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= dateRangeLabel %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input type="text" readonly value="<%= `${filters?.from || ''} - ${filters?.to || ''}` %>" data-date-range-input class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm">
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div></div>
                    <div><div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div><div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div></div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 xl:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden xl:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2"><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button><div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div><button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button></div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500"><% weekdayShortLabels.forEach((weekdayLabel) => { %><span><%= weekdayLabel %></span><% }) %></div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2"><button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button><button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button></div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= filters?.from || '' %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= filters?.to || '' %>" data-to-date-hidden>
          </div>
        </div>

        <div class="hidden space-y-3 rounded-2xl border border-slate-200/80 bg-white/70 p-3" data-advanced-filter-panel>
          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("party_name") %></label>
            <div class="sm:col-span-9">
              <select name="party_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value=""><%= allLabel %></option>
                <% customerOptions.forEach((customer) => { %>
                  <option value="<%= customer.id %>" <%= selectedPartyId === Number(customer.id) ? "selected" : "" %>><%= resolveCustomerOptionName(customer) %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("status") %></label>
            <div class="sm:col-span-9">
              <select name="voucher_status" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="all" <%= selectedVoucherStatus === "all" ? "selected" : "" %>><%= allLabel %></option>
                <option value="approved" <%= selectedVoucherStatus === "approved" ? "selected" : "" %>><%= t("approved") %></option>
                <option value="pending" <%= selectedVoucherStatus === "pending" ? "selected" : "" %>><%= t("pending") %></option>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= articleGroupLabel %></label>
            <div class="sm:col-span-9">
              <select name="group_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value=""><%= allLabel %></option>
                <% groupOptions.forEach((group) => { %>
                  <option value="<%= group.id %>" <%= selectedGroupId === Number(group.id) ? "selected" : "" %>><%= group.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= articleSubgroupLabel %></label>
            <div class="sm:col-span-9">
              <select name="subgroup_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value=""><%= allLabel %></option>
                <% subgroupOptions.forEach((subgroup) => { %>
                  <option value="<%= subgroup.id %>" <%= selectedSubgroupId === Number(subgroup.id) ? "selected" : "" %>><%= subgroup.name %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= articleCategoryLabel %></label>
            <div class="sm:col-span-9">
              <select name="category_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value=""><%= allLabel %></option>
                <% categoryOptions.forEach((category) => { %>
                  <option value="<%= category.id %>" <%= selectedCategoryId === Number(category.id) ? "selected" : "" %>><%= locale === "ur" ? (category.name_ur || category.name || "-") : (category.name || category.name_ur || "-") %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <% if (showReturnReasonFilter) { %>
            <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
              <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= returnReasonLabel %></label>
              <div class="sm:col-span-9">
                <select name="return_reason_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                  <option value=""><%= allLabel %></option>
                  <% returnReasonOptions.forEach((reason) => { %>
                    <option value="<%= reason.id %>" <%= selectedReturnReasonId === Number(reason.id) ? "selected" : "" %>><%= reason.description || reason.code || "-" %></option>
                  <% }) %>
                </select>
              </div>
            </div>
          <% } %>

          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("salesman") %></label>
            <div class="sm:col-span-9">
              <select name="salesman_employee_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value=""><%= allLabel %></option>
                <% salesmanOptions.forEach((salesman) => { %>
                  <option value="<%= salesman.id %>" <%= selectedSalesmanId === Number(salesman.id) ? "selected" : "" %>><%= salesman.name || salesman.code || "-" %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <% if (showReceiveAccountFilter) { %>
            <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
              <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("receive_into_account") %></label>
              <div class="sm:col-span-9">
                <select name="receive_into_account_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                  <option value=""><%= allLabel %></option>
                  <% receiveAccountOptions.forEach((account) => { %>
                    <option value="<%= account.id %>" <%= selectedReceiveIntoAccountId === Number(account.id) ? "selected" : "" %>><%= account.name || account.code || "-" %></option>
                  <% }) %>
                </select>
              </div>
            </div>
          <% } %>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t("branches") : t("branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_id" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified">
                <option value=""><%= allLabel %></option>
                <% branchOptions.forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchId === Number(branch.id) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700" value="<%= branchOptions[0]?.name || branchId || '-' %>">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("order_by") %></label>
          <div class="sm:col-span-9">
