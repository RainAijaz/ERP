                      </span>
                      <span class="inline-flex items-baseline gap-1 text-[10px] font-medium tracking-[0.04em] text-slate-200">
                        <span class="text-slate-300"><%= pairsShortLabel %>:</span>
                        <span class="tabular-nums text-white/90"><%= formatQty(totals.looseQty || 0) %></span>
                      </span>
                    </div>
                  </td>
                  <td class="px-3 py-3 text-right font-extrabold"></td>
                  <td class="px-3 py-3 text-right font-extrabold tabular-nums text-white"><%= formatMoney(totals.grossAmount || 0) %></td>
                  <td class="px-3 py-3 text-right font-extrabold tabular-nums text-white"><%= formatMoney(totals.discountAmount || 0) %></td>
                  <td class="px-3 py-3 text-right font-black tabular-nums text-emerald-100"><%= formatMoney(totals.netAmount || 0) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-3"></td>
                  <% } %>
                <% } %>
              </tr>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="relative mt-3 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[1180px] w-full text-sm tabular-nums" data-table data-report-table>
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <% if (selectedOrderBy === "voucher") { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= invoiceLabel %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("date") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("bill_number") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("customer_name") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("receive_into_account") %></th>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= salesTypeLabel %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("payment_received_amount") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("remaining_amount") %></th>
                <% } else if (selectedOrderBy === "article") { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("group") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("parties_label") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("vouchers_label") %></th>
                <% } else { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= paymentAccountLabel %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("vouchers_label") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("items_label") %></th>
                <% } %>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("quantity") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= pairRateLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("gross_amount") %></th>
                <% if (selectedOrderBy === "voucher") { %>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= pairDiscountLabel %></th>
                <% } %>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= totalDiscountLabel %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("net_amount") %></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100" data-table-body>
              <% summaryRows.forEach((row) => { %>
                <tr class="<%= selectedOrderBy === 'voucher' && Number(row.total_qty || 0) < 0 ? 'bg-rose-50 hover:bg-rose-100' : 'odd:bg-slate-50 even:bg-white hover:bg-slate-100' %>" data-row data-active="true" data-report-entry>
                  <% if (selectedOrderBy === "voucher") { %>
                    <td class="px-3 py-2 font-semibold text-slate-800"><%= row.voucher_no || "-" %></td>
                    <td class="px-3 py-2"><%= formatDate(row.voucher_date) %></td>
                    <td class="px-3 py-2"><%= row.bill_number || "-" %></td>
                    <td class="px-3 py-2"><%= row.customer_label || "-" %></td>
                    <td class="px-3 py-2"><%= row.receive_account_name || "-" %></td>
                    <td class="px-3 py-2">
                      <span class="inline-flex rounded-md border px-2 py-0.5 text-[11px] font-semibold <%= paymentTypeTone(row.payment_type) %>"><%= paymentTypeLabel(row.payment_type) %></span>
                    </td>
                    <% if (String(row.payment_type || '').trim().toUpperCase() === 'CREDIT') { %>
                      <td class="px-3 py-2 text-right font-semibold text-sky-700"><%= formatMoney(row.payment_received_amount || 0) %></td>
                      <td class="px-3 py-2 text-right font-semibold <%= Number(row.remaining_amount || 0) > 0 ? 'text-amber-700' : 'text-emerald-700' %>"><%= formatMoney(row.remaining_amount || 0) %></td>
                    <% } else { %>
                      <td class="px-3 py-2 text-right text-slate-400">-</td>
                      <td class="px-3 py-2 text-right text-slate-400">-</td>
                    <% } %>
                  <% } else if (selectedOrderBy === "article") { %>
                    <td class="px-3 py-2 font-medium text-slate-800"><%= row.group_label || "-" %></td>
                    <td class="px-3 py-2 text-right"><%= row.customer_count || 0 %></td>
                    <td class="px-3 py-2 text-right"><%= row.voucher_count || 0 %></td>
                  <% } else { %>
                    <td class="px-3 py-2 font-medium text-slate-800"><%= row.group_label || "-" %></td>
                    <td class="px-3 py-2 text-right"><%= row.voucher_count || 0 %></td>
                    <td class="px-3 py-2 text-right"><%= row.article_count || 0 %></td>
                  <% } %>
                  <td class="px-3 py-2 text-right font-semibold">
                    <div class="flex flex-wrap items-center justify-end gap-2">
                      <% if (selectedOrderBy === "voucher" && Number(row.total_qty || 0) < 0) { %>
                        <span class="inline-flex rounded-md border border-rose-200 bg-rose-50 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-[0.08em] text-rose-700"><%= saleReturnLabel %></span>
                      <% } %>
                      <span class="<%= Number(row.total_qty || 0) < 0 ? 'tabular-nums text-rose-700' : 'tabular-nums text-slate-900' %>"><%= formatQty(row.total_qty || 0) %></span>
                    </div>
                  </td>
                  <td class="px-3 py-2 text-right"><%= formatMoney(row.avg_rate || 0) %></td>
                  <td class="px-3 py-2 text-right"><%= formatMoney(row.total_gross_amount || 0) %></td>
                  <% if (selectedOrderBy === "voucher") { %>
                    <td class="px-3 py-2 text-right"><%= formatMoney(row.effective_pair_discount || 0) %></td>
                  <% } %>
                  <td class="px-3 py-2 text-right text-rose-700"><%= formatMoney(row.total_discount_amount || 0) %></td>
                  <td class="px-3 py-2 text-right font-semibold text-emerald-700"><%= formatMoney(row.total_net_amount || 0) %></td>
                </tr>
              <% }) %>
              <tr class="bg-rose-700 text-white" data-row data-active="true" data-report-grand-total>
                <% if (selectedOrderBy === "voucher") { %>
                  <td colspan="8" class="px-3 py-2">
                    <div class="flex flex-wrap items-center justify-end gap-x-3 gap-y-1">
                      <span class="text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></span>
                      <span class="inline-flex items-baseline gap-1 rounded-md border border-white/20 bg-white/10 px-2.5 py-1 text-[11px] font-extrabold uppercase tracking-[0.06em] text-white">
                        <span class="text-white"><%= totalDozenSoldLabel %>:</span>
                        <span class="font-black tabular-nums text-white"><%= formatQty(totals.packedQty || 0) %></span>
                      </span>
                      <span class="inline-flex items-baseline gap-1 text-[10px] font-bold uppercase tracking-[0.06em] text-rose-100">
                        <span><%= totalPairsSoldLabel %>:</span>
                        <span class="tabular-nums text-white"><%= formatQty(totals.looseQty || 0) %></span>
                      </span>
                    </div>
                  </td>
                <% } else { %>
                  <td colspan="3" class="px-3 py-2">
                    <div class="flex flex-wrap items-center justify-end gap-x-3 gap-y-1">
                      <span class="text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></span>
                      <span class="inline-flex items-baseline gap-1 rounded-md border border-white/20 bg-white/10 px-2.5 py-1 text-[11px] font-extrabold uppercase tracking-[0.06em] text-white">
                        <span class="text-white"><%= totalDozenSoldLabel %>:</span>
                        <span class="font-black tabular-nums text-white"><%= formatQty(totals.packedQty || 0) %></span>
                      </span>
                      <span class="inline-flex items-baseline gap-1 text-[10px] font-bold uppercase tracking-[0.06em] text-rose-100">
                        <span><%= totalPairsSoldLabel %>:</span>
                        <span class="tabular-nums text-white"><%= formatQty(totals.looseQty || 0) %></span>
                      </span>
                    </div>
                  </td>
                <% } %>
                <td class="px-3 py-2 text-right font-extrabold"></td>
                <td class="px-3 py-2"></td>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatMoney(totals.grossAmount || 0) %></td>
                <% if (selectedOrderBy === "voucher") { %>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatMoney(totals.effectivePairDiscount || 0) %></td>
                <% } %>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatMoney(totals.discountAmount || 0) %></td>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatMoney(totals.netAmount || 0) %></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>
      <%- include("../../base/partials/table-footer", { t }) %>
    <% } %>
  </section>
</div>
<script><%- include("../../base/partials/date-range-picker.js") %></script>
<script><%- include("../../base/partials/searchable-select.js") %></script>
<script>(function(){
  if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
  const form = document.querySelector("[data-sales-report-filter-form]");
  if (form && typeof window.initReportDateRangePicker === "function") {
    window.initReportDateRangePicker({
      root: form,
      invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
      selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>
    });
  }

  const advancedFilterToggle = document.querySelector("[data-advanced-filter-toggle]");
  const advancedFilterPanel = document.querySelector("[data-advanced-filter-panel]");
  if (advancedFilterToggle && advancedFilterPanel) {
    advancedFilterToggle.addEventListener("click", () => {
      const expanded = advancedFilterToggle.getAttribute("aria-expanded") === "true";
      advancedFilterToggle.setAttribute("aria-expanded", expanded ? "false" : "true");
      advancedFilterPanel.classList.toggle("hidden", expanded);
    });
  }

  document.querySelector("[data-print-report]")?.addEventListener("click", () => window.print());
  document.querySelector("[data-download-report]")?.addEventListener("click", () => {
    const table = document.querySelector("[data-report-table]");
    if (!table) return;
    const csv = Array.from(table.querySelectorAll("tr"))
      .filter((tr) => !tr.classList.contains("hidden"))
      .map((tr) => Array.from(tr.querySelectorAll("th,td"))
        .map((cell) => `"${String(cell.textContent || "").replace(/\s+/g, " ").trim().replace(/"/g, '""')}"`)
        .join(","))
      .join("\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const link = document.createElement("a");
    link.href = URL.createObjectURL(blob);
    link.download = <%- JSON.stringify(downloadName) %>;
    document.body.appendChild(link);
    link.click();
    link.remove();
    URL.revokeObjectURL(link.href);
  });

  const searchInput = document.querySelector("[data-search-input]");
  const pageSizeSelect = document.querySelector("[data-page-size]");
  const prevButton = document.querySelector("[data-prev-page]");
  const nextButton = document.querySelector("[data-next-page]");
  const pageIndicator = document.querySelector("[data-page-indicator]");
  const showingCount = document.querySelector("[data-showing-count]");
  const detailGroupHeaders = Array.from(document.querySelectorAll("[data-report-group-header]"));
  const grandTotalRows = Array.from(document.querySelectorAll("[data-report-grand-total]"));
  const summaryRows = Array.from(document.querySelectorAll("[data-report-entry]"));
  const isDetailMode = detailGroupHeaders.length > 0;
  if (!pageSizeSelect || !pageIndicator || !showingCount) return;

  let currentPage = 1;

  const getPageSize = () => {
    const raw = String(pageSizeSelect.value || "10").toLowerCase();
    if (raw === "all") return Number.POSITIVE_INFINITY;
    const parsed = Number(raw);
    return Number.isFinite(parsed) && parsed > 0 ? parsed : 10;
  };

  const hideNodes = (nodes) => nodes.forEach((node) => node.classList.add("hidden"));
  const showNodes = (nodes) => nodes.forEach((node) => node.classList.remove("hidden"));

  const getDetailEntries = () => detailGroupHeaders.map((header) => {
    const key = header.getAttribute("data-report-group-key");
    const related = Array.from(document.querySelectorAll("[data-report-group-key]"))
      .filter((node) => node.getAttribute("data-report-group-key") === key);
    return {
      key,
      nodes: related,
      searchText: related.map((node) => String(node.textContent || "")).join(" ").toLowerCase()
    };
  });

  const getSummaryEntries = () => summaryRows.map((row, index) => ({
    key: `summary-${index}`,
    nodes: [row],
    searchText: String(row.textContent || "").toLowerCase()
  }));

  const render = () => {
    const query = String(searchInput?.value || "").trim().toLowerCase();
    const allEntries = isDetailMode ? getDetailEntries() : getSummaryEntries();
    const filteredEntries = query
      ? allEntries.filter((entry) => entry.searchText.includes(query))
      : allEntries;
    const pageSize = getPageSize();

    let totalPages = 1;
    let visibleEntries = filteredEntries;
    let startIndex = 0;

    if (Number.isFinite(pageSize)) {
      totalPages = Math.max(1, Math.ceil(filteredEntries.length / pageSize));
      currentPage = Math.min(currentPage, totalPages);
      startIndex = (currentPage - 1) * pageSize;
      visibleEntries = filteredEntries.slice(startIndex, startIndex + pageSize);
    } else {
      currentPage = 1;
    }

    allEntries.forEach((entry) => hideNodes(entry.nodes));
    visibleEntries.forEach((entry) => showNodes(entry.nodes));

    const hasVisibleEntries = visibleEntries.length > 0;
    grandTotalRows.forEach((row) => {
      row.classList.toggle("hidden", !hasVisibleEntries);
    });

    const startLabel = filteredEntries.length === 0 ? 0 : startIndex + 1;
    const endLabel = filteredEntries.length === 0 ? 0 : startIndex + visibleEntries.length;
    showingCount.textContent = `${<%- JSON.stringify(t("showing")) %>} ${startLabel} ${<%- JSON.stringify(t("to")) %>} ${endLabel} ${<%- JSON.stringify(t("of")) %>} ${filteredEntries.length} ${<%- JSON.stringify(t("entries")) %>}`;
    pageIndicator.textContent = String(currentPage);

    if (prevButton) {
      prevButton.disabled = currentPage <= 1;
      prevButton.classList.toggle("opacity-40", currentPage <= 1);
    }
    if (nextButton) {
      nextButton.disabled = currentPage >= totalPages;
      nextButton.classList.toggle("opacity-40", currentPage >= totalPages);
    }
  };

  searchInput?.addEventListener("input", () => {
    currentPage = 1;
    render();
  });
  pageSizeSelect.addEventListener("change", () => {
    currentPage = 1;
    render();
  });
  prevButton?.addEventListener("click", () => {
    if (currentPage <= 1) return;
    currentPage -= 1;
    render();
  });
  nextButton?.addEventListener("click", () => {
    currentPage += 1;
    render();
  });

  render();
})();</script>
