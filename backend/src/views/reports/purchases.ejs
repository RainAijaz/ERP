<script><%- include("../base/partials/date-range-picker.js") %></script>

<script>
  (function () {
    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }

    const form = document.querySelector("[data-purchase-report-filter-form]");
    if (!form) return;

    if (typeof window.initReportDateRangePicker === "function") {
      window.initReportDateRangePicker({
        root: form,
        invalidDateRangeMessage: <%- JSON.stringify(t("invalid_date_range")) %>,
        selectDateRangeText: <%- JSON.stringify(t("select_date_range")) %>,
      });
    }

    const allMultiValue = <%- JSON.stringify(allMultiOptionValue) %>;
    const allMultiSelects = Array.from(form.querySelectorAll('select[data-all-multi-select="true"]'));
    const setPrevSelectionState = (select) => {
      const options = Array.from(select?.options || []);
      const selectedValues = options.filter((option) => option.selected).map((option) => option.value);
      const hasAll = selectedValues.includes(allMultiValue);
      if (select) select.dataset.prevHasAll = hasAll ? "1" : "0";
    };
    const normalizeAllSelection = (select, useIntent = false) => {
      if (!select) return;
      const options = Array.from(select.options || []);
      const allOption = options.find((option) => option.value === allMultiValue);
      if (!allOption) return;

      const selectedValues = options.filter((option) => option.selected).map((option) => option.value);
      const hasSpecific = selectedValues.some((value) => value !== allMultiValue);
      const hasAll = selectedValues.includes(allMultiValue);
      const prevHasAll = String(select.dataset.prevHasAll || "0") === "1";

      if (hasSpecific && hasAll) {
        if (useIntent && prevHasAll) {
          allOption.selected = false;
        } else {
          options.forEach((option) => {
            if (option.value !== allMultiValue) option.selected = false;
          });
          allOption.selected = true;
        }
      } else if (!hasSpecific && !hasAll) {
        allOption.selected = true;
      }

      setPrevSelectionState(select);
    };

    allMultiSelects.forEach((select) => {
      normalizeAllSelection(select);
      setPrevSelectionState(select);
      select.addEventListener("focus", () => setPrevSelectionState(select));
      select.addEventListener("change", () => normalizeAllSelection(select, true));
    });

    const purchaseCategoryInputs = Array.from(form.querySelectorAll('input[data-purchase-category-filter][name="purchase_category"]'));
    const rawMaterialFilterRows = Array.from(form.querySelectorAll("[data-rm-filter-row]"));
    const orderByProductLabel = form.querySelector("[data-order-by-product-label]");
    const entityLabels = {
      all: <%- JSON.stringify(t("item")) %>,
      raw_material: <%- JSON.stringify(t("raw_material")) %>,
      asset: <%- JSON.stringify(t("asset")) %>,
    };
    const resetSelectToAll = (select) => {
      if (!select) return;
      const options = Array.from(select.options || []);
      const allOption = options.find((option) => option.value === allMultiValue);
      if (!allOption) return;
      options.forEach((option) => {
        option.selected = option.value === allMultiValue;
      });
      normalizeAllSelection(select, false);
    };
    const syncPurchaseCategoryVisibility = () => {
      const selectedCategory = String(
        purchaseCategoryInputs.find((input) => input.checked)?.value || "all",
      ).toLowerCase();
      const showRawMaterialFilters = selectedCategory !== "asset";
      rawMaterialFilterRows.forEach((row) => {
        row.classList.toggle("hidden", !showRawMaterialFilters);
        if (!showRawMaterialFilters) {
          const select = row.querySelector("select[data-all-multi-select='true']");
          resetSelectToAll(select);
        }
      });
      if (orderByProductLabel) {
        orderByProductLabel.textContent =
          entityLabels[selectedCategory] || entityLabels.all;
      }
    };

    const purchaseTypeInputs = Array.from(form.querySelectorAll('input[data-purchase-type-filter][name="purchase_type"]'));
    const cashAccountWrap = form.querySelector("[data-cash-account-filter]");
    const cashAccountSelect = cashAccountWrap?.querySelector('select[name="cash_paid_account_id"]');

    const syncCashAccountVisibility = () => {
      const selectedType = String(purchaseTypeInputs.find((input) => input.checked)?.value || "all").toLowerCase();
      const show = selectedType === "cash";
      if (cashAccountWrap) cashAccountWrap.classList.toggle("hidden", !show);
      if (!show && cashAccountSelect) cashAccountSelect.value = "";
    };

    purchaseCategoryInputs.forEach((input) =>
      input.addEventListener("change", syncPurchaseCategoryVisibility),
    );
    syncPurchaseCategoryVisibility();

    purchaseTypeInputs.forEach((input) => input.addEventListener("change", syncCashAccountVisibility));
    syncCashAccountVisibility();

    form.addEventListener("submit", () => {
      allMultiSelects.forEach((select) => normalizeAllSelection(select));
    });

    document.querySelector("[data-print-report]")?.addEventListener("click", () => window.print());

    document.querySelector("[data-download-report]")?.addEventListener("click", () => {
      const table = document.querySelector("[data-report-table]");
      if (!table) return;
      const rows = Array.from(table.querySelectorAll("tr"));
      const csv = rows
        .map((tr) =>
          Array.from(tr.querySelectorAll("th,td"))
            .map((cell) => `"${String(cell.textContent || "").replace(/\s+/g, " ").trim().replace(/"/g, '""')}"`)
            .join(","),
        )
        .join("\n");

      const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = "purchase-report.csv";
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(link.href);
    });
  })();
</script>



