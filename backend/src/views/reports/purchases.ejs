<%
  const orderBy = String(filters?.orderBy || "party").toLowerCase();
  const reportType = String(filters?.reportType || "details").toLowerCase();
  const purchaseType = String(filters?.purchaseType || "all").toLowerCase();
  const purchaseCategory = String(filters?.purchaseCategory || "all").toLowerCase();
  const reportLoaded = Boolean(filters?.reportLoaded);
  const groups = Array.isArray(reportData?.groups) ? reportData.groups : [];
  const summaryRows = Array.isArray(reportData?.summaryRows) ? reportData.summaryRows : [];
  const grandTotalQty = Number(reportData?.grandTotalQty || 0);
  const grandTotalAmount = Number(reportData?.grandTotalAmount || 0);
  const grandAvgRate = Number(reportData?.grandAvgRate || 0);
  const grandAvgFixedPurchaseRate = Number(reportData?.grandAvgFixedPurchaseRate || 0);
  const grandAvgWeightedAverageRate = Number(reportData?.grandAvgWeightedAverageRate || 0);
  const grandAvgVarianceAmount = Number(reportData?.grandAvgVarianceAmount || 0);
  const grandAvgVariancePercent = Number(reportData?.grandAvgVariancePercent || 0);
  const isGrandRateDifferenceHigh = Boolean(reportData?.isGrandRateDifferenceHigh);
  const rateAlertPercent = Number(reportData?.rateAlertPercent || 10);
  const hasData = reportType === "summary" ? summaryRows.length > 0 : groups.length > 0;
  const selectedGroupIds = Array.isArray(filters?.groupIds) ? filters.groupIds : [];
  const selectedSubgroupIds = Array.isArray(filters?.subgroupIds) ? filters.subgroupIds : [];
  const selectedCashAccountId = Number(filters?.cashAccountId || 0) || null;
  const allMultiOptionValue = "__ALL__";
  const partyAllSelected = !Array.isArray(filters?.partyIds) || filters.partyIds.length === 0;
  const rawMaterialAllSelected = !Array.isArray(filters?.rawMaterialIds) || filters.rawMaterialIds.length === 0;
  const branchAllSelected = !Array.isArray(filters?.branchIds) || filters.branchIds.length === 0;
  const groupAllSelected = !selectedGroupIds.length;
  const subgroupAllSelected = !selectedSubgroupIds.length;
  const isAssetCategory = purchaseCategory === "asset";
  const entityLabel = purchaseCategory === "asset"
    ? t("asset")
    : purchaseCategory === "raw_material"
      ? t("raw_material")
      : t("item");
  const dateRangeLabel = (() => {
    const value = typeof t === "function" ? t("date_range") : "";
    return value || "Date Range";
  })();
  const weekdayShortLabels = [
    t("weekday_sun_short"),
    t("weekday_mon_short"),
    t("weekday_tue_short"),
    t("weekday_wed_short"),
    t("weekday_thu_short"),
    t("weekday_fri_short"),
    t("weekday_sat_short"),
  ];

  const formatDate = (value) => {
    return formatDateDisplay(value, "-");
  };
  const formatNumber = (value, digits = 2) => {
    return formatNumberDisplay(value, { decimals: digits, fallback: "0" });
  };
  const headerTooltip = (key) => {
    const value = t(key);
    return value && value !== key ? value : "";
  };
  const splitGroupLabel = (value) => {
    const text = String(value || "").trim();
    if (!text) return ["-"];
    const parts = text.split("|").map((part) => String(part || "").trim()).filter(Boolean);
    return parts.length ? parts : [text];
  };
  const distinctCount = (rows, key) => {
    const set = new Set();
    (rows || []).forEach((row) => {
      const value = row?.[key];
      if (value !== null && value !== undefined && String(value).trim() !== "") set.add(String(value));
    });
    return set.size;
  };
  const detailColumnCount = 12;
  const detailTotalsLabelSpan = 4;
  const reportPurposeTooltip = (() => {
    const key = "purchase_reports_purpose_tooltip";
    const value = t(key);
    return value && value !== key ? value : "";
  })();
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= t("purchase_reports") %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= t("date_filters_auto_corrected") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-purchase-report-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= dateRangeLabel %></label>
          <div class="sm:col-span-9">
            <div class="relative" data-date-range-wrap>
              <input
                type="text"
                readonly
                value="<%= `${filters?.from || ''} - ${filters?.to || ''}` %>"
                data-date-range-input
                class="h-10 w-full cursor-pointer rounded-lg border border-slate-300 bg-white px-3 pr-10 text-sm"
              >
              <button type="button" class="absolute inset-y-0 right-2 inline-flex items-center text-slate-500 hover:text-slate-700" data-date-range-toggle aria-label="<%= t('open_date_range_picker') %>">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </button>
              <div class="absolute left-0 z-50 mt-2 hidden max-h-[62vh] overflow-auto rounded-xl border border-slate-200 bg-white p-2.5 shadow-lg" style="width:min(700px,calc(100vw - 1rem));" data-date-range-panel>
                <div class="grid grid-cols-1 gap-2 lg:grid-cols-[156px_1fr]">
                  <div class="space-y-1.5">
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('from_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-from-display>-</div>
                    </div>
                    <div>
                      <div class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t('to_date') %></div>
                      <div class="mt-1 rounded-lg border border-slate-200 bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-700" data-date-range-to-display>-</div>
                    </div>
                  </div>
                  <div>
                    <div class="mb-1.5 text-center text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600" data-date-range-caption><%= t('select_date_range') %></div>
                    <div class="grid grid-cols-1 gap-3 xl:grid-cols-[1fr_auto_1fr]">
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-1-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-1-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <% weekdayShortLabels.forEach((weekdayLabel) => { %>
                            <span><%= weekdayLabel %></span>
                          <% }) %>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-1-grid></div>
                      </div>
                      <div class="hidden xl:block w-px bg-slate-200 self-stretch"></div>
                      <div class="min-w-[210px] rounded-lg border border-slate-200 bg-slate-50/40 p-2">
                        <div class="mb-1 flex items-center justify-between gap-2">
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-prev>&larr;</button>
                          <div class="text-center text-xs font-semibold text-slate-700" data-date-range-month-2-label></div>
                          <button type="button" class="rounded-md border border-slate-300 px-2 py-0.5 text-xs font-semibold text-slate-700" data-date-range-month-2-next>&rarr;</button>
                        </div>
                        <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold uppercase text-slate-500">
                          <% weekdayShortLabels.forEach((weekdayLabel) => { %>
                            <span><%= weekdayLabel %></span>
                          <% }) %>
                        </div>
                        <div class="mt-1 grid grid-cols-7 gap-1" data-date-range-month-2-grid></div>
                      </div>
                    </div>
                  </div>
                </div>
                <div class="mt-1.5 flex items-center justify-end gap-2">
                  <button type="button" class="rounded-lg border border-slate-300 bg-white px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-date-range-cancel><%= t('cancel') %></button>
                  <button type="button" class="rounded-lg bg-accent px-3 py-1.25 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-date-range-apply><%= t('apply') %></button>
                </div>
              </div>
            </div>
            <input type="hidden" name="from_date" value="<%= filters?.from || '' %>" data-from-date-hidden>
            <input type="hidden" name="to_date" value="<%= filters?.to || '' %>" data-to-date-hidden>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("party_name") %></label>
          <div class="sm:col-span-9">
            <select name="party_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= partyAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.suppliers || []).forEach((supplier) => { %>
                <option value="<%= supplier.id %>" <%= (filters?.partyIds || []).includes(Number(supplier.id)) ? "selected" : "" %>><%= supplier.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("category") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseCategory === 'all' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_category" value="all" data-purchase-category-filter <%= purchaseCategory === "all" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("all") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseCategory === 'raw_material' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_category" value="raw_material" data-purchase-category-filter <%= purchaseCategory === "raw_material" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("raw_material") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseCategory === 'asset' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_category" value="asset" data-purchase-category-filter <%= purchaseCategory === "asset" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("asset") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= isAssetCategory ? 'hidden' : '' %>" data-rm-filter-row>
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("raw_material") %></label>
          <div class="sm:col-span-9">
            <select name="raw_material_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= rawMaterialAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.rawMaterials || []).forEach((item) => { %>
                <option value="<%= item.id %>" <%= (filters?.rawMaterialIds || []).includes(Number(item.id)) ? "selected" : "" %>><%= item.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= isAssetCategory ? 'hidden' : '' %>" data-rm-filter-row>
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("group") %></label>
          <div class="sm:col-span-9">
            <select name="raw_material_group_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= groupAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.groups || []).forEach((group) => { %>
                <option value="<%= group.id %>" <%= selectedGroupIds.includes(Number(group.id)) ? "selected" : "" %>><%= group.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= isAssetCategory ? 'hidden' : '' %>" data-rm-filter-row>
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("sub_group") %></label>
          <div class="sm:col-span-9">
            <select name="raw_material_subgroup_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= subgroupAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.subgroups || []).forEach((subgroup) => { %>
                <option value="<%= subgroup.id %>" <%= selectedSubgroupIds.includes(Number(subgroup.id)) ? "selected" : "" %>><%= subgroup.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? t("branches") : t("branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= (filters?.branchIds || []).includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("order_by") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= orderBy === 'party' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="party" <%= orderBy === "party" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("party_name") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= orderBy === 'invoice' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="invoice" <%= orderBy === "invoice" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("voucher_no") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= orderBy === 'product' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="order_by" value="product" <%= orderBy === "product" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span data-order-by-product-label><%= entityLabel %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("report_type") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= reportType === 'details' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="details" <%= reportType === "details" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("details") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= reportType === 'summary' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="report_type" value="summary" <%= reportType === "summary" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("summary") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= t("purchase_type") %></label>
          <div class="sm:col-span-9 grid grid-cols-1 gap-2 lg:grid-cols-[minmax(220px,1fr)_minmax(260px,1fr)]">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseType === 'all' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_type" value="all" data-purchase-type-filter <%= purchaseType === "all" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("all") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseType === 'cash' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_type" value="cash" data-purchase-type-filter <%= purchaseType === "cash" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("cash_purchase") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= purchaseType === 'credit' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="purchase_type" value="credit" data-purchase-type-filter <%= purchaseType === "credit" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("credit_purchase") %></span>
              </label>
            </div>
            <div class="<%= purchaseType === 'cash' ? '' : 'hidden' %>" data-cash-account-filter>
              <span class="mb-1 block text-xs font-semibold uppercase tracking-[0.08em] text-slate-700"><%= t("cash_paid_account") %></span>
              <select name="cash_paid_account_id" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value=""><%= t("all") %></option>
                <% (options?.cashAccounts || []).forEach((account) => { %>
                  <option value="<%= account.id %>" <%= selectedCashAccountId === Number(account.id) ? "selected" : "" %>><%= account.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-center gap-2 pt-1 sm:grid-cols-12">
          <div class="sm:col-start-4 sm:col-span-9 flex items-center gap-2">
            <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-report-print-area>
    <div class="flex items-center justify-end gap-2" data-report-controls>
      <button type="button" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 disabled:opacity-40" data-print-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
      <button type="button" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" data-download-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
    </div>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <div class="mt-3 rounded-xl border border-rose-200 bg-rose-50/60 px-3 py-2 text-xs font-semibold text-rose-700">
