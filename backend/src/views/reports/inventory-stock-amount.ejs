<%
  const tt = (key, fallback) => {
    const value = typeof t === "function" ? t(key) : "";
    return value && value !== key ? value : fallback;
  };

  const resolvedReportMeta =
    typeof reportMeta !== "undefined" && reportMeta ? reportMeta : {};
  const includeAmounts = resolvedReportMeta.includeAmounts !== false;
  const showRateTypeFilter = resolvedReportMeta.showRateTypeFilter !== false;
  const reportTitleKey = String(resolvedReportMeta.titleKey || "stock_amount_report");
  const reportTitleFallback = String(resolvedReportMeta.titleFallback || "Stock Amount Report");
  const downloadFileName = String(resolvedReportMeta.downloadFileName || "stock-amount-report.csv");
  const reportPurposeTooltip = (() => {
    const key = `${reportTitleKey}_purpose_tooltip`;
    const value = t(key);
    return value && value !== key ? value : "";
  })();

  const reportLoaded = Boolean(filters?.reportLoaded);
  const stockType = String(filters?.stockType || "FG").toUpperCase();
  const stockStatus = String(filters?.stockStatus || "PACKED").toUpperCase() === "LOOSE" ? "LOOSE" : "PACKED";
  const rateType = String(filters?.rateType || "SALE").toUpperCase() === "COST" ? "COST" : "SALE";
  const viewType = String(filters?.viewType || "details").toLowerCase() === "summary" ? "summary" : "details";
  const asOfDate = String(filters?.asOfDate || "");
  const selectedBranchIds = Array.isArray(filters?.branchIds) ? filters.branchIds : [];
  const selectedGroupIds = Array.isArray(filters?.productGroupIds) ? filters.productGroupIds : [];
  const selectedSubgroupIds = Array.isArray(filters?.productSubgroupIds) ? filters.productSubgroupIds : [];
  const selectedUnitId = Number(filters?.unitId || 0) || null;
  const allMultiOptionValue = "__ALL__";

  const branchAllSelected = !selectedBranchIds.length;
  const groupAllSelected = !selectedGroupIds.length;
  const subgroupAllSelected = !selectedSubgroupIds.length;
  const includeBranchColumn = Boolean(user?.isAdmin) && selectedBranchIds.length !== 1;

  const showFgSfgSection = stockType === "FG" || stockType === "SFG";
  const showRmSection = stockType === "RM";
  const isRmOnly = stockType === "RM";

  const fgSfgDetailRows = Array.isArray(reportData?.fgSfgDetailRows) ? reportData.fgSfgDetailRows : [];
  const rmDetailRows = Array.isArray(reportData?.rmDetailRows) ? reportData.rmDetailRows : [];
  const fgSfgSummaryRows = Array.isArray(reportData?.fgSfgSummaryRows) ? reportData.fgSfgSummaryRows : [];
  const rmSummaryRows = Array.isArray(reportData?.rmSummaryRows) ? reportData.rmSummaryRows : [];

  const hasData = viewType === "summary"
    ? ((showFgSfgSection && fgSfgSummaryRows.length > 0) || (showRmSection && rmSummaryRows.length > 0))
    : ((showFgSfgSection && fgSfgDetailRows.length > 0) || (showRmSection && rmDetailRows.length > 0));

  const formatQty = (value) => formatNumberDisplay(value, { decimals: 3, fallback: "0" });
  const formatRate = (value) => formatNumberDisplay(value, { decimals: 4, fallback: "0" });
  const formatAmount = (value) => formatNumberDisplay(value, { decimals: 2, fallback: "0" });

  const rmSummaryTotalQty = rmSummaryRows.reduce((sum, row) => sum + Number(row?.quantity || 0), 0);
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-xl font-display font-semibold tracking-tight text-ink sm:text-2xl"><%= tt(reportTitleKey, reportTitleFallback) %></h1>
      <% if (reportPurposeTooltip) { %>
        <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-slate-300 bg-white text-[10px] font-bold text-slate-600 cursor-help" title="<%= reportPurposeTooltip %>" aria-label="<%= reportPurposeTooltip %>">i</span>
      <% } %>
    </div>
    <% if (filters?.invalidFilterInput) { %>
      <div class="mt-2 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800"><%= tt("date_filters_auto_corrected", "Some date filters were invalid and have been reset.") %></div>
    <% } %>

    <form method="post" action="<%= reportPath %>" class="mt-3 max-w-6xl rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-inventory-stock-filter-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="space-y-3">
        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("as_on", "As On") %></label>
          <div class="sm:col-span-9">
            <input
              type="date"
              name="as_of_date"
              value="<%= asOfDate %>"
              class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm"
            >
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("stock_type", "Stock Type") %></label>
          <div class="sm:col-span-9">
            <select name="stock_type" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <% (options?.stockTypes || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === stockType ? "selected" : "" %>><%= t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12 <%= stockType === 'FG' ? '' : 'hidden' %>" data-finished-status-filter-row>
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("status", "Status") %></label>
          <div class="sm:col-span-9">
            <select name="stock_status" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" <%= stockType === "FG" ? "" : "disabled" %>>
              <% (options?.stockStatuses || []).forEach((option) => { %>
                <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === stockStatus ? "selected" : "" %>><%= t(option.labelKey) %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("product_groups", "Product Groups") %></label>
          <div class="sm:col-span-9">
            <select name="product_group_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= groupAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.productGroups || []).forEach((group) => { %>
                <option value="<%= group.id %>" <%= selectedGroupIds.includes(Number(group.id)) ? "selected" : "" %>><%= group.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("product_subgroups", "Product Sub-Groups") %></label>
          <div class="sm:col-span-9">
            <select name="product_subgroup_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
              <option value="<%= allMultiOptionValue %>" <%= subgroupAllSelected ? "selected" : "" %>><%= t("all") %></option>
              <% (options?.productSubgroups || []).forEach((subgroup) => { %>
                <option value="<%= subgroup.id %>" <%= selectedSubgroupIds.includes(Number(subgroup.id)) ? "selected" : "" %>><%= subgroup.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("units", "Units") %></label>
          <div class="sm:col-span-9">
            <select name="unit_id" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" <%= isRmOnly ? "disabled" : "" %>>
              <option value=""><%= t("all") %></option>
              <% (options?.units || []).forEach((unit) => { %>
                <option value="<%= unit.id %>" <%= selectedUnitId === Number(unit.id) ? "selected" : "" %>><%= unit.code || unit.name %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= user?.isAdmin ? tt("branches", "Branches") : tt("branch", "Branch") %></label>
          <div class="sm:col-span-9">
            <% if (user?.isAdmin) { %>
              <select name="branch_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <option value="<%= allMultiOptionValue %>" <%= branchAllSelected ? "selected" : "" %>><%= t("all") %></option>
                <% (options?.branches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= selectedBranchIds.includes(Number(branch.id)) ? "selected" : "" %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" readonly value="<%= (options?.branches || [])[0]?.name || branchId %>" class="h-10 w-full rounded-lg border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700">
            <% } %>
          </div>
        </div>

        <% if (showRateTypeFilter) { %>
          <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
            <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("rate_type", "Rate Type") %></label>
            <div class="sm:col-span-9">
              <select name="rate_type" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
                <% (options?.rateTypes || []).forEach((option) => { %>
                  <option value="<%= option.value %>" <%= String(option.value || "").toUpperCase() === rateType ? "selected" : "" %>><%= t(option.labelKey) %></option>
                <% }) %>
              </select>
            </div>
          </div>
        <% } %>

        <div class="grid grid-cols-1 items-start gap-1.5 sm:grid-cols-12">
          <label class="text-sm font-semibold text-slate-700 sm:col-span-3"><%= tt("view_filter", "View Filter") %></label>
          <div class="sm:col-span-9">
            <div class="flex flex-wrap gap-2 rounded-xl bg-white/60 p-1">
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= viewType === 'details' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="view_filter" value="details" <%= viewType === "details" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("details") %></span>
              </label>
              <label class="inline-flex cursor-pointer items-center gap-2 rounded-lg px-1 py-1 text-sm <%= viewType === 'summary' ? 'font-semibold text-accent' : 'font-medium text-slate-700 hover:text-accent' %>">
                <input type="radio" name="view_filter" value="summary" <%= viewType === "summary" ? "checked" : "" %> class="h-4 w-4 text-accent focus:ring-accent">
                <span><%= t("summary") %></span>
              </label>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 items-center gap-2 pt-1 sm:grid-cols-12">
          <div class="sm:col-start-4 sm:col-span-9 flex items-center gap-2">
            <button type="submit" class="inline-flex items-center rounded-lg bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
            <a href="<%= reportPath %>" class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
          </div>
        </div>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm" data-report-print-area>
    <div class="flex items-center justify-end gap-2" data-report-controls>
      <button type="button" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 disabled:opacity-40" data-print-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("print") %></button>
      <button type="button" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" data-download-report <%= reportLoaded && hasData ? "" : "disabled" %>><%= t("download") %></button>
    </div>

    <% if (!reportLoaded) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= tt("load_report_to_view", "Load report to view") %></div>
    <% } else if (!hasData) { %>
      <div class="mt-4 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= tt("no_entries", "No entries") %></div>
    <% } else if (viewType === "details") { %>

      <% if (showFgSfgSection && fgSfgDetailRows.length) { %>
        <div class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= tt("finished", "Finished") %>/<%= tt("semi_finished", "Semi-Finished") %></div>
        <div class="relative mt-2 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[980px] w-full text-sm tabular-nums" data-report-table data-export-title="<%= `${tt(reportTitleKey, reportTitleFallback)} - ${tt("finished", "Finished")}/${tt("semi_finished", "Semi-Finished")} (${tt("details", "Details")})` %>">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("sku", "SKU") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("article", "Article") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("units", "Units") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("quantity") %></th>
                <% if (includeAmounts) { %>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("rate") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("total_amount", "Total Amount") %></th>
                <% } %>
                <% if (includeBranchColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("branch", "Branch") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% fgSfgDetailRows.forEach((row) => { %>
                <tr class="bg-white odd:bg-slate-50 even:bg-white hover:bg-slate-100">
                  <td class="px-3 py-2"><%= row.sku_code || "-" %></td>
                  <td class="px-3 py-2"><%= row.article_name || "-" %></td>
                  <td class="px-3 py-2"><%= row.unit_label || "-" %></td>
                  <td class="px-3 py-2 text-right font-semibold"><%= formatQty(row.quantity) %></td>
                  <% if (includeAmounts) { %>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatRate(row.rate) %></td>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatAmount(row.amount) %></td>
                  <% } %>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"><%= row.branch_name || "-" %></td>
                  <% } %>
                </tr>
              <% }) %>

              <% if (includeAmounts) { %>
                <tr class="bg-rose-700 text-white">
                  <td colspan="<%= 3 + (includeBranchColumn ? 1 : 0) %>" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(reportData?.totals?.fgSfgQuantity || 0) %></td>
                  <td class="px-3 py-2"></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(reportData?.totals?.fgSfgAmount || 0) %></td>
                </tr>
              <% } else { %>
                <tr class="bg-rose-700 text-white">
                  <td colspan="3" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(reportData?.totals?.fgSfgQuantity || 0) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"></td>
                  <% } %>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (showRmSection && rmDetailRows.length) { %>
        <div class="mt-4 text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= tt("raw_materials", "Raw Materials") %></div>
        <div class="relative mt-2 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[1080px] w-full text-sm tabular-nums" data-report-table data-export-title="<%= `${tt(reportTitleKey, reportTitleFallback)} - ${tt("raw_materials", "Raw Materials")} (${tt("details", "Details")})` %>">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("raw_material", "Raw Material") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("color", "Color") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("size", "Size") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("units", "Units") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("quantity") %></th>
                <% if (includeAmounts) { %>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("rate") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("total_amount", "Total Amount") %></th>
                <% } %>
                <% if (includeBranchColumn) { %>
                  <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("branch", "Branch") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% rmDetailRows.forEach((row) => { %>
                <tr class="bg-white odd:bg-slate-50 even:bg-white hover:bg-slate-100">
                  <td class="px-3 py-2"><%= row.item_name || "-" %></td>
                  <td class="px-3 py-2"><%= row.color_name || "-" %></td>
                  <td class="px-3 py-2"><%= row.size_name || "-" %></td>
                  <td class="px-3 py-2"><%= row.unit_label || "-" %></td>
                  <td class="px-3 py-2 text-right font-semibold"><%= formatQty(row.quantity) %></td>
                  <% if (includeAmounts) { %>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatRate(row.rate) %></td>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatAmount(row.amount) %></td>
                  <% } %>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"><%= row.branch_name || "-" %></td>
                  <% } %>
                </tr>
              <% }) %>

              <% if (includeAmounts) { %>
                <tr class="bg-rose-700 text-white">
                  <td colspan="<%= 4 + (includeBranchColumn ? 1 : 0) %>" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(reportData?.totals?.rmQuantity || 0) %></td>
                  <td class="px-3 py-2"></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(reportData?.totals?.rmAmount || 0) %></td>
                </tr>
              <% } else { %>
                <tr class="bg-rose-700 text-white">
                  <td colspan="4" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(reportData?.totals?.rmQuantity || 0) %></td>
                  <% if (includeBranchColumn) { %>
                    <td class="px-3 py-2"></td>
                  <% } %>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>

    <% } else { %>

      <% if (showFgSfgSection && fgSfgSummaryRows.length) { %>
        <div class="mt-3 text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= tt("finished", "Finished") %>/<%= tt("semi_finished", "Semi-Finished") %></div>
        <div class="relative mt-2 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[920px] w-full text-sm tabular-nums" data-report-table data-export-title="<%= `${tt(reportTitleKey, reportTitleFallback)} - ${tt("finished", "Finished")}/${tt("semi_finished", "Semi-Finished")} (${tt("summary", "Summary")})` %>">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("article", "Article") %></th>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("units", "Units") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("quantity") %></th>
                <% if (includeAmounts) { %>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("rate") %></th>
                  <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("total_amount", "Total Amount") %></th>
                <% } %>
              </tr>
            </thead>
            <tbody>
              <% fgSfgSummaryRows.forEach((row) => { %>
                <tr class="bg-white odd:bg-slate-50 even:bg-white hover:bg-slate-100">
                  <td class="px-3 py-2"><%= row.article_name || "-" %></td>
                  <td class="px-3 py-2"><%= row.unit_label || "-" %></td>
                  <td class="px-3 py-2 text-right font-semibold"><%= formatQty(row.quantity) %></td>
                  <% if (includeAmounts) { %>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatRate(row.rate) %></td>
                    <td class="px-3 py-2 text-right font-semibold"><%= formatAmount(row.amount) %></td>
                  <% } %>
                </tr>
              <% }) %>

              <% if (includeAmounts) { %>
                <tr class="bg-rose-700 text-white">
                  <td colspan="2" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(reportData?.totals?.fgSfgQuantity || 0) %></td>
                  <td class="px-3 py-2"></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatAmount(reportData?.totals?.fgSfgAmount || 0) %></td>
                </tr>
              <% } else { %>
                <tr class="bg-rose-700 text-white">
                  <td colspan="2" class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                  <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(reportData?.totals?.fgSfgQuantity || 0) %></td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (showRmSection && rmSummaryRows.length) { %>
        <div class="mt-4 text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= tt("raw_materials", "Raw Materials") %></div>
        <div class="relative mt-2 overflow-x-auto rounded-2xl border border-slate-200">
          <table class="min-w-[520px] w-full text-sm tabular-nums" data-report-table data-export-title="<%= `${tt(reportTitleKey, reportTitleFallback)} - ${tt("raw_materials", "Raw Materials")} (${tt("summary", "Summary")})` %>">
            <thead class="bg-slate-100 text-slate-700">
              <tr>
                <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= tt("raw_material", "Raw Material") %></th>
                <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= t("quantity") %></th>
              </tr>
            </thead>
            <tbody>
              <% rmSummaryRows.forEach((row) => { %>
                <tr class="bg-white odd:bg-slate-50 even:bg-white hover:bg-slate-100">
                  <td class="px-3 py-2"><%= row.item_name || "-" %></td>
                  <td class="px-3 py-2 text-right font-semibold"><%= formatQty(row.quantity) %></td>
                </tr>
              <% }) %>
              <tr class="bg-rose-700 text-white">
                <td class="px-3 py-2 text-right text-xs font-extrabold uppercase tracking-[0.08em]"><%= t("grand_total") %></td>
                <td class="px-3 py-2 text-right font-extrabold"><%= formatQty(rmSummaryTotalQty) %></td>
              </tr>
            </tbody>
          </table>
        </div>
      <% } %>

    <% } %>
  </section>
</div>

<script><%- include("../base/partials/searchable-select.js") %></script>
<script>
  (function () {
    const form = document.querySelector("[data-inventory-stock-filter-form]");
    if (!form) return;

    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }

    const allMultiValue = <%- JSON.stringify(allMultiOptionValue) %>;
    const allMultiSelects = Array.from(form.querySelectorAll('select[data-all-multi-select="true"]'));
    const setPrevSelectionState = (select) => {
      const options = Array.from(select?.options || []);
      const selectedValues = options.filter((option) => option.selected).map((option) => option.value);
      const hasAll = selectedValues.includes(allMultiValue);
      if (select) select.dataset.prevHasAll = hasAll ? "1" : "0";
    };
    const normalizeAllSelection = (select, useIntent = false) => {
      if (!select) return;
      const options = Array.from(select.options || []);
      const allOption = options.find((option) => option.value === allMultiValue);
      if (!allOption) return;

      const selectedValues = options.filter((option) => option.selected).map((option) => option.value);
      const hasSpecific = selectedValues.some((value) => value !== allMultiValue);
      const hasAll = selectedValues.includes(allMultiValue);
      const prevHasAll = String(select.dataset.prevHasAll || "0") === "1";

      if (hasSpecific && hasAll) {
        if (useIntent && prevHasAll) {
          allOption.selected = false;
        } else {
          options.forEach((option) => {
            if (option.value !== allMultiValue) option.selected = false;
          });
          allOption.selected = true;
        }
      } else if (!hasSpecific && !hasAll) {
        allOption.selected = true;
      }

      setPrevSelectionState(select);
    };

    allMultiSelects.forEach((select) => {
      normalizeAllSelection(select);
      setPrevSelectionState(select);
      select.addEventListener("focus", () => setPrevSelectionState(select));
      select.addEventListener("change", () => normalizeAllSelection(select, true));
    });

    const stockTypeSelect = form.querySelector('select[name="stock_type"]');
    const unitSelect = form.querySelector('select[name="unit_id"]');
    const statusFilterRow = form.querySelector("[data-finished-status-filter-row]");
    const statusSelect = form.querySelector('select[name="stock_status"]');
    const syncStockTypeDependentState = () => {
      if (!stockTypeSelect || !unitSelect) return;
      const currentStockType = String(stockTypeSelect.value || "").toUpperCase();
      const isFg = currentStockType === "FG";
      const isRm = String(stockTypeSelect.value || "").toUpperCase() === "RM";

      unitSelect.disabled = isRm;
      if (isRm) unitSelect.value = "";

      if (statusFilterRow) {
        statusFilterRow.classList.toggle("hidden", !isFg);
      }
      if (statusSelect) {
        statusSelect.disabled = !isFg;
        if (!isFg) statusSelect.value = "PACKED";
      }
    };
    stockTypeSelect?.addEventListener("change", syncStockTypeDependentState);
    syncStockTypeDependentState();

    form.addEventListener("submit", () => {
      allMultiSelects.forEach((select) => normalizeAllSelection(select));
    });

    document.querySelector("[data-print-report]")?.addEventListener("click", () => window.print());

    document.querySelector("[data-download-report]")?.addEventListener("click", () => {
      const tables = Array.from(document.querySelectorAll("[data-report-table]"));
      if (!tables.length) return;

      const csvBlocks = tables.map((table) => {
        const lines = [];
        const title = String(table.getAttribute("data-export-title") || "").trim();
        if (title) lines.push(`"${title.replace(/"/g, '""')}"`);
        Array.from(table.querySelectorAll("tr")).forEach((row) => {
          const cells = Array.from(row.querySelectorAll("th,td")).map((cell) =>
            `"${String(cell.textContent || "").replace(/\s+/g, " ").trim().replace(/"/g, '""')}"`,
          );
          if (cells.length) lines.push(cells.join(","));
        });
        return lines.join("\n");
      });

      const blob = new Blob([csvBlocks.join("\n\n")], { type: "text/csv;charset=utf-8;" });
      const link = document.createElement("a");
      link.href = URL.createObjectURL(blob);
      link.download = <%- JSON.stringify(downloadFileName) %>;
      document.body.appendChild(link);
      link.click();
      link.remove();
      URL.revokeObjectURL(link.href);
    });
  })();
</script>
