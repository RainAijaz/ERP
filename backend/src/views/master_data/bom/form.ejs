<%
  const isEdit = formMode === "edit";
  const header = formState?.header || {};
  const selectedLevel = String(header.level || "").toUpperCase();
  const selectedItemType = selectedLevel === "SEMI_FINISHED" ? "SFG" : selectedLevel === "FINISHED" ? "FG" : null;
  const selectedItemId = Number(header.item_id || 0);
  const initialOutputUoms =
    (options?.itemOutputUomMap && Array.isArray(options.itemOutputUomMap[String(selectedItemId)]))
      ? options.itemOutputUomMap[String(selectedItemId)]
      : (options?.uoms || []);
  const isDraft = !header.status || header.status === "DRAFT";
  const isEditable = !isEdit || isDraft;
  const submitPath = isEdit ? `${basePath}/${header.id}/save-draft` : `${basePath}/save-draft`;
  const tx = (key, fallback) => {
    const value = typeof t === "function" ? t(key) : "";
    return value && value !== key ? value : fallback;
  };
%>

<style>
  #bom-form input[type="number"]::-webkit-outer-spin-button,
  #bom-form input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  #bom-form input[type="number"] {
    -moz-appearance: textfield;
  }
  #bom-form [data-searchable-wrapper] {
    z-index: 1;
  }
  #bom-form [data-searchable-wrapper]:focus-within {
    z-index: 80;
  }
  #bom-form [data-rm-view-toggle],
  #bom-form [data-labour-view-toggle] {
    border-color: #cbd5e1;
    background: #ffffff;
    color: #475569;
  }
  #bom-form [data-rm-view-toggle][data-active="true"],
  #bom-form [data-labour-view-toggle][data-active="true"] {
    border-color: #0f172a;
    background: #0f172a;
    color: #ffffff;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.25);
  }
  #bom-form [data-rm-view-toggle][data-active="false"],
  #bom-form [data-labour-view-toggle][data-active="false"] {
    border-color: #cbd5e1;
    background: #ffffff;
    color: #475569;
  }
  #bom-header { order: 10; }
  #bom-form [data-header-lock-notice] { order: 20; }
  #bom-stage { order: 25; }
  #bom-sfg { order: 30; }
  #bom-rm { order: 40; }
  #bom-labour { order: 50; }
  #bom-form [data-bom-save-wrap] { order: 60; }
</style>

<div class="mx-auto w-full max-w-7xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-lg">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="space-y-1">
        <h1 class="text-2xl font-display text-ink">
          <%= isEdit ? (t("bom_edit_title") ) : (t("bom_new_title") ) %>
        </h1>
        <p class="text-sm text-muted"><%= t("bom_header_required_message")  %></p>
      </div>
      <div class="flex flex-wrap gap-2">
        <% if (isEdit && header.status === "APPROVED" && can('SCREEN', 'master_data.bom', 'create')) { %>
          <form method="POST" action="<%= basePath %>/<%= header.id %>/create-new-version">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="inline-flex min-w-[8.5rem] items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-700 transition hover:border-slate-400 hover:text-slate-900" title="<%= t('bom_create_new_version')  %>">
              <%= t("bom_revise")  %>
            </button>
          </form>
        <% } %>
        <% if (isEdit && isDraft) { %>
          <button
            type="submit"
            form="bom-form"
            formaction="<%= basePath %>/<%= header.id %>/<%= user?.isAdmin ? 'approve-draft' : 'send-for-approval' %>"
            formmethod="POST"
            data-bom-approve-now="<%= user?.isAdmin ? '1' : '0' %>"
            data-bom-send-approval="<%= user?.isAdmin ? '0' : '1' %>"
            class="inline-flex min-w-[8.5rem] items-center justify-center rounded-xl bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white shadow-sm transition hover:brightness-95"
          >
            <%= user?.isAdmin ? (t("approve") ) : (t("send_for_approval") ) %>
          </button>
        <% } %>
        <% if (isEdit && String(header.status || '').toUpperCase() === "PENDING" && user?.isAdmin) { %>
          <a
            href="/administration/approvals?status=PENDING&entity_type=BOM&entity_id=<%= header.id %>"
            class="inline-flex min-w-[8.5rem] items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-700 transition hover:border-slate-400 hover:text-slate-900"
          >
            <%= t("open_approval")  %>
          </a>
        <% } %>
      </div>
    </div>
  </section>

  <form id="bom-form" method="POST" action="<%= submitPath %>" class="flex flex-col gap-6">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="submit_intent" value="" data-bom-submit-intent>
    <input type="hidden" name="switch_after_save" value="0" data-bom-switch-after-save>
    <input type="hidden" name="switch_level" value="" data-bom-switch-level>
    <input type="hidden" name="switch_item_id" value="" data-bom-switch-item-id>
    <input type="hidden" name="switch_output_qty" value="" data-bom-switch-output-qty>
    <input type="hidden" name="switch_output_uom_id" value="" data-bom-switch-output-uom-id>
    <input type="hidden" name="rm_lines_json" value="<%- JSON.stringify(formState?.rm_lines || []) %>" data-lines-json="rm_lines">
    <input type="hidden" name="sku_rules_json" value="[]" data-lines-json="sku_rules">
    <input type="hidden" name="sfg_lines_json" value="<%- JSON.stringify(formState?.sfg_lines || []) %>" data-lines-json="sfg_lines">
    <input type="hidden" name="labour_lines_json" value="<%- JSON.stringify(formState?.labour_lines || []) %>" data-lines-json="labour_lines">
    <input type="hidden" name="stage_routes_json" value="<%- JSON.stringify(formState?.stage_routes || []) %>" data-lines-json="stage_routes">

    <section id="bom-header" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <div class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_header")  %></div>
        <% if (header.bom_no) { %>
          <div class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("code")  %>: <%= header.bom_no %></div>
        <% } %>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4" data-header-enter-row>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("level")  %></span>
          <select name="level" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" data-searchable-select="true" data-searchable-variant="unified" data-header-field="level" <%= isEditable ? "" : "disabled" %> required>
            <option value=""><%= t("select") %></option>
            <% (options?.levelOptions || []).forEach(function(levelOpt) { %>
              <option value="<%= levelOpt.value %>" <%= selectedLevel === levelOpt.value ? "selected" : "" %>>
                <%= t(levelOpt.label) || levelOpt.value %>
              </option>
            <% }) %>
          </select>
        </label>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("article_name")  %></span>
          <select name="item_id" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" data-searchable-select="true" data-searchable-variant="unified" data-header-field="item_id" <%= isEditable ? "" : "disabled" %> required>
            <option value=""><%= t("select") %></option>
            <% (options?.items || []).filter(function(item) { return !selectedItemType || item.item_type === selectedItemType; }).forEach(function(item) { %>
              <option value="<%= item.id %>" <%= Number(header.item_id) === Number(item.id) ? "selected" : "" %>>
                <%= item.name %>
              </option>
            <% }) %>
          </select>
          <% if (!isEdit && (!options?.items || options.items.length === 0)) { %>
            <div class="mt-1 text-xs font-medium text-amber-700"><%= t("bom_no_available_articles")  %></div>
          <% } %>
        </label>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("bom_output_batch_size")  %></span>
          <input type="number" step="0.001" min="0.001" name="output_qty" value="<%= header.output_qty ?? 1 %>" data-no-stepper="true" data-header-field="output_qty" class="h-10 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-700 transition focus:border-black focus:outline-none focus:ring-2 focus:ring-black/20" <%= isEditable ? "" : "readonly" %> required>
        </label>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("bom_output_uom")  %></span>
          <select name="output_uom_id" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" data-searchable-select="true" data-searchable-variant="unified" data-header-field="output_uom_id" <%= isEditable ? "" : "disabled" %> required>
            <option value=""><%= t("select") %></option>
            <% (initialOutputUoms || []).forEach(function(uom) { %>
              <option value="<%= uom.id %>" <%= Number(header.output_uom_id) === Number(uom.id) ? "selected" : "" %>><%= uom.name %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <% if (isEdit) { %>
        <div class="mt-5 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("version")  %></div>
            <div class="mt-1 text-sm font-semibold text-slate-800">V<%= header.version_no %></div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("status") %></div>
            <div class="mt-1">
              <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold uppercase tracking-[0.08em] <%= (String(header.status || '').toUpperCase() === 'APPROVED') ? 'bg-emerald-100 text-emerald-700' : (String(header.status || '').toUpperCase() === 'PENDING') ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
                <%= t((header.status || '').toLowerCase()) || header.status %>
              </span>
            </div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("created")  %></div>
            <div class="mt-1 text-sm font-semibold text-slate-800"><%= formatDateDisplay(header.created_at) %></div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("approved")  %></div>
            <div class="mt-1 text-sm font-semibold text-slate-800"><%= formatDateDisplay(header.approved_at) %></div>
          </div>
        </div>
      <% } %>
    </section>

    <section class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800 <%= (header.item_id && header.level && Number(header.output_qty || 0) > 0 && header.output_uom_id) ? 'hidden' : '' %>" data-header-lock-notice>
      <span class="font-semibold"><%= t("notice")  %>:</span>
      <%= t("bom_header_required_message")  %>
    </section>

    <section id="bom-stage" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24">
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("production_stages")  %></h2>
      </div>
      <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
        <table class="w-full table-fixed text-sm">
          <colgroup>
            <col class="w-[16%]">
            <col class="w-[34%]">
            <col class="w-[18%]">
            <col class="w-[18%]">
            <col class="w-[14%]">
          </colgroup>
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
            <tr>
              <th class="px-3 py-2 text-left"><%= t("sr_no")  %></th>
              <th class="px-3 py-2 text-left"><%= t("department")  %></th>
              <th class="px-3 py-2 text-center"><%= t("bom_stage_mandatory_in_flow")  %></th>
              <th class="px-3 py-2 text-center"><%= t("bom_stage_strict_sequence")  %></th>
              <th class="px-3 py-2 text-right"><%= t("actions")  %></th>
            </tr>
          </thead>
          <tbody data-lines-body="stage_route"></tbody>
        </table>
      </div>
    </section>

    <section id="bom-rm" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24 space-y-5">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_tab_rm")  %></h2>
        <div class="inline-flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-rm-view-toggle="materials"
            data-active="true"
            class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
          >
            <%= t("bom_rm_view_material_lines")  %>
          </button>
          <button
            type="button"
            data-rm-view-toggle="sku_rules"
            data-active="false"
            class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
          >
            <%= t("bom_sku_rules")  %>
          </button>
        </div>
      </div>
      <section data-rm-view="materials" class="rounded-xl border border-slate-200 bg-white">
        <div class="border-b border-slate-200 px-3 py-3">
          <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600"><%= t("bom_rm_view_material_lines")  %></h3>
          <p class="mt-1 text-xs text-slate-500"><%= t("bom_rm_section_hint")  %></p>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="w-full table-fixed text-sm">
            <colgroup>
              <col class="w-[22%]">
              <col class="w-[14%]">
              <col class="w-[14%]">
              <col class="w-[14%]">
              <col class="w-[16%]">
              <col class="w-[10%]">
              <col class="w-[8%]">
              <col class="w-[10%]">
              <col class="w-[6%]">
            </colgroup>
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_material')  %>"><%= t("bom_rm_col_material")  %></th>
                <th class="px-3 py-2 text-left"><%= t("color")  %></th>
                <th class="px-3 py-2 text-left"><%= t("size")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit')  %>"><%= t("base_unit")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_consumption_department')  %>"><%= t("bom_rm_col_department")  %></th>
                <th class="px-3 py-2 text-left"><%= t("bom_rules_col_qty")  %></th>
                <th class="px-3 py-2 text-left"><%= t("normal_loss_pct")  %></th>
                <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions')  %>"><%= t("bom_rm_col_actions")  %></th>
              </tr>
            </thead>
            <tbody data-lines-body="rm"></tbody>
          </table>
        </div>
      </section>
      <section data-rm-view="sku_rules" class="hidden rounded-xl border border-slate-200 bg-white">
        <div class="border-b border-slate-200 px-3 py-3">
          <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600"><%= t("bom_sku_rules")  %></h3>
          <p class="mt-1 text-xs text-slate-500"><%= t("bom_sku_rules_hint")  %></p>
          <div class="mt-2 flex flex-wrap items-center gap-2" data-sku-rule-chips></div>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left"><%= t("bom_rm_col_material")  %></th>
                <th class="px-3 py-2 text-left"><%= t("bom_rm_col_department")  %></th>
                <th class="px-3 py-2 text-left"><%= t("color")  %></th>
                <th class="px-3 py-2 text-left"><%= t("size")  %></th>
                <th class="px-3 py-2 text-left"><%= t("bom_rules_col_qty")  %></th>
                <th class="px-3 py-2 text-left"><%= t("bom_rules_col_uom")  %></th>
              </tr>
            </thead>
            <tbody data-sku-rules-body></tbody>
          </table>
        </div>
      </section>
    </section>

    <section id="bom-sfg" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24">
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_tab_sfg_per_sku")  %></h2>
      </div>
      <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
            <tr>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_article_sku')  %>"><%= t("article_sku")  %></th>
              <th class="px-3 py-2 text-left" data-sfg-part-col-title title="<%= t('bom_hint_step_upper_sku')  %>"><span data-sfg-part-col-label><%= t("bom_sfg_col_step_upper_sku")  %></span></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_step_quantity')  %>"><%= t("bom_sfg_col_step_qty")  %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_sfg_consumed_stage')  %>"><%= t("bom_sfg_col_consumed_stage")  %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit')  %>"><%= t("base_unit")  %></th>
            </tr>
          </thead>
          <tbody data-lines-body="sfg"></tbody>
        </table>
      </div>
    </section>

    <section id="bom-labour" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24 space-y-4">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_tab_labour")  %></h2>
        <div class="inline-flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-labour-view-toggle="selection"
            data-active="true"
            class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
          >
            <%= t("bom_labour_selection_title")  %>
          </button>
          <button
            type="button"
            data-labour-view-toggle="size_rules"
            data-active="false"
            class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
          >
            <%= t("bom_labour_size_rules_title")  %>
          </button>
        </div>
      </div>
      <section class="rounded-xl border border-slate-200 bg-white" data-labour-view="selection">
        <div class="border-b border-slate-200 px-3 py-3">
          <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600"><%= t("bom_labour_selection_title")  %></h3>
          <p class="mt-1 text-xs text-slate-500"><%= t("bom_labour_selection_hint")  %></p>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_labour')  %>"><%= t("labours")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_department')  %>"><%= t("department")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rate_type')  %>"><%= t("rate_type")  %></th>
                <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions')  %>"><%= t("actions")  %></th>
              </tr>
            </thead>
            <tbody data-lines-body="labour_selection"></tbody>
          </table>
        </div>
      </section>
      <section class="rounded-xl border border-slate-200 bg-white hidden" data-labour-view="size_rules">
        <div class="border-b border-slate-200 px-3 py-3">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600"><%= t("bom_labour_size_rules_title")  %></h3>
            <p class="mt-1 text-xs text-slate-500"><%= t("bom_labour_size_rules_hint")  %></p>
            <div class="mt-2 flex flex-wrap items-center gap-2" data-labour-rule-sku-sections></div>
          </div>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_labour')  %>"><%= t("labours")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_department')  %>"><%= t("department")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rate_value')  %>"><%= t("bom_labour_col_rate")  %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rate_type')  %>"><%= t("rate_type")  %></th>
              </tr>
            </thead>
            <tbody data-lines-body="labour_rule"></tbody>
          </table>
        </div>
      </section>
    </section>

    <% if (isEditable) { %>
      <div class="flex justify-center" data-bom-save-wrap>
        <button type="button" data-bom-save-draft class="rounded-xl bg-accent px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.16em] text-white shadow-sm transition hover:brightness-95">
          <%= t("save_draft")  %>
        </button>
      </div>
    <% } %>
  </form>
</div>

<div class="fixed inset-0 z-[95] hidden items-center justify-center bg-slate-900/40 p-4" data-bom-header-change-modal>
  <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white shadow-xl" role="dialog" aria-modal="true" aria-labelledby="bom-header-change-title">
    <div class="relative border-b border-slate-200 px-6 py-4">
      <button
        type="button"
        data-bom-header-modal-close
        class="absolute right-4 top-4 inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-400 transition hover:bg-slate-100 hover:text-slate-700"
        aria-label="<%= tx('close', 'Close') %>"
        title="<%= tx('close', 'Close') %>"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
      <div class="flex items-start gap-3 pr-10">
        <div class="mt-0.5 inline-flex h-8 w-8 items-center justify-center rounded-full bg-amber-100 text-amber-700">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 8v5m0 3h.01M4.93 19h14.14c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.2 16c-.77 1.33.19 3 1.73 3z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <div class="text-sm font-semibold text-slate-700" id="bom-header-change-title" data-bom-header-modal-title><%= tx("bom_header_change_modal_title", "BOM setup changed") %></div>
          <p class="mt-1 text-xs text-slate-500 whitespace-pre-line" data-bom-header-modal-message><%= tx("bom_header_change_modal_message", "You changed BOM Setup fields. This affects material, SFG, and labour sections.") %></p>
        </div>
      </div>
    </div>
    <div class="px-6 py-4">
      <p class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs text-amber-800" data-bom-header-modal-hint><%= tx("bom_header_change_modal_hint", "Save Draft & Switch: saves current draft and opens selected BOM context. Apply: keeps new header values and clears impacted sections.") %></p>
    </div>
    <div class="space-y-2 border-t border-slate-200 px-6 py-5">
      <button type="button" data-bom-header-modal-secondary class="hidden w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-slate-600 transition hover:border-slate-300 hover:text-slate-800">
        <%= tx("bom_header_change_modal_save_switch", "Save Draft & Switch") %>
      </button>
      <button type="button" data-bom-header-modal-apply class="w-full rounded-xl bg-slate-900 px-4 py-3 text-xs font-semibold uppercase tracking-[0.2em] text-white transition hover:bg-slate-800">
        <%= tx("bom_header_change_modal_apply", "Apply") %>
      </button>
    </div>
  </div>
</div>

<script><%- include("../../base/partials/searchable-select.js") %></script>
<script><%- include("../../base/partials/voucher-row-enter-navigation.js") %></script>
<script>
  (function () {
    const editable = <%- JSON.stringify(Boolean(isEditable)) %>;
    const options = <%- JSON.stringify(options || {}) %>;
    const state = {
      rm: <%- JSON.stringify(formState?.rm_lines || []) %>,
      sfg: <%- JSON.stringify(formState?.sfg_lines || []) %>,
      labour: <%- JSON.stringify(formState?.labour_lines || []) %>,
      stage_routes: <%- JSON.stringify(formState?.stage_routes || []) %>,
      labour_selection: [],
      labourRuleRateMap: {},
      labourRuleLockedMap: {},
      labourRuleOpenSkuId: "",
      labourRuleOpenFallbackSizeId: null,
      sku_override: <%- JSON.stringify(formState?.sku_overrides || []) %>,
      skuRuleOpenSkuId: "",
    };
    const labels = {
      select: "<%= t('select')  %>",
      all: "<%= t('all')  %>",
      specific: "<%= t('bom_specific')  %>",
      skuRules: "<%= t('bom_sku_rules')  %>",
      add: "<%= t('add')  %>",
      remove: "<%= t('delete')  %>",
      clear: "<%= t('clear')  %>",
    };
    const headerModalCopy = {
      qty: {
        title: "<%= t('bom_header_change_qty_title')  %>",
        message: "<%= t('bom_header_change_qty_message')  %>",
        hint: "<%= t('bom_header_change_qty_hint')  %>",
        applyLabel: "<%= t('bom_header_change_apply_clear_quantities')  %>",
      },
      uom: {
        title: "<%= t('bom_header_change_uom_title')  %>",
        message: "<%= t('bom_header_change_uom_message')  %>",
        hint: "<%= t('bom_header_change_uom_hint')  %>",
        applyLabel: "<%= t('bom_header_change_apply_clear_quantities')  %>",
      },
      identity: {
        title: "<%= t('bom_header_change_identity_title')  %>",
        message: "<%= t('bom_header_change_identity_message')  %>",
        hint: "<%= t('bom_header_change_identity_hint')  %>",
        applyLabel: "<%= t('bom_header_change_apply_start_fresh')  %>",
        secondaryLabel: "<%= t('bom_header_change_save_switch')  %>",
      },
    };
    const serverErrorMessage = <%- JSON.stringify(errorMessage || "") %>;
    const serverErrorDetails = <%- JSON.stringify((errors || []).map((err) => err?.message).filter(Boolean)) %>;
    let allowBomSubmit = false;
    let bomForm = null;
    let saveDraftBtn = null;
    let submitIntentInput = null;
    let switchAfterSaveInput = null;
    let switchLevelInput = null;
    let switchItemIdInput = null;
    let switchOutputQtyInput = null;
    let switchOutputUomInput = null;
    let headerCommittedState = null;
    let applyingHeaderState = false;
    const esc = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");

    const makeOptions = (rows, selected, textFn) =>
      rows
        .map((row) => {
          const optionValue = row.id || row.value;
          const optionText = textFn ? textFn(row) : row.name || row.label || row.value;
          return `<option value="${esc(optionValue)}" ${String(selected || "") === String(optionValue) ? "selected" : ""}>${esc(optionText)}</option>`;
        })
        .join("");

    const rmItemUomById = new Map((options.rmItems || []).map((item) => [String(item.id), String(item.base_uom_id || "")]));
    const sfgSkuUomById = new Map((options.sfgSkus || []).map((sku) => [String(sku.id), String(sku.base_uom_id || "")]));
    const uomNameById = new Map((options.uoms || []).map((uom) => [String(uom.id), String(uom.name || "")]));
    const rmItemNameById = new Map((options.rmItems || []).map((item) => [String(item.id), item.name || item.code || item.id]));
    const departmentNameById = new Map((options.departments || []).map((dept) => [String(dept.id), dept.name || dept.id]));
    const labourNameById = new Map((options.labours || []).map((labour) => [String(labour.id), labour.name || labour.code || labour.id]));
    const rmItemColorMap = options.rmItemColorMap || {};
    const rmItemSizeMap = options.rmItemSizeMap || {};
    const labourDeptMap = options.labourDeptMap || {};
    const stageById = new Map((options.productionStages || []).map((stage) => [String(stage.id), stage]));
    const stageIdByDeptId = new Map((options.productionStages || [])
      .map((stage) => [String(stage?.dept_id || ""), String(stage?.id || "")])
      .filter(([deptId, stageId]) => deptId && stageId));
    const uomConversionMap = (options && typeof options.uomConversionMap === "object" && options.uomConversionMap)
      ? options.uomConversionMap
      : {};
    const productionDepartments = (options.departments || []).filter((department) => department?.is_production === true);
    const stageDeptOptions = [];
    const seenStageDeptIds = new Set();
    (options.productionStages || []).forEach((stage) => {
      const deptId = String(stage?.dept_id || "").trim();
      if (!deptId || seenStageDeptIds.has(deptId)) return;
      seenStageDeptIds.add(deptId);
      stageDeptOptions.push({
        id: deptId,
        name: String(stage?.dept_name || departmentNameById.get(deptId) || deptId),
      });
    });
    if (!stageDeptOptions.length) {
      productionDepartments.forEach((department) => {
        const deptId = String(department?.id || "").trim();
        if (!deptId || seenStageDeptIds.has(deptId)) return;
        seenStageDeptIds.add(deptId);
        stageDeptOptions.push({
          id: deptId,
          name: String(department?.name || deptId),
        });
      });
    }
    const labourDefaultsByItem = options.itemLabourDefaultsMap || {};
    const headerLevelToItemType = { FINISHED: "FG", SEMI_FINISHED: "SFG" };
    const headerItemSelect = document.querySelector('select[name="item_id"]');
    const headerOutputUomSelect = document.querySelector('select[name="output_uom_id"]');
    const headerLevelSelect = document.querySelector('select[name="level"]');
    const allHeaderItems = Array.isArray(options.items) ? options.items : [];
    const headerItemById = new Map(allHeaderItems.map((item) => [String(item.id || ""), item]));
    const sfgSection = document.getElementById("bom-sfg");
    const sfgPartColumnLabelEl = document.querySelector("[data-sfg-part-col-label]");
    const sfgPartColumnTitleEl = document.querySelector("[data-sfg-part-col-title]");
    const stepLabel = "<%= t('step')  %>";
    const upperLabel = "<%= t('upper')  %>";
    const sfgPartDefaultColLabel = "<%= t('bom_sfg_col_step_upper_sku')  %>";
    const sfgPartDefaultHint = "<%= t('bom_hint_step_upper_sku')  %>";
    const sfgPartStepHint = "<%= t('bom_hint_step_sku')  %>";
    const sfgPartUpperHint = "<%= t('bom_hint_upper_sku')  %>";
    const plusIcon = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><path d="M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>';
    const deleteIcon = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 12h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>';
    const resolveRmUomId = (row) => rmItemUomById.get(String(row?.rm_item_id || "")) || String(row?.uom_id || "");
    const resolveSfgUomId = (row) => sfgSkuUomById.get(String(row?.sfg_sku_id || "")) || String(row?.uom_id || "");
    const getUomName = (uomId) => uomNameById.get(String(uomId || "")) || "";
    const getRmColorsForItem = (rmItemId) => {
      const rows = rmItemColorMap[String(rmItemId || "")];
      return Array.isArray(rows) ? rows : [];
    };
    const getRmSizesForItem = (rmItemId) => {
      const rows = rmItemSizeMap[String(rmItemId || "")];
      return Array.isArray(rows) ? rows : [];
    };
    const getSelectedStageDepartmentIdSet = () => {
      const rows = Array.isArray(state?.stage_routes) ? state.stage_routes : [];
      return new Set(
        rows
          .map((line) => String(line?.dept_id || "").trim())
          .filter(Boolean),
      );
    };
    const getDraftFallbackDepartments = () => {
      if (Array.isArray(stageDeptOptions) && stageDeptOptions.length) {
        return stageDeptOptions;
      }
      return Array.isArray(productionDepartments) ? productionDepartments : [];
    };
    const getDepartmentsScopedToSelectedStages = () => {
      const selectedDeptIds = getSelectedStageDepartmentIdSet();
      const scopedBase = getDraftFallbackDepartments();
      if (!selectedDeptIds.size) return scopedBase;
      return scopedBase.filter((dept) => selectedDeptIds.has(String(dept.id || "")));
    };
    const getLabourDepartmentsForLabour = (labourId) => {
      const allowedDeptIds = Array.isArray(labourDeptMap[String(labourId || "")]) ? labourDeptMap[String(labourId || "")] : [];
      const stageScopedDepartments = getDepartmentsScopedToSelectedStages();
      if (!allowedDeptIds.length) return stageScopedDepartments;
      return stageScopedDepartments.filter((dept) => allowedDeptIds.includes(String(dept.id)));
    };
    const upsertStageRouteForDepartment = (deptId) => {
      const normalizedDeptId = String(deptId || "").trim();
      if (!normalizedDeptId) return false;
      const mappedStageId = String(stageIdByDeptId.get(normalizedDeptId) || "").trim();
      if (!mappedStageId) return false;
      if (!Array.isArray(state.stage_routes)) state.stage_routes = [];
      const alreadyExists = state.stage_routes.some(
        (line) => String(line?.dept_id || "").trim() === normalizedDeptId,
      );
      if (alreadyExists) return false;
      const emptyRowIndex = state.stage_routes.findIndex(
        (line) => !String(line?.dept_id || "").trim(),
      );
      const nextRow = {
        dept_id: normalizedDeptId,
        stage_id: mappedStageId,
        sequence_no: "",
        is_required: true,
        enforce_sequence: true,
      };
      if (emptyRowIndex >= 0) {
        state.stage_routes[emptyRowIndex] = {
          ...(state.stage_routes[emptyRowIndex] || {}),
          ...nextRow,
        };
        return true;
      }
      state.stage_routes.push(nextRow);
      return true;
    };
    const ensureStageRoutesCoverDepartments = (deptIds = []) => {
      const seen = new Set();
      let changed = false;
      deptIds.forEach((deptId) => {
        const normalizedDeptId = String(deptId || "").trim();
        if (!normalizedDeptId || seen.has(normalizedDeptId)) return;
        seen.add(normalizedDeptId);
        if (upsertStageRouteForDepartment(normalizedDeptId)) changed = true;
      });
      return changed;
    };
    const getSelectedStageChoicesForSfg = () => {
      const rows = Array.isArray(state?.stage_routes) ? state.stage_routes : [];
      const byStageId = new Map();
      rows.forEach((line, index) => {
        const deptId = String(line?.dept_id || "").trim();
        const stageId = String(stageIdByDeptId.get(deptId) || line?.stage_id || "").trim();
        if (!stageId || byStageId.has(stageId)) return;
        const stage = stageById.get(stageId);
        const deptName = String(stage?.dept_name || departmentNameById.get(deptId) || deptId || "").trim();
        const stageName = String(stage?.name || "").trim();
        const baseLabel = deptName || stageName || stageId;
        const displayLabel = stageName && stageName !== deptName
          ? `${index + 1}. ${baseLabel} (${stageName})`
          : `${index + 1}. ${baseLabel}`;
        byStageId.set(stageId, {
          id: stageId,
          name: displayLabel,
        });
      });
      return [...byStageId.values()];
    };
    const actionButtons = (type) =>
      `<div class="inline-flex items-center gap-2">
        <button type="button" data-add-after="${type}" title="${labels.add}" aria-label="${labels.add}" class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-white p-2 text-slate-600 transition hover:border-slate-300 hover:text-slate-900">${plusIcon}</button>
        <button type="button" data-remove-row="${type}" title="${labels.remove}" aria-label="${labels.remove}" class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-white p-2 text-slate-600 transition hover:border-slate-300 hover:text-slate-900">${deleteIcon}</button>
      </div>`;

    const rateTypeLabel = {
      PER_PAIR: "<%= t('rate_type_per_pair')  %>",
      PER_DOZEN: "<%= t('rate_type_per_dozen')  %>",
    };
    const defaultLabourSelectionRow = () => ({ labour_id: "", dept_id: "", rate_type: "PER_PAIR" });
    const normalizeLabourRateType = (rateType) => {
      const normalized = String(rateType || "PER_PAIR").toUpperCase();
      return Object.prototype.hasOwnProperty.call(rateTypeLabel, normalized) ? normalized : "PER_PAIR";
    };
    const normalizeLabourSelectionRow = (row) => ({
      labour_id: String(row?.labour_id || "").trim(),
      dept_id: String(row?.dept_id || "").trim(),
      rate_type: normalizeLabourRateType(row?.rate_type),
    });
    const toLabourComboKey = (row) => {
      const normalized = normalizeLabourSelectionRow(row);
      return `${normalized.labour_id}:${normalized.dept_id}:${normalized.rate_type}`;
    };
    const toLabourRateKey = (row, sizeKey) => `${toLabourComboKey(row)}:${String(sizeKey || "ALL")}`;
    const isLabourRateLockedByKey = (key) => Boolean(state.labourRuleLockedMap && state.labourRuleLockedMap[key]);
    const isLabourRateLocked = (selectionRow, sizeKey) => isLabourRateLockedByKey(toLabourRateKey(selectionRow, sizeKey));
    const clearLabourRateLocksForComboKey = (comboKey) => {
      if (!comboKey || !state.labourRuleLockedMap || typeof state.labourRuleLockedMap !== "object") return;
      Object.keys(state.labourRuleLockedMap).forEach((key) => {
        if (String(key || "").startsWith(`${comboKey}:`)) {
          delete state.labourRuleLockedMap[key];
        }
      });
    };
    const toLabourSizeKeyFromLine = (line) => (
      String(line?.size_scope || "").toUpperCase() === "SPECIFIC"
        ? String(line?.size_id || "").trim()
        : "ALL"
    );
    const allSizesLabel = "<%= t('all_sizes')  %>";
    const skuRuleChipsHost = document.querySelector("[data-sku-rule-chips]");
    const skuRulesBody = document.querySelector("[data-sku-rules-body]");
    const labourRuleSkuChipsHost = document.querySelector("[data-labour-rule-sku-sections]");
    const rmViewToggleButtons = Array.from(document.querySelectorAll("[data-rm-view-toggle]"));
    const rmViewPanels = Array.from(document.querySelectorAll("[data-rm-view]"));
    const labourViewToggleButtons = Array.from(document.querySelectorAll("[data-labour-view-toggle]"));
    const labourViewPanels = Array.from(document.querySelectorAll("[data-labour-view]"));
    const nonHeaderSections = Array.from(document.querySelectorAll("#bom-stage, #bom-rm, #bom-labour"));
    const headerLockNotice = document.querySelector("[data-header-lock-notice]");
    const headerChangeModal = document.querySelector("[data-bom-header-change-modal]");
    const headerModalTitleEl = headerChangeModal?.querySelector("[data-bom-header-modal-title]");
    const headerModalMessageEl = headerChangeModal?.querySelector("[data-bom-header-modal-message]");
    const headerModalHintEl = headerChangeModal?.querySelector("[data-bom-header-modal-hint]");
    const headerModalApplyBtn = headerChangeModal?.querySelector("[data-bom-header-modal-apply]");
    const headerModalSecondaryBtn = headerChangeModal?.querySelector("[data-bom-header-modal-secondary]");
    const headerModalCloseBtn = headerChangeModal?.querySelector("[data-bom-header-modal-close]");
    let rmViewMode = "materials";
    let labourViewMode = "selection";
    let suppressNextSfgQtyAutofill = false;

    const setSelectOptions = (selectEl, rows, selectedValue, textFn) => {
      if (!selectEl) return;
      const selected = String(selectedValue || "");
      selectEl.innerHTML = `<option value="">${esc(labels.select)}</option>${makeOptions(rows || [], selected, textFn)}`;
      const hasSelected = Array.from(selectEl.options).some((opt) => String(opt.value) === selected);
      selectEl.value = hasSelected ? selected : "";
    };
    const getReadonlyVariantMeta = (rows, selectedValue) => {
      const optionsList = Array.isArray(rows) ? rows : [];
      const normalizedSelected = String(selectedValue || "").trim();
      if (!optionsList.length) {
        return { value: "", label: "-" };
      }
      if (optionsList.length === 1) {
        const only = optionsList[0] || {};
        return {
          value: String(only.id || "").trim(),
          label: String(only.name || only.code || only.id || "-"),
        };
      }
      const selected = optionsList.find((row) => String(row?.id || "").trim() === normalizedSelected);
      if (selected) {
        return {
          value: normalizedSelected,
          label: String(selected.name || selected.code || selected.id || "-"),
        };
      }
      return { value: "", label: labels.skuRules };
    };

    const refreshRmVariantSelectors = (row, rmItemId) => {
      if (!row) return;
      const hidden = row.querySelector('[data-col="uom_id"]');
      const display = row.querySelector('[data-col-display="uom_id"]');
      const colorInput = row.querySelector('input[data-col="color_id"]');
      const colorDisplay = row.querySelector('input[data-col-display="color_id"]');
      const sizeInput = row.querySelector('input[data-col="size_id"]');
      const sizeDisplay = row.querySelector('input[data-col-display="size_id"]');
      const uomId = rmItemUomById.get(String(rmItemId || "")) || "";
      const colorOptions = getRmColorsForItem(rmItemId);
      const sizeOptions = getRmSizesForItem(rmItemId);
      if (hidden) hidden.value = uomId;
      if (display) display.value = getUomName(uomId);
      const colorMeta = getReadonlyVariantMeta(colorOptions, colorInput?.value);
      const sizeMeta = getReadonlyVariantMeta(sizeOptions, sizeInput?.value);
      if (colorInput) colorInput.value = colorMeta.value;
      if (colorDisplay) colorDisplay.value = colorMeta.label;
      if (sizeInput) sizeInput.value = sizeMeta.value;
      if (sizeDisplay) sizeDisplay.value = sizeMeta.label;
    };

    const refreshLabourDepartmentSelector = (row, labourId) => {
      if (!row) return;
      const deptSelect = row.querySelector('[data-col="dept_id"]');
      setSelectOptions(deptSelect, getLabourDepartmentsForLabour(labourId), deptSelect?.value || "");
    };
    const pruneDepartmentScopedRows = () => {
      const selectedDeptIds = getSelectedStageDepartmentIdSet();
      if (!selectedDeptIds.size) return;
      const keepDept = (deptId) => selectedDeptIds.has(String(deptId || "").trim());
      // Non-destructive: do not clear RM/Labour selections automatically while user is still building stage routes.
      // Only trim invalid dept-scoped override rows, which are derived data and safe to regenerate.
      if (Array.isArray(state.sku_override)) {
        state.sku_override = state.sku_override.filter((line) => keepDept(line?.dept_id));
      }
    };
    const getAllowedOutputUomsForSelectedItem = () => {
      const itemId = String(headerItemSelect?.value || "").trim();
      if (!itemId) return Array.isArray(options.uoms) ? options.uoms : [];
      const mappedRows = options.itemOutputUomMap && Array.isArray(options.itemOutputUomMap[itemId])
        ? options.itemOutputUomMap[itemId]
        : [];
      if (mappedRows.length) return mappedRows;
      const selectedItem = headerItemById.get(itemId);
      const baseUomId = String(selectedItem?.base_uom_id || "").trim();
      if (!baseUomId) return [];
      const fallbackBaseUom = (options.uoms || []).find((uom) => String(uom?.id || "") === baseUomId);
      return fallbackBaseUom ? [fallbackBaseUom] : [];
    };
    const renderOutputUomOptions = (preferredValue = null) => {
      if (!headerOutputUomSelect) return;
      const selectedValue = preferredValue === null
        ? String(headerOutputUomSelect.value || "")
        : String(preferredValue || "");
      setSelectOptions(
        headerOutputUomSelect,
        getAllowedOutputUomsForSelectedItem(),
        selectedValue,
        (uom) => uom.name || uom.code || uom.id,
      );
      headerOutputUomSelect.disabled = !editable;
    };

    const renderHeaderItemsByLevel = (preserveSelectedItem = true) => {
      if (!headerItemSelect || !headerLevelSelect) return;
      const currentValue = preserveSelectedItem ? String(headerItemSelect.value || "") : "";
      const level = String(headerLevelSelect.value || "").toUpperCase();
      const requiredItemType = headerLevelToItemType[level] || null;
      const filteredItems = requiredItemType
        ? allHeaderItems.filter((item) => String(item.item_type || "").toUpperCase() === requiredItemType)
        : [];
      headerItemSelect.innerHTML =
        `<option value="">${esc(labels.select)}</option>` + makeOptions(filteredItems, currentValue, (item) => item.name || item.code || item.id);
      const hasCurrent = filteredItems.some((item) => String(item.id) === currentValue);
      headerItemSelect.value = hasCurrent ? currentValue : "";
      headerItemSelect.disabled = !editable || !requiredItemType;
      renderOutputUomOptions();
    };

    const getSelectedHeaderItem = () => {
      const itemId = String(headerItemSelect?.value || "");
      return headerItemById.get(itemId) || null;
    };

    const getSfgPartType = () => String(getSelectedHeaderItem()?.sfg_part_type || "").trim().toUpperCase();

    const getSfgPartColumnLabel = () => {
      const partType = getSfgPartType();
      if (partType === "STEP") return `${stepLabel} SKU`;
      if (partType === "UPPER") return `${upperLabel} SKU`;
      return sfgPartDefaultColLabel;
    };

    const updateSfgPartColumnPresentation = () => {
      const partType = getSfgPartType();
      const label = getSfgPartColumnLabel();
      if (sfgPartColumnLabelEl) sfgPartColumnLabelEl.textContent = label;
      if (sfgPartColumnTitleEl) {
        if (partType === "STEP") {
          sfgPartColumnTitleEl.setAttribute("title", sfgPartStepHint);
        } else if (partType === "UPPER") {
          sfgPartColumnTitleEl.setAttribute("title", sfgPartUpperHint);
        } else {
          sfgPartColumnTitleEl.setAttribute("title", sfgPartDefaultHint);
        }
      }
    };

    const getHeaderSizeOptions = () => {
      const itemId = String(headerItemSelect?.value || "");
      const rows = options.itemSizeMap && Array.isArray(options.itemSizeMap[itemId]) ? options.itemSizeMap[itemId] : [];
      return rows;
    };
    const getLabourSizeScopes = () => {
      const sizeRows = getHeaderSizeOptions();
      if (sizeRows.length) {
        return sizeRows.map((size) => ({ id: String(size.id), name: size.name || size.id }));
      }
      return [{ id: "ALL", name: allSizesLabel }];
    };
    const hydrateLabourRatesFromGlobalDefaults = (activeSelection, scopeRows) => {
      const itemId = String(headerItemSelect?.value || "").trim();
      const defaults = labourDefaultsByItem[itemId] || null;
      const defaultRateMap = defaults && defaults.labour_rate_map && typeof defaults.labour_rate_map === "object"
        ? defaults.labour_rate_map
        : {};
      const nextRateMap = {};
      const nextLockedMap = {};
      activeSelection.forEach((row) => {
        scopeRows.forEach((scope) => {
          const scopeId = String(scope.id || "ALL");
          const sizeKey = scopeId || "ALL";
          const directKey = toLabourRateKey(row, sizeKey);
          const allKey = toLabourRateKey(row, "ALL");
          const resolvedRate = String(
            defaultRateMap[directKey]
            ?? (sizeKey === "ALL" ? "" : defaultRateMap[allKey])
            ?? "",
          ).trim();
          if (resolvedRate) nextRateMap[directKey] = resolvedRate;
          nextLockedMap[directKey] = true;
        });
      });
      state.labourRuleRateMap = nextRateMap;
      state.labourRuleLockedMap = nextLockedMap;
    };
    const syncLabourLinesFromSelectionAndRates = () => {
      const normalizedSelection = (Array.isArray(state.labour_selection) ? state.labour_selection : [])
        .map((row) => normalizeLabourSelectionRow(row));
      const activeSelection = normalizedSelection.filter((row) => row.labour_id && row.dept_id);
      state.labour_selection = normalizedSelection.length ? normalizedSelection : [defaultLabourSelectionRow()];

      if (!state.labourRuleRateMap || typeof state.labourRuleRateMap !== "object") {
        state.labourRuleRateMap = {};
      }
      if (!state.labourRuleLockedMap || typeof state.labourRuleLockedMap !== "object") {
        state.labourRuleLockedMap = {};
      }
      const scopeRows = getLabourSizeScopes();
      hydrateLabourRatesFromGlobalDefaults(activeSelection, scopeRows);
      const validSizeKeys = new Set(scopeRows.map((scope) => String(scope.id)));
      const validComboKeys = new Set(activeSelection.map((row) => toLabourComboKey(row)));
      Object.keys(state.labourRuleRateMap).forEach((key) => {
        const separatorIndex = key.lastIndexOf(":");
        if (separatorIndex <= 0) {
          delete state.labourRuleRateMap[key];
          delete state.labourRuleLockedMap[key];
          return;
        }
        const comboKey = key.slice(0, separatorIndex);
        const sizeKey = key.slice(separatorIndex + 1);
        if (!validComboKeys.has(comboKey) || !validSizeKeys.has(sizeKey)) {
          delete state.labourRuleRateMap[key];
          delete state.labourRuleLockedMap[key];
        }
      });

      const nextLines = [];
      activeSelection.forEach((row) => {
        scopeRows.forEach((scope) => {
          const scopeId = String(scope.id || "ALL");
          const directRate = state.labourRuleRateMap[toLabourRateKey(row, scopeId)];
          const inheritedRate = scopeId === "ALL" ? "" : state.labourRuleRateMap[toLabourRateKey(row, "ALL")];
          nextLines.push({
            size_scope: scopeId === "ALL" ? "ALL" : "SPECIFIC",
            size_id: scopeId === "ALL" ? null : scopeId,
            dept_id: row.dept_id || null,
            labour_id: row.labour_id || null,
            rate_type: row.rate_type || "PER_PAIR",
            rate_value: String(directRate ?? inheritedRate ?? "").trim(),
          });
        });
      });
      state.labour = nextLines;
    };
    const initializeLabourStateFromExistingLines = () => {
      const lines = Array.isArray(state.labour) ? state.labour : [];
      const selectionMap = new Map();
      const rateMap = {};
      lines.forEach((line) => {
        const selectionRow = normalizeLabourSelectionRow(line);
        const hasSelection = selectionRow.labour_id || selectionRow.dept_id;
        if (!hasSelection) return;
        const comboKey = toLabourComboKey(selectionRow);
        if (!selectionMap.has(comboKey)) {
          selectionMap.set(comboKey, selectionRow);
        }
        const rateValue = String(line?.rate_value ?? "").trim();
        if (!rateValue) return;
        const sizeKey = toLabourSizeKeyFromLine(line);
        if (!sizeKey) return;
        rateMap[toLabourRateKey(selectionRow, sizeKey)] = rateValue;
      });
      state.labour_selection = selectionMap.size ? Array.from(selectionMap.values()) : [defaultLabourSelectionRow()];
      state.labourRuleRateMap = rateMap;
      state.labourRuleLockedMap = {};
      syncLabourLinesFromSelectionAndRates();
    };
    const getHeaderSkuOptions = () => {
      const itemId = String(headerItemSelect?.value || "");
      const rows = options.itemSkuMap && Array.isArray(options.itemSkuMap[itemId]) ? options.itemSkuMap[itemId] : [];
      return rows;
    };
    const findHeaderSkuById = (skuId) =>
      getHeaderSkuOptions().find((row) => String(row.id || "") === String(skuId || "")) || null;
    const findHeaderSkuBySizeId = (sizeId) =>
      getHeaderSkuOptions().find((row) => String(row.size_id || "") === String(sizeId || "")) || null;
    const shouldShowSfgSection = () => {
      const level = String(headerLevelSelect?.value || "").trim().toUpperCase();
      if (level !== "FINISHED") return false;
      const item = getSelectedHeaderItem();
      if (!item) return false;
      if (String(item.item_type || "").toUpperCase() !== "FG") return false;
      return Boolean(item.uses_sfg);
    };
    const getLabourActiveSku = () => {
      const skuOptions = getHeaderSkuOptions();
      if (!skuOptions.length) {
        state.labourRuleOpenSkuId = "";
        return null;
      }
      const hasCurrent = skuOptions.some((sku) => String(sku.id) === String(state.labourRuleOpenSkuId || ""));
      if (!hasCurrent) state.labourRuleOpenSkuId = String(skuOptions[0].id);
      return skuOptions.find((sku) => String(sku.id) === String(state.labourRuleOpenSkuId || "")) || null;
    };
    const getLabourSizeKeyFromSku = (sku) => {
      const sizeId = String(sku?.size_id || "").trim();
      return sizeId || "ALL";
    };
    const showErrorModal = (message) => {
      const text = String(message || "").trim();
      if (!text) return;
      if (typeof window.showUiErrorModal === "function") {
        window.showUiErrorModal(text, "<%= t('error_generic')  %>");
      }
    };
    const getRmDuplicateCombo = () => {
      const seen = new Map();
      for (let idx = 0; idx < (state.rm || []).length; idx += 1) {
        const line = state.rm[idx] || {};
        const rmItemId = String(line.rm_item_id || "").trim();
        const deptId = String(line.dept_id || "").trim();
        if (!rmItemId || !deptId) continue;
        const key = `${rmItemId}:${deptId}`;
        if (seen.has(key)) return { firstIndex: seen.get(key), secondIndex: idx, key };
        seen.set(key, idx);
      }
      return null;
    };
    const getLabourSelectionDuplicateCombo = () => {
      const seen = new Map();
      for (let idx = 0; idx < (state.labour_selection || []).length; idx += 1) {
        const line = normalizeLabourSelectionRow(state.labour_selection[idx] || {});
        const labourId = String(line.labour_id || "").trim();
        const deptId = String(line.dept_id || "").trim();
        const rateType = normalizeLabourRateType(line.rate_type);
        if (!labourId || !deptId || !rateType) continue;
        const key = `${labourId}:${deptId}:${rateType}`;
        if (seen.has(key)) return { firstIndex: seen.get(key), secondIndex: idx, key };
        seen.set(key, idx);
      }
      return null;
    };
    const getStageRouteDuplicateCombo = () => {
      const seen = new Map();
      for (let idx = 0; idx < (state.stage_routes || []).length; idx += 1) {
        const line = state.stage_routes[idx] || {};
        const deptId = String(line.dept_id || "").trim();
        if (!deptId) continue;
        if (seen.has(deptId)) return { firstIndex: seen.get(deptId), secondIndex: idx, key: deptId };
        seen.set(deptId, idx);
      }
      return null;
    };
    const hasClientDuplicateCombos = () => {
      const rmDuplicate = getRmDuplicateCombo();
      if (rmDuplicate) {
        showErrorModal("<%= t('bom_error_rm_department_duplicate')  %>");
        return true;
      }
      const labourDuplicate = getLabourSelectionDuplicateCombo();
      if (labourDuplicate) {
        showErrorModal("<%= t('bom_error_labour_department_duplicate')  %>");
        return true;
      }
      const stageDuplicate = getStageRouteDuplicateCombo();
      if (stageDuplicate) {
        showErrorModal("<%= t('error_duplicate_name')  %>");
        return true;
      }
      return false;
    };
    const resolveRmDuplicateOnChange = (rowIndex, changedCol) => {
      const duplicate = getRmDuplicateCombo();
      if (!duplicate) return false;
      if (duplicate.firstIndex !== rowIndex && duplicate.secondIndex !== rowIndex) return false;
      const line = state.rm[rowIndex];
      if (!line) return false;
      if (changedCol === "rm_item_id") {
        line.rm_item_id = "";
        line.uom_id = "";
      } else if (changedCol === "dept_id") {
        line.dept_id = "";
      }
      showErrorModal("<%= t('bom_error_rm_department_duplicate')  %>");
      return true;
    };
    const resolveLabourSelectionDuplicateOnChange = (rowIndex, changedCol) => {
      const duplicate = getLabourSelectionDuplicateCombo();
      if (!duplicate) return false;
      if (duplicate.firstIndex !== rowIndex && duplicate.secondIndex !== rowIndex) return false;
      const line = state.labour_selection[rowIndex];
      if (!line) return false;
      if (changedCol === "labour_id") {
        line.labour_id = "";
      } else if (changedCol === "dept_id") {
        line.dept_id = "";
      } else if (changedCol === "rate_type") {
        line.rate_type = "PER_PAIR";
      }
      syncLabourLinesFromSelectionAndRates();
      showErrorModal("<%= t('bom_error_labour_department_duplicate')  %>");
      return true;
    };
    const findSkuOverride = (skuId, targetRmItemId, targetDeptId) =>
      (state.sku_override || []).find(
        (row) => String(row?.sku_id || "") === String(skuId || "")
          && String(row?.target_rm_item_id || "") === String(targetRmItemId || "")
          && String(row?.dept_id || "") === String(targetDeptId || ""),
      ) || (() => {
        const materialRows = (state.rm || []).filter(
          (line) => String(line?.rm_item_id || "") === String(targetRmItemId || ""),
        );
        const deptSet = new Set(
          materialRows
            .map((line) => String(line?.dept_id || "").trim())
            .filter(Boolean),
        );
        if (deptSet.size !== 1 || !deptSet.has(String(targetDeptId || "").trim())) return null;
        return (state.sku_override || []).find(
          (row) =>
            String(row?.sku_id || "") === String(skuId || "")
            && String(row?.target_rm_item_id || "") === String(targetRmItemId || "")
            && !String(row?.dept_id || "").trim(),
        ) || null;
      })();
    const getSkuCodeLabel = (sku) => {
      if (!sku) return "";
      return String(sku.sku_code || sku.code || sku.id || "").trim();
    };
    const getSkuLabel = (sku) => {
      if (!sku) return "";
      return getSkuCodeLabel(sku);
    };
    const getSkuVariantPeerIds = (skuId) => {
      const allSkus = getHeaderSkuOptions();
      const current = allSkus.find((row) => String(row.id) === String(skuId || ""));
      if (!current) return [];
      const key = [
        String(current.size_id || ""),
        String(current.color_id || ""),
        String(current.packing_type_id || ""),
      ].join("|");
      const peerIds = allSkus
        .filter((row) => String(row.id) !== String(current.id))
        .filter((row) => [
          String(row.size_id || ""),
          String(row.color_id || ""),
          String(row.packing_type_id || ""),
        ].join("|") === key)
        .map((row) => String(row.id || ""))
        .filter(Boolean);
      return peerIds;
    };
    const applyRulesToRmLineForSku = (rmLine, sku, overrideLine = null) => {
      const targetRmItemId = String(rmLine?.rm_item_id || "").trim();
      const deptId = String(rmLine?.dept_id || "").trim();
      if (!targetRmItemId) return null;
      let effectiveRmItemId = targetRmItemId;
      // SKU Rules are the source of qty truth; RM line qty is derived aggregate.
      let qty = 0;
      let qtyIsExplicit = false;
      let uomId = resolveRmUomId(rmLine) || "";
      let rmColorId = String(rmLine?.color_id || "").trim();
      let rmSizeId = String(rmLine?.size_id || "").trim();
      let excluded = false;

      if (overrideLine) {
        if (overrideLine.is_excluded) excluded = true;
        const overrideQtyRaw = String(overrideLine.override_qty ?? "").trim();
        const overrideQty = overrideQtyRaw === "" ? null : Number(overrideQtyRaw);
        if (Number.isFinite(overrideQty) && overrideQty >= 0) {
          qty = overrideQty;
          qtyIsExplicit = true;
        }
        if (String(overrideLine.replacement_rm_item_id || "").trim()) {
          effectiveRmItemId = String(overrideLine.replacement_rm_item_id);
          const overrideUomId = rmItemUomById.get(String(effectiveRmItemId || "")) || "";
          if (overrideUomId) uomId = overrideUomId;
        }
        if (String(overrideLine.rm_color_id || "").trim()) {
          rmColorId = String(overrideLine.rm_color_id).trim();
        }
        if (String(overrideLine.rm_size_id || "").trim()) {
          rmSizeId = String(overrideLine.rm_size_id).trim();
        }
      }

      return {
        targetRmItemId,
        effectiveRmItemId,
        qty,
        qtyIsExplicit,
        uomId,
        deptId,
        rmColorId,
        rmSizeId,
        excluded,
      };
    };
    const getSkuRulesRows = (skuId) => {
      const sku = getHeaderSkuOptions().find((row) => String(row.id) === String(skuId || ""));
      if (!sku) return [];
      const rmLines = (state.rm || []).filter((row) => String(row?.rm_item_id || "").trim());
      return rmLines.map((rmLine) => {
        const overrideLine = findSkuOverride(sku.id, rmLine.rm_item_id, rmLine.dept_id);
        const baseline = applyRulesToRmLineForSku(rmLine, sku, null);
        const effective = applyRulesToRmLineForSku(rmLine, sku, overrideLine);
        return {
          sku,
          baseline,
          effective,
        };
      }).filter((row) => row.baseline && row.effective);
    };
    const ensureSkuRuleOpenSku = () => {
      const skuOptions = getHeaderSkuOptions();
      if (!skuOptions.length) {
        state.skuRuleOpenSkuId = "";
        return null;
      }
      const hasCurrent = skuOptions.some((sku) => String(sku.id) === String(state.skuRuleOpenSkuId || ""));
      if (!hasCurrent) state.skuRuleOpenSkuId = String(skuOptions[0].id);
      return skuOptions.find((sku) => String(sku.id) === String(state.skuRuleOpenSkuId || "")) || null;
    };
    const upsertSkuOverrideLine = (nextLine) => {
      const skuId = String(nextLine?.sku_id || "");
      const targetRmItemId = String(nextLine?.target_rm_item_id || "");
      const targetDeptId = String(nextLine?.dept_id || "");
      if (!skuId || !targetRmItemId || !targetDeptId) return;
      const idx = (state.sku_override || []).findIndex(
        (row) =>
          String(row?.sku_id || "") === skuId
          && String(row?.target_rm_item_id || "") === targetRmItemId
          && String(row?.dept_id || "") === targetDeptId,
      );
      const hasAnyChange = Boolean(
        nextLine.is_excluded
        || String(nextLine.override_qty ?? "").trim() !== ""
        || String(nextLine.replacement_rm_item_id || "").trim()
        || String(nextLine.rm_color_id || "").trim()
        || String(nextLine.rm_size_id || "").trim(),
      );
      if (!hasAnyChange) {
        if (idx >= 0) state.sku_override.splice(idx, 1);
        return;
      }
      if (idx >= 0) {
        state.sku_override[idx] = { ...state.sku_override[idx], ...nextLine };
      } else {
        state.sku_override = (state.sku_override || []).filter((row) => !(
          String(row?.sku_id || "") === skuId
          && String(row?.target_rm_item_id || "") === targetRmItemId
          && !String(row?.dept_id || "").trim()
        ));
        state.sku_override.push(nextLine);
      }
    };
    const applySkuRuleRowToOverrides = (row) => {
      if (!(row instanceof HTMLElement)) return;
      const skuId = String(row.getAttribute("data-sku-id") || "");
      const targetRmItemId = String(row.getAttribute("data-target-rm-item-id") || "");
      const targetDeptId = String(row.getAttribute("data-target-dept-id") || "");
      if (!skuId || !targetRmItemId || !targetDeptId) return;
      const baselineQty = Number(row.getAttribute("data-baseline-qty") || 0);
      const baselineExplicit = String(row.getAttribute("data-baseline-explicit") || "") === "1";
      const baselineColorId = String(row.getAttribute("data-baseline-rm-color-id") || "");
      const baselineSizeId = String(row.getAttribute("data-baseline-rm-size-id") || "");
      const qtyInput = row.querySelector('[data-sku-rule-col="required_qty"]');
      const colorSelect = row.querySelector('[data-sku-rule-col="rm_color_id"]');
      const sizeSelect = row.querySelector('[data-sku-rule-col="rm_size_id"]');
      const enteredQtyRaw = String(qtyInput?.value ?? "").trim();
      const enteredQty = enteredQtyRaw === "" ? null : Number(enteredQtyRaw);
      const selectedColorId = String(colorSelect?.value || "").trim();
      const selectedSizeId = String(sizeSelect?.value || "").trim();
      const existing = findSkuOverride(skuId, targetRmItemId, targetDeptId) || {
        sku_id: skuId,
        target_rm_item_id: targetRmItemId,
        dept_id: targetDeptId,
        is_excluded: false,
        override_qty: null,
        override_uom_id: null,
        replacement_rm_item_id: null,
        rm_color_id: null,
        rm_size_id: null,
        notes: null,
      };
      const qtyDiff = Number.isFinite(enteredQty) && enteredQty >= 0 && (!baselineExplicit || Math.abs(enteredQty - baselineQty) > 1e-9);
      const colorDiff = selectedColorId && selectedColorId !== baselineColorId;
      const sizeDiff = selectedSizeId && selectedSizeId !== baselineSizeId;
      const nextLine = {
        ...existing,
        sku_id: skuId,
        target_rm_item_id: targetRmItemId,
        dept_id: targetDeptId,
        override_qty: qtyDiff ? enteredQty : null,
        rm_color_id: colorDiff ? selectedColorId : null,
        rm_size_id: sizeDiff ? selectedSizeId : null,
      };
      upsertSkuOverrideLine(nextLine);
      const peerSkuIds = getSkuVariantPeerIds(skuId);
      peerSkuIds.forEach((peerSkuId) => {
        upsertSkuOverrideLine({
          ...nextLine,
          sku_id: peerSkuId,
        });
      });
    };
    const syncSkuRulesFromDom = () => {
      const rows = Array.from(document.querySelectorAll("[data-sku-rule-row]"));
      rows.forEach((row) => applySkuRuleRowToOverrides(row));
    };
    const renderSkuRules = () => {
      if (!(skuRulesBody instanceof HTMLElement)) return;
      const skuOptions = getHeaderSkuOptions();
      const activeSku = ensureSkuRuleOpenSku();
      if (skuRuleChipsHost) {
        skuRuleChipsHost.innerHTML = skuOptions.length
          ? skuOptions.map((sku) => {
            const skuId = String(sku.id);
            const isActive = skuId === String(activeSku?.id || "");
            return `
              <button
                type="button"
                data-sku-rule-chip="${esc(skuId)}"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                title="${esc(getSkuCodeLabel(sku))}"
              >
                ${esc(getSkuCodeLabel(sku))}
              </button>
            `;
          }).join("")
          : `<span class="text-xs text-slate-500"><%= t("no_entries")  %></span>`;
      }
      if (!activeSku) {
        skuRulesBody.innerHTML = `<tr><td colspan="6" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_sku_available")  %></td></tr>`;
        return;
      }
      const rows = getSkuRulesRows(activeSku.id);
      if (!rows.length) {
        skuRulesBody.innerHTML = `<tr><td colspan="6" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_material_lines_for_sku_rules")  %></td></tr>`;
        return;
      }
      skuRulesBody.innerHTML = rows.map(({ sku, baseline, effective }, rowIndex) => {
        const materialName = rmItemNameById.get(String(effective.effectiveRmItemId || "")) || effective.effectiveRmItemId;
        const deptName = departmentNameById.get(String(effective.deptId || "")) || "";
        const uomName = getUomName(effective.uomId);
        const rmColorOptions = getRmColorsForItem(effective.effectiveRmItemId);
        const rmSizeOptions = getRmSizesForItem(effective.effectiveRmItemId);
        const baselineQty = Number(baseline.qty || 0);
        const baselineQtyExplicit = Boolean(baseline.qtyIsExplicit);
        const baselineColor = String(baseline.rmColorId || "");
        const baselineSize = String(baseline.rmSizeId || "");
        const qtyValue = effective.excluded
          ? ""
          : (effective.qtyIsExplicit ? String(effective.qty ?? "") : "");
        const rowClass = effective.excluded ? "opacity-60" : "";
        const colorControl = rmColorOptions.length
          ? `<select data-sku-rule-col="rm_color_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable && !effective.excluded ? "" : "disabled"}>
                <option value="">${esc(labels.select)}</option>
                ${makeOptions(rmColorOptions, effective.rmColorId)}
              </select>`
          : `<input type="text" value="-" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-500" readonly>`;
        const sizeControl = rmSizeOptions.length
          ? `<select data-sku-rule-col="rm_size_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable && !effective.excluded ? "" : "disabled"}>
                <option value="">${esc(labels.select)}</option>
                ${makeOptions(rmSizeOptions, effective.rmSizeId)}
              </select>`
          : `<input type="text" value="-" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-500" readonly>`;
        return `
          <tr
            class="border-b border-slate-100 ${rowClass}"
            data-sku-rule-row="true"
            data-row-index="${rowIndex}"
            data-sku-id="${esc(sku.id)}"
            data-target-rm-item-id="${esc(effective.targetRmItemId)}"
            data-target-dept-id="${esc(effective.deptId)}"
            data-baseline-qty="${esc(baselineQty)}"
            data-baseline-explicit="${baselineQtyExplicit ? "1" : "0"}"
            data-baseline-rm-color-id="${esc(baselineColor)}"
            data-baseline-rm-size-id="${esc(baselineSize)}"
          >
            <td class="px-3 py-2 font-medium text-slate-700">${esc(materialName)}</td>
            <td class="px-3 py-2 text-slate-600">${esc(deptName)}</td>
            <td class="px-3 py-2">
              ${colorControl}
            </td>
            <td class="px-3 py-2">
              ${sizeControl}
            </td>
            <td class="px-3 py-2">
              <input data-sku-rule-col="required_qty" data-no-stepper="true" type="number" min="0" step="0.001" value="${esc(qtyValue)}" ${editable && !effective.excluded ? "" : "readonly"} class="w-32 rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm ${effective.excluded ? "bg-slate-50 text-slate-500" : ""}">
            </td>
            <td class="px-3 py-2 text-slate-600">${esc(uomName)}</td>
          </tr>
        `;
      }).join("");
    };
    const buildSkuRulesForSubmission = () => {
      const errors = [];
      const entries = [];
      const rmLines = (state.rm || []).filter(
        (row) => String(row?.rm_item_id || "").trim() && String(row?.dept_id || "").trim(),
      );
      if (!rmLines.length) return { entries, errors };

      const skuOptions = getHeaderSkuOptions();
      if (!skuOptions.length) {
        errors.push("<%= t('bom_no_sku_available')  %>");
        return { entries, errors };
      }

      skuOptions.forEach((sku) => {
        rmLines.forEach((rmLine) => {
          const overrideLine = findSkuOverride(sku.id, rmLine.rm_item_id, rmLine.dept_id);
          const baseline = applyRulesToRmLineForSku(rmLine, sku, null);
          const effective = applyRulesToRmLineForSku(rmLine, sku, overrideLine);
          if (!effective || effective.excluded) return;
          const hasExplicitQty = Boolean(effective.qtyIsExplicit);
          const hasColorOverride = String(effective.rmColorId || "").trim() !== String(baseline?.rmColorId || "").trim();
          const hasSizeOverride = String(effective.rmSizeId || "").trim() !== String(baseline?.rmSizeId || "").trim();
          const hasReplacement = String(effective.effectiveRmItemId || "").trim() !== String(effective.targetRmItemId || "").trim();
          if (!hasExplicitQty && !hasColorOverride && !hasSizeOverride && !hasReplacement) return;
          const qty = hasExplicitQty ? Number(effective.qty) : null;
          const rmName = rmItemNameById.get(String(effective.targetRmItemId || "")) || String(effective.targetRmItemId || "");
          const deptName = departmentNameById.get(String(effective.deptId || "")) || String(effective.deptId || "");
          const skuCode = getSkuCodeLabel(sku) || String(sku?.id || "");
          if (qty !== null && (!Number.isFinite(qty) || qty < 0)) {
            errors.push(`SKU ${skuCode}: ${rmName} / ${deptName} -> <%= t("bom_rules_col_qty")  %>.`);
            return;
          }
          entries.push({
            sku_id: String(sku.id || "").trim(),
            target_rm_item_id: String(effective.targetRmItemId || "").trim(),
            dept_id: String(effective.deptId || "").trim(),
            rm_color_id: String(effective.rmColorId || "").trim(),
            rm_size_id: String(effective.rmSizeId || "").trim(),
            replacement_rm_item_id: hasReplacement ? String(effective.effectiveRmItemId || "").trim() : "",
            required_qty: qty === null ? null : Number((Math.round(qty * 1000) / 1000).toFixed(3)),
            uom_id: String(effective.uomId || "").trim(),
          });
        });
      });
      return { entries, errors };
    };
    const aggregateRmLinesFromSkuRules = (skuRuleEntries) => {
      const qtyByRmDept = new Map();
      (skuRuleEntries || []).forEach((entry) => {
        const rmItemId = String(entry?.target_rm_item_id || "").trim();
        const deptId = String(entry?.dept_id || "").trim();
        const qtyRaw = entry?.required_qty;
        const qty = qtyRaw === null || qtyRaw === "" ? null : Number(qtyRaw);
        if (!rmItemId || !deptId || qty === null || !Number.isFinite(qty) || qty < 0) return;
        const key = `${rmItemId}:${deptId}`;
        const existing = qtyByRmDept.get(key) || { total: 0, count: 0 };
        qtyByRmDept.set(key, {
          total: Number(existing.total || 0) + qty,
          count: Number(existing.count || 0) + 1,
        });
      });
      const seen = new Set();
      return (state.rm || [])
        .map((line) => {
          const rmItemId = String(line?.rm_item_id || "").trim();
          const deptId = String(line?.dept_id || "").trim();
          if (!rmItemId || !deptId) return null;
          const key = `${rmItemId}:${deptId}`;
          if (seen.has(key)) return null;
          seen.add(key);
          const qtySummary = qtyByRmDept.get(`${rmItemId}:${deptId}`) || { total: 0, count: 0 };
          const ruleCount = Number(qtySummary.count || 0);
          const averageQty = ruleCount > 0
            ? Number((Number(qtySummary.total || 0) / ruleCount).toFixed(3))
            : Number(line?.qty || 0);
          return {
            rm_item_id: rmItemId,
            color_id: String(line?.color_id || "").trim(),
            size_id: String(line?.size_id || "").trim(),
            dept_id: deptId,
            qty: Number((Math.round(averageQty * 1000) / 1000).toFixed(3)),
            rule_count: ruleCount,
            uom_id: resolveRmUomId(line) || "",
            normal_loss_pct: line?.normal_loss_pct ?? 0,
          };
        })
        .filter(Boolean);
    };

    const getRelevantSfgSkus = () => {
      const headerItemId = String(headerItemSelect?.value || "");
      const linkedSfgItemIds = Array.isArray(options.fgToSfgMap?.[headerItemId]) ? options.fgToSfgMap[headerItemId] : [];
      if (linkedSfgItemIds.length) {
        const itemIdSet = new Set(linkedSfgItemIds.map((id) => String(id)));
        return (options.sfgSkus || []).filter((sku) => itemIdSet.has(String(sku.item_id || "")));
      }
      return [];
    };
    const getPlannedOutputQtyValue = () => {
      const raw = String(document.querySelector('input[name="output_qty"]')?.value || "").trim();
      const qty = Number(raw);
      if (!Number.isFinite(qty) || qty <= 0) return "";
      return String(qty);
    };
    const getPlannedOutputQtyNumber = () => {
      const qty = Number(getPlannedOutputQtyValue());
      return Number.isFinite(qty) && qty > 0 ? qty : null;
    };
    const formatQtyForInput = (qty) => {
      const numeric = Number(qty);
      if (!Number.isFinite(numeric) || numeric <= 0) return "";
      return String(Math.round(numeric * 1000) / 1000);
    };
    const getUomConversionFactor = (fromUomId, toUomId) => {
      const fromKey = String(fromUomId || "").trim();
      const toKey = String(toUomId || "").trim();
      if (!fromKey || !toKey || fromKey === toKey) return 1;
      const direct = Number(uomConversionMap?.[fromKey]?.[toKey]);
      if (Number.isFinite(direct) && direct > 0) return direct;
      const reverse = Number(uomConversionMap?.[toKey]?.[fromKey]);
      if (Number.isFinite(reverse) && reverse > 0) return 1 / reverse;
      return null;
    };
    const getDefaultSfgRequiredQty = (selectedSfgSkuId) => {
      const plannedOutputQty = getPlannedOutputQtyNumber();
      if (!plannedOutputQty) return "";
      const outputUomId = String(headerOutputUomSelect?.value || "").trim();
      const sfgUomId = String(sfgSkuUomById.get(String(selectedSfgSkuId || "").trim()) || "").trim();
      if (!outputUomId || !sfgUomId) return formatQtyForInput(plannedOutputQty);
      const factor = getUomConversionFactor(outputUomId, sfgUomId);
      if (!factor) return "";
      return formatQtyForInput(plannedOutputQty * factor);
    };

    const isHeaderReady = () => {
      const level = String(headerLevelSelect?.value || "").trim();
      const itemId = String(headerItemSelect?.value || "").trim();
      const outputQty = Number(document.querySelector('input[name="output_qty"]')?.value || 0);
      const outputUom = String(document.querySelector('select[name="output_uom_id"]')?.value || "").trim();
      return Boolean(level && itemId && outputQty > 0 && outputUom);
    };

    const updateHeaderSectionState = () => {
      const ready = isHeaderReady();
      nonHeaderSections.forEach((section) => {
        section.classList.toggle("hidden", !ready);
      });
      if (sfgSection) {
        const showSfg = ready && shouldShowSfgSection();
        sfgSection.classList.toggle("hidden", !showSfg);
      }
      updateSfgPartColumnPresentation();
      if (headerLockNotice) headerLockNotice.classList.toggle("hidden", ready);
    };
    const getHeaderState = () => ({
      level: String(headerLevelSelect?.value || "").trim(),
      item_id: String(headerItemSelect?.value || "").trim(),
      output_qty: String(document.querySelector('input[name="output_qty"]')?.value || "").trim(),
      output_uom_id: String(document.querySelector('select[name="output_uom_id"]')?.value || "").trim(),
    });
    const isHeaderStateReady = (headerState) => {
      const state = headerState || {};
      const level = String(state.level || "").trim();
      const itemId = String(state.item_id || "").trim();
      const outputUom = String(state.output_uom_id || "").trim();
      const outputQty = Number(state.output_qty || 0);
      return Boolean(level && itemId && outputQty > 0 && outputUom);
    };
    const isSameHeaderState = (a, b) =>
      String(a?.level || "") === String(b?.level || "")
      && String(a?.item_id || "") === String(b?.item_id || "")
      && String(a?.output_qty || "") === String(b?.output_qty || "")
      && String(a?.output_uom_id || "") === String(b?.output_uom_id || "");
    const getHeaderChangeKind = (previousState, nextState) => {
      const prev = previousState || {};
      const next = nextState || {};
      const levelChanged = String(prev.level || "") !== String(next.level || "");
      const itemChanged = String(prev.item_id || "") !== String(next.item_id || "");
      const qtyChanged = String(prev.output_qty || "") !== String(next.output_qty || "");
      const uomChanged = String(prev.output_uom_id || "") !== String(next.output_uom_id || "");
      if (levelChanged || itemChanged) return "identity";
      if (uomChanged) return "uom";
      if (qtyChanged) return "qty";
      return "none";
    };
    const clearSwitchAfterSaveIntent = () => {
      if (switchAfterSaveInput) switchAfterSaveInput.value = "0";
      if (switchLevelInput) switchLevelInput.value = "";
      if (switchItemIdInput) switchItemIdInput.value = "";
      if (switchOutputQtyInput) switchOutputQtyInput.value = "";
      if (switchOutputUomInput) switchOutputUomInput.value = "";
    };
    const setSwitchAfterSaveIntent = (nextState) => {
      clearSwitchAfterSaveIntent();
      if (!nextState) return;
      if (switchAfterSaveInput) switchAfterSaveInput.value = "1";
      if (switchLevelInput) switchLevelInput.value = String(nextState.level || "");
      if (switchItemIdInput) switchItemIdInput.value = String(nextState.item_id || "");
      if (switchOutputQtyInput) switchOutputQtyInput.value = String(nextState.output_qty || "");
      if (switchOutputUomInput) switchOutputUomInput.value = String(nextState.output_uom_id || "");
    };
    const clearQuantityFieldsForHeaderChange = () => {
      suppressNextSfgQtyAutofill = true;
      (state.rm || []).forEach((line) => {
        if (!line) return;
        line.qty = "";
      });
      (state.sfg || []).forEach((line) => {
        if (!line) return;
        line.required_qty = "";
      });
      (state.sku_override || []).forEach((line) => {
        if (!line) return;
        line.override_qty = "";
      });
      // Also clear live inputs so next syncStateFromDom does not repopulate cleared values.
      Array.from(document.querySelectorAll('[data-lines-body="sfg"] [data-col="required_qty"]')).forEach((input) => {
        if (input instanceof HTMLInputElement) input.value = "";
      });
      Array.from(document.querySelectorAll('[data-sku-rules-body] [data-sku-rule-col="required_qty"]')).forEach((input) => {
        if (input instanceof HTMLInputElement) input.value = "";
      });
    };
    const applyHeaderState = (nextState) => {
      const safeState = nextState || {};
      applyingHeaderState = true;
      if (headerLevelSelect) headerLevelSelect.value = String(safeState.level || "");
      renderHeaderItemsByLevel(false);
      if (headerItemSelect) {
        const itemId = String(safeState.item_id || "");
        const hasItem = Array.from(headerItemSelect.options || []).some((opt) => String(opt.value || "") === itemId);
        headerItemSelect.value = hasItem ? itemId : "";
      }
      const outputQtyInput = document.querySelector('input[name="output_qty"]');
      if (outputQtyInput) outputQtyInput.value = String(safeState.output_qty || "");
      renderOutputUomOptions(String(safeState.output_uom_id || ""));
      applyingHeaderState = false;
      syncStateFromDom();
      updateHeaderSectionState();
      renderAll();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
    };
    const hasDependentBomData = () => {
      const hasStageRoutes = (state.stage_routes || []).some((row) =>
        String(row?.dept_id || "").trim(),
      );
      const hasRm = (state.rm || []).some((row) =>
        String(row?.rm_item_id || "").trim()
        || String(row?.dept_id || "").trim(),
      );
      const hasSfg = (state.sfg || []).some((row) =>
        String(row?.sfg_sku_id || "").trim()
        || Number(row?.required_qty || 0) > 0,
      );
      const hasLabourSelection = (state.labour_selection || []).some((row) =>
        String(row?.labour_id || "").trim()
        || String(row?.dept_id || "").trim(),
      );
      const hasLabourRates = (state.labour || []).some((row) => String(row?.rate_value || "").trim());
      const hasSkuOverrides = (state.sku_override || []).some((row) =>
        Boolean(row?.is_excluded)
        || String(row?.override_qty || "").trim()
        || String(row?.replacement_rm_item_id || "").trim()
        || String(row?.rm_color_id || "").trim()
        || String(row?.rm_size_id || "").trim(),
      );
      return hasStageRoutes || hasRm || hasSfg || hasLabourSelection || hasLabourRates || hasSkuOverrides;
    };
    const resetDependentBomStateForHeaderChange = () => {
      state.rm = editable ? [addDefaults.rm()] : [];
      state.sfg = [];
      state.stage_routes = editable ? [addDefaults.stage_route()] : [];
      state.labour_selection = editable ? [defaultLabourSelectionRow()] : [];
      state.labourRuleRateMap = {};
      state.labourRuleLockedMap = {};
      state.labour = [];
      state.labourRuleOpenSkuId = "";
      state.labourRuleOpenFallbackSizeId = null;
      state.sku_override = [];
      state.skuRuleOpenSkuId = "";
      syncLabourLinesFromSelectionAndRates();
    };
    const applyLabourDefaultsForSelectedItem = (force = false) => {
      const itemId = String(headerItemSelect?.value || "").trim();
      if (!itemId) return false;
      const defaults = labourDefaultsByItem[itemId];
      const hasSelectionValues = (state.labour_selection || []).some((row) =>
        String(row?.labour_id || "").trim()
        || String(row?.dept_id || "").trim(),
      );
      const hasRateValues = Object.keys(state.labourRuleRateMap || {}).length > 0
        || (state.labour || []).some((row) => String(row?.rate_value || "").trim());
      if (!force && (hasSelectionValues || hasRateValues)) return false;

      if (!defaults || !Array.isArray(defaults.labour_selection) || !defaults.labour_selection.length) {
        if (force) {
          state.labour_selection = editable ? [defaultLabourSelectionRow()] : [];
          state.labourRuleRateMap = {};
          state.labourRuleLockedMap = {};
          syncLabourLinesFromSelectionAndRates();
        }
        return false;
      }

      state.labour_selection = defaults.labour_selection.map((row) => normalizeLabourSelectionRow(row));
      ensureStageRoutesCoverDepartments(
        state.labour_selection.map((row) => String(row?.dept_id || "").trim()).filter(Boolean),
      );
      state.labourRuleRateMap = {};
      state.labourRuleLockedMap = {};
      Object.entries(defaults.labour_rate_map || {}).forEach(([key, value]) => {
        const text = String(value || "").trim();
        if (!text) return;
        state.labourRuleRateMap[key] = text;
      });
      Object.entries(defaults.labour_rate_locked_map || {}).forEach(([key, value]) => {
        if (!value) return;
        state.labourRuleLockedMap[key] = true;
      });
      syncLabourLinesFromSelectionAndRates();
      return true;
    };
    const commitHeaderChange = (changedField, config = {}) => {
      const syncFromDom = config?.syncFromDom !== false;
      const field = String(changedField || "").trim();
      const isIdentityField = field === "level" || field === "item_id";
      if (field === "level" || field === "item_id") {
        renderHeaderItemsByLevel(true);
        applyLabourDefaultsForSelectedItem(true);
      }
      const shouldSyncFromDom = syncFromDom && !isIdentityField;
      if (shouldSyncFromDom) {
        syncStateFromDom();
      } else {
        syncLabourLinesFromSelectionAndRates();
      }
      updateHeaderSectionState();
      renderAll();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      headerCommittedState = getHeaderState();
    };
    const decodeHtmlEntities = (value) =>
      String(value ?? "")
        .replace(/&amp;/gi, "&")
        .replace(/&lt;/gi, "<")
        .replace(/&gt;/gi, ">")
        .replace(/&quot;/gi, "\"")
        .replace(/&#39;/gi, "'");
    const openHeaderChangeModal = (config = {}) =>
      new Promise((resolve) => {
        if (!(headerChangeModal instanceof HTMLElement)) {
          resolve("cancel");
          return;
        }
        if (headerModalTitleEl) {
          headerModalTitleEl.textContent = decodeHtmlEntities(config.title || "<%= tx('bom_header_change_modal_title', 'BOM setup changed') %>");
        }
        if (headerModalMessageEl) {
          headerModalMessageEl.textContent = decodeHtmlEntities(config.message || "<%= tx('bom_header_change_modal_message', 'You changed BOM Setup fields. This affects material, SFG, and labour sections.') %>");
        }
        if (headerModalHintEl) {
          headerModalHintEl.textContent = decodeHtmlEntities(config.hint || "<%= tx('bom_header_change_modal_hint', 'Save Draft & Switch: saves current draft and opens selected BOM context. Apply: keeps new header values and clears impacted sections.') %>");
        }
        if (headerModalApplyBtn) {
          headerModalApplyBtn.textContent = decodeHtmlEntities(config.applyLabel || "<%= tx('bom_header_change_modal_apply', 'Apply') %>");
        }
        if (headerModalSecondaryBtn) {
          const hasSecondary = Boolean(config.secondaryLabel);
          headerModalSecondaryBtn.classList.toggle("hidden", !hasSecondary);
          if (hasSecondary) headerModalSecondaryBtn.textContent = decodeHtmlEntities(config.secondaryLabel);
        }
        let settled = false;
        const close = (result) => {
          if (settled) return;
          settled = true;
          document.removeEventListener("keydown", onKeydown);
          headerChangeModal.removeEventListener("click", onBackdropClick);
          headerModalApplyBtn?.removeEventListener("click", onApply);
          headerModalSecondaryBtn?.removeEventListener("click", onSecondary);
          headerModalCloseBtn?.removeEventListener("click", onCancel);
          headerChangeModal.classList.add("hidden");
          headerChangeModal.classList.remove("flex");
          resolve(result);
        };
        const onApply = () => close("apply");
        const onSecondary = () => close("secondary");
        const onCancel = () => close("cancel");
        const onKeydown = (event) => {
          if (event.key === "Escape") {
            event.preventDefault();
            close("cancel");
          }
        };
        const onBackdropClick = (event) => {
          if (event.target === headerChangeModal) close("cancel");
        };
        headerModalApplyBtn?.addEventListener("click", onApply);
        headerModalSecondaryBtn?.addEventListener("click", onSecondary);
        headerModalCloseBtn?.addEventListener("click", onCancel);
        document.addEventListener("keydown", onKeydown);
        headerChangeModal.addEventListener("click", onBackdropClick);
        headerChangeModal.classList.remove("hidden");
        headerChangeModal.classList.add("flex");
        window.setTimeout(() => {
          if (headerModalApplyBtn instanceof HTMLElement) headerModalApplyBtn.focus();
        }, 0);
      });

    const renderRm = () => {
      const body = document.querySelector('[data-lines-body="rm"]');
      if (!body) return;
      const rmDepartmentOptions = getDraftFallbackDepartments();
      const skuRuleEntries = buildSkuRulesForSubmission().entries || [];
      const aggregatedRmLines = aggregateRmLinesFromSkuRules(skuRuleEntries);
      const aggregatedQtyByRmDept = new Map(
        (aggregatedRmLines || []).map((line) => [
          `${String(line?.rm_item_id || "").trim()}:${String(line?.dept_id || "").trim()}`,
          {
            qty: Number(line?.qty || 0),
            ruleCount: Number(line?.rule_count || 0),
          },
        ]),
      );
      body.innerHTML = state.rm
        .map((row, idx) => {
          const fixedUomId = resolveRmUomId(row);
          const fixedUomName = getUomName(fixedUomId);
          const rmItemId = String(row?.rm_item_id || "").trim();
          const deptId = String(row?.dept_id || "").trim();
          const rmColorOptions = getRmColorsForItem(rmItemId);
          const rmSizeOptions = getRmSizesForItem(rmItemId);
          const colorMeta = getReadonlyVariantMeta(rmColorOptions, row?.color_id);
          const sizeMeta = getReadonlyVariantMeta(rmSizeOptions, row?.size_id);
          if (String(row?.color_id || "").trim() !== colorMeta.value) row.color_id = colorMeta.value;
          if (String(row?.size_id || "").trim() !== sizeMeta.value) row.size_id = sizeMeta.value;
          const comboKey = `${rmItemId}:${deptId}`;
          const aggregateSummary = aggregatedQtyByRmDept.get(comboKey);
          const aggregatedQty = aggregateSummary
            ? Number(aggregateSummary.qty || 0)
            : Number(row?.qty || 0);
          const normalizedQty = Number.isFinite(aggregatedQty) && aggregatedQty >= 0
            ? (Math.round(aggregatedQty * 1000) / 1000)
            : 0;
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2"><select data-col="rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.rmItems || [], row.rm_item_id, (r) => r.name || r.code || r.id)}</select></td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="color_id" value="${esc(colorMeta.value)}" />
              <input type="text" data-col-display="color_id" value="${esc(colorMeta.label)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly tabindex="-1">
            </td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="size_id" value="${esc(sizeMeta.value)}" />
              <input type="text" data-col-display="size_id" value="${esc(sizeMeta.label)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly tabindex="-1">
            </td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="uom_id" value="${esc(fixedUomId)}" />
              <input type="text" data-col-display="uom_id" value="${esc(fixedUomName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly>
            </td>
            <td class="px-3 py-2"><select data-col="dept_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(rmDepartmentOptions, row.dept_id)}</select></td>
            <td class="px-3 py-2">
              <input data-col="qty" data-no-stepper="true" type="number" min="0" step="0.001" value="${esc(normalizedQty)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly tabindex="-1">
            </td>
            <td class="px-3 py-2">
              <input data-col="normal_loss_pct" data-no-stepper="true" type="number" min="0" max="100" step="0.001" value="${esc(row.normal_loss_pct ?? 0)}" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "readonly"}>
            </td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("rm") : ""}</td>
          </tr>`;
        })
        .join("");
    };

    const renderSfg = () => {
      const body = document.querySelector('[data-lines-body="sfg"]');
      if (!body) return;
      if (!shouldShowSfgSection()) {
        body.innerHTML = "";
        return;
      }
      const fgSkuOptions = getHeaderSkuOptions().filter((sku) => Number(sku?.size_id || 0) > 0);
      const sfgOptions = getRelevantSfgSkus();
      const stageChoices = getSelectedStageChoicesForSfg();
      if (!fgSkuOptions.length) {
        body.innerHTML = `<tr><td colspan="5" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_sku_available")  %></td></tr>`;
        return;
      }
      const existingBySkuId = new Map((state.sfg || []).map((row) => [String(row?.fg_sku_id || ""), row]));
      const existingBySizeId = new Map((state.sfg || []).map((row) => [String(row?.fg_size_id || ""), row]));
      const nextSfg = fgSkuOptions.map((sku) => {
        const bySku = existingBySkuId.get(String(sku.id || ""));
        const bySize = existingBySizeId.get(String(sku.size_id || ""));
        const existing = bySku || bySize || {};
        const selectedSfgSkuId = String(existing?.sfg_sku_id || "");
        const resolvedUomId = sfgSkuUomById.get(selectedSfgSkuId) || String(existing?.uom_id || "");
        const existingQtyText = String(existing?.required_qty ?? "").trim();
        const defaultRequiredQty = selectedSfgSkuId ? getDefaultSfgRequiredQty(selectedSfgSkuId) : "";
        return {
          fg_sku_id: String(sku.id || ""),
          fg_size_id: String(sku.size_id || ""),
          sfg_sku_id: selectedSfgSkuId,
          required_qty: existingQtyText || (suppressNextSfgQtyAutofill ? "" : defaultRequiredQty),
          consumed_in_stage_id: String(existing?.consumed_in_stage_id || ""),
          uom_id: String(resolvedUomId || ""),
        };
      });
      state.sfg = nextSfg;
      suppressNextSfgQtyAutofill = false;
      body.innerHTML = nextSfg
        .map((row, idx) => {
          const mappedFgSku = findHeaderSkuById(row.fg_sku_id);
          const fgSkuLabel = getSkuLabel(mappedFgSku) || mappedFgSku?.sku_code || row.fg_sku_id;
          const fgSizeId = String(mappedFgSku?.size_id || row.fg_size_id || "");
          const fixedUomId = resolveSfgUomId(row);
          const fixedUomName = getUomName(fixedUomId);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2">
              <input type="hidden" data-col="fg_sku_id" value="${esc(row.fg_sku_id)}">
              <input type="hidden" data-col="fg_size_id" value="${esc(fgSizeId)}">
              <input type="text" value="${esc(fgSkuLabel)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-700" readonly>
            </td>
            <td class="px-3 py-2"><select data-col="sfg_sku_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(sfgOptions, row.sfg_sku_id, (r) => getSkuLabel(r) || r.item_name || r.id)}</select></td>
            <td class="px-3 py-2"><input data-col="required_qty" data-no-stepper="true" type="number" min="0.001" step="0.001" value="${esc(row.required_qty ?? "")}" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "readonly"}></td>
            <td class="px-3 py-2"><select data-col="consumed_in_stage_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(stageChoices, row.consumed_in_stage_id, (r) => r.name || r.id)}</select></td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="uom_id" value="${esc(fixedUomId)}">
              <input type="text" data-col-display="uom_id" value="${esc(fixedUomName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly>
            </td>
          </tr>`;
        })
        .join("");
    };

    const renderStageRoutes = () => {
      const body = document.querySelector('[data-lines-body="stage_route"]');
      if (!(body instanceof HTMLElement)) return;
      const lines = Array.isArray(state.stage_routes) ? state.stage_routes : [];
      if (!lines.length && editable) {
        state.stage_routes = [addDefaults.stage_route()];
      }
      const rows = Array.isArray(state.stage_routes) ? state.stage_routes : [];
      const selectedDeptCount = new Map();
      rows.forEach((line) => {
        const selectedDeptId = String(line?.dept_id || "").trim();
        if (!selectedDeptId) return;
        selectedDeptCount.set(selectedDeptId, Number(selectedDeptCount.get(selectedDeptId) || 0) + 1);
      });
      body.innerHTML = rows
        .map((row, idx) => {
          const stageId = String(row?.stage_id || "").trim();
          const deptId = String(row?.dept_id || stageById.get(stageId)?.dept_id || "").trim();
          const isRequired = row?.is_required !== false;
          const enforceSequence = row?.enforce_sequence !== false;
          const deptOptionsForRow = (stageDeptOptions || []).filter((option) => {
            const optionId = String(option?.id || "").trim();
            if (!optionId) return false;
            if (optionId === deptId) return true;
            return !selectedDeptCount.has(optionId);
          });
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2 text-sm font-semibold text-slate-600">${idx + 1}</td>
            <td class="px-3 py-2">
              <select data-col="dept_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}>
                <option value="">${labels.select}</option>
                ${makeOptions(deptOptionsForRow, deptId, (r) => r.name || r.id)}
              </select>
            </td>
            <td class="px-3 py-2 text-center">
              <input type="checkbox" data-col="is_required" class="h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-700" ${isRequired ? "checked" : ""} ${editable ? "" : "disabled"}>
            </td>
            <td class="px-3 py-2 text-center">
              <input type="checkbox" data-col="enforce_sequence" class="h-4 w-4 rounded border-slate-300 text-slate-900 focus:ring-slate-700" ${enforceSequence ? "checked" : ""} ${editable ? "" : "disabled"}>
            </td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("stage_route") : ""}</td>
          </tr>
          `;
        })
        .join("");
    };

    const renderLabourSelection = () => {
      const body = document.querySelector('[data-lines-body="labour_selection"]');
      if (!body) return;
      const lines = Array.isArray(state.labour_selection) ? state.labour_selection : [];
      body.innerHTML = lines
        .map((row, idx) => {
          const normalizedRow = normalizeLabourSelectionRow(row);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2"><select data-col="labour_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.labours || [], normalizedRow.labour_id, (r) => r.name || r.code || r.id)}</select></td>
            <td class="px-3 py-2"><select data-col="dept_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(getLabourDepartmentsForLabour(normalizedRow.labour_id), normalizedRow.dept_id)}</select></td>
            <td class="px-3 py-2"><select data-col="rate_type" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions((options.labourRateTypeOptions || []).map((r) => ({ value: r.value, id: r.value })), normalizedRow.rate_type, (r) => rateTypeLabel[r.value] || r.value)}</select></td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("labour_selection") : ""}</td>
          </tr>`;
        })
        .join("");
    };

    const renderLabourRules = () => {
      syncLabourLinesFromSelectionAndRates();
      const body = document.querySelector('[data-lines-body="labour_rule"]');
      if (!(body instanceof HTMLElement)) return;
      const skuOptions = getHeaderSkuOptions();
      const activeSku = getLabourActiveSku();
      const sizeScopes = getLabourSizeScopes();
      const hasSkuOptions = skuOptions.length > 0;
      let activeSizeKey = "ALL";
      if (labourRuleSkuChipsHost) {
        if (hasSkuOptions) {
          labourRuleSkuChipsHost.innerHTML = skuOptions.map((sku) => {
            const skuId = String(sku.id || "");
            const isActive = skuId === String(activeSku?.id || "");
            const label = getSkuCodeLabel(sku) || String(sku.sku_code || sku.id || "");
            return `
              <button
                type="button"
                data-labour-rule-chip="${esc(skuId)}"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                title="${esc(label)}"
              >
                ${esc(label)}
              </button>
            `;
          }).join("");
        } else {
          if (!state.labourRuleOpenFallbackSizeId || !sizeScopes.some((scope) => String(scope.id) === String(state.labourRuleOpenFallbackSizeId))) {
            state.labourRuleOpenFallbackSizeId = sizeScopes.length ? String(sizeScopes[0].id) : "ALL";
          }
          labourRuleSkuChipsHost.innerHTML = sizeScopes.map((scope) => {
            const scopeId = String(scope.id || "ALL");
            const isActive = scopeId === String(state.labourRuleOpenFallbackSizeId || "");
            return `
              <button
                type="button"
                data-labour-rule-fallback-size="${esc(scopeId)}"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                title="${esc(scope.name || scopeId)}"
              >
                ${esc(scope.name || scopeId)}
              </button>
            `;
          }).join("");
        }
      }
      if (hasSkuOptions) {
        if (!activeSku) {
          body.innerHTML = `<tr><td colspan="4" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_sku_available")  %></td></tr>`;
          return;
        }
        activeSizeKey = getLabourSizeKeyFromSku(activeSku);
      } else {
        activeSizeKey = String(state.labourRuleOpenFallbackSizeId || sizeScopes[0]?.id || "ALL");
      }
      const activeRows = (state.labour || []).filter((row) => {
        const sizeKey = toLabourSizeKeyFromLine(row);
        return String(sizeKey || "ALL") === activeSizeKey;
      });
      if (!activeRows.length) {
        body.innerHTML = `<tr><td colspan="4" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_labour_selected")  %></td></tr>`;
        return;
      }
      body.innerHTML = activeRows
        .map((row, idx) => {
          const labourId = String(row?.labour_id || "");
          const deptId = String(row?.dept_id || "");
          const rateType = normalizeLabourRateType(row?.rate_type);
          const selectionRow = { labour_id: labourId, dept_id: deptId, rate_type: rateType };
          const locked = true;
          const labourName = labourNameById.get(labourId) || labourId || "-";
          const deptName = departmentNameById.get(deptId) || deptId || "-";
          const lockHint = locked
            ? `<div class="mt-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500">${esc("<%= t('bom_labour_locked_from_rates')  %>")}</div>`
            : "";
          return `
            <tr data-row-index="${idx}" data-labour-rule-entry="true" data-labour-id="${esc(labourId)}" data-dept-id="${esc(deptId)}" data-rate-type="${esc(rateType)}" data-size-id="${esc(activeSizeKey)}" data-rate-locked="${locked ? "1" : "0"}" class="border-b border-slate-100">
              <td class="px-3 py-2 text-slate-700">${esc(labourName)}</td>
              <td class="px-3 py-2 text-slate-700">${esc(deptName)}</td>
              <td class="px-3 py-2"><input data-labour-rule-col="rate_value" data-no-stepper="true" type="number" min="0" step="0.0001" value="${esc(row?.rate_value ?? "")}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly>${lockHint}</td>
              <td class="px-3 py-2 text-slate-700">${esc(rateTypeLabel[rateType] || rateType)}</td>
            </tr>
          `;
        })
        .join("");
    };

    const setRmViewMode = (mode) => {
      rmViewMode = ["materials", "sku_rules"].includes(mode) ? mode : "materials";
      rmViewPanels.forEach((panel) => {
        const panelMode = String(panel.getAttribute("data-rm-view") || "");
        panel.classList.toggle("hidden", panelMode !== rmViewMode);
      });
      rmViewToggleButtons.forEach((button) => {
        const buttonMode = String(button.getAttribute("data-rm-view-toggle") || "");
        button.setAttribute("data-active", buttonMode === rmViewMode ? "true" : "false");
      });
      if (rmViewMode === "sku_rules") {
        renderSkuRules();
      }
    };
    const setLabourViewMode = (mode) => {
      labourViewMode = ["selection", "size_rules"].includes(mode) ? mode : "selection";
      labourViewPanels.forEach((panel) => {
        const panelMode = String(panel.getAttribute("data-labour-view") || "");
        panel.classList.toggle("hidden", panelMode !== labourViewMode);
      });
      labourViewToggleButtons.forEach((button) => {
        const buttonMode = String(button.getAttribute("data-labour-view-toggle") || "");
        button.setAttribute("data-active", buttonMode === labourViewMode ? "true" : "false");
      });
      if (labourViewMode === "size_rules") {
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      }
    };

    const renderAll = () => {
      updateSfgPartColumnPresentation();
      renderStageRoutes();
      renderRm();
      renderSkuRules();
      renderSfg();
      renderLabourSelection();
      renderLabourRules();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
    };
    const renderRmWithSkuRules = () => {
      renderRm();
      renderSkuRules();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
    };
    const renderLabourSections = () => {
      renderLabourSelection();
      renderLabourRules();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
    };

    const addDefaults = {
      rm: () => ({ rm_item_id: "", color_id: "", size_id: "", dept_id: "", qty: 0, uom_id: "", normal_loss_pct: 0 }),
      sfg: () => ({ fg_sku_id: "", fg_size_id: "", sfg_sku_id: "", required_qty: "", consumed_in_stage_id: "", uom_id: "" }),
      stage_route: () => ({ dept_id: "", stage_id: "", sequence_no: "", is_required: true, enforce_sequence: true }),
      labour_selection: () => defaultLabourSelectionRow(),
      sku_override: () => ({ sku_id: "", target_rm_item_id: "", dept_id: "", is_excluded: false, override_qty: "", replacement_rm_item_id: "", rm_color_id: "", rm_size_id: "" }),
    };
    const getStateKeyForRowType = (type) => (type === "stage_route" ? "stage_routes" : type);

    const addRow = (type, insertAtIndex = null) => {
      if (!editable || !addDefaults[type]) return;
      const stateKey = getStateKeyForRowType(type);
      syncStateFromDom();
      if (!Array.isArray(state[stateKey])) state[stateKey] = [];
      const nextRow = addDefaults[type]();
      if (Number.isInteger(insertAtIndex) && insertAtIndex >= 0 && insertAtIndex <= state[stateKey].length) {
        state[stateKey].splice(insertAtIndex, 0, nextRow);
      } else {
        state[stateKey].push(nextRow);
      }
      if (type === "labour_selection") {
        syncLabourLinesFromSelectionAndRates();
        renderLabourSections();
        return;
      }
      if (type === "rm") {
        renderRmWithSkuRules();
        return;
      }
      renderAll();
    };

    const ensureMinimumRows = () => {
      if (!editable) return;
      ["rm", "stage_route", "labour_selection"].forEach((type) => {
        const stateKey = getStateKeyForRowType(type);
        if (!Array.isArray(state[stateKey]) || state[stateKey].length === 0) {
          state[stateKey] = [addDefaults[type]()];
        }
      });
      if (!Array.isArray(state.sku_override)) state.sku_override = [];
      syncLabourLinesFromSelectionAndRates();
    };

    document.addEventListener("click", (event) => {
      const inlineAddBtn = event.target.closest("[data-add-after]");
      if (inlineAddBtn) {
        const type = inlineAddBtn.getAttribute("data-add-after");
        if (type === "rule") return;
        const row = inlineAddBtn.closest("tr");
        const idx = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(idx)) addRow(type, idx + 1);
        return;
      }
      const rmViewToggleBtn = event.target.closest("[data-rm-view-toggle]");
      if (rmViewToggleBtn) {
        const nextMode = String(rmViewToggleBtn.getAttribute("data-rm-view-toggle") || "materials");
        setRmViewMode(nextMode);
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourViewToggleBtn = event.target.closest("[data-labour-view-toggle]");
      if (labourViewToggleBtn) {
        const nextMode = String(labourViewToggleBtn.getAttribute("data-labour-view-toggle") || "selection");
        setLabourViewMode(nextMode);
        return;
      }
      const skuRuleChipBtn = event.target.closest("[data-sku-rule-chip]");
      if (skuRuleChipBtn) {
        state.skuRuleOpenSkuId = String(skuRuleChipBtn.getAttribute("data-sku-rule-chip") || "");
        renderSkuRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourRuleChipBtn = event.target.closest("[data-labour-rule-chip]");
      if (labourRuleChipBtn) {
        syncLabourRulesFromDom();
        state.labourRuleOpenSkuId = String(labourRuleChipBtn.getAttribute("data-labour-rule-chip") || "");
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourRuleFallbackSizeBtn = event.target.closest("[data-labour-rule-fallback-size]");
      if (labourRuleFallbackSizeBtn) {
        syncLabourRulesFromDom();
        state.labourRuleOpenFallbackSizeId = String(labourRuleFallbackSizeBtn.getAttribute("data-labour-rule-fallback-size") || "ALL");
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const removeBtn = event.target.closest("[data-remove-row]");
      if (!removeBtn) return;
      const type = removeBtn.getAttribute("data-remove-row");
      const row = removeBtn.closest("tr");
      const idx = Number(row?.getAttribute("data-row-index"));
      if (!Number.isFinite(idx)) return;
      const stateKey = getStateKeyForRowType(type);
      syncStateFromDom();
      if (!Array.isArray(state[stateKey])) return;
      state[stateKey].splice(idx, 1);
      const keepAtLeastOne = new Set(["rm", "stage_route", "labour_selection"]);
      if (!state[stateKey].length && addDefaults[type] && keepAtLeastOne.has(type)) state[stateKey].push(addDefaults[type]());
      if (type === "labour_selection") {
        syncLabourLinesFromSelectionAndRates();
        renderLabourSections();
        return;
      }
      if (type === "rm") {
        renderRmWithSkuRules();
        return;
      }
      renderAll();
    });

    document.addEventListener("change", async (event) => {
      const headerControl = event.target instanceof HTMLElement
        ? event.target.closest("[data-header-field]")
        : null;
      if (headerControl instanceof HTMLElement) {
        if (applyingHeaderState) return;
        const changedField = String(headerControl.getAttribute("data-header-field") || "").trim();
        if (!changedField) return;
        if (!headerCommittedState) headerCommittedState = getHeaderState();
        const nextHeaderState = getHeaderState();
        if (isSameHeaderState(nextHeaderState, headerCommittedState)) return;
        const headerChangeKind = getHeaderChangeKind(headerCommittedState, nextHeaderState);
        const committedHeaderReady = isHeaderStateReady(headerCommittedState);
        if (!committedHeaderReady) {
          commitHeaderChange(changedField);
          return;
        }
        syncStateFromDom();
        if (!hasDependentBomData()) {
          commitHeaderChange(changedField);
          return;
        }
        const modalConfig = headerChangeKind === "identity"
          ? headerModalCopy.identity
          : (headerChangeKind === "uom" ? headerModalCopy.uom : headerModalCopy.qty);
        const decision = await openHeaderChangeModal(modalConfig);
        if (decision === "secondary" && headerChangeKind === "identity") {
          setSwitchAfterSaveIntent(nextHeaderState);
          applyHeaderState(headerCommittedState);
          if (bomForm instanceof HTMLFormElement) {
            if (submitIntentInput) submitIntentInput.value = "";
            allowBomSubmit = true;
            bomForm.requestSubmit();
          }
          return;
        }
        if (decision === "apply") {
          clearSwitchAfterSaveIntent();
          if (headerChangeKind === "identity") {
            resetDependentBomStateForHeaderChange();
          } else {
            clearQuantityFieldsForHeaderChange();
          }
          commitHeaderChange(changedField, { syncFromDom: false });
          return;
        }
        applyHeaderState(headerCommittedState);
        return;
      }
      const stageControl = event.target.closest('[data-lines-body="stage_route"] [data-col="dept_id"]');
      if (stageControl) {
        syncStateFromDom();
        const stageRow = stageControl.closest("tr");
        const stageRowIndex = Number(stageRow?.getAttribute("data-row-index"));
        const selectedDeptId = String(stageControl.value || "").trim();
        if (selectedDeptId && Number.isFinite(stageRowIndex) && stageRowIndex === (state.stage_routes.length - 1)) {
          state.stage_routes.push(addDefaults.stage_route());
          renderStageRoutes();
        }
        pruneDepartmentScopedRows();
        syncLabourLinesFromSelectionAndRates();
        renderRmWithSkuRules();
        renderLabourSections();
        return;
      }
      const skuRuleControl = event.target.closest("[data-sku-rule-col]");
      if (skuRuleControl) {
        const row = skuRuleControl.closest("[data-sku-rule-row]");
        if (!row) return;
        applySkuRuleRowToOverrides(row);
        renderRmWithSkuRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const rmItemControl = event.target.closest('[data-col="rm_item_id"]');
      if (rmItemControl) {
        const row = rmItemControl.closest("tr");
        refreshRmVariantSelectors(row, rmItemControl.value);
        syncStateFromDom();
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveRmDuplicateOnChange(rowIndex, "rm_item_id")) {
          renderRmWithSkuRules();
          return;
        }
        renderSkuRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const rmVariantControl = event.target.closest('[data-lines-body="rm"] [data-col="color_id"], [data-lines-body="rm"] [data-col="size_id"]');
      if (rmVariantControl) {
        syncStateFromDom();
        const row = rmVariantControl.closest("tr");
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        const changedCol = rmVariantControl.getAttribute("data-col");
        if (Number.isFinite(rowIndex) && changedCol && resolveRmDuplicateOnChange(rowIndex, changedCol)) {
          renderRmWithSkuRules();
          return;
        }
        renderRmWithSkuRules();
        return;
      }
      const rmDeptControl = event.target.closest('[data-lines-body="rm"] [data-col="dept_id"]');
      if (rmDeptControl) {
        const row = rmDeptControl.closest("tr");
        syncStateFromDom();
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveRmDuplicateOnChange(rowIndex, "dept_id")) {
          renderRmWithSkuRules();
          return;
        }
        const selectedDeptId = String(rmDeptControl.value || "").trim();
        const stageChanged = selectedDeptId ? upsertStageRouteForDepartment(selectedDeptId) : false;
        if (stageChanged) {
          renderStageRoutes();
        }
        syncLabourLinesFromSelectionAndRates();
        renderSkuRules();
        renderLabourSections();
        return;
      }
      const labourControl = event.target.closest('[data-lines-body="labour_selection"] [data-col="labour_id"]');
      if (labourControl) {
        const row = labourControl.closest("tr");
        refreshLabourDepartmentSelector(row, labourControl.value);
        syncStateFromDom();
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveLabourSelectionDuplicateOnChange(rowIndex, "labour_id")) {
          renderLabourSections();
          return;
        }
        renderLabourSections();
        return;
      }
      const labourSelectionControl = event.target.closest('[data-lines-body="labour_selection"] [data-col="dept_id"], [data-lines-body="labour_selection"] [data-col="rate_type"]');
      if (labourSelectionControl) {
        syncStateFromDom();
        const changedCol = String(labourSelectionControl.getAttribute("data-col") || "").trim();
        const row = labourSelectionControl.closest("tr");
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveLabourSelectionDuplicateOnChange(rowIndex, changedCol || "dept_id")) {
          renderLabourSections();
          return;
        }
        let stageChanged = false;
        if (changedCol === "dept_id") {
          const selectedDeptId = String(labourSelectionControl.value || "").trim();
          if (selectedDeptId) stageChanged = upsertStageRouteForDepartment(selectedDeptId);
        }
        if (stageChanged) {
          renderStageRoutes();
        }
        renderLabourSections();
        return;
      }
      const labourRateControl = event.target.closest('[data-lines-body="labour_rule"] [data-labour-rule-col="rate_value"]');
      if (labourRateControl) {
        const ruleRow = labourRateControl.closest("[data-labour-rule-entry]");
        const labourId = String(ruleRow?.getAttribute("data-labour-id") || "").trim();
        const deptId = String(ruleRow?.getAttribute("data-dept-id") || "").trim();
        const rateType = normalizeLabourRateType(ruleRow?.getAttribute("data-rate-type"));
        const sizeId = String(ruleRow?.getAttribute("data-size-id") || "ALL").trim() || "ALL";
        const key = toLabourRateKey({ labour_id: labourId, dept_id: deptId, rate_type: rateType }, sizeId);
        const locked = String(ruleRow?.getAttribute("data-rate-locked") || "0") === "1" || isLabourRateLockedByKey(key);
        if (locked) {
          if (labourRateControl instanceof HTMLInputElement) {
            labourRateControl.value = String(state.labourRuleRateMap?.[key] || "").trim();
          }
          showErrorModal("<%= t('bom_labour_locked_message')  %>");
          return;
        }
        syncLabourRulesFromDom();
        syncLabourLinesFromSelectionAndRates();
        return;
      }
      const sfgSkuControl = event.target.closest('[data-col="sfg_sku_id"]');
      if (sfgSkuControl) {
        const row = sfgSkuControl.closest("tr");
        const selectedSkuId = String(sfgSkuControl.value || "").trim();
        const uomId = sfgSkuUomById.get(selectedSkuId) || "";
        const hidden = row?.querySelector('[data-col="uom_id"]');
        const display = row?.querySelector('[data-col-display="uom_id"]');
        const qtyInput = row?.querySelector('[data-col="required_qty"]');
        if (hidden) hidden.value = uomId;
        if (display) display.value = getUomName(uomId);
        if (selectedSkuId && qtyInput) {
          const currentQty = String(qtyInput.value || "").trim();
          if (!currentQty || Number(currentQty) <= 0) {
            const defaultRequiredQty = getDefaultSfgRequiredQty(selectedSkuId);
            if (defaultRequiredQty) qtyInput.value = defaultRequiredQty;
          }
        }
        syncStateFromDom();
        return;
      }
      const fgSkuControl = event.target.closest('[data-col="fg_sku_id"]');
      if (fgSkuControl) {
        const row = fgSkuControl.closest("tr");
        const fgSku = findHeaderSkuById(fgSkuControl.value);
        const hiddenSize = row?.querySelector('[data-col="fg_size_id"]');
        if (hiddenSize) hiddenSize.value = String(fgSku?.size_id || "");
      }
    });

    const bindEnterNavigation = () => {
      if (!editable || typeof window.createVoucherRowEnterNavigator !== "function") return;
      const form = document.getElementById("bom-form");
      const headerSection = document.getElementById("bom-header");
      if (form instanceof HTMLElement && headerSection instanceof HTMLElement) {
        const headerNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: headerSection,
          rowSelector: "[data-header-enter-row]",
          fieldAttr: "data-header-field",
          fieldOrder: ["level", "item_id", "output_qty", "output_uom_id"],
          canAppendRow: () => false,
        });
        headerNavigator?.bind();
      }
      const rowConfigs = [
        { type: "rm", fieldOrder: ["rm_item_id", "dept_id", "normal_loss_pct"] },
        { type: "stage_route", fieldOrder: ["dept_id", "is_required", "enforce_sequence"] },
        { type: "labour_selection", fieldOrder: ["labour_id", "dept_id", "rate_type"] },
      ];
      rowConfigs.forEach((cfg) => {
        const linesBody = document.querySelector(`[data-lines-body="${cfg.type}"]`);
        if (!(linesBody instanceof HTMLElement)) return;
        const navigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody,
          fieldAttr: "data-col",
          fieldOrder: cfg.fieldOrder,
          appendRow: () => {
            if (cfg.type === "stage_route") {
              window.setTimeout(() => addRow(cfg.type), 0);
              return true;
            }
            addRow(cfg.type);
            return true;
          },
          canAppendRow: () => Boolean(editable),
        });
        navigator?.bind();
      });
      const stageBody = document.querySelector('[data-lines-body="stage_route"]');
      if (stageBody instanceof HTMLElement) {
        stageBody.addEventListener("click", (event) => {
          const addBtn = event.target instanceof HTMLElement
            ? event.target.closest('[data-add-after="stage_route"]')
            : null;
          if (addBtn) {
            event.preventDefault();
            event.stopPropagation();
            const row = addBtn.closest("tr");
            const idx = Number(row?.getAttribute("data-row-index"));
            if (Number.isFinite(idx)) addRow("stage_route", idx + 1);
            return;
          }
          const removeBtn = event.target instanceof HTMLElement
            ? event.target.closest('[data-remove-row="stage_route"]')
            : null;
          if (!removeBtn) return;
          event.preventDefault();
          event.stopPropagation();
          const row = removeBtn.closest("tr");
          const idx = Number(row?.getAttribute("data-row-index"));
          if (!Number.isFinite(idx)) return;
          syncStateFromDom();
          state.stage_routes.splice(idx, 1);
          if (!state.stage_routes.length) state.stage_routes.push(addDefaults.stage_route());
          renderAll();
        }, true);
        stageBody.addEventListener("keyup", (event) => {
          if (event.key !== "Enter") return;
          const target = event.target instanceof HTMLElement ? event.target : null;
          const activeElement = document.activeElement instanceof HTMLElement ? document.activeElement : null;
          const checkbox = target?.closest('[data-lines-body="stage_route"] [data-col="is_required"], [data-lines-body="stage_route"] [data-col="enforce_sequence"]')
            || activeElement?.closest('[data-lines-body="stage_route"] [data-col="is_required"], [data-lines-body="stage_route"] [data-col="enforce_sequence"]');
          if (!(checkbox instanceof HTMLElement)) return;
          event.preventDefault();
          syncStateFromDom();
          const row = checkbox.closest("tr");
          const rowIndex = Number(row?.getAttribute("data-row-index"));
          if (!Number.isFinite(rowIndex)) return;
          const rows = Array.isArray(state.stage_routes) ? state.stage_routes : [];
          const nextRowIndex = rowIndex + 1;
          if (nextRowIndex >= rows.length) {
            addRow("stage_route");
          }
          window.setTimeout(() => {
            const nextRow = document.querySelector(`[data-lines-body="stage_route"] tr[data-row-index="${nextRowIndex}"]`);
            const nextDeptField = nextRow?.querySelector('[data-col="dept_id"]');
            if (nextDeptField && window.VoucherRowEnterNavigation?.focusFieldElement) {
              window.VoucherRowEnterNavigation.focusFieldElement(nextDeptField, { openSearchable: true });
            }
          }, 0);
        }, true);
      }
      const sfgBody = document.querySelector('[data-lines-body="sfg"]');
      if (sfgBody instanceof HTMLElement) {
        const sfgNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: sfgBody,
          fieldAttr: "data-col",
          fieldOrder: ["sfg_sku_id", "required_qty", "consumed_in_stage_id"],
          canAppendRow: () => false,
        });
        sfgNavigator?.bind();
      }
      const labourRuleBody = document.querySelector('[data-lines-body="labour_rule"]');
      if (labourRuleBody instanceof HTMLElement) {
        const labourRuleNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: labourRuleBody,
          rowSelector: '[data-labour-rule-entry="true"]',
          fieldAttr: "data-labour-rule-col",
          fieldOrder: ["rate_value"],
          canAppendRow: () => false,
        });
        labourRuleNavigator?.bind();
      }
      if (skuRulesBody instanceof HTMLElement) {
        const skuRuleNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: skuRulesBody,
          rowSelector: '[data-sku-rule-row="true"]',
          fieldAttr: "data-sku-rule-col",
          fieldOrder: ["rm_color_id", "rm_size_id", "required_qty"],
          canAppendRow: () => false,
        });
        skuRuleNavigator?.bind();
        skuRulesBody.addEventListener("keydown", (event) => {
          const key = String(event.key || "");
          if (key !== "ArrowUp" && key !== "ArrowDown") return;
          const target = event.target;
          if (!(target instanceof HTMLInputElement)) return;
          if (!target.matches('[data-sku-rule-col="required_qty"]')) return;
          const row = target.closest('[data-sku-rule-row="true"]');
          const rowIndex = Number(row?.getAttribute("data-row-index"));
          if (!Number.isFinite(rowIndex)) return;
          const step = key === "ArrowDown" ? 1 : -1;
          const rows = Array.from(
            skuRulesBody.querySelectorAll('[data-sku-rule-row="true"]'),
          );
          event.preventDefault();
          event.stopPropagation();
          for (
            let idx = rowIndex + step;
            idx >= 0 && idx < rows.length;
            idx += step
          ) {
            const nextRow = rows[idx];
            const qtyInput = nextRow?.querySelector(
              '[data-sku-rule-col="required_qty"]',
            );
            if (
              qtyInput instanceof HTMLInputElement
              && !qtyInput.readOnly
              && !qtyInput.disabled
            ) {
              qtyInput.focus();
              qtyInput.select();
              return;
            }
          }
        });
      }
    };

    const collectRows = (type, mapFn) => {
      return Array.from(document.querySelectorAll(`[data-lines-body="${type}"] tr`)).map((row, index) => mapFn(row, index));
    };

    const getValue = (row, col) => row.querySelector(`[data-col="${col}"]`)?.value ?? "";

    const syncLabourRulesFromDom = () => {
      const ruleRows = Array.from(document.querySelectorAll('[data-lines-body="labour_rule"] [data-labour-rule-entry="true"]'));
      if (!ruleRows.length) return;
      if (!state.labourRuleRateMap || typeof state.labourRuleRateMap !== "object") {
        state.labourRuleRateMap = {};
      }
      if (!state.labourRuleLockedMap || typeof state.labourRuleLockedMap !== "object") {
        state.labourRuleLockedMap = {};
      }
      ruleRows.forEach((row) => {
        const labourId = String(row.getAttribute("data-labour-id") || "").trim();
        const deptId = String(row.getAttribute("data-dept-id") || "").trim();
        const rateType = normalizeLabourRateType(row.getAttribute("data-rate-type"));
        const sizeId = String(row.getAttribute("data-size-id") || "ALL").trim() || "ALL";
        const rateInput = row.querySelector('[data-labour-rule-col="rate_value"]');
        const rateValue = String(rateInput?.value ?? "").trim();
        const selectionRow = { labour_id: labourId, dept_id: deptId, rate_type: rateType };
        const key = toLabourRateKey(selectionRow, sizeId);
        const rowLocked = String(row.getAttribute("data-rate-locked") || "0") === "1" || isLabourRateLockedByKey(key);
        if (rowLocked) return;
        if (!labourId || !deptId || !rateValue) {
          delete state.labourRuleRateMap[key];
          return;
        }
        state.labourRuleRateMap[key] = rateValue;
      });
    };
    const getSanitizedStageRoutesForSubmission = () => {
      const rows = Array.isArray(state.stage_routes) ? state.stage_routes : [];
      return rows
        .map((row) => {
          const deptId = String(row?.dept_id || "").trim();
          return {
            dept_id: deptId,
            stage_id: stageIdByDeptId.get(deptId) || String(row?.stage_id || "").trim(),
            sequence_no: Number(row?.sequence_no || 0),
            is_required: row?.is_required !== false,
            enforce_sequence: row?.enforce_sequence !== false,
          };
        })
        .filter((row) => row.dept_id)
        .map((row, index) => ({
          ...row,
          sequence_no: Number(index + 1),
        }));
    };
    const getSanitizedSfgLinesForSubmission = () => {
      const rows = Array.isArray(state.sfg) ? state.sfg : [];
      const byKey = new Map();
      rows.forEach((row, index) => {
        const fgSizeId = String(row?.fg_size_id || "").trim();
        const sfgSkuId = String(row?.sfg_sku_id || "").trim();
        const requiredQty = String(row?.required_qty ?? "").trim();
        const consumedInStageId = String(row?.consumed_in_stage_id || "").trim();
        const uomId = String(row?.uom_id || "").trim();
        if (!fgSizeId && !sfgSkuId && !requiredQty && !consumedInStageId) return;
        const key = fgSizeId ? `size:${fgSizeId}:${sfgSkuId}` : `row:${index}`;
        const score = (sfgSkuId ? 2 : 0) + (requiredQty ? 1 : 0) + (consumedInStageId ? 1 : 0);
        const existing = byKey.get(key);
        if (!existing || score >= existing.score) {
          byKey.set(key, {
            score,
            line: {
              fg_sku_id: String(row?.fg_sku_id || "").trim(),
              fg_size_id: fgSizeId,
              sfg_sku_id: sfgSkuId,
              required_qty: requiredQty,
              consumed_in_stage_id: consumedInStageId,
              uom_id: uomId,
            },
          });
        }
      });
      return [...byKey.values()].map((entry) => entry.line);
    };

    const syncStateFromDom = () => {
      state.rm = collectRows("rm", (row) => ({
        rm_item_id: getValue(row, "rm_item_id"),
        color_id: getValue(row, "color_id"),
        size_id: getValue(row, "size_id"),
        dept_id: getValue(row, "dept_id"),
        qty: getValue(row, "qty"),
        uom_id: getValue(row, "uom_id"),
        normal_loss_pct: getValue(row, "normal_loss_pct"),
      }));
      state.sfg = collectRows("sfg", (row) => ({
        fg_sku_id: getValue(row, "fg_sku_id"),
        fg_size_id: getValue(row, "fg_size_id"),
        sfg_sku_id: getValue(row, "sfg_sku_id"),
        required_qty: getValue(row, "required_qty"),
        consumed_in_stage_id: getValue(row, "consumed_in_stage_id"),
        uom_id: getValue(row, "uom_id"),
      }));
      if (!shouldShowSfgSection()) {
        state.sfg = [];
      } else {
        state.sfg = getSanitizedSfgLinesForSubmission();
      }
      state.stage_routes = collectRows("stage_route", (row, index) => ({
        dept_id: getValue(row, "dept_id"),
        stage_id: stageIdByDeptId.get(String(getValue(row, "dept_id") || "").trim()) || "",
        sequence_no: Number(index + 1),
        is_required: row.querySelector('[data-col="is_required"]')?.checked !== false,
        enforce_sequence: row.querySelector('[data-col="enforce_sequence"]')?.checked !== false,
      }));
      state.labour_selection = collectRows("labour_selection", (row) => normalizeLabourSelectionRow({
        labour_id: getValue(row, "labour_id"),
        dept_id: getValue(row, "dept_id"),
        rate_type: getValue(row, "rate_type"),
      }));
      if (!state.labour_selection.length) state.labour_selection = [defaultLabourSelectionRow()];
      syncLabourRulesFromDom();
      syncLabourLinesFromSelectionAndRates();
      const skuOverrideBody = document.querySelector('[data-lines-body="sku_override"]');
      if (skuOverrideBody) {
        state.sku_override = collectRows("sku_override", (row) => ({
          sku_id: getValue(row, "sku_id"),
          target_rm_item_id: getValue(row, "target_rm_item_id"),
          dept_id: getValue(row, "dept_id"),
          is_excluded: row.querySelector('[data-col="is_excluded"]')?.checked === true,
          override_qty: getValue(row, "override_qty"),
          replacement_rm_item_id: getValue(row, "replacement_rm_item_id"),
          rm_color_id: getValue(row, "rm_color_id"),
          rm_size_id: getValue(row, "rm_size_id"),
        })).filter((row) => row.sku_id || row.target_rm_item_id || row.dept_id || row.is_excluded || String(row.override_qty ?? "").trim() !== "" || row.replacement_rm_item_id || row.rm_color_id || row.rm_size_id);
      } else if (!Array.isArray(state.sku_override)) {
        state.sku_override = [];
      }
    };

    document.getElementById("bom-form")?.addEventListener("submit", (event) => {
      const submitter = event.submitter;
      const isApproveNow = submitter instanceof HTMLElement && submitter.matches("[data-bom-approve-now='1']");
      const isSendForApproval = submitter instanceof HTMLElement && submitter.matches("[data-bom-send-approval='1']");
      const isExplicitSave = allowBomSubmit
        || (submitter instanceof HTMLElement && submitter.matches("[data-bom-save-draft]"));
      const isExplicitApprovalFlow = isApproveNow || isSendForApproval;
      if (!isExplicitSave && !isExplicitApprovalFlow) {
        event.preventDefault();
        return;
      }
      allowBomSubmit = false;
      syncStateFromDom();
      syncSkuRulesFromDom();
      if (hasClientDuplicateCombos()) {
        event.preventDefault();
        return;
      }

      const skuRulesResult = buildSkuRulesForSubmission();
      const skuRuleEntries = skuRulesResult.entries || [];
      const sfgEntries = getSanitizedSfgLinesForSubmission();
      state.sfg = sfgEntries;

      document.querySelector('[data-lines-json="rm_lines"]').value = JSON.stringify(state.rm);
      document.querySelector('[data-lines-json="sku_rules"]').value = JSON.stringify(skuRuleEntries);
      document.querySelector('[data-lines-json="sfg_lines"]').value = JSON.stringify(sfgEntries);
      document.querySelector('[data-lines-json="labour_lines"]').value = JSON.stringify(state.labour);
      document.querySelector('[data-lines-json="stage_routes"]').value = JSON.stringify(getSanitizedStageRoutesForSubmission());
      if (submitIntentInput) {
        submitIntentInput.value = isApproveNow ? "approve" : (isSendForApproval ? "send_for_approval" : "");
      }
    });

    bomForm = document.getElementById("bom-form");
    if (bomForm instanceof HTMLFormElement) {
      submitIntentInput = bomForm.querySelector("[data-bom-submit-intent]");
      switchAfterSaveInput = bomForm.querySelector("[data-bom-switch-after-save]");
      switchLevelInput = bomForm.querySelector("[data-bom-switch-level]");
      switchItemIdInput = bomForm.querySelector("[data-bom-switch-item-id]");
      switchOutputQtyInput = bomForm.querySelector("[data-bom-switch-output-qty]");
      switchOutputUomInput = bomForm.querySelector("[data-bom-switch-output-uom-id]");
      saveDraftBtn = bomForm.querySelector("[data-bom-save-draft]");
      if (saveDraftBtn instanceof HTMLButtonElement) {
        saveDraftBtn.addEventListener("click", () => {
          clearSwitchAfterSaveIntent();
          if (submitIntentInput) submitIntentInput.value = "";
          allowBomSubmit = true;
          bomForm.requestSubmit();
        });
      }
      bomForm.addEventListener(
        "wheel",
        (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const numberInput = target.closest('input[data-no-stepper="true"]');
          if (!(numberInput instanceof HTMLInputElement)) return;
          if (document.activeElement !== numberInput) return;
          event.preventDefault();
        },
        { passive: false },
      );

      bomForm.addEventListener("keydown", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target instanceof HTMLInputElement && target.dataset.noStepper === "true" && (event.key === "ArrowUp" || event.key === "ArrowDown")) {
          event.preventDefault();
          return;
        }
        if (event.key !== "Enter") return;
        const isExplicitSubmitButton = target instanceof HTMLButtonElement && target.type === "submit";
        if (isExplicitSubmitButton && target.matches("[data-bom-save-draft]")) return;
        if (target instanceof HTMLTextAreaElement) return;
        event.preventDefault();
      });
    }

    initializeLabourStateFromExistingLines();
    ensureMinimumRows();
    renderHeaderItemsByLevel(true);
    applyLabourDefaultsForSelectedItem(false);
    updateHeaderSectionState();
    renderAll();
    setRmViewMode("materials");
    setLabourViewMode("selection");
    bindEnterNavigation();
    headerCommittedState = getHeaderState();
    const detailLines = Array.isArray(serverErrorDetails)
      ? [...new Set(serverErrorDetails.map((msg) => String(msg || "").trim()).filter(Boolean))]
      : [];
    if (String(serverErrorMessage || "").trim() || detailLines.length) {
      const detailsText = detailLines.map((msg, idx) => `${idx + 1}. ${msg}`).join("\n");
      const modalMessage = [String(serverErrorMessage || "").trim(), detailsText].filter(Boolean).join("\n");
      const modalTitle = "<%= t('error_generic')  %>";
      const showServerErrors = () => {
        if (typeof window.showUiErrorModal === "function") {
          window.showUiErrorModal(modalMessage, modalTitle);
          return;
        }
        window.__pendingUiErrorModalPayload = { message: modalMessage, title: modalTitle };
      };
      showServerErrors();
    }
  })();
</script>
