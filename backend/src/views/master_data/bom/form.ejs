<%
  const isEdit = formMode === "edit";
  const header = formState?.header || {};
  const selectedLevel = String(header.level || "").toUpperCase();
  const selectedItemType = selectedLevel === "SEMI_FINISHED" ? "SFG" : selectedLevel === "FINISHED" ? "FG" : null;
  const isDraft = !header.status || header.status === "DRAFT";
  const isEditable = !isEdit || isDraft;
  const submitPath = isEdit ? `${basePath}/${header.id}/save-draft` : `${basePath}/save-draft`;
  const tx = (key, fallback) => {
    const value = typeof t === "function" ? t(key) : "";
    return value && value !== key ? value : fallback;
  };
%>

<style>
  #bom-form input[type="number"]::-webkit-outer-spin-button,
  #bom-form input[type="number"]::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  #bom-form input[type="number"] {
    -moz-appearance: textfield;
  }
  #bom-form [data-searchable-wrapper] {
    z-index: 1;
  }
  #bom-form [data-searchable-wrapper]:focus-within {
    z-index: 80;
  }
  #bom-form [data-rm-view-toggle],
  #bom-form [data-rm-mode-toggle],
  #bom-form [data-labour-view-toggle] {
    border-color: #cbd5e1;
    background: #ffffff;
    color: #475569;
  }
  #bom-form [data-rm-view-toggle][data-active="true"],
  #bom-form [data-rm-mode-toggle][data-active="true"],
  #bom-form [data-labour-view-toggle][data-active="true"] {
    border-color: #0f172a;
    background: #0f172a;
    color: #ffffff;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.25);
  }
  #bom-form [data-rm-view-toggle][data-active="false"],
  #bom-form [data-rm-mode-toggle][data-active="false"],
  #bom-form [data-labour-view-toggle][data-active="false"] {
    border-color: #cbd5e1;
    background: #ffffff;
    color: #475569;
  }
  #bom-header { order: 10; }
  #bom-form [data-header-lock-notice] { order: 20; }
  #bom-sfg { order: 30; }
  #bom-rm { order: 40; }
  #bom-labour { order: 50; }
  #bom-form [data-bom-save-wrap] { order: 60; }
</style>

<div class="mx-auto w-full max-w-7xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-lg">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="space-y-1">
        <h1 class="text-2xl font-display text-ink">
          <%= isEdit ? (t("bom_edit_title") || "Edit BOM") : (t("bom_new_title") || "Add BOM") %>
        </h1>
        <p class="text-sm text-muted"><%= t("bom_header_required_message") || "Complete the BOM setup first. Material, SFG, and labour sections unlock after that." %></p>
      </div>
      <div class="flex flex-wrap gap-2">
        <% if (!isEdit && user?.isAdmin) { %>
          <button type="button" data-bom-approve-now class="inline-flex min-w-[8.5rem] items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white shadow-sm transition hover:bg-slate-800">
            <%= t("approve") || "Approve" %>
          </button>
        <% } %>
        <% if (isEdit && header.status === "APPROVED" && can('SCREEN', 'master_data.bom', 'create')) { %>
          <form method="POST" action="<%= basePath %>/<%= header.id %>/create-new-version">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="inline-flex min-w-[8.5rem] items-center justify-center rounded-xl border border-slate-300 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-slate-700 transition hover:border-slate-400 hover:text-slate-900" title="<%= t('bom_create_new_version') || 'Create New Version' %>">
              <%= t("bom_revise") || "Revise" %>
            </button>
          </form>
        <% } %>
        <% if (isEdit && isDraft) { %>
          <form method="POST" action="<%= basePath %>/<%= header.id %>/send-for-approval">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="inline-flex min-w-[8.5rem] items-center justify-center rounded-xl bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-white shadow-sm transition hover:brightness-95">
              <%= user?.isAdmin ? (t("approve") || "Approve") : (t("send_for_approval") || "Send for Approval") %>
            </button>
          </form>
        <% } %>
      </div>
    </div>
  </section>

  <form id="bom-form" method="POST" action="<%= submitPath %>" class="flex flex-col gap-6">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="submit_intent" value="" data-bom-submit-intent>
    <input type="hidden" name="rm_lines_json" value="<%- JSON.stringify(formState?.rm_lines || []) %>" data-lines-json="rm_lines">
    <input type="hidden" name="sfg_lines_json" value="<%- JSON.stringify(formState?.sfg_lines || []) %>" data-lines-json="sfg_lines">
    <input type="hidden" name="labour_lines_json" value="<%- JSON.stringify(formState?.labour_lines || []) %>" data-lines-json="labour_lines">
    <input type="hidden" name="variant_rules_json" value="<%- JSON.stringify(formState?.variant_rules || []) %>" data-lines-json="variant_rules">
    <input type="hidden" name="sku_overrides_json" value="<%- JSON.stringify(formState?.sku_overrides || []) %>" data-lines-json="sku_overrides">

    <section id="bom-header" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <div class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_header") || "BOM Setup" %></div>
        <% if (header.bom_no) { %>
          <div class="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("code") || "Code" %>: <%= header.bom_no %></div>
        <% } %>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4" data-header-enter-row>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("level") || "Level" %></span>
          <select name="level" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" data-searchable-select="true" data-searchable-variant="unified" data-header-field="level" <%= isEditable ? "" : "disabled" %> required>
            <option value=""><%= t("select") %></option>
            <% (options?.levelOptions || []).forEach(function(levelOpt) { %>
              <option value="<%= levelOpt.value %>" <%= selectedLevel === levelOpt.value ? "selected" : "" %>>
                <%= t(levelOpt.label) || levelOpt.value %>
              </option>
            <% }) %>
          </select>
        </label>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("article_name") || "Article Name" %></span>
          <select name="item_id" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" data-searchable-select="true" data-searchable-variant="unified" data-header-field="item_id" <%= isEditable ? "" : "disabled" %> required>
            <option value=""><%= t("select") %></option>
            <% (options?.items || []).filter(function(item) { return !selectedItemType || item.item_type === selectedItemType; }).forEach(function(item) { %>
              <option value="<%= item.id %>" <%= Number(header.item_id) === Number(item.id) ? "selected" : "" %>>
                <%= item.name %>
              </option>
            <% }) %>
          </select>
          <% if (!isEdit && (!options?.items || options.items.length === 0)) { %>
            <div class="mt-1 text-xs font-medium text-amber-700"><%= t("bom_no_available_articles") || "No new articles are available. Use BOM Register to revise an existing BOM." %></div>
          <% } %>
        </label>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("bom_output_batch_size") || "Planned Output Qty" %></span>
          <input type="number" step="0.001" min="0.001" name="output_qty" value="<%= header.output_qty ?? 1 %>" data-no-stepper="true" data-header-field="output_qty" class="h-10 w-full rounded-xl border border-slate-200 bg-white px-3 text-sm text-slate-700 transition focus:border-black focus:outline-none focus:ring-2 focus:ring-black/20" <%= isEditable ? "" : "readonly" %> required>
        </label>
        <label class="block text-sm font-semibold text-slate-600">
          <span><%= t("bom_output_uom") || "Output Unit (UOM)" %></span>
          <select name="output_uom_id" class="mt-2 w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-700" data-searchable-select="true" data-searchable-variant="unified" data-header-field="output_uom_id" <%= isEditable ? "" : "disabled" %> required>
            <option value=""><%= t("select") %></option>
            <% (options?.uoms || []).forEach(function(uom) { %>
              <option value="<%= uom.id %>" <%= Number(header.output_uom_id) === Number(uom.id) ? "selected" : "" %>><%= uom.name %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <% if (isEdit) { %>
        <div class="mt-5 grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-4">
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("version") || "Version" %></div>
            <div class="mt-1 text-sm font-semibold text-slate-800">V<%= header.version_no %></div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("status") %></div>
            <div class="mt-1">
              <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold uppercase tracking-[0.08em] <%= (String(header.status || '').toUpperCase() === 'APPROVED') ? 'bg-emerald-100 text-emerald-700' : (String(header.status || '').toUpperCase() === 'PENDING') ? 'bg-amber-100 text-amber-700' : 'bg-blue-100 text-blue-700' %>">
                <%= t((header.status || '').toLowerCase()) || header.status %>
              </span>
            </div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("created") || "Created" %></div>
            <div class="mt-1 text-sm font-semibold text-slate-800"><%= formatDateDisplay(header.created_at) %></div>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
            <div class="text-[10px] font-semibold uppercase tracking-[0.14em] text-slate-500"><%= t("approved") || "Approved" %></div>
            <div class="mt-1 text-sm font-semibold text-slate-800"><%= formatDateDisplay(header.approved_at) %></div>
          </div>
        </div>
      <% } %>
    </section>

    <section class="rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800 <%= (header.item_id && header.level && Number(header.output_qty || 0) > 0 && header.output_uom_id) ? 'hidden' : '' %>" data-header-lock-notice>
      <span class="font-semibold"><%= t("notice") || "Notice" %>:</span>
      <%= t("bom_header_required_message") || "Complete the BOM setup first. Material, SFG, and labour sections unlock after that." %>
    </section>

    <section id="bom-rm" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24 space-y-5">
      <div class="rounded-xl border border-slate-200 bg-slate-50/70 p-3">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div class="space-y-1">
            <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-700"><%= t("bom_tab_rm") || "Raw Material Inputs for This BOM" %></h2>
            <p class="text-xs text-slate-500"><%= t("bom_rm_section_hint") || "Add all raw materials required for one planned output batch, then fine-tune size-specific rules if needed." %></p>
          </div>
          <div class="flex flex-col items-end gap-2">
            <div class="inline-flex flex-wrap items-center gap-2">
              <button
                type="button"
                data-rm-mode-toggle="materials"
                data-active="true"
                class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
              >
                <%= t("bom_rm_view_material_lines") || "Material Lines" %>
              </button>
              <button
                type="button"
                data-rm-mode-toggle="sku_rules"
                data-active="false"
                class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
              >
                <%= t("bom_sku_rules") || "SKU Rules" %>
              </button>
              <button
                type="button"
                data-rm-mode-toggle="advanced"
                data-active="false"
                class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
              >
                <%= t("bom_advanced_rules") || "Advanced Rules" %>
              </button>
            </div>
            <div class="hidden inline-flex flex-wrap items-center gap-2" data-rm-advanced-toggles hidden aria-hidden="true">
              <button
                type="button"
                data-rm-view-toggle="size_rules"
                data-active="true"
                class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
              >
                <%= t("bom_rm_view_variant_rules") || "Size Rules" %>
              </button>
              <button
                type="button"
                data-rm-view-toggle="color_rules"
                data-active="false"
                class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
              >
                <%= t("bom_color_rules") || "Color Rules" %>
              </button>
              <button
                type="button"
                data-rm-view-toggle="packing_rules"
                data-active="false"
                class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
              >
                <%= t("bom_packing_rules") || "Packing Rules" %>
              </button>
            </div>
          </div>
        </div>
      </div>
      <div data-rm-view="sku_rules" class="space-y-3">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <div>
            <div class="mb-2 text-xs font-medium text-slate-500"><%= t("bom_sku_rules_hint") || "Select a SKU to edit final raw material requirements. Only differences are saved as SKU overrides." %></div>
            <div class="flex flex-wrap items-center gap-2" data-sku-rule-chips></div>
          </div>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_material') || 'Select the raw material used in this BOM.' %>"><%= t("bom_rm_col_material") || "Material" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_consumption_department') || 'Production department that consumes this material.' %>"><%= t("department") || "Department" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rm_color') || 'Raw material color to consume for the selected SKU scope.' %>"><%= t("bom_rm_col_color") || "RM Color" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_required_qty') || 'Required quantity for this line.' %>"><%= t("bom_rules_col_qty") || "Required Qty" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit') || 'Base unit is picked from the selected material and is read-only.' %>"><%= t("base_unit") || "Unit" %></th>
              </tr>
            </thead>
            <tbody data-sku-rules-body></tbody>
          </table>
        </div>
      </div>
      <div data-rm-view="materials" class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
        <table class="w-full table-fixed text-sm">
          <colgroup>
            <col class="w-[34%]">
            <col class="w-[24%]">
            <col class="w-[32%]">
            <col class="w-[10%]">
          </colgroup>
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
            <tr>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_material') || 'Select the raw material used in this BOM.' %>"><%= t("bom_rm_col_material") || "Material" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit') || 'Base unit is picked from the selected material and is read-only.' %>"><%= t("base_unit") || "Base Unit" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_consumption_department') || 'Production department that consumes this material.' %>"><%= t("bom_rm_col_department") || "Consumption Department" %></th>
              <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions') || 'Use plus/minus to add or remove rows.' %>"><%= t("bom_rm_col_actions") || "Actions" %></th>
            </tr>
          </thead>
          <tbody data-lines-body="rm"></tbody>
        </table>
      </div>
      <div data-rm-view="size_rules" class="hidden space-y-3">
        <div class="space-y-3" data-rule-size-sections></div>
        <div class="hidden overflow-x-auto lg:overflow-visible overflow-y-visible rounded-xl border border-slate-200" data-rule-size-grid-template data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_size_rule_material') || 'Material to which this size rule applies.' %>"><%= t("bom_rm_col_material") || "Material" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_size_rule_uom') || 'Unit for the size-specific quantity.' %>"><%= t("bom_rules_col_uom") || "Unit" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_size_rule_qty') || 'Required quantity for the selected size.' %>"><%= t("bom_rules_col_qty") || "Required Qty" %></th>
                <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions') || 'Use plus/minus to add or remove rows.' %>"><%= t("bom_rm_col_actions") || "Actions" %></th>
              </tr>
            </thead>
            <tbody data-lines-body="rule"></tbody>
          </table>
        </div>
      </div>
      <div data-rm-view="color_rules" class="hidden space-y-3">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <div class="mb-2 text-xs font-medium text-slate-500"><%= t("bom_color_scope_hint") || "Choose a SKU variant scope to edit material color mapping." %></div>
          <div class="flex flex-wrap items-center gap-2" data-rule-color-scopes></div>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_color_rule_material') || 'Material whose color mapping you want to control.' %>"><%= t("bom_rm_col_material") || "Material" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit') || 'Base unit is picked from the selected material and is read-only.' %>"><%= t("base_unit") || "Unit" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rm_color') || 'Raw material color to consume for the selected SKU scope.' %>"><%= t("bom_rm_col_color") || "Raw Material Color" %></th>
                <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions') || 'Use plus/minus to add or remove rows.' %>"><%= t("actions") %></th>
              </tr>
            </thead>
            <tbody data-lines-body="color_rule"></tbody>
          </table>
        </div>
      </div>
      <div data-rm-view="packing_rules" class="hidden overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
            <tr>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_packing_rule_material') || 'Base material that will be replaced.' %>"><%= t("bom_rm_col_material") || "Material" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit') || 'Base unit is picked from the selected material and is read-only.' %>"><%= t("base_unit") || "Unit" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_packing') || 'Packing type condition for this replacement.' %>"><%= t("packing") || "Packing" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_size_optional') || 'Optional size filter; leave blank to apply for all sizes.' %>"><%= t("size") || "Size (Optional)" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_replace_with') || 'Material to consume instead of base material.' %>"><%= t("replace_with") || "Replace With RM" %></th>
              <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions') || 'Use plus/minus to add or remove rows.' %>"><%= t("actions") %></th>
            </tr>
          </thead>
          <tbody data-lines-body="packing_rule"></tbody>
        </table>
      </div>
    </section>

    <section id="bom-sfg" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24">
      <div class="mb-3 flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_tab_sfg_per_sku") || "List Semi-Finished Products Used For Each SKU" %></h2>
      </div>
      <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
            <tr>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_article_sku') || 'Finished article SKU this row applies to.' %>"><%= t("article_sku") || "Article SKU" %></th>
              <th class="px-3 py-2 text-left" data-sfg-part-col-title title="<%= t('bom_hint_step_upper_sku') || 'Select the semi-finished SKU used for this finished SKU.' %>"><span data-sfg-part-col-label><%= t("bom_sfg_col_step_upper_sku") || "Step/Upper SKU" %></span></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_base_unit') || 'Base unit for selected SKU.' %>"><%= t("base_unit") || "Unit" %></th>
              <th class="px-3 py-2 text-left" title="<%= t('bom_hint_step_quantity') || 'Quantity of selected step/upper SKU required for this finished SKU.' %>"><%= t("bom_sfg_col_step_qty") || "Step Quantity" %></th>
            </tr>
          </thead>
          <tbody data-lines-body="sfg"></tbody>
        </table>
      </div>
    </section>

    <section id="bom-labour" class="rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-sm scroll-mt-24 space-y-4">
      <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
        <h2 class="text-sm font-semibold uppercase tracking-[0.14em] text-slate-600"><%= t("bom_tab_labour") || "List Labour Rates by Size and Department" %></h2>
        <div class="inline-flex flex-wrap items-center gap-2">
          <button
            type="button"
            data-labour-view-toggle="selection"
            data-active="true"
            class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
          >
            <%= t("bom_labour_selection_title") || "Labours Selection" %>
          </button>
          <button
            type="button"
            data-labour-view-toggle="size_rules"
            data-active="false"
            class="rounded-full border px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] transition"
          >
            <%= t("bom_sku_rules") || "SKU Rules" %>
          </button>
        </div>
      </div>
      <section class="rounded-xl border border-slate-200 bg-white" data-labour-view="selection">
        <div class="border-b border-slate-200 px-3 py-3">
          <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600"><%= t("bom_labour_selection_title") || "Labours Selection" %></h3>
          <p class="mt-1 text-xs text-slate-500"><%= t("bom_labour_selection_hint") || "Select labour, department, and rate type. Size-wise rates are set below." %></p>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_labour') || 'Labour master to apply cost from.' %>"><%= t("labours") || "Labours" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_department') || 'Production department for this labour.' %>"><%= t("department") || "Department" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rate_type') || 'Cost basis (per pair or per dozen).' %>"><%= t("rate_type") || "Rate Type" %></th>
                <th class="px-3 py-2 text-right" title="<%= t('bom_hint_actions') || 'Use plus/minus to add or remove rows.' %>"><%= t("actions") || "Actions" %></th>
              </tr>
            </thead>
            <tbody data-lines-body="labour_selection"></tbody>
          </table>
        </div>
      </section>
      <section class="rounded-xl border border-slate-200 bg-white hidden" data-labour-view="size_rules">
        <div class="border-b border-slate-200 px-3 py-3">
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600"><%= t("bom_sku_rules") || "SKU Rules" %></h3>
            <p class="mt-1 text-xs text-slate-500"><%= t("bom_labour_sku_rules_hint") || "Select a SKU to set labour rates. These rates apply by SKU size scope." %></p>
            <div class="mt-2 flex flex-wrap items-center gap-2" data-labour-rule-sku-sections></div>
          </div>
        </div>
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="min-w-full text-sm">
            <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.1em] text-slate-500">
              <tr>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_labour') || 'Labour master to apply cost from.' %>"><%= t("labours") || "Labours" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_department') || 'Production department for this labour.' %>"><%= t("department") || "Department" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rate_type') || 'Cost basis (per pair or per dozen).' %>"><%= t("rate_type") || "Rate Type" %></th>
                <th class="px-3 py-2 text-left" title="<%= t('bom_hint_rate_value') || 'Enter the labour rate amount for this SKU scope.' %>"><%= t("rate_value") || "Rate Value" %></th>
              </tr>
            </thead>
            <tbody data-lines-body="labour_rule"></tbody>
          </table>
        </div>
      </section>
    </section>

    <% if (isEditable) { %>
      <div class="flex justify-center" data-bom-save-wrap>
        <button type="button" data-bom-save-draft class="rounded-xl bg-accent px-5 py-2.5 text-xs font-semibold uppercase tracking-[0.16em] text-white shadow-sm transition hover:brightness-95">
          <%= t("save_draft") || "Save Draft" %>
        </button>
      </div>
    <% } %>
  </form>
</div>

<div class="fixed inset-0 z-[95] hidden items-center justify-center bg-slate-900/40 p-4" data-bom-header-change-modal>
  <div class="w-full max-w-xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
    <div class="relative border-b border-slate-200 px-6 py-5">
      <button
        type="button"
        data-bom-header-modal-close
        class="absolute right-6 top-5 inline-flex h-8 w-8 items-center justify-center rounded-lg text-slate-400 transition hover:bg-slate-100 hover:text-slate-700"
        aria-label="<%= tx('close', 'Close') %>"
        title="<%= tx('close', 'Close') %>"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>
      </button>
      <div class="flex items-start gap-3">
        <div class="mt-0.5 inline-flex h-8 w-8 items-center justify-center rounded-full bg-amber-100 text-amber-700">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 8v5m0 3h.01M4.93 19h14.14c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.2 16c-.77 1.33.19 3 1.73 3z" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div>
          <h3 class="text-base font-semibold text-slate-800"><%= tx("bom_header_change_modal_title", "BOM setup changed") %></h3>
          <p class="mt-1 text-sm text-slate-600"><%= tx("bom_header_change_modal_message", "You changed BOM Setup fields. This can reset dependent material, SFG, and labour sections.") %></p>
        </div>
      </div>
    </div>
    <div class="bg-slate-50 px-6 py-4 text-sm text-slate-700">
      <p><%= tx("bom_header_change_modal_hint", "Save Draft to keep current entries. Discard Changes to continue with the new setup and clear dependent sections.") %></p>
    </div>
    <div class="flex flex-col-reverse gap-2 border-t border-slate-200 px-6 py-4 sm:flex-row sm:justify-end">
      <button type="button" data-bom-header-modal-discard class="rounded-xl border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-700 transition hover:border-rose-400 hover:bg-rose-50">
        <%= tx("bom_header_change_modal_discard", "Clear and Continue") %>
      </button>
      <button type="button" data-bom-header-modal-save class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800">
        <%= tx("bom_header_change_modal_save", "Save Draft and Continue") %>
      </button>
    </div>
  </div>
</div>

<script><%- include("../../base/partials/searchable-select.js") %></script>
<script><%- include("../../base/partials/voucher-row-enter-navigation.js") %></script>
<script>
  (function () {
    const editable = <%- JSON.stringify(Boolean(isEditable)) %>;
    const options = <%- JSON.stringify(options || {}) %>;
    const initialVariantRules = <%- JSON.stringify(formState?.variant_rules || []) %>;
    const state = {
      rm: <%- JSON.stringify(formState?.rm_lines || []) %>,
      sfg: <%- JSON.stringify(formState?.sfg_lines || []) %>,
      labour: <%- JSON.stringify(formState?.labour_lines || []) %>,
      labour_selection: [],
      labourRuleRateMap: {},
      labourRuleOpenSkuId: "",
      labourRuleOpenFallbackSizeId: null,
      rule: (initialVariantRules || []).filter((row) => String(row?.action_type || "").toUpperCase() === "ADJUST_QTY"),
      color_rule: (initialVariantRules || []).filter((row) => {
        const action = String(row?.action_type || "").toUpperCase();
        const newValue = row?.new_value && typeof row.new_value === "object" ? row.new_value : {};
        return action === "REPLACE_RM" && (newValue.rm_color_id || 0) && !(newValue.replacement_rm_item_id || 0);
      }).map((row) => ({
        target_rm_item_id: row.target_rm_item_id || "",
        sku_color_id: String(row.color_scope || "").toUpperCase() === "SPECIFIC" ? (row.color_id || "") : "",
        rm_color_id: (row.new_value && row.new_value.rm_color_id) || "",
      })),
      packing_rule: (initialVariantRules || []).filter((row) => {
        const action = String(row?.action_type || "").toUpperCase();
        const newValue = row?.new_value && typeof row.new_value === "object" ? row.new_value : {};
        return action === "REPLACE_RM" && (newValue.replacement_rm_item_id || 0);
      }).map((row) => ({
        target_rm_item_id: row.target_rm_item_id || "",
        packing_type_id: String(row.packing_scope || "").toUpperCase() === "SPECIFIC" ? (row.packing_type_id || "") : "",
        size_id: String(row.size_scope || "").toUpperCase() === "SPECIFIC" ? (row.size_id || "") : "",
        replacement_rm_item_id: (row.new_value && row.new_value.replacement_rm_item_id) || "",
      })),
      sku_override: <%- JSON.stringify(formState?.sku_overrides || []) %>,
      ruleOpenSizeId: null,
      colorRuleOpenScope: "ALL",
      skuRuleOpenSkuId: "",
      ruleRemovedKeys: new Set(),
    };
    const labels = {
      select: "<%= t('select') || 'Select' %>",
      all: "<%= t('all') || 'All' %>",
      specific: "<%= t('bom_specific') || 'Specific' %>",
      add: "<%= t('add') || 'Add' %>",
      remove: "<%= t('delete') || 'Delete' %>",
      clear: "<%= t('clear') || 'Clear' %>",
    };
    const serverErrorMessage = <%- JSON.stringify(errorMessage || "") %>;
    const serverErrorDetails = <%- JSON.stringify((errors || []).map((err) => err?.message).filter(Boolean)) %>;
    let allowBomSubmit = false;
    let bomForm = null;
    let saveDraftBtn = null;
    let approveNowBtn = null;
    let submitIntentInput = null;
    let headerCommittedState = null;
    let applyingHeaderState = false;
    const rmUiText = {
      sizePickerHint: "<%= t('bom_rules_size_picker_hint') || 'Choose a size tab to edit material quantities for that size.' %>",
      activeSizeLabel: "<%= t('bom_rules_active_size_label') || 'Editing rules for size' %>",
      ruleCountLabel: "<%= t('bom_rules_count_label') || 'rules' %>",
      colMaterial: "<%= t('bom_rm_col_material') || 'Material' %>",
      colQty: "<%= t('bom_rules_col_qty') || 'Required Qty' %>",
      colUom: "<%= t('bom_rules_col_uom') || 'Unit' %>",
      colActions: "<%= t('bom_rm_col_actions') || 'Actions' %>",
      colMaterialHelp: "<%= t('bom_hint_size_rule_material') || 'Material to which this size rule applies.' %>",
      colQtyHelp: "<%= t('bom_hint_size_rule_qty') || 'Required quantity for the selected size.' %>",
      colUomHelp: "<%= t('bom_hint_size_rule_uom') || 'Unit for the size-specific quantity.' %>",
      colActionsHelp: "<%= t('bom_hint_actions') || 'Use plus/minus to add or remove rows.' %>",
      colColor: "<%= t('color') || 'Color' %>",
      colPacking: "<%= t('packing') || 'Packing' %>",
      colReplace: "<%= t('replace_with') || 'Replace With' %>",
      colSku: "<%= t('sku') || 'SKU' %>",
    };
    const esc = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");

    const makeOptions = (rows, selected, textFn) =>
      rows
        .map((row) => {
          const optionValue = row.id || row.value;
          const optionText = textFn ? textFn(row) : row.name || row.label || row.value;
          return `<option value="${esc(optionValue)}" ${String(selected || "") === String(optionValue) ? "selected" : ""}>${esc(optionText)}</option>`;
        })
        .join("");

    const rmItemUomById = new Map((options.rmItems || []).map((item) => [String(item.id), String(item.base_uom_id || "")]));
    const sfgSkuUomById = new Map((options.sfgSkus || []).map((sku) => [String(sku.id), String(sku.base_uom_id || "")]));
    const uomNameById = new Map((options.uoms || []).map((uom) => [String(uom.id), String(uom.name || "")]));
    const rmItemNameById = new Map((options.rmItems || []).map((item) => [String(item.id), item.name || item.code || item.id]));
    const departmentNameById = new Map((options.departments || []).map((dept) => [String(dept.id), dept.name || dept.id]));
    const labourNameById = new Map((options.labours || []).map((labour) => [String(labour.id), labour.name || labour.code || labour.id]));
    const rmItemColorMap = options.rmItemColorMap || {};
    const rmItemSizeMap = options.rmItemSizeMap || {};
    const labourDeptMap = options.labourDeptMap || {};
    const headerLevelToItemType = { FINISHED: "FG", SEMI_FINISHED: "SFG" };
    const headerItemSelect = document.querySelector('select[name="item_id"]');
    const headerLevelSelect = document.querySelector('select[name="level"]');
    const allHeaderItems = Array.isArray(options.items) ? options.items : [];
    const headerItemById = new Map(allHeaderItems.map((item) => [String(item.id || ""), item]));
    const sfgSection = document.getElementById("bom-sfg");
    const sfgPartColumnLabelEl = document.querySelector("[data-sfg-part-col-label]");
    const sfgPartColumnTitleEl = document.querySelector("[data-sfg-part-col-title]");
    const stepLabel = "<%= t('step') || 'Step' %>";
    const upperLabel = "<%= t('upper') || 'Upper' %>";
    const sfgPartDefaultColLabel = "<%= t('bom_sfg_col_step_upper_sku') || 'Step/Upper SKU' %>";
    const sfgPartDefaultHint = "<%= t('bom_hint_step_upper_sku') || 'Select the semi-finished SKU used for this finished SKU.' %>";
    const sfgPartStepHint = "<%= t('bom_hint_step_sku') || 'Select step SKU used for this finished SKU.' %>";
    const sfgPartUpperHint = "<%= t('bom_hint_upper_sku') || 'Select upper SKU used for this finished SKU.' %>";
    const plusIcon = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /><path d="M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>';
    const deleteIcon = '<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 12h12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" /></svg>';
    const resolveRmUomId = (row) => rmItemUomById.get(String(row?.rm_item_id || "")) || String(row?.uom_id || "");
    const resolveSfgUomId = (row) => sfgSkuUomById.get(String(row?.sfg_sku_id || "")) || String(row?.uom_id || "");
    const getUomName = (uomId) => uomNameById.get(String(uomId || "")) || "";
    const getRmColorsForItem = (rmItemId) => {
      const rows = rmItemColorMap[String(rmItemId || "")];
      return Array.isArray(rows) ? rows : [];
    };
    const getRmSizesForItem = (rmItemId) => {
      const rows = rmItemSizeMap[String(rmItemId || "")];
      return Array.isArray(rows) ? rows : [];
    };
    const getLabourDepartmentsForLabour = (labourId) => {
      const allowedDeptIds = Array.isArray(labourDeptMap[String(labourId || "")]) ? labourDeptMap[String(labourId || "")] : [];
      if (!allowedDeptIds.length) return [];
      return (options.departments || []).filter((dept) => allowedDeptIds.includes(String(dept.id)));
    };
    const actionButtons = (type) =>
      `<div class="inline-flex items-center gap-2">
        <button type="button" data-add-after="${type}" title="${labels.add}" aria-label="${labels.add}" class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-white p-2 text-slate-600 transition hover:border-slate-300 hover:text-slate-900">${plusIcon}</button>
        <button type="button" data-remove-row="${type}" title="${labels.remove}" aria-label="${labels.remove}" class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-white p-2 text-slate-600 transition hover:border-slate-300 hover:text-slate-900">${deleteIcon}</button>
      </div>`;

    const rateTypeLabel = {
      PER_PAIR: "<%= t('rate_type_per_pair') || 'Per Pair' %>",
      PER_DOZEN: "<%= t('rate_type_per_dozen') || 'Per Dozen' %>",
    };
    const defaultLabourSelectionRow = () => ({ labour_id: "", dept_id: "", rate_type: "PER_PAIR" });
    const normalizeLabourRateType = (rateType) => {
      const normalized = String(rateType || "PER_PAIR").toUpperCase();
      return Object.prototype.hasOwnProperty.call(rateTypeLabel, normalized) ? normalized : "PER_PAIR";
    };
    const normalizeLabourSelectionRow = (row) => ({
      labour_id: String(row?.labour_id || "").trim(),
      dept_id: String(row?.dept_id || "").trim(),
      rate_type: normalizeLabourRateType(row?.rate_type),
    });
    const toLabourComboKey = (row) => {
      const normalized = normalizeLabourSelectionRow(row);
      return `${normalized.labour_id}:${normalized.dept_id}:${normalized.rate_type}`;
    };
    const toLabourRateKey = (row, sizeKey) => `${toLabourComboKey(row)}:${String(sizeKey || "ALL")}`;
    const toLabourSizeKeyFromLine = (line) => (
      String(line?.size_scope || "").toUpperCase() === "SPECIFIC"
        ? String(line?.size_id || "").trim()
        : "ALL"
    );
    const allSizesLabel = "<%= t('all_sizes') || 'All Sizes' %>";
    const ruleSectionsHost = document.querySelector("[data-rule-size-sections]");
    const colorRuleScopesHost = document.querySelector("[data-rule-color-scopes]");
    const skuRuleChipsHost = document.querySelector("[data-sku-rule-chips]");
    const skuRulesBody = document.querySelector("[data-sku-rules-body]");
    const labourRuleSkuChipsHost = document.querySelector("[data-labour-rule-sku-sections]");
    const rmModeToggleButtons = Array.from(document.querySelectorAll("[data-rm-mode-toggle]"));
    const rmAdvancedTogglesHost = document.querySelector("[data-rm-advanced-toggles]");
    const rmViewToggleButtons = Array.from(document.querySelectorAll("[data-rm-view-toggle]"));
    const rmViewPanels = Array.from(document.querySelectorAll("[data-rm-view]"));
    const labourViewToggleButtons = Array.from(document.querySelectorAll("[data-labour-view-toggle]"));
    const labourViewPanels = Array.from(document.querySelectorAll("[data-labour-view]"));
    const nonHeaderSections = Array.from(document.querySelectorAll("#bom-rm, #bom-labour"));
    const headerLockNotice = document.querySelector("[data-header-lock-notice]");
    const headerChangeModal = document.querySelector("[data-bom-header-change-modal]");
    const headerModalSaveBtn = headerChangeModal?.querySelector("[data-bom-header-modal-save]");
    const headerModalDiscardBtn = headerChangeModal?.querySelector("[data-bom-header-modal-discard]");
    const headerModalCancelBtn = headerChangeModal?.querySelector("[data-bom-header-modal-cancel]");
    const headerModalCloseBtn = headerChangeModal?.querySelector("[data-bom-header-modal-close]");
    let rmEditorMode = "materials";
    let rmViewMode = "materials";
    let labourViewMode = "selection";

    const setSelectOptions = (selectEl, rows, selectedValue, textFn) => {
      if (!selectEl) return;
      const selected = String(selectedValue || "");
      selectEl.innerHTML = `<option value="">${esc(labels.select)}</option>${makeOptions(rows || [], selected, textFn)}`;
      const hasSelected = Array.from(selectEl.options).some((opt) => String(opt.value) === selected);
      selectEl.value = hasSelected ? selected : "";
    };

    const refreshRmVariantSelectors = (row, rmItemId) => {
      if (!row) return;
      const hidden = row.querySelector('[data-col="uom_id"]');
      const display = row.querySelector('[data-col-display="uom_id"]');
      const uomId = rmItemUomById.get(String(rmItemId || "")) || "";
      if (hidden) hidden.value = uomId;
      if (display) display.value = getUomName(uomId);
    };

    const refreshLabourDepartmentSelector = (row, labourId) => {
      if (!row) return;
      const deptSelect = row.querySelector('[data-col="dept_id"]');
      setSelectOptions(deptSelect, getLabourDepartmentsForLabour(labourId), deptSelect?.value || "");
    };

    const renderHeaderItemsByLevel = (preserveSelectedItem = true) => {
      if (!headerItemSelect || !headerLevelSelect) return;
      const currentValue = preserveSelectedItem ? String(headerItemSelect.value || "") : "";
      const level = String(headerLevelSelect.value || "").toUpperCase();
      const requiredItemType = headerLevelToItemType[level] || null;
      const filteredItems = requiredItemType
        ? allHeaderItems.filter((item) => String(item.item_type || "").toUpperCase() === requiredItemType)
        : [];
      headerItemSelect.innerHTML =
        `<option value="">${esc(labels.select)}</option>` + makeOptions(filteredItems, currentValue, (item) => item.name || item.code || item.id);
      const hasCurrent = filteredItems.some((item) => String(item.id) === currentValue);
      headerItemSelect.value = hasCurrent ? currentValue : "";
      headerItemSelect.disabled = !editable || !requiredItemType;
    };

    const getSelectedHeaderItem = () => {
      const itemId = String(headerItemSelect?.value || "");
      return headerItemById.get(itemId) || null;
    };

    const getSfgPartType = () => String(getSelectedHeaderItem()?.sfg_part_type || "").trim().toUpperCase();

    const getSfgPartColumnLabel = () => {
      const partType = getSfgPartType();
      if (partType === "STEP") return `${stepLabel} SKU`;
      if (partType === "UPPER") return `${upperLabel} SKU`;
      return sfgPartDefaultColLabel;
    };

    const updateSfgPartColumnPresentation = () => {
      const partType = getSfgPartType();
      const label = getSfgPartColumnLabel();
      if (sfgPartColumnLabelEl) sfgPartColumnLabelEl.textContent = label;
      if (sfgPartColumnTitleEl) {
        if (partType === "STEP") {
          sfgPartColumnTitleEl.setAttribute("title", sfgPartStepHint);
        } else if (partType === "UPPER") {
          sfgPartColumnTitleEl.setAttribute("title", sfgPartUpperHint);
        } else {
          sfgPartColumnTitleEl.setAttribute("title", sfgPartDefaultHint);
        }
      }
    };

    const getHeaderSizeOptions = () => {
      const itemId = String(headerItemSelect?.value || "");
      const rows = options.itemSizeMap && Array.isArray(options.itemSizeMap[itemId]) ? options.itemSizeMap[itemId] : [];
      return rows;
    };
    const getLabourSizeScopes = () => {
      const sizeRows = getHeaderSizeOptions();
      if (sizeRows.length) {
        return sizeRows.map((size) => ({ id: String(size.id), name: size.name || size.id }));
      }
      return [{ id: "ALL", name: allSizesLabel }];
    };
    const syncLabourLinesFromSelectionAndRates = () => {
      const normalizedSelection = (Array.isArray(state.labour_selection) ? state.labour_selection : [])
        .map((row) => normalizeLabourSelectionRow(row));
      const activeSelection = normalizedSelection.filter((row) => row.labour_id || row.dept_id);
      state.labour_selection = normalizedSelection.length ? normalizedSelection : [defaultLabourSelectionRow()];

      if (!state.labourRuleRateMap || typeof state.labourRuleRateMap !== "object") {
        state.labourRuleRateMap = {};
      }
      const scopeRows = getLabourSizeScopes();
      const validSizeKeys = new Set(scopeRows.map((scope) => String(scope.id)));
      const validComboKeys = new Set(activeSelection.map((row) => toLabourComboKey(row)));
      Object.keys(state.labourRuleRateMap).forEach((key) => {
        const separatorIndex = key.lastIndexOf(":");
        if (separatorIndex <= 0) {
          delete state.labourRuleRateMap[key];
          return;
        }
        const comboKey = key.slice(0, separatorIndex);
        const sizeKey = key.slice(separatorIndex + 1);
        if (!validComboKeys.has(comboKey) || !validSizeKeys.has(sizeKey)) {
          delete state.labourRuleRateMap[key];
        }
      });

      const nextLines = [];
      activeSelection.forEach((row) => {
        scopeRows.forEach((scope) => {
          const scopeId = String(scope.id || "ALL");
          const directRate = state.labourRuleRateMap[toLabourRateKey(row, scopeId)];
          const inheritedRate = scopeId === "ALL" ? "" : state.labourRuleRateMap[toLabourRateKey(row, "ALL")];
          nextLines.push({
            size_scope: scopeId === "ALL" ? "ALL" : "SPECIFIC",
            size_id: scopeId === "ALL" ? null : scopeId,
            dept_id: row.dept_id || null,
            labour_id: row.labour_id || null,
            rate_type: row.rate_type || "PER_PAIR",
            rate_value: String(directRate ?? inheritedRate ?? "").trim(),
          });
        });
      });
      state.labour = nextLines;
    };
    const initializeLabourStateFromExistingLines = () => {
      const lines = Array.isArray(state.labour) ? state.labour : [];
      const selectionMap = new Map();
      const rateMap = {};
      lines.forEach((line) => {
        const selectionRow = normalizeLabourSelectionRow(line);
        const hasSelection = selectionRow.labour_id || selectionRow.dept_id;
        if (!hasSelection) return;
        const comboKey = toLabourComboKey(selectionRow);
        if (!selectionMap.has(comboKey)) {
          selectionMap.set(comboKey, selectionRow);
        }
        const rateValue = String(line?.rate_value ?? "").trim();
        if (!rateValue) return;
        const sizeKey = toLabourSizeKeyFromLine(line);
        if (!sizeKey) return;
        rateMap[toLabourRateKey(selectionRow, sizeKey)] = rateValue;
      });
      state.labour_selection = selectionMap.size ? Array.from(selectionMap.values()) : [defaultLabourSelectionRow()];
      state.labourRuleRateMap = rateMap;
      syncLabourLinesFromSelectionAndRates();
    };
    const getHeaderSkuOptions = () => {
      const itemId = String(headerItemSelect?.value || "");
      const rows = options.itemSkuMap && Array.isArray(options.itemSkuMap[itemId]) ? options.itemSkuMap[itemId] : [];
      return rows;
    };
    const findHeaderSkuById = (skuId) =>
      getHeaderSkuOptions().find((row) => String(row.id || "") === String(skuId || "")) || null;
    const findHeaderSkuBySizeId = (sizeId) =>
      getHeaderSkuOptions().find((row) => String(row.size_id || "") === String(sizeId || "")) || null;
    const shouldShowSfgSection = () => {
      const level = String(headerLevelSelect?.value || "").trim().toUpperCase();
      if (level !== "FINISHED") return false;
      const item = getSelectedHeaderItem();
      if (!item) return false;
      if (String(item.item_type || "").toUpperCase() !== "FG") return false;
      return Boolean(item.uses_sfg);
    };
    const getLabourActiveSku = () => {
      const skuOptions = getHeaderSkuOptions();
      if (!skuOptions.length) {
        state.labourRuleOpenSkuId = "";
        return null;
      }
      const hasCurrent = skuOptions.some((sku) => String(sku.id) === String(state.labourRuleOpenSkuId || ""));
      if (!hasCurrent) state.labourRuleOpenSkuId = String(skuOptions[0].id);
      return skuOptions.find((sku) => String(sku.id) === String(state.labourRuleOpenSkuId || "")) || null;
    };
    const getLabourSizeKeyFromSku = (sku) => {
      const sizeId = String(sku?.size_id || "").trim();
      return sizeId || "ALL";
    };
    const getHeaderColorOptions = () => {
      const itemId = String(headerItemSelect?.value || "");
      const skuRows = options.itemSkuMap && Array.isArray(options.itemSkuMap[itemId]) ? options.itemSkuMap[itemId] : [];
      const colorMap = new Map();
      skuRows.forEach((row) => {
        const colorId = String(row?.color_id || "");
        if (!colorId) return;
        if (!colorMap.has(colorId)) colorMap.set(colorId, row?.color_name || colorId);
      });
      return Array.from(colorMap.entries()).map(([id, name]) => ({ id, name }));
    };
    const getRmUnitNameByItemId = (itemId) => {
      const uomId = rmItemUomById.get(String(itemId || "")) || "";
      return getUomName(uomId);
    };
    const getColorRuleRmOptions = () => {
      const rmMap = new Map();
      (state.rm || []).forEach((line) => {
        const itemId = String(line?.rm_item_id || "").trim();
        if (!itemId || rmMap.has(itemId)) return;
        const item = (options.rmItems || []).find((row) => String(row.id) === itemId);
        rmMap.set(itemId, { id: itemId, name: item?.name || item?.code || itemId });
      });
      const allRmOptions = Array.from(rmMap.values());
      const multiColorOnly = allRmOptions.filter((row) => getRmColorsForItem(row.id).length > 1);
      if (multiColorOnly.length) return multiColorOnly;
      const hasAnyColor = allRmOptions.filter((row) => getRmColorsForItem(row.id).length > 0);
      return hasAnyColor.length ? hasAnyColor : allRmOptions;
    };

    const seedColorRulesForNoSkuColorVariants = () => {
      const skuColorOptions = getHeaderColorOptions();
      if (skuColorOptions.length) return;
      if (Array.isArray(state.color_rule) && state.color_rule.some((row) => Number(row?.target_rm_item_id || 0))) return;
      const candidateMaterials = getColorRuleRmOptions().filter((row) => getRmColorsForItem(row.id).length > 1);
      if (!candidateMaterials.length) return;
      state.color_rule = candidateMaterials.map((row) => ({
        target_rm_item_id: String(row.id || ""),
        sku_color_id: "",
        rm_color_id: "",
      }));
    };
    const getColorScopeOptions = () => {
      const skuColorOptions = getHeaderColorOptions();
      const defaultLabel = skuColorOptions.length
        ? "<%= t('bom_all_skus') || 'All SKUs' %>"
        : "<%= t('bom_all_skus_no_color') || 'All SKUs (no color variants)' %>";
      return [
        { id: "ALL", name: defaultLabel },
        ...skuColorOptions.map((row) => ({ id: String(row.id || ""), name: row.name || row.id })),
      ];
    };
    const toColorScopeKey = (value) => {
      const key = String(value || "").trim();
      return key ? key : "ALL";
    };
    const showErrorModal = (message) => {
      const text = String(message || "").trim();
      if (!text) return;
      if (typeof window.showUiErrorModal === "function") {
        window.showUiErrorModal(text, "<%= t('error_generic') || 'Error' %>");
      }
    };
    const getRmDuplicateCombo = () => {
      const seen = new Map();
      for (let idx = 0; idx < (state.rm || []).length; idx += 1) {
        const line = state.rm[idx] || {};
        const rmItemId = String(line.rm_item_id || "").trim();
        const deptId = String(line.dept_id || "").trim();
        if (!rmItemId || !deptId) continue;
        const key = `${rmItemId}:${deptId}`;
        if (seen.has(key)) return { firstIndex: seen.get(key), secondIndex: idx, key };
        seen.set(key, idx);
      }
      return null;
    };
    const getLabourSelectionDuplicateCombo = () => {
      const seen = new Map();
      for (let idx = 0; idx < (state.labour_selection || []).length; idx += 1) {
        const line = state.labour_selection[idx] || {};
        const labourId = String(line.labour_id || "").trim();
        const deptId = String(line.dept_id || "").trim();
        if (!labourId || !deptId) continue;
        const key = `${labourId}:${deptId}`;
        if (seen.has(key)) return { firstIndex: seen.get(key), secondIndex: idx, key };
        seen.set(key, idx);
      }
      return null;
    };
    const hasClientDuplicateCombos = () => {
      const rmDuplicate = getRmDuplicateCombo();
      if (rmDuplicate) {
        showErrorModal("<%= t('bom_error_rm_department_duplicate') || 'This material is already added for the selected consumption department. Use a different material or department.' %>");
        return true;
      }
      const labourDuplicate = getLabourSelectionDuplicateCombo();
      if (labourDuplicate) {
        showErrorModal("<%= t('bom_error_labour_department_duplicate') || 'This labour is already added for the selected department. Choose a different labour or department.' %>");
        return true;
      }
      return false;
    };
    const resolveRmDuplicateOnChange = (rowIndex, changedCol) => {
      const duplicate = getRmDuplicateCombo();
      if (!duplicate) return false;
      if (duplicate.firstIndex !== rowIndex && duplicate.secondIndex !== rowIndex) return false;
      const line = state.rm[rowIndex];
      if (!line) return false;
      if (changedCol === "rm_item_id") {
        line.rm_item_id = "";
        line.uom_id = "";
      } else if (changedCol === "dept_id") {
        line.dept_id = "";
      }
      showErrorModal("<%= t('bom_error_rm_department_duplicate') || 'This material is already added for the selected consumption department. Use a different material or department.' %>");
      return true;
    };
    const resolveLabourSelectionDuplicateOnChange = (rowIndex, changedCol) => {
      const duplicate = getLabourSelectionDuplicateCombo();
      if (!duplicate) return false;
      if (duplicate.firstIndex !== rowIndex && duplicate.secondIndex !== rowIndex) return false;
      const line = state.labour_selection[rowIndex];
      if (!line) return false;
      if (changedCol === "labour_id") {
        line.labour_id = "";
      } else if (changedCol === "dept_id") {
        line.dept_id = "";
      }
      syncLabourLinesFromSelectionAndRates();
      showErrorModal("<%= t('bom_error_labour_department_duplicate') || 'This labour is already added for the selected department. Choose a different labour or department.' %>");
      return true;
    };
    const findSkuOverride = (skuId, targetRmItemId, targetDeptId) =>
      (state.sku_override || []).find(
        (row) => String(row?.sku_id || "") === String(skuId || "")
          && String(row?.target_rm_item_id || "") === String(targetRmItemId || "")
          && String(row?.dept_id || "") === String(targetDeptId || ""),
      ) || (() => {
        const materialRows = (state.rm || []).filter(
          (line) => String(line?.rm_item_id || "") === String(targetRmItemId || ""),
        );
        const deptSet = new Set(
          materialRows
            .map((line) => String(line?.dept_id || "").trim())
            .filter(Boolean),
        );
        if (deptSet.size !== 1 || !deptSet.has(String(targetDeptId || "").trim())) return null;
        return (state.sku_override || []).find(
          (row) =>
            String(row?.sku_id || "") === String(skuId || "")
            && String(row?.target_rm_item_id || "") === String(targetRmItemId || "")
            && !String(row?.dept_id || "").trim(),
        ) || null;
      })();
    const getSkuLabel = (sku) => {
      if (!sku) return "";
      const parts = [];
      if (sku.size_name) parts.push(sku.size_name);
      if (sku.color_name) parts.push(sku.color_name);
      if (sku.packing_name || sku.packing_type_name) parts.push(sku.packing_name || sku.packing_type_name);
      if (sku.grade_name) parts.push(sku.grade_name);
      if (parts.length) return `(${parts.filter(Boolean).join(" ")})`;
      return String(sku.sku_code || "");
    };
    const getSkuVariantPeerIds = (skuId) => {
      const allSkus = getHeaderSkuOptions();
      const current = allSkus.find((row) => String(row.id) === String(skuId || ""));
      if (!current) return [];
      const key = [
        String(current.size_id || ""),
        String(current.color_id || ""),
        String(current.packing_type_id || ""),
      ].join("|");
      const peerIds = allSkus
        .filter((row) => String(row.id) !== String(current.id))
        .filter((row) => [
          String(row.size_id || ""),
          String(row.color_id || ""),
          String(row.packing_type_id || ""),
        ].join("|") === key)
        .map((row) => String(row.id || ""))
        .filter(Boolean);
      return peerIds;
    };
    const pickMatchingSizeRule = (targetRmItemId, sizeId) => {
      const target = String(targetRmItemId || "");
      const size = String(sizeId || "");
      return (state.rule || []).find((row) =>
        String(row?.target_rm_item_id || "") === target
        && String(row?.size_id || "") === size
        && Number(row?.new_value?.qty || 0) > 0,
      ) || null;
    };
    const pickMatchingColorRule = (targetRmItemId, skuColorId) => {
      const target = String(targetRmItemId || "");
      const skuColor = String(skuColorId || "");
      const rows = (state.color_rule || []).filter((row) =>
        String(row?.target_rm_item_id || "") === target
        && String(row?.rm_color_id || "").trim(),
      );
      if (!rows.length) return null;
      const specific = rows.find((row) => String(row?.sku_color_id || "") === skuColor && skuColor);
      if (specific) return specific;
      return rows.find((row) => !String(row?.sku_color_id || "").trim()) || null;
    };
    const pickMatchingPackingRule = (targetRmItemId, packingTypeId, sizeId) => {
      const target = String(targetRmItemId || "");
      const packing = String(packingTypeId || "");
      if (!packing) return null;
      const rows = (state.packing_rule || []).filter((row) =>
        String(row?.target_rm_item_id || "") === target
        && String(row?.replacement_rm_item_id || "").trim()
        && String(row?.packing_type_id || "") === packing,
      );
      if (!rows.length) return null;
      const size = String(sizeId || "");
      return rows.find((row) => String(row?.size_id || "") === size)
        || rows.find((row) => !String(row?.size_id || "").trim())
        || null;
    };
    const applyRulesToRmLineForSku = (rmLine, sku, overrideLine = null) => {
      const targetRmItemId = String(rmLine?.rm_item_id || "").trim();
      const deptId = String(rmLine?.dept_id || "").trim();
      if (!targetRmItemId) return null;
      let effectiveRmItemId = targetRmItemId;
      let qty = Number(rmLine?.qty || 0);
      if (!Number.isFinite(qty) || qty <= 0) qty = 1;
      let qtyIsExplicit = false;
      let uomId = resolveRmUomId(rmLine) || "";
      let rmColorId = "";
      let excluded = false;

      const sizeRule = pickMatchingSizeRule(targetRmItemId, sku?.size_id);
      if (sizeRule) {
        const ruleQty = Number(sizeRule?.new_value?.qty || 0);
        if (Number.isFinite(ruleQty) && ruleQty > 0) {
          qty = ruleQty;
          qtyIsExplicit = true;
        }
        const ruleUomId = String(sizeRule?.new_value?.uom_id || "").trim();
        if (ruleUomId) uomId = ruleUomId;
      }

      const colorRule = pickMatchingColorRule(targetRmItemId, sku?.color_id);
      if (colorRule) {
        rmColorId = String(colorRule?.rm_color_id || "").trim();
      }

      const packingRule = pickMatchingPackingRule(targetRmItemId, sku?.packing_type_id, sku?.size_id);
      if (packingRule) {
        effectiveRmItemId = String(packingRule?.replacement_rm_item_id || "").trim() || effectiveRmItemId;
        const replacementUomId = rmItemUomById.get(String(effectiveRmItemId || "")) || "";
        if (replacementUomId) uomId = replacementUomId;
      }

      if (overrideLine) {
        if (overrideLine.is_excluded) excluded = true;
        const overrideQty = Number(overrideLine.override_qty || 0);
        if (Number.isFinite(overrideQty) && overrideQty > 0) {
          qty = overrideQty;
          qtyIsExplicit = true;
        }
        if (String(overrideLine.replacement_rm_item_id || "").trim()) {
          effectiveRmItemId = String(overrideLine.replacement_rm_item_id);
          const overrideUomId = rmItemUomById.get(String(effectiveRmItemId || "")) || "";
          if (overrideUomId) uomId = overrideUomId;
        }
        if (String(overrideLine.rm_color_id || "").trim()) {
          rmColorId = String(overrideLine.rm_color_id).trim();
        }
      }

      return {
        targetRmItemId,
        effectiveRmItemId,
        qty,
        qtyIsExplicit,
        uomId,
        deptId,
        rmColorId,
        excluded,
      };
    };
    const getSkuRulesRows = (skuId) => {
      const sku = getHeaderSkuOptions().find((row) => String(row.id) === String(skuId || ""));
      if (!sku) return [];
      const rmLines = (state.rm || []).filter((row) => String(row?.rm_item_id || "").trim());
      return rmLines.map((rmLine) => {
        const overrideLine = findSkuOverride(sku.id, rmLine.rm_item_id, rmLine.dept_id);
        const baseline = applyRulesToRmLineForSku(rmLine, sku, null);
        const effective = applyRulesToRmLineForSku(rmLine, sku, overrideLine);
        return {
          sku,
          baseline,
          effective,
        };
      }).filter((row) => row.baseline && row.effective);
    };
    const ensureSkuRuleOpenSku = () => {
      const skuOptions = getHeaderSkuOptions();
      if (!skuOptions.length) {
        state.skuRuleOpenSkuId = "";
        return null;
      }
      const hasCurrent = skuOptions.some((sku) => String(sku.id) === String(state.skuRuleOpenSkuId || ""));
      if (!hasCurrent) state.skuRuleOpenSkuId = String(skuOptions[0].id);
      return skuOptions.find((sku) => String(sku.id) === String(state.skuRuleOpenSkuId || "")) || null;
    };
    const upsertSkuOverrideLine = (nextLine) => {
      const skuId = String(nextLine?.sku_id || "");
      const targetRmItemId = String(nextLine?.target_rm_item_id || "");
      const targetDeptId = String(nextLine?.dept_id || "");
      if (!skuId || !targetRmItemId || !targetDeptId) return;
      const idx = (state.sku_override || []).findIndex(
        (row) =>
          String(row?.sku_id || "") === skuId
          && String(row?.target_rm_item_id || "") === targetRmItemId
          && String(row?.dept_id || "") === targetDeptId,
      );
      const hasAnyChange = Boolean(
        nextLine.is_excluded
        || Number(nextLine.override_qty || 0) > 0
        || String(nextLine.replacement_rm_item_id || "").trim()
        || String(nextLine.rm_color_id || "").trim(),
      );
      if (!hasAnyChange) {
        if (idx >= 0) state.sku_override.splice(idx, 1);
        return;
      }
      if (idx >= 0) {
        state.sku_override[idx] = { ...state.sku_override[idx], ...nextLine };
      } else {
        state.sku_override = (state.sku_override || []).filter((row) => !(
          String(row?.sku_id || "") === skuId
          && String(row?.target_rm_item_id || "") === targetRmItemId
          && !String(row?.dept_id || "").trim()
        ));
        state.sku_override.push(nextLine);
      }
    };
    const renderSkuRules = () => {
      if (!(skuRulesBody instanceof HTMLElement)) return;
      const skuOptions = getHeaderSkuOptions();
      const activeSku = ensureSkuRuleOpenSku();
      if (skuRuleChipsHost) {
        skuRuleChipsHost.innerHTML = skuOptions.length
          ? skuOptions.map((sku) => {
            const skuId = String(sku.id);
            const isActive = skuId === String(activeSku?.id || "");
            return `
              <button
                type="button"
                data-sku-rule-chip="${esc(skuId)}"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                title="${esc(getSkuLabel(sku))}"
              >
                ${esc(getSkuLabel(sku))}
              </button>
            `;
          }).join("")
          : `<span class="text-xs text-slate-500"><%= t("no_entries") || "No entries" %></span>`;
      }
      if (!activeSku) {
        skuRulesBody.innerHTML = `<tr><td colspan="5" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_sku_available") || "No SKU available for selected article." %></td></tr>`;
        return;
      }
      const rows = getSkuRulesRows(activeSku.id);
      if (!rows.length) {
        skuRulesBody.innerHTML = `<tr><td colspan="5" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_material_lines_for_sku_rules") || "Add material lines first to edit SKU rules." %></td></tr>`;
        return;
      }
      skuRulesBody.innerHTML = rows.map(({ sku, baseline, effective }, rowIndex) => {
        const materialName = rmItemNameById.get(String(effective.effectiveRmItemId || "")) || effective.effectiveRmItemId;
        const deptName = departmentNameById.get(String(effective.deptId || "")) || "";
        const uomName = getUomName(effective.uomId);
        const rmColorOptions = getRmColorsForItem(effective.effectiveRmItemId);
        const baselineQty = Number(baseline.qty || 0);
        const baselineQtyExplicit = Boolean(baseline.qtyIsExplicit);
        const baselineColor = String(baseline.rmColorId || "");
        const qtyValue = effective.excluded
          ? ""
          : (effective.qtyIsExplicit ? String(effective.qty || "") : "");
        const rowClass = effective.excluded ? "opacity-60" : "";
        const colorControl = rmColorOptions.length
          ? `<select data-sku-rule-col="rm_color_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable && !effective.excluded ? "" : "disabled"}>
                <option value="">${esc(labels.select)}</option>
                ${makeOptions(rmColorOptions, effective.rmColorId)}
              </select>`
          : `<input type="text" value="-" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-500" readonly>`;
        return `
          <tr
            class="border-b border-slate-100 ${rowClass}"
            data-sku-rule-row="true"
            data-row-index="${rowIndex}"
            data-sku-id="${esc(sku.id)}"
            data-target-rm-item-id="${esc(effective.targetRmItemId)}"
            data-target-dept-id="${esc(effective.deptId)}"
            data-baseline-qty="${esc(baselineQty)}"
            data-baseline-explicit="${baselineQtyExplicit ? "1" : "0"}"
            data-baseline-rm-color-id="${esc(baselineColor)}"
          >
            <td class="px-3 py-2 font-medium text-slate-700">${esc(materialName)}</td>
            <td class="px-3 py-2 text-slate-600">${esc(deptName)}</td>
            <td class="px-3 py-2">
              ${colorControl}
            </td>
            <td class="px-3 py-2">
              <input data-sku-rule-col="required_qty" data-no-stepper="true" type="number" min="0.001" step="0.001" value="${esc(qtyValue)}" ${editable && !effective.excluded ? "" : "readonly"} class="w-32 rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm ${effective.excluded ? "bg-slate-50 text-slate-500" : ""}">
            </td>
            <td class="px-3 py-2 text-slate-600">${esc(uomName)}</td>
          </tr>
        `;
      }).join("");
    };

    const getRelevantSfgSkus = () => {
      const headerItemId = String(headerItemSelect?.value || "");
      const linkedSfgItemIds = Array.isArray(options.fgToSfgMap?.[headerItemId]) ? options.fgToSfgMap[headerItemId] : [];
      if (linkedSfgItemIds.length) {
        const itemIdSet = new Set(linkedSfgItemIds.map((id) => String(id)));
        return (options.sfgSkus || []).filter((sku) => itemIdSet.has(String(sku.item_id || "")));
      }
      return [];
    };

    const isHeaderReady = () => {
      const level = String(headerLevelSelect?.value || "").trim();
      const itemId = String(headerItemSelect?.value || "").trim();
      const outputQty = Number(document.querySelector('input[name="output_qty"]')?.value || 0);
      const outputUom = String(document.querySelector('select[name="output_uom_id"]')?.value || "").trim();
      return Boolean(level && itemId && outputQty > 0 && outputUom);
    };

    const updateHeaderSectionState = () => {
      const ready = isHeaderReady();
      nonHeaderSections.forEach((section) => {
        section.classList.toggle("hidden", !ready);
      });
      if (sfgSection) {
        const showSfg = ready && shouldShowSfgSection();
        sfgSection.classList.toggle("hidden", !showSfg);
      }
      updateSfgPartColumnPresentation();
      if (headerLockNotice) headerLockNotice.classList.toggle("hidden", ready);
    };
    const getHeaderState = () => ({
      level: String(headerLevelSelect?.value || "").trim(),
      item_id: String(headerItemSelect?.value || "").trim(),
      output_qty: String(document.querySelector('input[name="output_qty"]')?.value || "").trim(),
      output_uom_id: String(document.querySelector('select[name="output_uom_id"]')?.value || "").trim(),
    });
    const isSameHeaderState = (a, b) =>
      String(a?.level || "") === String(b?.level || "")
      && String(a?.item_id || "") === String(b?.item_id || "")
      && String(a?.output_qty || "") === String(b?.output_qty || "")
      && String(a?.output_uom_id || "") === String(b?.output_uom_id || "");
    const applyHeaderState = (nextState) => {
      const safeState = nextState || {};
      applyingHeaderState = true;
      if (headerLevelSelect) headerLevelSelect.value = String(safeState.level || "");
      renderHeaderItemsByLevel(false);
      if (headerItemSelect) {
        const itemId = String(safeState.item_id || "");
        const hasItem = Array.from(headerItemSelect.options || []).some((opt) => String(opt.value || "") === itemId);
        headerItemSelect.value = hasItem ? itemId : "";
      }
      const outputQtyInput = document.querySelector('input[name="output_qty"]');
      if (outputQtyInput) outputQtyInput.value = String(safeState.output_qty || "");
      const outputUomSelect = document.querySelector('select[name="output_uom_id"]');
      if (outputUomSelect) outputUomSelect.value = String(safeState.output_uom_id || "");
      applyingHeaderState = false;
      syncStateFromDom();
      updateHeaderSectionState();
      renderAll();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
    };
    const hasDependentBomData = () => {
      const hasRm = (state.rm || []).some((row) =>
        String(row?.rm_item_id || "").trim()
        || String(row?.dept_id || "").trim(),
      );
      const hasSfg = (state.sfg || []).some((row) =>
        String(row?.sfg_sku_id || "").trim()
        || Number(row?.required_qty || 0) > 0,
      );
      const hasLabourSelection = (state.labour_selection || []).some((row) =>
        String(row?.labour_id || "").trim()
        || String(row?.dept_id || "").trim(),
      );
      const hasLabourRates = (state.labour || []).some((row) => String(row?.rate_value || "").trim());
      const hasSizeRules = normalizeRuleRows(state.rule).some((row) =>
        String(row?.target_rm_item_id || "").trim()
        && Number(row?.new_value?.qty || 0) > 0,
      );
      const hasColorRules = (state.color_rule || []).some((row) =>
        String(row?.target_rm_item_id || "").trim()
        || String(row?.sku_color_id || "").trim()
        || String(row?.rm_color_id || "").trim(),
      );
      const hasPackingRules = (state.packing_rule || []).some((row) =>
        String(row?.target_rm_item_id || "").trim()
        || String(row?.packing_type_id || "").trim()
        || String(row?.size_id || "").trim()
        || String(row?.replacement_rm_item_id || "").trim(),
      );
      const hasSkuOverrides = (state.sku_override || []).some((row) =>
        Boolean(row?.is_excluded)
        || String(row?.override_qty || "").trim()
        || String(row?.replacement_rm_item_id || "").trim()
        || String(row?.rm_color_id || "").trim(),
      );
      return hasRm || hasSfg || hasLabourSelection || hasLabourRates || hasSizeRules || hasColorRules || hasPackingRules || hasSkuOverrides;
    };
    const resetDependentBomStateForHeaderChange = () => {
      state.rm = editable ? [addDefaults.rm()] : [];
      state.sfg = [];
      state.labour_selection = editable ? [defaultLabourSelectionRow()] : [];
      state.labourRuleRateMap = {};
      state.labour = [];
      state.labourRuleOpenSkuId = "";
      state.labourRuleOpenFallbackSizeId = null;
      state.rule = [];
      state.color_rule = [];
      state.packing_rule = [];
      state.sku_override = [];
      state.ruleOpenSizeId = null;
      state.colorRuleOpenScope = "ALL";
      state.skuRuleOpenSkuId = "";
      state.ruleRemovedKeys = new Set();
      syncLabourLinesFromSelectionAndRates();
    };
    const commitHeaderChange = (changedField) => {
      if (String(changedField || "") === "level") {
        renderHeaderItemsByLevel(false);
      }
      syncStateFromDom();
      updateHeaderSectionState();
      renderAll();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      headerCommittedState = getHeaderState();
    };
    const openHeaderChangeModal = () =>
      new Promise((resolve) => {
        if (!(headerChangeModal instanceof HTMLElement)) {
          resolve("cancel");
          return;
        }
        let settled = false;
        const close = (result) => {
          if (settled) return;
          settled = true;
          document.removeEventListener("keydown", onKeydown);
          headerChangeModal.removeEventListener("click", onBackdropClick);
          headerModalSaveBtn?.removeEventListener("click", onSave);
          headerModalDiscardBtn?.removeEventListener("click", onDiscard);
          headerModalCancelBtn?.removeEventListener("click", onCancel);
          headerModalCloseBtn?.removeEventListener("click", onCancel);
          headerChangeModal.classList.add("hidden");
          headerChangeModal.classList.remove("flex");
          resolve(result);
        };
        const onSave = () => close("save");
        const onDiscard = () => close("discard");
        const onCancel = () => close("cancel");
        const onKeydown = (event) => {
          if (event.key === "Escape") {
            event.preventDefault();
            close("cancel");
          }
        };
        const onBackdropClick = (event) => {
          if (event.target === headerChangeModal) close("cancel");
        };
        headerModalSaveBtn?.addEventListener("click", onSave);
        headerModalDiscardBtn?.addEventListener("click", onDiscard);
        headerModalCancelBtn?.addEventListener("click", onCancel);
        headerModalCloseBtn?.addEventListener("click", onCancel);
        document.addEventListener("keydown", onKeydown);
        headerChangeModal.addEventListener("click", onBackdropClick);
        headerChangeModal.classList.remove("hidden");
        headerChangeModal.classList.add("flex");
        window.setTimeout(() => {
          if (headerModalSaveBtn instanceof HTMLElement) headerModalSaveBtn.focus();
        }, 0);
      });

    const renderRm = () => {
      const body = document.querySelector('[data-lines-body="rm"]');
      if (!body) return;
      body.innerHTML = state.rm
        .map((row, idx) => {
          const fixedUomId = resolveRmUomId(row);
          const fixedUomName = getUomName(fixedUomId);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2"><select data-col="rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.rmItems || [], row.rm_item_id, (r) => r.name || r.code || r.id)}</select></td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="uom_id" value="${esc(fixedUomId)}" />
              <input type="text" data-col-display="uom_id" value="${esc(fixedUomName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly>
            </td>
            <td class="px-3 py-2"><select data-col="dept_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.departments || [], row.dept_id)}</select></td>
            <td class="px-3 py-2 text-right">
              <input type="hidden" data-col="qty" value="${esc(row.qty ?? 1)}" />
              <input type="hidden" data-col="color_id" value="">
              <input type="hidden" data-col="size_id" value="">
              <input type="hidden" data-col="normal_loss_pct" value="${esc(row.normal_loss_pct ?? 0)}" />
              ${editable ? actionButtons("rm") : ""}
            </td>
          </tr>`;
        })
        .join("");
    };

    const renderSfg = () => {
      const body = document.querySelector('[data-lines-body="sfg"]');
      if (!body) return;
      if (!shouldShowSfgSection()) {
        body.innerHTML = "";
        return;
      }
      const fgSkuOptions = getHeaderSkuOptions().filter((sku) => Number(sku?.size_id || 0) > 0);
      const sfgOptions = getRelevantSfgSkus();
      if (!fgSkuOptions.length) {
        body.innerHTML = `<tr><td colspan="4" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_sku_available") || "No SKU available for selected article." %></td></tr>`;
        return;
      }
      const existingBySkuId = new Map((state.sfg || []).map((row) => [String(row?.fg_sku_id || ""), row]));
      const existingBySizeId = new Map((state.sfg || []).map((row) => [String(row?.fg_size_id || ""), row]));
      const nextSfg = fgSkuOptions.map((sku) => {
        const bySku = existingBySkuId.get(String(sku.id || ""));
        const bySize = existingBySizeId.get(String(sku.size_id || ""));
        const existing = bySku || bySize || {};
        return {
          fg_sku_id: String(sku.id || ""),
          fg_size_id: String(sku.size_id || ""),
          sfg_sku_id: String(existing?.sfg_sku_id || ""),
          required_qty: existing?.required_qty ?? "",
          uom_id: String(existing?.uom_id || ""),
        };
      });
      state.sfg = nextSfg;
      body.innerHTML = nextSfg
        .map((row, idx) => {
          const mappedFgSku = findHeaderSkuById(row.fg_sku_id);
          const fgSkuLabel = getSkuLabel(mappedFgSku) || mappedFgSku?.sku_code || row.fg_sku_id;
          const fgSizeId = String(mappedFgSku?.size_id || row.fg_size_id || "");
          const fixedUomId = resolveSfgUomId(row);
          const fixedUomName = getUomName(fixedUomId);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2">
              <input type="hidden" data-col="fg_sku_id" value="${esc(row.fg_sku_id)}">
              <input type="hidden" data-col="fg_size_id" value="${esc(fgSizeId)}">
              <input type="text" value="${esc(fgSkuLabel)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-700" readonly>
            </td>
            <td class="px-3 py-2"><select data-col="sfg_sku_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(sfgOptions, row.sfg_sku_id, (r) => r.sku_code || r.item_name || r.id)}</select></td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="uom_id" value="${esc(fixedUomId)}">
              <input type="text" data-col-display="uom_id" value="${esc(fixedUomName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly>
            </td>
            <td class="px-3 py-2"><input data-col="required_qty" data-no-stepper="true" type="number" min="0.001" step="0.001" value="${esc(row.required_qty ?? "")}" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "readonly"}></td>
          </tr>`;
        })
        .join("");
    };

    const renderLabourSelection = () => {
      const body = document.querySelector('[data-lines-body="labour_selection"]');
      if (!body) return;
      const lines = Array.isArray(state.labour_selection) ? state.labour_selection : [];
      body.innerHTML = lines
        .map((row, idx) => {
          const normalizedRow = normalizeLabourSelectionRow(row);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2"><select data-col="labour_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.labours || [], normalizedRow.labour_id, (r) => r.name || r.code || r.id)}</select></td>
            <td class="px-3 py-2"><select data-col="dept_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(getLabourDepartmentsForLabour(normalizedRow.labour_id), normalizedRow.dept_id)}</select></td>
            <td class="px-3 py-2"><select data-col="rate_type" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions((options.labourRateTypeOptions || []).map((r) => ({ value: r.value, id: r.value })), normalizedRow.rate_type, (r) => rateTypeLabel[r.value] || r.value)}</select></td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("labour_selection") : ""}</td>
          </tr>`;
        })
        .join("");
    };

    const renderLabourRules = () => {
      syncLabourLinesFromSelectionAndRates();
      const body = document.querySelector('[data-lines-body="labour_rule"]');
      if (!(body instanceof HTMLElement)) return;
      const skuOptions = getHeaderSkuOptions();
      const activeSku = getLabourActiveSku();
      const sizeScopes = getLabourSizeScopes();
      const hasSkuOptions = skuOptions.length > 0;
      let activeSizeKey = "ALL";
      if (labourRuleSkuChipsHost) {
        if (hasSkuOptions) {
          labourRuleSkuChipsHost.innerHTML = skuOptions.map((sku) => {
            const skuId = String(sku.id || "");
            const isActive = skuId === String(activeSku?.id || "");
            const label = getSkuLabel(sku) || String(sku.sku_code || sku.id || "");
            return `
              <button
                type="button"
                data-labour-rule-chip="${esc(skuId)}"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                title="${esc(label)}"
              >
                ${esc(label)}
              </button>
            `;
          }).join("");
        } else {
          if (!state.labourRuleOpenFallbackSizeId || !sizeScopes.some((scope) => String(scope.id) === String(state.labourRuleOpenFallbackSizeId))) {
            state.labourRuleOpenFallbackSizeId = sizeScopes.length ? String(sizeScopes[0].id) : "ALL";
          }
          labourRuleSkuChipsHost.innerHTML = sizeScopes.map((scope) => {
            const scopeId = String(scope.id || "ALL");
            const isActive = scopeId === String(state.labourRuleOpenFallbackSizeId || "");
            return `
              <button
                type="button"
                data-labour-rule-fallback-size="${esc(scopeId)}"
                class="inline-flex items-center rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                title="${esc(scope.name || scopeId)}"
              >
                ${esc(scope.name || scopeId)}
              </button>
            `;
          }).join("");
        }
      }
      if (hasSkuOptions) {
        if (!activeSku) {
          body.innerHTML = `<tr><td colspan="4" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_sku_available") || "No SKU available for selected article." %></td></tr>`;
          return;
        }
        activeSizeKey = getLabourSizeKeyFromSku(activeSku);
      } else {
        activeSizeKey = String(state.labourRuleOpenFallbackSizeId || sizeScopes[0]?.id || "ALL");
      }
      const activeRows = (state.labour || []).filter((row) => {
        const sizeKey = toLabourSizeKeyFromLine(row);
        return String(sizeKey || "ALL") === activeSizeKey;
      });
      if (!activeRows.length) {
        body.innerHTML = `<tr><td colspan="4" class="px-3 py-3 text-sm text-slate-500"><%= t("bom_no_labour_selected") || "Add labour lines first to set size-wise rates." %></td></tr>`;
        return;
      }
      body.innerHTML = activeRows
        .map((row, idx) => {
          const labourId = String(row?.labour_id || "");
          const deptId = String(row?.dept_id || "");
          const rateType = normalizeLabourRateType(row?.rate_type);
          const labourName = labourNameById.get(labourId) || labourId || "-";
          const deptName = departmentNameById.get(deptId) || deptId || "-";
          return `
            <tr data-row-index="${idx}" data-labour-rule-entry="true" data-labour-id="${esc(labourId)}" data-dept-id="${esc(deptId)}" data-rate-type="${esc(rateType)}" data-size-id="${esc(activeSizeKey)}" class="border-b border-slate-100">
              <td class="px-3 py-2 text-slate-700">${esc(labourName)}</td>
              <td class="px-3 py-2 text-slate-700">${esc(deptName)}</td>
              <td class="px-3 py-2 text-slate-700">${esc(rateTypeLabel[rateType] || rateType)}</td>
              <td class="px-3 py-2"><input data-labour-rule-col="rate_value" data-no-stepper="true" type="number" min="0" step="0.0001" value="${esc(row?.rate_value ?? "")}" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "readonly"}></td>
            </tr>
          `;
        })
        .join("");
    };

    const normalizeRuleRows = (rows) => {
      return (Array.isArray(rows) ? rows : [])
        .map((entry) => {
          const sizeId = Number(entry?.size_id || 0);
          const rmItemId = Number(entry?.target_rm_item_id || 0);
          if (!sizeId || !rmItemId) return null;
          const nextValue = entry?.new_value && typeof entry.new_value === "object" ? entry.new_value : {};
          const qty = Number(nextValue.qty || 0) > 0 ? Number(nextValue.qty) : "";
          const uomId = Number(nextValue.uom_id || 0) || Number(resolveRmUomId({ rm_item_id: rmItemId })) || null;
          return {
            size_id: sizeId,
            target_rm_item_id: rmItemId,
            new_value: {
              qty,
              uom_id: uomId,
            },
          };
        })
        .filter(Boolean);
    };

    const renderRules = () => {
      if (!ruleSectionsHost) return;
      const sizeOptions = getHeaderSizeOptions();
      const rmRows = (state.rm || []).filter((row) => Number(row.rm_item_id));
      const rmRowMap = new Map(rmRows.map((row) => [Number(row.rm_item_id), row]));
      const normalizedRules = normalizeRuleRows(state.rule);
      const existingMap = new Map(
        normalizedRules.map((row) => [`${row.size_id}:${row.target_rm_item_id}`, row]),
      );
      const merged = [];
      (sizeOptions || []).forEach((size) => {
        const sizeId = Number(size.id);
        rmRows.forEach((rmRow) => {
          const rmItemId = Number(rmRow.rm_item_id);
          const key = `${sizeId}:${rmItemId}`;
          if (state.ruleRemovedKeys.has(key)) return;
            const existing = existingMap.get(key);
            const fallbackUomId = Number(resolveRmUomId(rmRow)) || null;
            merged.push({
              size_id: sizeId,
              target_rm_item_id: rmItemId,
              new_value: {
                qty: Number(existing?.new_value?.qty || 0) > 0 ? Number(existing.new_value.qty) : "",
                uom_id: Number(existing?.new_value?.uom_id || 0) || fallbackUomId,
              },
            });
          });
      });
      state.rule = merged;

      const grouped = new Map();
      merged.forEach((row) => {
        const key = String(row.size_id);
        if (!grouped.has(key)) grouped.set(key, []);
        grouped.get(key).push(row);
      });
      if (sizeOptions.length && !state.ruleOpenSizeId) state.ruleOpenSizeId = String(sizeOptions[0].id);
      if (state.ruleOpenSizeId && !sizeOptions.some((row) => String(row.id) === String(state.ruleOpenSizeId))) {
        state.ruleOpenSizeId = sizeOptions.length ? String(sizeOptions[0].id) : null;
      }

      if (!sizeOptions.length) {
        ruleSectionsHost.innerHTML = `<div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-600"><%= t("no_entries") %></div>`;
        return;
      }

      const activeSizeId = String(state.ruleOpenSizeId || sizeOptions[0].id);
      const activeSize = sizeOptions.find((size) => String(size.id) === activeSizeId) || sizeOptions[0];
      const activeRows = grouped.get(String(activeSize.id)) || [];

      ruleSectionsHost.innerHTML = `
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
          <div class="mb-2 text-xs font-medium text-slate-500">${esc(rmUiText.sizePickerHint)}</div>
          <div class="flex flex-wrap items-center gap-2">
            ${sizeOptions
              .map((size) => {
                const sizeId = String(size.id);
                const isActive = sizeId === String(activeSize.id);
                const count = (grouped.get(sizeId) || []).length;
                return `
                  <button
                    type="button"
                    data-rule-toggle-size="${sizeId}"
                    class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
                  >
                    <span>${esc(size.name || size.id)}</span>
                    <span class="rounded-full ${isActive ? "bg-white/20 text-white" : "bg-slate-100 text-slate-600"} px-2 py-0.5 text-[10px]">${count} ${esc(rmUiText.ruleCountLabel)}</span>
                  </button>
                `;
              })
              .join("")}
          </div>
        </div>
        <section class="rounded-xl border border-slate-200 bg-white p-3">
          <div class="mb-3 flex flex-wrap items-center justify-between gap-2">
            <div class="text-sm font-semibold text-slate-700">${esc(rmUiText.activeSizeLabel)}: ${esc(activeSize.name || activeSize.id)}</div>
            <div class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.08em] text-slate-600">${activeRows.length} ${esc(rmUiText.ruleCountLabel)}</div>
          </div>
          <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
            <table class="min-w-full text-sm">
              <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-[0.08em] text-slate-500">
                <tr>
                  <th class="px-3 py-2 text-left" title="${esc(rmUiText.colMaterialHelp)}">${esc(rmUiText.colMaterial)}</th>
                  <th class="px-3 py-2 text-left" title="${esc(rmUiText.colUomHelp)}">${esc(rmUiText.colUom)}</th>
                  <th class="px-3 py-2 text-left" title="${esc(rmUiText.colQtyHelp)}">${esc(rmUiText.colQty)}</th>
                  <th class="px-3 py-2 text-right" title="${esc(rmUiText.colActionsHelp)}">${esc(rmUiText.colActions)}</th>
