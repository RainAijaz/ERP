                        <td class="px-3 py-2"><select data-rule-uom data-searchable-select="true" data-searchable-variant="unified" class="w-40 rounded-lg border border-slate-200 px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}>${makeOptions(options.uoms || [], uomId)}</select></td>
                        <td class="px-3 py-2"><input data-rule-qty data-no-stepper="true" type="number" min="0.001" step="0.001" value="${esc(row.new_value?.qty || "")}" class="w-32 rounded-lg border border-slate-200 px-2 py-1.5 text-sm" ${editable ? "" : "readonly"} /></td>
                        <td class="px-3 py-2 text-right">
                          ${editable ? `<button type="button" data-rule-remove-entry="${activeSize.id}:${row.target_rm_item_id}" class="inline-flex items-center justify-center rounded-md border border-slate-200 bg-white p-2 text-slate-600 transition hover:border-slate-300 hover:text-slate-900">${deleteIcon}</button>` : ""}
                        </td>
                      </tr>
                    `;
                  })
                  .join("")}
              </tbody>
            </table>
          </div>
        </section>
      `;
    };

    const renderColorRules = () => {
      const body = document.querySelector('[data-lines-body="color_rule"]');
      if (!body) return;
      seedColorRulesForNoSkuColorVariants();
      const rmBaseOptions = getColorRuleRmOptions();
      const colorScopeOptions = getColorScopeOptions();
      const allowedScopeKeys = new Set(colorScopeOptions.map((row) => String(row.id)));
      if (!Array.isArray(state.color_rule) || state.color_rule.length === 0) {
        state.color_rule = [addDefaults.color_rule()];
      }
      const hasSpecificSkuColors = colorScopeOptions.some((row) => String(row.id) !== "ALL");
      if (!hasSpecificSkuColors) {
        state.color_rule = state.color_rule.map((row) => ({ ...row, sku_color_id: "" }));
      }
      const groupedCount = new Map();
      state.color_rule.forEach((row) => {
        const scopeKey = toColorScopeKey(row.sku_color_id);
        groupedCount.set(scopeKey, (groupedCount.get(scopeKey) || 0) + 1);
      });
      const currentScope = toColorScopeKey(state.colorRuleOpenScope);
      state.colorRuleOpenScope = allowedScopeKeys.has(currentScope)
        ? currentScope
        : String(colorScopeOptions[0]?.id || "ALL");
      if (colorRuleScopesHost) {
        colorRuleScopesHost.innerHTML = colorScopeOptions
          .map((scope) => {
            const scopeId = String(scope.id || "ALL");
            const isActive = scopeId === String(state.colorRuleOpenScope);
            const count = groupedCount.get(scopeId) || 0;
            return `
              <button
                type="button"
                data-color-rule-toggle-scope="${esc(scopeId)}"
                class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] transition ${isActive ? "border-slate-800 bg-slate-900 text-white" : "border-slate-200 bg-white text-slate-700 hover:border-slate-300"}"
              >
                <span>${esc(scope.name || scopeId)}</span>
                <span class="rounded-full ${isActive ? "bg-white/20 text-white" : "bg-slate-100 text-slate-600"} px-2 py-0.5 text-[10px]">${count} ${esc(rmUiText.ruleCountLabel)}</span>
              </button>
            `;
          })
          .join("");
      }
      body.innerHTML = (state.color_rule || [])
        .map((row, idx) => {
          const scopeKey = toColorScopeKey(row.sku_color_id);
          const rmColorOptions = getRmColorsForItem(row.target_rm_item_id);
          const unitName = getRmUnitNameByItemId(row.target_rm_item_id);
          const isActiveScopeRow = String(scopeKey) === String(state.colorRuleOpenScope);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100${isActiveScopeRow ? "" : " hidden"}">
            <td class="px-3 py-2"><select data-col="target_rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(rmBaseOptions, row.target_rm_item_id)}</select></td>
            <td class="px-3 py-2"><input type="text" value="${esc(unitName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly></td>
            <td class="px-3 py-2">
              <input type="hidden" data-col="sku_color_id" value="${esc(scopeKey === "ALL" ? "" : scopeKey)}">
              <select data-col="rm_color_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(rmColorOptions, row.rm_color_id)}</select>
            </td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("color_rule") : ""}</td>
          </tr>`;
        })
        .join("");
    };

    const renderPackingRules = () => {
      const body = document.querySelector('[data-lines-body="packing_rule"]');
      if (!body) return;
      const rmBaseOptions = (state.rm || []).map((line) => {
        const item = (options.rmItems || []).find((row) => String(row.id) === String(line.rm_item_id));
        return { id: line.rm_item_id, name: item?.name || item?.code || line.rm_item_id };
      }).filter((row) => row.id);
      const sizeOptions = getHeaderSizeOptions();
      body.innerHTML = (state.packing_rule || [])
        .map((row, idx) => {
          const unitName = getRmUnitNameByItemId(row.target_rm_item_id);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2"><select data-col="target_rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(rmBaseOptions, row.target_rm_item_id)}</select></td>
            <td class="px-3 py-2"><input type="text" value="${esc(unitName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly></td>
            <td class="px-3 py-2"><select data-col="packing_type_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.packings || [], row.packing_type_id)}</select></td>
            <td class="px-3 py-2"><select data-col="size_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${esc(labels.all)}</option>${makeOptions(sizeOptions, row.size_id)}</select></td>
            <td class="px-3 py-2"><select data-col="replacement_rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.rmItems || [], row.replacement_rm_item_id, (r) => r.name || r.code || r.id)}</select></td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("packing_rule") : ""}</td>
          </tr>`;
        })
        .join("");
    };

    const renderSkuOverrides = () => {
      const body = document.querySelector('[data-lines-body="sku_override"]');
      if (!body) return;
      const skuOptions = getHeaderSkuOptions();
      const rmBaseOptions = (state.rm || []).map((line) => {
        const item = (options.rmItems || []).find((row) => String(row.id) === String(line.rm_item_id));
        return { id: line.rm_item_id, name: item?.name || item?.code || line.rm_item_id };
      }).filter((row) => row.id);
      body.innerHTML = (state.sku_override || [])
        .map((row, idx) => {
          const rmColorOptions = getRmColorsForItem(row.target_rm_item_id);
          const unitItemId = row.replacement_rm_item_id || row.target_rm_item_id;
          const unitName = getRmUnitNameByItemId(unitItemId);
          return `
          <tr data-row-index="${idx}" class="border-b border-slate-100">
            <td class="px-3 py-2"><select data-col="sku_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(skuOptions, row.sku_id, (r) => {
              const parts = [r.sku_code];
              if (r.size_name) parts.push(r.size_name);
              if (r.color_name) parts.push(r.color_name);
              if (r.packing_name) parts.push(r.packing_name);
              return parts.join(" / ");
            })}</select></td>
            <td class="px-3 py-2"><select data-col="target_rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(rmBaseOptions, row.target_rm_item_id)}</select></td>
            <td class="px-3 py-2"><input type="text" value="${esc(unitName)}" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-2 py-1.5 text-sm text-slate-600" readonly></td>
            <td class="px-3 py-2"><input data-col="override_qty" data-no-stepper="true" type="number" min="0.001" step="0.001" value="${esc(row.override_qty ?? "")}" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "readonly"}></td>
            <td class="px-3 py-2"><select data-col="replacement_rm_item_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(options.rmItems || [], row.replacement_rm_item_id, (r) => r.name || r.code || r.id)}</select></td>
            <td class="px-3 py-2"><select data-col="rm_color_id" data-searchable-select="true" data-searchable-variant="unified" class="w-full rounded-lg border border-slate-200 bg-white px-2 py-1.5 text-sm" ${editable ? "" : "disabled"}><option value="">${labels.select}</option>${makeOptions(rmColorOptions, row.rm_color_id)}</select></td>
            <td class="px-3 py-2 text-center"><input data-col="is_excluded" type="checkbox" ${row.is_excluded ? "checked" : ""} ${editable ? "" : "disabled"}></td>
            <td class="px-3 py-2 text-right">${editable ? actionButtons("sku_override") : ""}</td>
          </tr>`;
        })
        .join("");
    };

    const setRmViewMode = (mode) => {
      const allowedModes = new Set(["sku_rules", "materials", "size_rules", "color_rules", "packing_rules"]);
      const requestedMode = allowedModes.has(mode) ? mode : "materials";
      const isAdvancedRequested = ["size_rules", "color_rules", "packing_rules"].includes(requestedMode);
      rmViewMode = isAdvancedRequested && rmEditorMode !== "advanced" ? "materials" : requestedMode;
      rmViewPanels.forEach((panel) => {
        const panelMode = String(panel.getAttribute("data-rm-view") || "");
        panel.classList.toggle("hidden", panelMode !== rmViewMode);
      });
      rmViewToggleButtons.forEach((button) => {
        const buttonMode = String(button.getAttribute("data-rm-view-toggle") || "");
        button.setAttribute("data-active", buttonMode === rmViewMode ? "true" : "false");
      });
      if (rmViewMode === "sku_rules") {
        renderSkuRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      } else if (rmViewMode === "size_rules") {
        syncStateFromDom();
        renderRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      } else if (rmViewMode === "color_rules") {
        syncStateFromDom();
        renderColorRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      }
    };
    const setRmEditorMode = (mode) => {
      rmEditorMode = ["materials", "sku_rules", "advanced"].includes(mode) ? mode : "materials";
      rmModeToggleButtons.forEach((button) => {
        const buttonMode = String(button.getAttribute("data-rm-mode-toggle") || "");
        button.setAttribute("data-active", buttonMode === rmEditorMode ? "true" : "false");
      });
      if (rmAdvancedTogglesHost) {
        const hideAdvanced = rmEditorMode !== "advanced";
        rmAdvancedTogglesHost.classList.toggle("hidden", hideAdvanced);
        rmAdvancedTogglesHost.hidden = hideAdvanced;
        rmAdvancedTogglesHost.setAttribute("aria-hidden", hideAdvanced ? "true" : "false");
      }
      if (rmEditorMode === "advanced") {
        const currentAdvancedMode = ["size_rules", "color_rules", "packing_rules"].includes(rmViewMode)
          ? rmViewMode
          : "size_rules";
        setRmViewMode(currentAdvancedMode);
      } else {
        setRmViewMode(rmEditorMode);
      }
    };
    const setLabourViewMode = (mode) => {
      labourViewMode = ["selection", "size_rules"].includes(mode) ? mode : "selection";
      labourViewPanels.forEach((panel) => {
        const panelMode = String(panel.getAttribute("data-labour-view") || "");
        panel.classList.toggle("hidden", panelMode !== labourViewMode);
      });
      labourViewToggleButtons.forEach((button) => {
        const buttonMode = String(button.getAttribute("data-labour-view-toggle") || "");
        button.setAttribute("data-active", buttonMode === labourViewMode ? "true" : "false");
      });
      if (labourViewMode === "size_rules") {
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      }
    };

    const renderAll = () => {
      updateSfgPartColumnPresentation();
      renderRm();
      renderSfg();
      renderLabourSelection();
      renderLabourRules();
      renderRules();
      renderColorRules();
      renderPackingRules();
      renderSkuOverrides();
      renderSkuRules();
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
    };

    const addDefaults = {
      rm: () => ({ rm_item_id: "", color_id: "", size_id: "", dept_id: "", qty: 1, uom_id: "", normal_loss_pct: 0 }),
      sfg: () => ({ fg_sku_id: "", fg_size_id: "", sfg_sku_id: "", required_qty: "", uom_id: "" }),
      labour_selection: () => defaultLabourSelectionRow(),
      rule: () => ({ size_scope: "SPECIFIC", size_id: "", packing_scope: "ALL", packing_type_id: null, color_scope: "ALL", color_id: null, action_type: "ADJUST_QTY", material_scope: "SPECIFIC", target_rm_item_id: "", new_value: { qty: "", uom_id: "" } }),
      color_rule: () => ({ target_rm_item_id: "", sku_color_id: "", rm_color_id: "" }),
      packing_rule: () => ({ target_rm_item_id: "", packing_type_id: "", size_id: "", replacement_rm_item_id: "" }),
      sku_override: () => ({ sku_id: "", target_rm_item_id: "", dept_id: "", is_excluded: false, override_qty: "", replacement_rm_item_id: "", rm_color_id: "" }),
    };

    const addRow = (type, insertAtIndex = null) => {
      if (!editable || !addDefaults[type]) return;
      syncStateFromDom();
      const nextRow = addDefaults[type]();
      if (type === "color_rule") {
        const scopeKey = toColorScopeKey(state.colorRuleOpenScope);
        nextRow.sku_color_id = scopeKey === "ALL" ? "" : scopeKey;
      }
      if (Number.isInteger(insertAtIndex) && insertAtIndex >= 0 && insertAtIndex <= state[type].length) {
        state[type].splice(insertAtIndex, 0, nextRow);
      } else {
        state[type].push(nextRow);
      }
      if (type === "labour_selection") {
        syncLabourLinesFromSelectionAndRates();
      }
      renderAll();
    };

    const ensureMinimumRows = () => {
      if (!editable) return;
      ["rm", "labour_selection"].forEach((type) => {
        if (!Array.isArray(state[type]) || state[type].length === 0) {
          state[type] = [addDefaults[type]()];
        }
      });
      if (!Array.isArray(state.color_rule)) state.color_rule = [];
      if (!Array.isArray(state.packing_rule)) state.packing_rule = [];
      if (!Array.isArray(state.sku_override)) state.sku_override = [];
      syncLabourLinesFromSelectionAndRates();
    };

    document.addEventListener("click", (event) => {
      const inlineAddBtn = event.target.closest("[data-add-after]");
      if (inlineAddBtn) {
        const type = inlineAddBtn.getAttribute("data-add-after");
        if (type === "rule") return;
        const row = inlineAddBtn.closest("tr");
        const idx = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(idx)) addRow(type, idx + 1);
        return;
      }
      const rmModeToggleBtn = event.target.closest("[data-rm-mode-toggle]");
      if (rmModeToggleBtn) {
        const nextMode = String(rmModeToggleBtn.getAttribute("data-rm-mode-toggle") || "materials");
        setRmEditorMode(nextMode);
        return;
      }
      const rmViewToggleBtn = event.target.closest("[data-rm-view-toggle]");
      if (rmViewToggleBtn) {
        const nextMode = String(rmViewToggleBtn.getAttribute("data-rm-view-toggle") || "materials");
        if (rmEditorMode !== "advanced") setRmEditorMode("advanced");
        setRmViewMode(nextMode);
        return;
      }
      const labourViewToggleBtn = event.target.closest("[data-labour-view-toggle]");
      if (labourViewToggleBtn) {
        const nextMode = String(labourViewToggleBtn.getAttribute("data-labour-view-toggle") || "selection");
        setLabourViewMode(nextMode);
        return;
      }
      const skuRuleChipBtn = event.target.closest("[data-sku-rule-chip]");
      if (skuRuleChipBtn) {
        state.skuRuleOpenSkuId = String(skuRuleChipBtn.getAttribute("data-sku-rule-chip") || "");
        renderSkuRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const ruleToggleBtn = event.target.closest("[data-rule-toggle-size]");
      if (ruleToggleBtn) {
        syncRuleRowsFromDom();
        state.ruleOpenSizeId = String(ruleToggleBtn.getAttribute("data-rule-toggle-size") || "");
        renderRules();
        return;
      }
      const labourRuleChipBtn = event.target.closest("[data-labour-rule-chip]");
      if (labourRuleChipBtn) {
        syncLabourRulesFromDom();
        state.labourRuleOpenSkuId = String(labourRuleChipBtn.getAttribute("data-labour-rule-chip") || "");
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourRuleFallbackSizeBtn = event.target.closest("[data-labour-rule-fallback-size]");
      if (labourRuleFallbackSizeBtn) {
        syncLabourRulesFromDom();
        state.labourRuleOpenFallbackSizeId = String(labourRuleFallbackSizeBtn.getAttribute("data-labour-rule-fallback-size") || "ALL");
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const colorRuleToggleBtn = event.target.closest("[data-color-rule-toggle-scope]");
      if (colorRuleToggleBtn) {
        syncStateFromDom();
        const nextScope = toColorScopeKey(colorRuleToggleBtn.getAttribute("data-color-rule-toggle-scope"));
        state.colorRuleOpenScope = nextScope;
        const hasRowsForScope = (state.color_rule || []).some((row) => toColorScopeKey(row.sku_color_id) === nextScope);
        if (!hasRowsForScope && editable) {
          state.color_rule.push({
            target_rm_item_id: "",
            sku_color_id: nextScope === "ALL" ? "" : nextScope,
            rm_color_id: "",
          });
        }
        renderColorRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const ruleRemoveBtn = event.target.closest("[data-rule-remove-entry]");
      if (ruleRemoveBtn) {
        const key = String(ruleRemoveBtn.getAttribute("data-rule-remove-entry") || "");
        state.ruleRemovedKeys.add(key);
        state.rule = normalizeRuleRows(state.rule).filter((row) => `${row.size_id}:${row.target_rm_item_id}` !== key);
        renderRules();
        return;
      }
      const removeBtn = event.target.closest("[data-remove-row]");
      if (!removeBtn) return;
      const type = removeBtn.getAttribute("data-remove-row");
      const row = removeBtn.closest("tr");
      const idx = Number(row?.getAttribute("data-row-index"));
      if (!Number.isFinite(idx)) return;
      syncStateFromDom();
      state[type].splice(idx, 1);
      const keepAtLeastOne = new Set(["rm", "labour_selection"]);
      if (!state[type].length && addDefaults[type] && keepAtLeastOne.has(type)) state[type].push(addDefaults[type]());
      if (type === "labour_selection") syncLabourLinesFromSelectionAndRates();
      renderAll();
    });

    document.addEventListener("change", async (event) => {
      const headerControl = event.target instanceof HTMLElement
        ? event.target.closest("[data-header-field]")
        : null;
      if (headerControl instanceof HTMLElement) {
        if (applyingHeaderState) return;
        const changedField = String(headerControl.getAttribute("data-header-field") || "").trim();
        if (!changedField) return;
        if (!headerCommittedState) headerCommittedState = getHeaderState();
        const nextHeaderState = getHeaderState();
        if (isSameHeaderState(nextHeaderState, headerCommittedState)) return;
        syncStateFromDom();
        if (!hasDependentBomData()) {
          commitHeaderChange(changedField);
          return;
        }
        const decision = await openHeaderChangeModal();
        if (decision === "save") {
          applyHeaderState(headerCommittedState);
          if (bomForm instanceof HTMLFormElement) {
            allowBomSubmit = true;
            bomForm.requestSubmit();
          }
          return;
        }
        if (decision === "discard") {
          resetDependentBomStateForHeaderChange();
          commitHeaderChange(changedField);
          return;
        }
        applyHeaderState(headerCommittedState);
        return;
      }
      const skuRuleControl = event.target.closest("[data-sku-rule-col]");
      if (skuRuleControl) {
        const row = skuRuleControl.closest("[data-sku-rule-row]");
        if (!row) return;
        const skuId = String(row.getAttribute("data-sku-id") || "");
        const targetRmItemId = String(row.getAttribute("data-target-rm-item-id") || "");
        const targetDeptId = String(row.getAttribute("data-target-dept-id") || "");
        if (!skuId || !targetRmItemId || !targetDeptId) return;
        const baselineQty = Number(row.getAttribute("data-baseline-qty") || 0);
        const baselineExplicit = String(row.getAttribute("data-baseline-explicit") || "") === "1";
        const baselineColorId = String(row.getAttribute("data-baseline-rm-color-id") || "");
        const qtyInput = row.querySelector('[data-sku-rule-col="required_qty"]');
        const colorSelect = row.querySelector('[data-sku-rule-col="rm_color_id"]');
        const enteredQty = Number(qtyInput?.value || 0);
        const selectedColorId = String(colorSelect?.value || "").trim();
        const existing = findSkuOverride(skuId, targetRmItemId, targetDeptId) || {
          sku_id: skuId,
          target_rm_item_id: targetRmItemId,
          dept_id: targetDeptId,
          is_excluded: false,
          override_qty: null,
          override_uom_id: null,
          replacement_rm_item_id: null,
          rm_color_id: null,
          notes: null,
        };
        const qtyDiff = Number.isFinite(enteredQty) && enteredQty > 0 && (!baselineExplicit || Math.abs(enteredQty - baselineQty) > 1e-9);
        const colorDiff = selectedColorId && selectedColorId !== baselineColorId;
        const nextLine = {
          ...existing,
          sku_id: skuId,
          target_rm_item_id: targetRmItemId,
          dept_id: targetDeptId,
          override_qty: qtyDiff ? enteredQty : null,
          rm_color_id: colorDiff ? selectedColorId : null,
        };
        upsertSkuOverrideLine(nextLine);
        const peerSkuIds = getSkuVariantPeerIds(skuId);
        peerSkuIds.forEach((peerSkuId) => {
          upsertSkuOverrideLine({
            ...nextLine,
            sku_id: peerSkuId,
          });
        });
        renderSkuRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const rmItemControl = event.target.closest('[data-col="rm_item_id"]');
      if (rmItemControl) {
        const row = rmItemControl.closest("tr");
        refreshRmVariantSelectors(row, rmItemControl.value);
        syncStateFromDom();
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveRmDuplicateOnChange(rowIndex, "rm_item_id")) {
          renderAll();
          if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
          return;
        }
        renderAll();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const rmDeptControl = event.target.closest('[data-lines-body="rm"] [data-col="dept_id"]');
      if (rmDeptControl) {
        const row = rmDeptControl.closest("tr");
        syncStateFromDom();
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveRmDuplicateOnChange(rowIndex, "dept_id")) {
          renderAll();
          if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
          return;
        }
        renderAll();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourControl = event.target.closest('[data-lines-body="labour_selection"] [data-col="labour_id"]');
      if (labourControl) {
        const row = labourControl.closest("tr");
        refreshLabourDepartmentSelector(row, labourControl.value);
        syncStateFromDom();
        const rowIndex = Number(row?.getAttribute("data-row-index"));
        if (Number.isFinite(rowIndex) && resolveLabourSelectionDuplicateOnChange(rowIndex, "labour_id")) {
          renderAll();
          if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
          return;
        }
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourSelectionControl = event.target.closest('[data-lines-body="labour_selection"] [data-col="dept_id"], [data-lines-body="labour_selection"] [data-col="rate_type"]');
      if (labourSelectionControl) {
        syncStateFromDom();
        const labourDeptControl = labourSelectionControl.closest('[data-col="dept_id"]');
        if (labourDeptControl) {
          const row = labourDeptControl.closest("tr");
          const rowIndex = Number(row?.getAttribute("data-row-index"));
          if (Number.isFinite(rowIndex) && resolveLabourSelectionDuplicateOnChange(rowIndex, "dept_id")) {
            renderAll();
            if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
            return;
          }
        }
        renderLabourRules();
        if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
        return;
      }
      const labourRateControl = event.target.closest('[data-lines-body="labour_rule"] [data-labour-rule-col="rate_value"]');
      if (labourRateControl) {
        syncLabourRulesFromDom();
        syncLabourLinesFromSelectionAndRates();
        return;
      }
      const sfgSkuControl = event.target.closest('[data-col="sfg_sku_id"]');
      if (sfgSkuControl) {
        const row = sfgSkuControl.closest("tr");
        const uomId = sfgSkuUomById.get(String(sfgSkuControl.value || "")) || "";
        const hidden = row?.querySelector('[data-col="uom_id"]');
        if (hidden) hidden.value = uomId;
      }
      const fgSkuControl = event.target.closest('[data-col="fg_sku_id"]');
      if (fgSkuControl) {
        const row = fgSkuControl.closest("tr");
        const fgSku = findHeaderSkuById(fgSkuControl.value);
        const hiddenSize = row?.querySelector('[data-col="fg_size_id"]');
        if (hiddenSize) hiddenSize.value = String(fgSku?.size_id || "");
      }
      const genericRuleTarget = event.target.closest('[data-col="target_rm_item_id"], [data-col="sku_id"]');
      if (genericRuleTarget) {
        syncStateFromDom();
        renderAll();
      }
    });

    const bindEnterNavigation = () => {
      if (!editable || typeof window.createVoucherRowEnterNavigator !== "function") return;
      const form = document.getElementById("bom-form");
      const headerSection = document.getElementById("bom-header");
      if (form instanceof HTMLElement && headerSection instanceof HTMLElement) {
        const headerNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: headerSection,
          rowSelector: "[data-header-enter-row]",
          fieldAttr: "data-header-field",
          fieldOrder: ["level", "item_id", "output_qty", "output_uom_id"],
          canAppendRow: () => false,
        });
        headerNavigator?.bind();
      }
      const rowConfigs = [
        { type: "rm", fieldOrder: ["rm_item_id", "dept_id"] },
        { type: "labour_selection", fieldOrder: ["labour_id", "dept_id", "rate_type"] },
        { type: "color_rule", fieldOrder: ["target_rm_item_id", "rm_color_id"] },
        { type: "packing_rule", fieldOrder: ["target_rm_item_id", "packing_type_id", "size_id", "replacement_rm_item_id"] },
      ];
      rowConfigs.forEach((cfg) => {
        const linesBody = document.querySelector(`[data-lines-body="${cfg.type}"]`);
        if (!(linesBody instanceof HTMLElement)) return;
        const navigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody,
          fieldAttr: "data-col",
          fieldOrder: cfg.fieldOrder,
          appendRow: () => {
            syncStateFromDom();
            addRow(cfg.type);
            return true;
          },
          canAppendRow: () => Boolean(editable),
        });
        navigator?.bind();
      });
      const sfgBody = document.querySelector('[data-lines-body="sfg"]');
      if (sfgBody instanceof HTMLElement) {
        const sfgNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: sfgBody,
          fieldAttr: "data-col",
          fieldOrder: ["sfg_sku_id", "required_qty"],
          canAppendRow: () => false,
        });
        sfgNavigator?.bind();
      }
      const labourRuleBody = document.querySelector('[data-lines-body="labour_rule"]');
      if (labourRuleBody instanceof HTMLElement) {
        const labourRuleNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: labourRuleBody,
          rowSelector: '[data-labour-rule-entry="true"]',
          fieldAttr: "data-labour-rule-col",
          fieldOrder: ["rate_value"],
          canAppendRow: () => false,
        });
        labourRuleNavigator?.bind();
      }
      if (skuRulesBody instanceof HTMLElement) {
        const skuRuleNavigator = window.createVoucherRowEnterNavigator({
          form,
          linesBody: skuRulesBody,
          rowSelector: '[data-sku-rule-row="true"]',
          fieldAttr: "data-sku-rule-col",
          fieldOrder: ["rm_color_id", "required_qty"],
          canAppendRow: () => false,
        });
        skuRuleNavigator?.bind();
      }
    };

    const collectRows = (type, mapFn) => {
      return Array.from(document.querySelectorAll(`[data-lines-body="${type}"] tr`)).map((row) => mapFn(row));
    };

    const getValue = (row, col) => row.querySelector(`[data-col="${col}"]`)?.value ?? "";

    const syncRuleRowsFromDom = () => {
      const existingRows = normalizeRuleRows(state.rule)
        .filter((row) => !state.ruleRemovedKeys.has(`${row.size_id}:${row.target_rm_item_id}`));
      const byKey = new Map(existingRows.map((row) => [`${row.size_id}:${row.target_rm_item_id}`, row]));
      const domRows = Array.from(document.querySelectorAll("[data-rule-entry]"))
        .map((row) => ({
          size_scope: "SPECIFIC",
          size_id: Number(row.getAttribute("data-size-id") || 0),
          packing_scope: "ALL",
          packing_type_id: null,
          color_scope: "ALL",
          color_id: null,
          action_type: "ADJUST_QTY",
          material_scope: "SPECIFIC",
          target_rm_item_id: Number(row.getAttribute("data-rm-item-id") || 0),
          new_value: {
            qty: Number(row.querySelector("[data-rule-qty]")?.value || 0),
            uom_id: Number(row.querySelector("[data-rule-uom]")?.value || 0) || null,
          },
        }))
        .filter((row) => row.size_id && row.target_rm_item_id && row.new_value.qty > 0);

      domRows.forEach((row) => {
        const key = `${row.size_id}:${row.target_rm_item_id}`;
        if (state.ruleRemovedKeys.has(key)) return;
        byKey.set(key, row);
      });

      state.rule = Array.from(byKey.values()).sort((a, b) =>
        `${a.size_id || 0}:${a.target_rm_item_id || 0}`.localeCompare(
          `${b.size_id || 0}:${b.target_rm_item_id || 0}`,
        ),
      );
    };

    const syncLabourRulesFromDom = () => {
      const ruleRows = Array.from(document.querySelectorAll('[data-lines-body="labour_rule"] [data-labour-rule-entry="true"]'));
      if (!ruleRows.length) return;
      if (!state.labourRuleRateMap || typeof state.labourRuleRateMap !== "object") {
        state.labourRuleRateMap = {};
      }
      ruleRows.forEach((row) => {
        const labourId = String(row.getAttribute("data-labour-id") || "").trim();
        const deptId = String(row.getAttribute("data-dept-id") || "").trim();
        const rateType = normalizeLabourRateType(row.getAttribute("data-rate-type"));
        const sizeId = String(row.getAttribute("data-size-id") || "ALL").trim() || "ALL";
        const rateInput = row.querySelector('[data-labour-rule-col="rate_value"]');
        const rateValue = String(rateInput?.value ?? "").trim();
        const selectionRow = { labour_id: labourId, dept_id: deptId, rate_type: rateType };
        const key = toLabourRateKey(selectionRow, sizeId);
        if (!labourId || !deptId || !rateValue) {
          delete state.labourRuleRateMap[key];
          return;
        }
        state.labourRuleRateMap[key] = rateValue;
      });
    };

    const syncStateFromDom = () => {
      state.rm = collectRows("rm", (row) => ({
        rm_item_id: getValue(row, "rm_item_id"),
        color_id: "",
        size_id: "",
        dept_id: getValue(row, "dept_id"),
        qty: getValue(row, "qty"),
        uom_id: getValue(row, "uom_id"),
        normal_loss_pct: getValue(row, "normal_loss_pct"),
      }));
      state.sfg = collectRows("sfg", (row) => ({
        fg_sku_id: getValue(row, "fg_sku_id"),
        fg_size_id: getValue(row, "fg_size_id"),
        sfg_sku_id: getValue(row, "sfg_sku_id"),
        required_qty: getValue(row, "required_qty"),
        uom_id: getValue(row, "uom_id"),
      }));
      if (!shouldShowSfgSection()) {
        state.sfg = [];
      }
      state.labour_selection = collectRows("labour_selection", (row) => normalizeLabourSelectionRow({
        labour_id: getValue(row, "labour_id"),
        dept_id: getValue(row, "dept_id"),
        rate_type: getValue(row, "rate_type"),
      }));
      if (!state.labour_selection.length) state.labour_selection = [defaultLabourSelectionRow()];
      syncLabourRulesFromDom();
      syncLabourLinesFromSelectionAndRates();
      state.color_rule = collectRows("color_rule", (row) => ({
        target_rm_item_id: getValue(row, "target_rm_item_id"),
        sku_color_id: getValue(row, "sku_color_id"),
        rm_color_id: getValue(row, "rm_color_id"),
      })).filter((row) => row.target_rm_item_id || row.sku_color_id || row.rm_color_id);
      state.packing_rule = collectRows("packing_rule", (row) => ({
        target_rm_item_id: getValue(row, "target_rm_item_id"),
        packing_type_id: getValue(row, "packing_type_id"),
        size_id: getValue(row, "size_id"),
        replacement_rm_item_id: getValue(row, "replacement_rm_item_id"),
      })).filter((row) => row.target_rm_item_id || row.packing_type_id || row.size_id || row.replacement_rm_item_id);
      const skuOverrideBody = document.querySelector('[data-lines-body="sku_override"]');
      if (skuOverrideBody) {
        state.sku_override = collectRows("sku_override", (row) => ({
          sku_id: getValue(row, "sku_id"),
          target_rm_item_id: getValue(row, "target_rm_item_id"),
          dept_id: getValue(row, "dept_id"),
          is_excluded: row.querySelector('[data-col="is_excluded"]')?.checked === true,
          override_qty: getValue(row, "override_qty"),
          replacement_rm_item_id: getValue(row, "replacement_rm_item_id"),
          rm_color_id: getValue(row, "rm_color_id"),
        })).filter((row) => row.sku_id || row.target_rm_item_id || row.dept_id || row.is_excluded || row.override_qty || row.replacement_rm_item_id || row.rm_color_id);
      } else if (!Array.isArray(state.sku_override)) {
        state.sku_override = [];
      }
      syncRuleRowsFromDom();
    };

    const composeVariantRulesPayload = () => {
      const sizeRules = normalizeRuleRows(state.rule).map((row) => ({
        size_scope: "SPECIFIC",
        size_id: Number(row.size_id || 0) || null,
        packing_scope: "ALL",
        packing_type_id: null,
        color_scope: "ALL",
        color_id: null,
        action_type: "ADJUST_QTY",
        material_scope: "SPECIFIC",
        target_rm_item_id: Number(row.target_rm_item_id || 0) || null,
        new_value: {
          qty: Number(row.new_value?.qty || 0) || null,
          uom_id: Number(row.new_value?.uom_id || 0) || null,
        },
      })).filter((row) => row.size_id && row.target_rm_item_id && row.new_value.qty && row.new_value.uom_id);

      const colorRules = (state.color_rule || []).map((row) => ({
        size_scope: "ALL",
        size_id: null,
        packing_scope: "ALL",
        packing_type_id: null,
        color_scope: row.sku_color_id ? "SPECIFIC" : "ALL",
        color_id: row.sku_color_id ? Number(row.sku_color_id) : null,
        action_type: "REPLACE_RM",
        material_scope: "SPECIFIC",
        target_rm_item_id: Number(row.target_rm_item_id || 0) || null,
        new_value: {
          rm_color_id: Number(row.rm_color_id || 0) || null,
        },
      })).filter((row) => row.target_rm_item_id && row.new_value.rm_color_id);

      const packingRules = (state.packing_rule || []).map((row) => ({
        size_scope: row.size_id ? "SPECIFIC" : "ALL",
        size_id: row.size_id ? Number(row.size_id) : null,
        packing_scope: row.packing_type_id ? "SPECIFIC" : "ALL",
        packing_type_id: row.packing_type_id ? Number(row.packing_type_id) : null,
        color_scope: "ALL",
        color_id: null,
        action_type: "REPLACE_RM",
        material_scope: "SPECIFIC",
        target_rm_item_id: Number(row.target_rm_item_id || 0) || null,
        new_value: {
          replacement_rm_item_id: Number(row.replacement_rm_item_id || 0) || null,
        },
      })).filter((row) => row.target_rm_item_id && row.packing_type_id && row.new_value.replacement_rm_item_id);

      return [...sizeRules, ...colorRules, ...packingRules];
    };

    document.getElementById("bom-form")?.addEventListener("submit", (event) => {
      const submitter = event.submitter;
      const submitIntent = String(submitIntentInput?.value || "").trim().toLowerCase();
      const isExplicitApprove = submitIntent === "approve"
        || (submitter instanceof HTMLElement && submitter.matches("[data-bom-approve-now]"));
      const isExplicitSave = allowBomSubmit
        || (submitter instanceof HTMLElement && submitter.matches("[data-bom-save-draft]"));
      if (!isExplicitSave && !isExplicitApprove) {
        event.preventDefault();
        return;
      }
      allowBomSubmit = false;
      syncStateFromDom();
      if (hasClientDuplicateCombos()) {
        event.preventDefault();
        return;
      }

      document.querySelector('[data-lines-json="rm_lines"]').value = JSON.stringify(state.rm);
      document.querySelector('[data-lines-json="sfg_lines"]').value = JSON.stringify(state.sfg);
      document.querySelector('[data-lines-json="labour_lines"]').value = JSON.stringify(state.labour);
      document.querySelector('[data-lines-json="variant_rules"]').value = JSON.stringify(composeVariantRulesPayload());
      document.querySelector('[data-lines-json="sku_overrides"]').value = JSON.stringify(state.sku_override || []);
      if (submitIntentInput) {
        submitIntentInput.value = isExplicitApprove ? "approve" : "";
      }
    });

    bomForm = document.getElementById("bom-form");
    if (bomForm instanceof HTMLFormElement) {
      submitIntentInput = bomForm.querySelector("[data-bom-submit-intent]");
      saveDraftBtn = bomForm.querySelector("[data-bom-save-draft]");
      approveNowBtn = document.querySelector("[data-bom-approve-now]");
      if (saveDraftBtn instanceof HTMLButtonElement) {
        saveDraftBtn.addEventListener("click", () => {
          if (submitIntentInput) submitIntentInput.value = "";
          allowBomSubmit = true;
          bomForm.requestSubmit();
        });
      }
      if (approveNowBtn instanceof HTMLButtonElement) {
        approveNowBtn.addEventListener("click", () => {
          if (submitIntentInput) submitIntentInput.value = "approve";
          allowBomSubmit = true;
          bomForm.requestSubmit();
        });
      }
      bomForm.addEventListener(
        "wheel",
        (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) return;
          const numberInput = target.closest('input[data-no-stepper="true"]');
          if (!(numberInput instanceof HTMLInputElement)) return;
          if (document.activeElement !== numberInput) return;
          event.preventDefault();
        },
        { passive: false },
      );

      bomForm.addEventListener("keydown", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target instanceof HTMLInputElement && target.dataset.noStepper === "true" && (event.key === "ArrowUp" || event.key === "ArrowDown")) {
          event.preventDefault();
          return;
        }
        if (event.key !== "Enter") return;
        const isExplicitSubmitButton = target instanceof HTMLButtonElement && target.type === "submit";
        if (isExplicitSubmitButton && target.matches("[data-bom-save-draft]")) return;
        if (target instanceof HTMLTextAreaElement) return;
        event.preventDefault();
      });
    }

    initializeLabourStateFromExistingLines();
    ensureMinimumRows();
    state.rule = normalizeRuleRows(state.rule);
    renderHeaderItemsByLevel(true);
    updateHeaderSectionState();
    renderAll();
    setRmEditorMode("materials");
    setLabourViewMode("selection");
    bindEnterNavigation();
    headerCommittedState = getHeaderState();
    const detailLines = Array.isArray(serverErrorDetails)
      ? [...new Set(serverErrorDetails.map((msg) => String(msg || "").trim()).filter(Boolean))]
      : [];
    if (String(serverErrorMessage || "").trim() || detailLines.length) {
      const detailsText = detailLines.map((msg, idx) => `${idx + 1}. ${msg}`).join("\n");
      const modalMessage = [String(serverErrorMessage || "").trim(), detailsText].filter(Boolean).join("\n");
      const modalTitle = "<%= t('error_generic') || 'Error' %>";
      const showServerErrors = () => {
        if (typeof window.showUiErrorModal === "function") {
          window.showUiErrorModal(modalMessage, modalTitle);
          return;
        }
        window.__pendingUiErrorModalPayload = { message: modalMessage, title: modalTitle };
      };
      window.setTimeout(showServerErrors, 0);
    }
  })();
</script>
