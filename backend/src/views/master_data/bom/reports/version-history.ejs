<%
  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const reportLoaded = Boolean(filters?.reportLoaded);
  const selectedItemIds = Array.isArray(filters?.itemIds)
    ? filters.itemIds.map((id) => Number(id)).filter((id) => Number.isInteger(id) && id > 0)
    : [];
  const resolveText = (key, fallback) => {
    const value = t(key);
    return value && value !== key ? value : fallback;
  };
  const statusPillClass = (statusValue) => {
    const v = String(statusValue || "").toUpperCase();
    if (v === "APPROVED") return "border-sky-200 bg-sky-50 text-sky-700";
    if (v === "DRAFT") return "border-amber-200 bg-amber-50 text-amber-700";
    if (v === "PENDING") return "border-blue-200 bg-blue-50 text-blue-700";
    return "border-rose-200 bg-rose-50 text-rose-700";
  };
  const lifecycleBadgeClass = (isActive) =>
    isActive ? "border-blue-200 bg-blue-50 text-blue-700" : "border-slate-300 bg-slate-100 text-slate-600";
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-2xl font-display font-semibold tracking-tight text-ink">
        <%= resolveText("bom_version_history_report", "BOM Version History") %>
      </h1>
    </div>
    <p class="mt-1 text-sm text-slate-600">
      <%= resolveText("bom_version_history_report_description", "Track BOM revisions by item, version, workflow state, and approver.") %>
    </p>

    <form method="post" action="<%= reportPath %>" class="mt-3 rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4" data-bom-version-history-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="grid grid-cols-1 gap-3 lg:grid-cols-2 xl:grid-cols-3">
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("type") %></span>
          <select name="level" data-searchable-select="true" data-searchable-variant="unified" data-bom-level-select class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.levels || []).forEach((row) => { %>
              <% const value = String(row.value || "FINISHED"); %>
              <option value="<%= value %>" <%= String(filters?.level || "FINISHED") === value ? "selected" : "" %>><%= value === "FINISHED" ? t("finished") : t("semi_finished") %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("article_name") %></span>
          <select name="item_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.items || []).forEach((item) => { %>
              <option value="<%= item.id %>" <%= selectedItemIds.includes(Number(item.id)) ? "selected" : "" %>><%= `${item.name || item.id}${item.code ? ` (${item.code})` : ""}` %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("status") %></span>
          <select name="status" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.statuses || []).forEach((row) => { %>
              <% const value = String(row.value || "ALL"); %>
              <option value="<%= value %>" <%= String(filters?.status || "ALL") === value ? "selected" : "" %>><%= value === "ALL" ? t("all") : (t(value.toLowerCase()) || value) %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("bom_lifecycle") %></span>
          <select name="lifecycle" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.lifecycles || []).forEach((row) => { %>
              <% const value = String(row.value || "ALL"); %>
              <option value="<%= value %>" <%= String(filters?.lifecycle || "ALL") === value ? "selected" : "" %>><%= value === "ALL" ? t("all") : t(value.toLowerCase()) %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("from_date") %></span>
          <input type="date" name="from_date" value="<%= filters?.fromDate || '' %>" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("to_date") %></span>
          <input type="date" name="to_date" value="<%= filters?.toDate || '' %>" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
        </label>
      </div>

      <div class="mt-3 flex flex-wrap gap-2">
        <button type="submit" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
        <a href="<%= reportPath %>" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <% if (filters?.validationMessage) { %>
      <div class="mb-3 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"><%= filters.validationMessage %></div>
    <% } %>
    <% if (filters?.missingRequiredItem) { %>
      <div class="mb-3 rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-sm text-amber-700"><%= resolveText("bom_report_article_required", "Please select at least one article to generate this ledger.") %></div>
    <% } %>
    <% if (!reportLoaded) { %>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!rows.length) { %>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <div class="mb-2 text-xs text-slate-600"><span class="font-semibold"><%= t("total") %>:</span> <%= Number(reportData?.totals?.rowCount || 0) %> <%= t("entries") %></div>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-290 w-full text-sm">
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]">SR.NO</th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("code") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("article_name") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("bom_stage") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("version") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("status") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("bom_lifecycle") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("date") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("approved") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("created_by") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("approved_by") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% rows.forEach((row, index) => { %>
              <tr class="bg-white odd:bg-slate-50/30">
                <td class="px-3 py-2"><%= index + 1 %></td>
                <td class="px-3 py-2"><%= row.bom_no || "-" %></td>
                <td class="px-3 py-2"><%= row.item_name || "-" %></td>
                <td class="px-3 py-2"><%= t(String(row.level || "").toLowerCase()) || row.level || "-" %></td>
                <td class="px-3 py-2">V<%= row.version_no || "-" %></td>
                <td class="px-3 py-2">
                  <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] <%= statusPillClass(row.status) %>">
                    <%= t(String(row.status || "").toLowerCase()) || row.status || "-" %>
                  </span>
                </td>
                <td class="px-3 py-2">
                  <% if (String(row.status || "").toUpperCase() === "APPROVED") { %>
                    <span class="inline-flex items-center rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] <%= lifecycleBadgeClass(row.bom_is_active !== false) %>"><%= row.bom_is_active !== false ? t("active") : t("inactive") %></span>
                  <% } else { %>
                    <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-500">N/A</span>
                  <% } %>
                </td>
                <td class="px-3 py-2"><%= formatDateDisplay(row.created_at) %></td>
                <td class="px-3 py-2"><%= formatDateDisplay(row.approved_at) %></td>
                <td class="px-3 py-2"><%= row.created_by_name || "-" %></td>
                <td class="px-3 py-2"><%= row.approved_by_name || "-" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <%- include("../../../base/partials/table-footer", { t, rowCount: reportData?.totals?.rowCount || 0 }) %>
    <% } %>
  </section>
</div>

<script>
  (function () {
    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }

    const form = document.querySelector("[data-bom-version-history-form]");
    const levelSelect = form?.querySelector("[data-bom-level-select]");
    const loadInput = form?.querySelector("input[name='load_report']");
    if (!form || !levelSelect || !loadInput) return;

    let filterSubmit = false;
    levelSelect.addEventListener("change", () => {
      filterSubmit = true;
      loadInput.value = "0";
      form.submit();
    });

    form.addEventListener("submit", () => {
      if (!filterSubmit) loadInput.value = "1";
    });
  })();
</script>
