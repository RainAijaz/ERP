<%
  const rows = Array.isArray(reportData?.rows) ? reportData.rows : [];
  const reportLoaded = Boolean(filters?.reportLoaded);
  const allMultiOptionValue = "__ALL__";
  const selectedItemIds = Array.isArray(filters?.itemIds)
    ? filters.itemIds.map((id) => Number(id)).filter((id) => Number.isInteger(id) && id > 0)
    : [];
  const itemAllSelected = selectedItemIds.length === 0;
  const resolveText = (key, fallback) => {
    const value = t(key);
    return value && value !== key ? value : fallback;
  };
  const toActionLabel = (actionValue) => {
    const v = String(actionValue || "").toLowerCase();
    if (!v) return "-";
    if (v === "approve_draft") return resolveText("approve", "Approve");
    if (v === "delete_draft") return resolveText("delete_draft", "Delete Draft");
    if (v === "create_version_from") return resolveText("bom_create_new_version", "Create New Version");
    if (v === "toggle_lifecycle") return resolveText("bom_lifecycle", "BOM Lifecycle");
    return v;
  };
  const bucketText = (days) => {
    const n = Number(days || 0);
    if (!Number.isFinite(n) || n <= 2) return "0-2";
    if (n <= 7) return "3-7";
    if (n <= 15) return "8-15";
    return "15+";
  };
%>

<div class="mx-auto w-full max-w-none space-y-4 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="flex items-center gap-2">
      <h1 class="text-2xl font-display font-semibold tracking-tight text-ink">
        <%= resolveText("bom_approval_queue_aging_report", "BOM Approval Queue Aging") %>
      </h1>
    </div>
    <p class="mt-1 text-sm text-slate-600">
      <%= resolveText("bom_approval_queue_aging_report_description", "Track pending BOM approvals by age bucket to identify bottlenecks.") %>
    </p>

    <form method="post" action="<%= reportPath %>" class="mt-3 rounded-xl border border-slate-200 bg-slate-50/30 p-3 sm:p-4">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="load_report" value="1">

      <div class="grid grid-cols-1 gap-3 lg:grid-cols-2 xl:grid-cols-3">
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("article_name") %></span>
          <select name="item_ids" multiple data-searchable-select="true" data-searchable-variant="unified" data-searchable-multi-search="inline" data-all-multi-select="true" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <option value="<%= allMultiOptionValue %>" <%= itemAllSelected ? "selected" : "" %>><%= t("all") %></option>
            <% (options?.items || []).forEach((item) => { %>
              <option value="<%= item.id %>" <%= selectedItemIds.includes(Number(item.id)) ? "selected" : "" %>><%= `${item.name || item.id}${item.code ? ` (${item.code})` : ""}` %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("status") %></span>
          <select name="request_status" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.requestStatuses || []).forEach((row) => { %>
              <% const value = String(row.value || "PENDING"); %>
              <option value="<%= value %>" <%= String(filters?.requestStatus || "PENDING") === value ? "selected" : "" %>><%= t(value.toLowerCase()) || value %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= resolveText("action", "Action") %></span>
          <select name="request_action" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.requestActions || []).forEach((row) => { %>
              <% const value = String(row.value || "ALL"); %>
              <option value="<%= value %>" <%= String(filters?.requestAction || "ALL") === value ? "selected" : "" %>><%= value === "ALL" ? t("all") : toActionLabel(value) %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= resolveText("aging_bucket", "Aging Bucket") %></span>
          <select name="aging_bucket" data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
            <% (options?.agingBuckets || []).forEach((row) => { %>
              <% const value = String(row.value || "ALL"); %>
              <option value="<%= value %>" <%= String(filters?.agingBucket || "ALL") === value ? "selected" : "" %>><%= value === "ALL" ? t("all") : value.replace("_", "-") %></option>
            <% }) %>
          </select>
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("from_date") %></span>
          <input type="date" name="from_date" value="<%= filters?.fromDate || '' %>" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-[0.08em] text-slate-600"><%= t("to_date") %></span>
          <input type="date" name="to_date" value="<%= filters?.toDate || '' %>" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm">
        </label>
      </div>

      <div class="mt-3 flex flex-wrap gap-2">
        <button type="submit" class="inline-flex items-center rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm"><%= t("load") %></button>
        <a href="<%= reportPath %>" class="inline-flex items-center rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= t("cancel") %></a>
      </div>
    </form>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <% if (filters?.validationMessage) { %>
      <div class="mb-3 rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700"><%= filters.validationMessage %></div>
    <% } %>
    <% if (reportLoaded) { %>
      <div class="mb-3 grid grid-cols-2 gap-2 sm:grid-cols-5">
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs"><span class="font-semibold"><%= t("total") %></span>: <%= Number(reportData?.totals?.rowCount || 0) %></div>
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs">0-2: <%= Number(reportData?.bucketCounts?.["0_2"] || 0) %></div>
        <div class="rounded-xl border border-yellow-200 bg-yellow-50 px-3 py-2 text-xs">3-7: <%= Number(reportData?.bucketCounts?.["3_7"] || 0) %></div>
        <div class="rounded-xl border border-orange-200 bg-orange-50 px-3 py-2 text-xs">8-15: <%= Number(reportData?.bucketCounts?.["8_15"] || 0) %></div>
        <div class="rounded-xl border border-rose-200 bg-rose-50 px-3 py-2 text-xs">15+: <%= Number(reportData?.bucketCounts?.["15_PLUS"] || 0) %></div>
      </div>
    <% } %>
    <% if (!reportLoaded) { %>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("load_report_to_view") %></div>
    <% } else if (!rows.length) { %>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-10 text-center text-2xl font-display text-slate-500"><%= t("no_entries") %></div>
    <% } else { %>
      <div class="overflow-x-auto rounded-2xl border border-slate-200">
        <table class="min-w-320 w-full text-sm">
          <thead class="bg-slate-100 text-slate-700">
            <tr>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]">#</th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= resolveText("request_id", "Request ID") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("date") %></th>
              <th class="px-3 py-2 text-right text-xs font-semibold uppercase tracking-[0.08em]"><%= resolveText("age_days", "Age (Days)") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= resolveText("aging_bucket", "Aging Bucket") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= resolveText("action", "Action") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("status") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("code") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("article_name") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("version") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= t("requested_by") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= resolveText("reviewed_by", "Reviewed By") %></th>
              <th class="px-3 py-2 text-left text-xs font-semibold uppercase tracking-[0.08em]"><%= resolveText("reviewed_at", "Reviewed At") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% rows.forEach((row, index) => { %>
              <tr class="bg-white odd:bg-slate-50/30">
                <td class="px-3 py-2"><%= index + 1 %></td>
                <td class="px-3 py-2"><%= row.id %></td>
                <td class="px-3 py-2"><%= formatDateDisplay(row.requested_at) %></td>
                <td class="px-3 py-2 text-right"><%= Number(row.age_days || 0) %></td>
                <td class="px-3 py-2"><%= bucketText(row.age_days) %></td>
                <td class="px-3 py-2"><%= toActionLabel(row.request_action) %></td>
                <td class="px-3 py-2"><%= t(String(row.status || "").toLowerCase()) || row.status || "-" %></td>
                <td class="px-3 py-2"><%= row.bom_no || "-" %></td>
                <td class="px-3 py-2"><%= row.item_name || "-" %></td>
                <td class="px-3 py-2"><%= row.version_no ? `V${row.version_no}` : "-" %></td>
                <td class="px-3 py-2"><%= row.requested_by_name || "-" %></td>
                <td class="px-3 py-2"><%= row.reviewed_by_name || "-" %></td>
                <td class="px-3 py-2"><%= formatDateDisplay(row.reviewed_at) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
      <%- include("../../../base/partials/table-footer", { t, rowCount: reportData?.totals?.rowCount || 0 }) %>
    <% } %>
  </section>
</div>

<script>
  (function () {
    if (typeof window.initSearchableSelects === "function") {
      window.initSearchableSelects();
    }
  })();
</script>
