<%
  const isSfgForm = typeof isFinishedView !== 'undefined' && !isFinishedView;
%>
<div id="create-mode-container">
  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <label class="mb-2 block text-xs font-bold uppercase tracking-wide text-slate-500">
        <%= t("article") %> <span class="text-rose-500">*</span>
      </label>
      <div class="relative">
        <select name="item_id" class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 focus:border-slate-400 focus:outline-none" required>
          <option value=""><%= t("select") %> <%= t("article") %></option>
          <% items.forEach(function(item) { %>
            <option value="<%= item.id %>"><%= item.code %> - <%= locale === 'ur' ? (item.name_ur || item.name) : item.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div>
      <label class="mb-2 block text-xs font-bold uppercase tracking-wide text-slate-500">
        <%= t("sizes") %> <span class="text-rose-500">*</span>
      </label>
      <select name="size_ids" multiple class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 focus:border-slate-400 focus:outline-none" required>
        <% sizes.forEach(function(size) { %>
          <option value="<%= size.id %>"><%= locale === 'ur' ? (size.name_ur || size.name) : size.name %></option>
        <% }) %>
      </select>
    </div>

    <% if (!isSfgForm) { %>
    <div>
      <label class="mb-2 block text-xs font-bold uppercase tracking-wide text-slate-500">
        <%= t("grades") %> <span class="text-rose-500">*</span>
      </label>
      <select name="grade_ids" multiple class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 focus:border-slate-400 focus:outline-none" required>
        <% grades.forEach(function(grade) { %>
          <option value="<%= grade.id %>"><%= locale === 'ur' ? (grade.name_ur || grade.name) : grade.name %></option>
        <% }) %>
      </select>
    </div>
    <% } %>

    <div>
      <label class="mb-2 block text-xs font-bold uppercase tracking-wide text-slate-500">
        <%= t("colors") %>
      </label>
      <select name="color_ids" multiple class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 focus:border-slate-400 focus:outline-none">
        <% colors.forEach(function(color) { %>
          <option value="<%= color.id %>"><%= locale === 'ur' ? (color.name_ur || color.name) : color.name %></option>
        <% }) %>
      </select>
    </div>

    <% if (!isSfgForm) { %>
    <div>
      <label class="mb-2 block text-xs font-bold uppercase tracking-wide text-slate-500">
        <%= t("packing_types") %> <span class="text-rose-500">*</span>
      </label>
      <select name="packing_type_ids" multiple class="w-full rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm text-slate-700 focus:border-slate-400 focus:outline-none" required>
        <% packings.forEach(function(pkg) { %>
          <option value="<%= pkg.id %>"><%= locale === 'ur' ? (pkg.name_ur || pkg.name) : pkg.name %></option>
        <% }) %>
      </select>
    </div>
    <% } %>
  </div>

  <div class="mt-6 border-t border-slate-100 pt-4">
    <label class="mb-3 block text-xs font-bold uppercase tracking-wide text-slate-500">
      <%= t("generated_combinations")  %>
    </label>
    <div class="rounded-xl border border-slate-200 bg-slate-50/50 p-4" id="rate-list-container">
      <div data-sku-rate-list class="space-y-3"></div>
      <div data-rate-list-empty class="text-center py-4 text-sm text-slate-400 italic">
        <%= t("select_options_to_generate")  %>
      </div>
    </div>
  </div>
</div>

<div id="edit-rates-container" class="hidden">
  <div class="mb-4 rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm text-amber-800">
    <strong><%= t("editing_rates_title") %></strong> <%= t("editing_rates_description") %>
  </div>
  <div class="mb-4 text-lg font-bold text-slate-800" id="edit-rates-article-title"></div>
  
  <div id="bulk-edit-list" class="space-y-3 max-h-[60vh] overflow-y-auto pr-2">
    </div>

  <label class="mt-4 flex cursor-pointer items-center gap-3 rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 hover:bg-slate-100 transition">
    <input type="checkbox" name="send_whatsapp" value="1" checked
           class="h-4 w-4 rounded border-slate-300 text-green-600 focus:ring-green-500">
    <div class="flex flex-col">
      <span class="text-sm font-semibold text-slate-700"><%= t('send_whatsapp_notification') || 'Send WhatsApp Notification' %></span>
      <span class="text-xs text-slate-400"><%= t('send_whatsapp_notification_hint') || 'Notify the sales group about this rate change' %></span>
    </div>
    <svg class="ml-auto h-5 w-5 text-green-500 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.413A9.953 9.953 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.95 7.95 0 01-4.054-1.11l-.29-.173-3.006.854.854-2.939-.19-.302A7.96 7.96 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z" clip-rule="evenodd"/>
    </svg>
  </label>
</div>