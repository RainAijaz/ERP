<div class="mx-auto w-full max-w-7xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white/95 p-6 shadow-lg">
    <div class="space-y-2">
      <h1 class="text-2xl font-display text-ink"><%= t("groups") %></h1>
      <p class="text-sm text-muted"><%= t("groups_description") %></p>
    </div>
  </section>

  <section class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <a class="group rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-md transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg" href="/master-data/products/groups">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= t("products") %></div>
      <div class="mt-2 text-lg font-semibold text-slate-800"><%= t("product_groups") %></div>
      <p class="mt-2 text-sm text-slate-500"><%= t("product_groups_description") %></p>
      <div class="mt-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">
        <%= t("open") %>
        <span class="transition group-hover:translate-x-1">></span>
      </div>
    </a>

    <a class="group rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-md transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg" href="/master-data/basic-info/party-groups">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= t("parties") %></div>
      <div class="mt-2 text-lg font-semibold text-slate-800"><%= t("party_groups") %></div>
      <p class="mt-2 text-sm text-slate-500"><%= t("party_groups_description") %></p>
      <div class="mt-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">
        <%= t("open") %>
        <span class="transition group-hover:translate-x-1">></span>
      </div>
    </a>

    <a class="group rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-md transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg" href="/master-data/basic-info/account-groups">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400"><%= t("accounts") %></div>
      <div class="mt-2 text-lg font-semibold text-slate-800"><%= t("account_groups") %></div>
      <p class="mt-2 text-sm text-slate-500"><%= t("account_groups_description") %></p>
      <div class="mt-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">
        <%= t("open") %>
        <span class="transition group-hover:translate-x-1">></span>
      </div>
    </a>

    <a class="group rounded-2xl border border-slate-200 bg-white/95 p-5 shadow-md transition hover:-translate-y-0.5 hover:border-slate-300 hover:shadow-lg" href="/master-data/basic-info/departments">
      <div class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">HR</div>
      <div class="mt-2 text-lg font-semibold text-slate-800"><%= t("departments") %></div>
      <p class="mt-2 text-sm text-slate-500"><%= t("departments_description") %></p>
      <div class="mt-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-accent">
        <%= t("open") %>
        <span class="transition group-hover:translate-x-1">></span>
      </div>
    </a>
  </section>
</div>
