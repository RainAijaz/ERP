<%
  const isAccountAccessScopeRow = (row) =>
    row && row.scopeType === 'REPORT' && row.scopeKey === 'account_activity_ledger';
  const accountAccessScopeRow = navRows.find((row) => isAccountAccessScopeRow(row)) || null;
  const accountAccessScopePath = accountAccessScopeRow ? accountAccessScopeRow.path : '';

  // EXTRACT SIDEBAR ITEMS:
  // Show container rows, top-level modules, and the account-activity report scope
  // so account-access restrictions can be intentionally selected.
  const sidebarRows = navRows.filter((row) =>
    row.hasChildren ||
    row.depth === 0 ||
    isAccountAccessScopeRow(row),
  );
%>

<div class="permissions-shell flex flex-col min-h-0 bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
  
  <div class="shrink-0 px-6 py-4 border-b border-slate-100 flex flex-col md:flex-row items-center justify-between gap-4 bg-white z-20">
    <div class="flex items-center gap-4 w-full md:w-auto">
      <div class="p-2 bg-accent/5 rounded-lg text-accent">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"></path></svg>
      </div>
      <div>
        <h1 class="text-lg font-bold text-slate-800"><%= t('permissions') %></h1>
        <p class="text-xs text-slate-500"><%= t('permissions_subtitle') %></p>
      </div>
      
      <div class="flex bg-slate-100 p-1 rounded-lg ml-2">
        <a href="?type=role" class="px-3 py-1 text-xs font-bold uppercase tracking-wide rounded shadow-sm transition-all <%= !isUserMode ? 'bg-white text-accent' : 'text-slate-500 hover:text-slate-700' %>">
          <%= t('roles') %>
        </a>
        <a href="?type=user" class="px-3 py-1 text-xs font-bold uppercase tracking-wide rounded shadow-sm transition-all <%= isUserMode ? 'bg-white text-accent' : 'text-slate-500 hover:text-slate-700' %>">
          <%= t('users') %>
        </a>
      </div>
    </div>

    <form method="GET" class="flex items-center gap-3 w-full md:w-auto">
      <input type="hidden" name="type" value="<%= isUserMode ? 'user' : 'role' %>">
      <select name="target_id" onchange="this.form.submit()" class="w-full md:w-64 rounded-lg border-slate-200 text-sm font-medium text-slate-700 focus:ring-accent focus:border-accent bg-slate-50 hover:bg-white transition-colors cursor-pointer">
        <% if (isUserMode) { %>
          <option value=""><%= t('select_user') %>...</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= targetId == u.id ? 'selected' : '' %>><%= u.username %></option>
          <% }) %>
        <% } else { %>
          <option value=""><%= t('select_role') %>...</option>
          <% roles.forEach(r => { %>
            <option value="<%= r.id %>" <%= targetId == r.id ? 'selected' : '' %>><%= r.name %></option>
          <% }) %>
        <% } %>
      </select>
    </form>
  </div>

  <% if (flash && flash.message) { %>
    <div class="shrink-0 px-6 py-2 bg-slate-50 border-b border-slate-100 flex items-center justify-center">
      <div class="text-sm px-4 py-1.5 rounded-full flex items-center gap-2 <%= flash.type === 'success' ? 'bg-emerald-100 text-emerald-800' : 'bg-rose-100 text-rose-800' %>">
        <span class="font-bold"><%= flash.type === 'success' ? '✓' : '!' %></span>
        <%= flash.message %>
      </div>
    </div>
  <% } %>

  <% if (targetId) { %>
    <% const canEditPermissions = can('SCREEN', 'administration.permissions', 'edit'); %>
    <form action="/administration/permissions/update" method="POST" class="flex-1 flex min-h-0 overflow-hidden">
      <input type="hidden" name="type" value="<%= isUserMode ? 'user' : 'role' %>">
      <input type="hidden" name="target_id" value="<%= targetId %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <aside class="w-72 bg-slate-50 border-r border-slate-200 flex flex-col shrink-0 overflow-hidden min-h-0 group">
        <div class="p-3 border-b border-slate-200/60 flex items-center justify-between">
           <span class="text-xs font-bold text-slate-400 uppercase tracking-wider"><%= t('modules') %></span>
           <span class="text-[10px] bg-white border border-slate-200 px-2 rounded-full text-slate-400"><%= sidebarRows.length %></span>
        </div>
        
        <div class="overflow-y-auto flex-1 min-h-0 p-2 space-y-0.5 custom-scrollbar">
          <button type="button" onclick="filterCategory('all')" class="category-btn w-full text-left px-3 py-2 rounded-md text-xs font-bold transition-colors bg-white shadow-sm text-accent ring-1 ring-slate-200 mb-2 hover:ring-accent/50" data-cat="all">
            <%= t('all_modules') %>
          </button>

          <% const labelForRow = (row) => {
             if (!row.description) return row.scopeKey || row.key || t('unknown');
             return /^[a-z0-9_.]+$/.test(row.description) ? t(row.description) : row.description;
          }; %>
          
          <% sidebarRows.forEach(row => { %>
            <button type="button" 
              onclick="filterCategory('<%= row.path %>')" 
              class="category-btn w-full text-left py-1.5 px-2 rounded-md text-xs transition-all text-slate-600 hover:bg-white hover:text-slate-900 border border-transparent hover:border-slate-200 flex items-center gap-2 truncate"
              style="padding-left: <%= (row.depth * 12) + 8 %>px" 
              data-cat="<%= row.path %>"
              title="<%= labelForRow(row) %>">
              
              <% if (row.depth === 0) { %>
                 <span class="opacity-70">📂</span>
                 <span class="font-bold"><%= labelForRow(row) %></span>
              <% } else { %>
                 <span class="text-slate-300">└</span>
                 <span><%= labelForRow(row) %></span>
              <% } %>
            </button>
          <% }) %>
        </div>
      </aside>

      <div class="flex-1 flex flex-col min-w-0 min-h-0 bg-white relative">
        
        <div id="module-empty-state" class="absolute inset-0 z-30 bg-slate-50/50 flex flex-col items-center justify-center text-center p-6">
            <div class="w-16 h-16 bg-white rounded-full shadow-sm flex items-center justify-center mb-4 border border-slate-100">
                <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7"></path></svg>
            </div>
            <h3 class="text-sm font-bold text-slate-700"><%= t('select_module') %></h3>
            <p class="text-xs text-slate-500 mt-1 max-w-xs"><%= t('select_module_permissions') %></p>
        </div>

        <div id="permission-toolbar" class="p-3 border-b border-slate-100 flex items-center justify-between gap-3 shrink-0 hidden">
            <div class="relative w-full max-w-md group">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-slate-400 group-focus-within:text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </div>
              <input id="permission-search" type="text" placeholder="<%= t('search_permissions') %>..." 
                class="w-full rounded-lg border-slate-200 bg-slate-50 text-sm pl-10 pr-8 focus:ring-2 focus:ring-accent focus:bg-white transition-all shadow-sm">
              <button type="button" id="permission-search-clear" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-rose-500 cursor-pointer hidden">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>

            <div class="flex items-center gap-2">
              <button type="button" id="expand-all" class="p-2 text-slate-500 hover:text-accent hover:bg-accent/10 rounded-lg transition-colors" title="<%= t('expand_all') %>"> 
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 13l-7 7-7-7m14-8l-7 7-7-7"/></svg>
              </button>
              <button type="button" id="collapse-all" class="p-2 text-slate-500 hover:text-accent hover:bg-accent/10 rounded-lg transition-colors" title="<%= t('collapse_all') %>"> 
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 11l7-7 7 7M5 19l7-7 7 7"/></svg>
              </button>
            </div>
        </div>

        <% if (!canEditPermissions) { %>
          <div class="px-4 py-2 bg-amber-50 border-b border-amber-100 text-xs text-amber-700 flex items-center gap-2">
            <span class="font-bold"><%= t('read_only') %></span>
            <span><%= t('permissions_read_only_hint') %></span>
          </div>
        <% } %>

        <% if (isUserMode) { %>
          <section id="account-access-shell" class="hidden flex-1 min-h-0 p-4 md:p-5 bg-slate-50/40">
            <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm flex h-full min-h-0 flex-col">
              <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                <div>
                  <h2 class="text-sm font-bold uppercase tracking-[0.08em] text-slate-800"><%= t('account_access') %></h2>
                  <p class="text-xs text-slate-500"><%= t('account_access_subtitle') %></p>
                </div>
                <div class="flex items-center gap-2">
                  <span class="inline-flex items-center rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.08em] text-slate-600"><%= t('account_access_financial_reports_context') %></span>
                  <button
                    type="button"
                    data-account-access-save
                    class="rounded-lg bg-accent px-4 py-2 text-xs font-bold uppercase tracking-[0.08em] text-white shadow-sm hover:bg-accent/90 disabled:cursor-not-allowed disabled:opacity-50"
                    <%= !canEditPermissions ? 'disabled' : '' %>
                  ><%= t('save_changes') %></button>
                </div>
              </div>

              <div class="mt-3 rounded-lg border border-slate-200 bg-slate-50/60 p-3">
                <div class="grid grid-cols-1 gap-3 sm:grid-cols-[1fr_auto] sm:items-end">
                  <label class="block text-sm">
                    <span class="mb-1 block text-xs font-semibold uppercase tracking-[0.08em] text-slate-700"><%= t('account_name') %></span>
                    <select data-account-access-add data-searchable-select="true" data-searchable-variant="unified" class="h-10 w-full rounded-lg border border-slate-300 bg-white px-3 text-sm" <%= !canEditPermissions ? 'disabled' : '' %>>
                      <option value=""><%= t('select_account_name') %></option>
                      <% (accountAccessAccounts || []).forEach((account) => { %>
                        <option
                          value="<%= account.id %>"
                          data-code="<%= account.code %>"
                          data-name="<%= account.name %>"
                          data-branches="<%= (account.branchNames || []).join(', ') %>"
                        ><%= account.name %></option>
                      <% }) %>
                    </select>
                  </label>
                  <button
                    type="button"
                    data-account-access-add-btn
                    class="h-10 w-10 rounded-lg border border-slate-300 bg-white text-slate-700 hover:border-accent hover:text-accent disabled:cursor-not-allowed disabled:opacity-50"
                    title="<%= t('add') %>"
                    <%= !canEditPermissions ? 'disabled' : '' %>
                  >
                    <span class="sr-only"><%= t('add') %></span>
                    <svg class="mx-auto h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                  </button>
                </div>
              </div>

              <div class="mt-3 flex items-center">
                <div class="relative w-full max-w-md group">
                  <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-4 w-4 text-slate-400 group-focus-within:text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                  </div>
                  <input
                    type="text"
                    data-account-access-row-search
                    placeholder="<%= t('search_permissions') %>..."
                    class="h-10 w-full rounded-lg border border-slate-200 bg-white pl-10 pr-3 text-sm focus:ring-2 focus:ring-accent"
                  >
                </div>
              </div>

              <div class="mt-3 flex-1 min-h-0 rounded-lg border border-slate-200 bg-white overflow-hidden">
                <div class="h-full min-h-0 overflow-auto custom-scrollbar">
                  <table class="w-full min-w-[620px] text-sm">
                    <thead class="bg-slate-50 text-xs uppercase tracking-[0.08em] text-slate-600">
                      <tr>
                        <th class="px-3 py-2 text-left"><%= t('account_code') %></th>
                        <th class="px-3 py-2 text-left"><%= t('account_name') %></th>
                        <th class="px-3 py-2 text-left"><%= t('restriction_level') %></th>
                        <th class="px-3 py-2 text-center"><%= t('actions') %></th>
                      </tr>
                    </thead>
                    <tbody data-account-access-body>
                      <% if (!accountAccessRows || !accountAccessRows.length) { %>
                        <tr data-account-access-empty>
                          <td colspan="4" class="px-3 py-6 text-center text-xs font-semibold text-slate-500"><%= t('no_records_found') %></td>
                        </tr>
                      <% } %>
                      <% (accountAccessRows || []).forEach((row) => { %>
                        <% const restrictionValue = row.canViewSummary ? 'summary' : 'details'; %>
                        <% const branchesText = (row.branchNames || []).join(', '); %>
                        <tr data-account-access-row data-account-id="<%= row.accountId %>" data-row-search="<%= ((row.code || '') + ' ' + (row.name || '') + ' ' + branchesText).toLowerCase() %>" class="border-t border-slate-100">
                          <td class="px-3 py-2 font-semibold text-slate-700" data-account-code><%= row.code || '-' %></td>
                          <td class="px-3 py-2 text-slate-700" data-account-name>
                            <div class="font-medium"><%= row.name || '-' %></div>
                            <% if (branchesText) { %>
                              <div class="mt-0.5 text-[11px] text-slate-400"><%= branchesText %></div>
                            <% } %>
                          </td>
                          <td class="px-3 py-2 text-slate-700">
                            <select data-account-restriction class="h-8 w-full rounded-md border border-slate-300 bg-white px-2 text-xs font-semibold" <%= !canEditPermissions ? 'disabled' : '' %>>
                              <option value="summary" <%= restrictionValue === 'summary' ? 'selected' : '' %>><%= t('account_access_restriction_summary') %></option>
                              <option value="details" <%= restrictionValue === 'details' ? 'selected' : '' %>><%= t('account_access_restriction_details') %></option>
                            </select>
                          </td>
                          <td class="px-3 py-2 text-center">
                            <button type="button" class="rounded-md border border-rose-200 bg-rose-50 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.08em] text-rose-700 hover:bg-rose-100 disabled:cursor-not-allowed disabled:opacity-50" data-account-remove <%= !canEditPermissions ? 'disabled' : '' %>><%= t('delete') %></button>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </section>
        <% } %>

        <div id="permission-table-container" class="flex-1 min-h-0 overflow-x-auto overflow-y-auto bg-slate-50/30 relative custom-scrollbar hidden">
          <table class="w-full text-left border-collapse table-auto">
            <thead class="bg-white sticky top-0 z-20 shadow-sm ring-1 ring-slate-200">
              <tr>
                <th class="p-3 pl-6 text-xs font-bold uppercase text-slate-500 border-b border-r w-[22rem] min-w-[18rem]">
                  <%= t('module') %> / <%= t('screen') %>
                </th>
                
                <% const actions = [
                     { key: 'can_view', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z', label: t('view'), color: 'text-indigo-600', tooltip: t('permissions_tip_view') },
                     { key: 'can_navigate', icon: 'M15 12a3 3 0 11-6 0 3 3 0 016 0z', label: t('navigation'), color: 'text-blue-600', tooltip: t('permissions_tip_navigate') },
                     { key: 'can_load', icon: 'M5 3h10a2 2 0 012 2v14l-7-3-7 3V5a2 2 0 012-2z', label: t('load'), color: 'text-cyan-600', tooltip: t('permissions_tip_load') },
                     { key: 'can_view_details', icon: 'M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 100 20 10 10 0 000-20z', label: t('view_details'), color: 'text-sky-600', tooltip: t('permissions_tip_view_details') },
                     { key: 'can_create', icon: 'M12 4v16m8-8H4', label: t('create'), color: 'text-emerald-600', tooltip: t('permissions_tip_create') },
                     { key: 'can_edit', icon: 'M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z', label: t('edit'), color: 'text-amber-600', tooltip: t('permissions_tip_edit') },
                     { key: 'can_delete', icon: 'M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16', label: t('deactivate'), color: 'text-rose-600', tooltip: t('permissions_tip_deactivate') },
                     { key: 'can_hard_delete', icon: 'M4 7h16M9 7V5h6v2M10 11v6M14 11v6M6 7l1 13h10l1-13', label: t('delete'), color: 'text-rose-700', tooltip: t('permissions_tip_delete') },
                     { key: 'can_approve', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z', label: t('approve'), color: 'text-purple-600', tooltip: t('permissions_tip_approve') },
                     { key: 'can_print', icon: 'M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z', label: t('print'), color: 'text-slate-600', tooltip: t('permissions_tip_print') },
                     { key: 'can_export_excel_csv', icon: 'M4 4h16v12H4zM8 16l2 4 2-4', label: t('export_excel_csv'), color: 'text-teal-600', tooltip: t('permissions_tip_export_excel_csv') },
                     { key: 'can_filter_all_branches', icon: 'M4 6h16M7 12h10M9 18h6', label: t('filter_all_branches'), color: 'text-lime-600', tooltip: t('permissions_tip_filter_all_branches') },
                     { key: 'can_view_cost_fields', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-10v12', label: t('view_cost_fields'), color: 'text-emerald-700', tooltip: t('permissions_tip_view_cost_fields') }
                   ] %>
                <% const permissionsRestrictedActions = ['can_create', 'can_delete', 'can_hard_delete', 'can_print']; %>
                
                <% actions.forEach(act => { %>
                  <th class="py-3 border-b text-center w-24 group cursor-help hover:bg-slate-50 transition-colors" title="<%= act.tooltip %>" data-action-col="<%= act.key %>">
                    <div class="flex flex-col items-center gap-1">
                      <span class="text-[10px] font-bold uppercase text-slate-500 group-hover:<%= act.color %> tracking-wide"><%= act.label %></span>
                    </div>
                  </th>
                <% }) %>
                <th class="py-3 border-b text-center w-12 text-[10px] text-slate-400 uppercase bg-slate-50/50"><%= t('all') %></th>
              </tr>
            </thead>
            
            <tbody class="divide-y divide-slate-100 bg-white">
              <% navRows.forEach(row => { %>
                <tr class="hover:bg-amber-50/60 group transition-colors permission-row" 
                    data-path="<%= row.path %>" 
                    data-parent="<%= row.parentPath || '' %>" 
                    data-depth="<%= row.depth %>" 
                    data-has-children="<%= row.hasChildren ? 'true' : 'false' %>" 
                    data-scope-type="<%= row.scopeType || '' %>"
                    data-search="<%= (labelForRow(row) || '') + ' ' + (row.scopeKey || '') %>">
                  
                  <td class="px-4 py-2 border-r text-sm font-medium text-slate-700 align-top">
                    <div class="flex items-center gap-2" style="padding-left: <%= (row.depth * 16) + 'px' %>">
                      <% if (row.hasChildren) { %>
                        <button type="button" class="w-4 h-4 flex items-center justify-center rounded bg-slate-100 hover:bg-slate-200 text-slate-500 text-[9px] group-toggle transition-colors border border-slate-200" data-toggle="<%= row.path %>">−</button>
                        <span class="text-amber-400/80">📂</span>
                      <% } else { %>
                        <span class="w-4 h-4 flex items-center justify-center text-[8px] text-slate-300">•</span>
                      <% } %>
                      <div class="flex flex-col leading-5">
                        <span class="<%= row.hasChildren ? 'font-bold text-slate-800' : '' %> whitespace-normal break-words" title="<%= labelForRow(row) %>">
                          <%= labelForRow(row) %>
                        </span>
                      </div>
                    </div>
                  </td>

                  <% const isPermissionsScreen = row.scopeType === 'SCREEN' && row.scopeKey === 'administration.permissions'; %>
                  <% const isApprovalSettingsScreen = row.scopeType === 'SCREEN' && row.scopeKey === 'administration.approval_settings'; %>
                  <% const isApprovalsScreen = row.scopeType === 'SCREEN' && row.scopeKey === 'administration.approvals'; %>
                  <% const isActivityLogScreen = row.scopeType === 'SCREEN' && row.scopeKey === 'administration.audit_logs'; %>
                  <% const isAdministrationScope = row.moduleGroup === 'Administration' || (row.scopeType === 'MODULE' && row.scopeKey === 'administration') || (row.scopeKey && row.scopeKey.startsWith('administration.')); %>
                  <% const permissionsScreenAllowedActions = ['can_view', 'can_edit']; %>
                  <% actions.forEach(act => { %>
                    <td class="text-center border-r last:border-r-0 relative p-0 h-10 w-24" data-action-col="<%= act.key %>">
                      <% const actionAllowedByScope = row.isConfigurableScope && Array.isArray(row.applicableActions) && row.applicableActions.includes(act.key); %>
                      <% const hideAction =
                        !actionAllowedByScope ||
                        (isPermissionsScreen && !permissionsScreenAllowedActions.includes(act.key)) ||
                        (isAdministrationScope && act.key === 'can_print') ||
                        (isApprovalsScreen && ['can_create','can_edit','can_delete','can_hard_delete','can_approve'].includes(act.key)) ||
                        (isActivityLogScreen && ['can_create','can_edit','can_delete','can_hard_delete','can_approve'].includes(act.key)) ||
                        (isApprovalSettingsScreen && ['can_create','can_delete','can_hard_delete','can_approve'].includes(act.key)); %>
                      <% if (!hideAction && row.isConfigurableScope && row.scopeId) { %>
                        <label class="w-full h-full flex items-center justify-center cursor-pointer hover:bg-black/5 transition-colors relative">
                          <% if (isUserMode) { %>
                            <input type="hidden" name="<%= row.scopeId %>:<%= act.key %>" value="false">
                          <% } %>
                          <input type="checkbox" name="<%= row.scopeId %>:<%= act.key %>" value="true"
                            <%= row.rights[act.key] ? 'checked' : '' %>
                            <%= !canEditPermissions ? 'disabled' : '' %>
                            class="rounded text-accent focus:ring-accent w-4 h-4 cursor-pointer transition permission-check-<%= row.scopeId %> permission-action <%= !canEditPermissions ? 'opacity-40 cursor-not-allowed' : '' %>" 
                            data-action="<%= act.key %>">
                            
                          <% 
                             // Visual dot for user overrides
                             const baseValue = isUserMode ? Boolean(row.baseRights && row.baseRights[act.key]) : false;
                             const overrideValue = isUserMode && row.overrideRights ? row.overrideRights[act.key] : null;
                             const hasOverride = isUserMode && overrideValue !== null && overrideValue !== undefined;
                             const overrideDiff = hasOverride && Boolean(overrideValue) !== baseValue;
                          %>
                          <% if (overrideDiff) { %>
                             <span class="absolute top-1.5 right-6 w-1.5 h-1.5 rounded-full bg-blue-400" title="User Override"></span>
                          <% } %>
                        </label>
                      <% } %>
                    </td>
                  <% }) %>

                  <td class="text-center p-0 h-10 w-12">
                    <% if (row.isConfigurableScope && row.scopeId) { %>
                      <div class="w-full h-full flex items-center justify-center hover:bg-slate-100">
                        <input type="checkbox" onchange="toggleRow(this, '<%= row.scopeId %>')" <%= !canEditPermissions ? 'disabled' : '' %> class="rounded-full text-slate-300 focus:ring-slate-400 w-4 h-4 cursor-pointer hover:text-accent <%= !canEditPermissions ? 'opacity-40 cursor-not-allowed' : '' %>" title="<%= t('select_all') %>">
                      </div>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        
        <div id="permission-footer" class="p-3 border-t border-slate-200 bg-white flex justify-between items-center shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.02)] z-20 shrink-0 hidden">
          <div class="text-xs text-slate-500 flex items-center gap-3">
             <% if (isUserMode) { %>
               <span class="px-2 py-1 bg-amber-50 text-amber-700 rounded border border-amber-100 font-medium">⚠️ Override Mode</span>
             <% } %>
          </div>
          <button type="submit" <%= !canEditPermissions ? 'disabled' : '' %> class="bg-accent text-white px-6 py-2 rounded-lg text-sm font-bold shadow-lg shadow-accent/20 hover:bg-accent/90 hover:-translate-y-0.5 transition-all flex items-center gap-2 <%= !canEditPermissions ? 'opacity-50 cursor-not-allowed hover:bg-accent' : '' %>">
            <span><%= t('save_changes') %></span>
          </button>
        </div>
      </div>
    </form>
    <% if (isUserMode) { %>
      <form action="/administration/permissions/account-access" method="POST" class="hidden" data-account-access-submit-form>
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input type="hidden" name="target_id" value="<%= targetId %>">
        <input type="hidden" name="rows_json" value="[]" data-account-access-json>
      </form>
    <% } %>
  <% } else { %>
    <div class="flex-1 flex flex-col items-center justify-center text-slate-400 bg-slate-50/50 m-4 border-2 border-dashed border-slate-200 rounded-xl">
      <div class="w-16 h-16 mb-4 rounded-full bg-slate-100 flex items-center justify-center text-3xl">👋</div>
      <p class="text-lg font-bold text-slate-600"><%= isUserMode ? t('select_user_to_configure') : t('select_role_to_configure') %></p>
      <p class="text-sm"><%= t('choose_option_top_right') %></p>
    </div>
  <% } %>
</div>

<script>
  // --- 1. SIDEBAR & VISIBILITY LOGIC ---
  let currentCategory = '';
  const collapsedPaths = new Set();
  const ACCOUNT_ACCESS_SCOPE_PATH = '<%= accountAccessScopePath %>';

  function syncAccountAccessPanel(path) {
    const panel = document.getElementById('account-access-shell');
    if (!panel) return;
    const normalizedPath = String(path || '').trim();
    const shouldShow =
      ACCOUNT_ACCESS_SCOPE_PATH !== '' &&
      normalizedPath === ACCOUNT_ACCESS_SCOPE_PATH;
    panel.classList.toggle('hidden', !shouldShow);
  }

  function filterCategory(path) {
    currentCategory = path;
    const btns = document.querySelectorAll('.category-btn');
    const searchInput = document.getElementById('permission-search');
    const moduleEmptyState = document.getElementById('module-empty-state');
    const permissionToolbar = document.getElementById('permission-toolbar');
    const permissionTableContainer = document.getElementById('permission-table-container');
    const permissionFooter = document.getElementById('permission-footer');
    const normalizedPath = String(path || '').trim();
    const isEmptySelection = !normalizedPath || normalizedPath === 'none';
    const isAccountAccessSelection =
      ACCOUNT_ACCESS_SCOPE_PATH !== '' &&
      normalizedPath === ACCOUNT_ACCESS_SCOPE_PATH;
    
    // Toggle right-pane mode: empty, permission matrix, or account-access focused panel.
    if (isEmptySelection) {
        moduleEmptyState?.classList.remove('hidden');
        permissionToolbar?.classList.add('hidden');
        permissionTableContainer?.classList.add('hidden');
        permissionFooter?.classList.add('hidden');
      syncAccountAccessPanel('');
        return;
    }

    moduleEmptyState?.classList.add('hidden');

    if (isAccountAccessSelection) {
        permissionToolbar?.classList.add('hidden');
        permissionTableContainer?.classList.add('hidden');
        permissionFooter?.classList.add('hidden');
      syncAccountAccessPanel(normalizedPath);
    } else {
        permissionToolbar?.classList.remove('hidden');
        permissionTableContainer?.classList.remove('hidden');
        permissionFooter?.classList.remove('hidden');
      syncAccountAccessPanel('');
    }

    // Sidebar Active State
    btns.forEach(btn => {
        if(btn.dataset.cat === normalizedPath) {
            btn.classList.add('bg-white', 'shadow-sm', 'text-accent', 'ring-1', 'ring-accent/30', 'border-l-4', 'border-l-accent');
            btn.classList.remove('text-slate-600', 'hover:bg-white', 'border-transparent');
        } else {
            btn.classList.remove('bg-white', 'shadow-sm', 'text-accent', 'ring-1', 'ring-accent/30', 'border-l-4', 'border-l-accent');
            btn.classList.add('text-slate-600', 'hover:bg-white', 'border-transparent');
        }
    });

    if(searchInput && searchInput.value === '') {
        document.getElementById('permission-search-clear').classList.add('hidden');
    }

    // AUTO-EXPAND LOGIC:
    // If a specific module is clicked, we ensure its immediate children are visible.
    // We achieve this by removing the clicked path from 'collapsedPaths'.
    if (normalizedPath !== 'all') {
        // Uncollapse the container itself and its ancestors so nested groups show immediately.
      const parts = normalizedPath.split('.');
        parts.forEach((_, idx) => {
            const ancestor = parts.slice(0, idx + 1).join('.');
            collapsedPaths.delete(ancestor);
        });

        // Also uncollapse the row in the DOM so 'applyFilters' sees it as open
        const rows = document.querySelectorAll('.permission-row');
        rows.forEach(row => {
            const rowPath = row.getAttribute('data-path');
          if (rowPath === normalizedPath) {
                collapsedPaths.delete(rowPath);
            }
        });
    }

    applyFilters();
  }

  function applyFilters() {
      const searchInput = document.getElementById('permission-search');
      const q = (searchInput?.value || '').trim().toLowerCase();
      const isSearch = q.length > 0;
      
      const rows = document.querySelectorAll('.permission-row');
      const matched = new Set();

      rows.forEach(row => {
          const rowPath = row.getAttribute('data-path');

          // 1. Sidebar Category Filter
          if (!isSearch) {
              // Show if row is the category itself OR inside the category
              if (currentCategory === 'all' || rowPath === currentCategory || rowPath.startsWith(currentCategory + '.')) {
                  row.classList.remove('hidden-by-category');
              } else {
                  row.classList.add('hidden-by-category');
                  return; 
              }
          } else {
              row.classList.remove('hidden-by-category');
          }

          // 2. Search OR Tree Collapse Logic
          if (isSearch) {
              const hay = row.getAttribute('data-search').toLowerCase();
              if (hay.includes(q)) matched.add(row);
          } else {
              // Hierarchy Check
              let parentPath = row.getAttribute('data-parent');
              let isHidden = false;
              
              // Walk up the tree
              while(parentPath) {
                  if (collapsedPaths.has(parentPath)) { isHidden = true; break; }
                  
                  const parts = parentPath.split('.');
                  if(parts.length > 1) {
                      parts.pop();
                      parentPath = parts.join('.');
                  } else {
                      parentPath = '';
                  }
              }
              if (!isHidden) matched.add(row);
          }
      });

      // Apply Visibility
      rows.forEach(row => {
          if (row.classList.contains('hidden-by-category') && !isSearch) {
              row.classList.add('hidden');
          } else {
              row.classList.toggle('hidden', !matched.has(row));
          }
      });

      // Update +/- Icons
      document.querySelectorAll('.group-toggle').forEach(btn => {
          const path = btn.getAttribute('data-toggle');
          btn.textContent = collapsedPaths.has(path) ? '+' : '−';
      });

      syncActionColumns();
  }

  function syncActionColumns() {
      const allActionHeaders = Array.from(document.querySelectorAll('th[data-action-col]'));
      const allActionCells = Array.from(document.querySelectorAll('td[data-action-col]'));

      const visibleRows = Array.from(document.querySelectorAll('.permission-row')).filter((row) => !row.classList.contains('hidden'));
      const visibleConfigurableRows = visibleRows.filter((row) => Boolean(row.querySelector("input.permission-action[type='checkbox']")));
      if (!visibleConfigurableRows.length) {
          allActionHeaders.forEach((th) => th.classList.remove('hidden'));
          allActionCells.forEach((td) => td.classList.remove('hidden'));
          return;
      }

      const actionKeys = allActionHeaders
        .map((th) => th.getAttribute('data-action-col'))
        .filter(Boolean);

      actionKeys.forEach((actionKey) => {
          const hasAnyInput = visibleConfigurableRows.some((row) => {
              const cell = row.querySelector(`td[data-action-col="${actionKey}"]`);
              if (!(cell instanceof HTMLElement)) return false;
              return Boolean(cell.querySelector('input[type="checkbox"]'));
          });

          const header = document.querySelector(`th[data-action-col="${actionKey}"]`);
          if (header instanceof HTMLElement) {
              header.classList.toggle('hidden', !hasAnyInput);
          }
          document.querySelectorAll(`td[data-action-col="${actionKey}"]`).forEach((cell) => {
              cell.classList.toggle('hidden', !hasAnyInput);
          });
      });
  }

  // --- 2. PERMISSION DEPENDENCY LOGIC (AUTO-CHECK) ---
  const dependencies = {
        'can_edit':   ['can_navigate', 'can_view'],
        'can_delete': ['can_navigate', 'can_view'],
        'can_hard_delete': ['can_navigate', 'can_view'],
        'can_create': ['can_view'],
        'can_approve': ['can_navigate', 'can_view'],
        'can_print':   ['can_navigate', 'can_load', 'can_view'],
        'can_navigate': ['can_view'],
        'can_load': ['can_view'],
        'can_view_details': ['can_load', 'can_view'],
        'can_export_excel_csv': ['can_load', 'can_view'],
        'can_filter_all_branches': ['can_load', 'can_view'],
        'can_view_cost_fields': ['can_load', 'can_view']
  };

  const escapeAttrValue = (value) =>
    String(value || '')
      .replace(/\\/g, '\\\\')
      .replace(/"/g, '\\"');

  const getPermissionActionCheckboxesByName = (name) => {
    const safeName = escapeAttrValue(name);
    return Array.from(
      document.querySelectorAll(`input.permission-action[type='checkbox'][name="${safeName}"]`),
    );
  };

  const syncDuplicatePermissionCheckboxes = (sourceCheckbox) => {
    if (!(sourceCheckbox instanceof HTMLInputElement)) return;
    const checkboxes = getPermissionActionCheckboxesByName(sourceCheckbox.name);
    checkboxes.forEach((checkbox) => {
      if (checkbox === sourceCheckbox) return;
      checkbox.checked = sourceCheckbox.checked;
    });
  };

  function checkDependencies(sourceCheckbox) {
        syncDuplicatePermissionCheckboxes(sourceCheckbox);
        if (!sourceCheckbox.checked) return;
        
        const parts = sourceCheckbox.name.split(':');
        const scopeId = parts[0];
        const action = parts[1];
        
        const required = dependencies[action];
        if (required) {
            required.forEach(reqAction => {
                checkAndFlash(scopeId, reqAction);
            });
        }
        
        // Always ensure View is checked if anything else is checked
        if (action !== 'can_view') checkAndFlash(scopeId, 'can_view');
  }

  function checkAndFlash(scopeId, reqAction) {
      const name = `${scopeId}:${reqAction}`;
      const targets = getPermissionActionCheckboxesByName(name);
      targets.forEach((target) => {
      if (target.checked) return;
      target.checked = true;

      // Pulse Animation
      const parent = target.closest('label');
      if(parent) {
        parent.classList.add('bg-blue-100', 'ring-2', 'ring-blue-100');
        setTimeout(() => parent.classList.remove('bg-blue-100', 'ring-2', 'ring-blue-100'), 400);
      }
      });
  }

  // --- 3. EVENT LISTENERS ---
  document.addEventListener('DOMContentLoaded', function() {
    document.body.classList.add('permissions-no-scroll');
    const adjustPermissionsHeight = () => {
      const shell = document.querySelector('.permissions-shell');
      if (!shell) return;
      const top = shell.getBoundingClientRect().top;
      const available = Math.max(320, window.innerHeight - top - 8);
      shell.style.height = `${available}px`;
      shell.style.maxHeight = `${available}px`;
    };
    adjustPermissionsHeight();
    window.addEventListener('resize', adjustPermissionsHeight);
    
    // Initial Collapse: Collapse everything that is NOT a root node
    const rows = document.querySelectorAll('.permission-row');
    rows.forEach(row => {
        const path = row.getAttribute('data-path');
        const depth = parseInt(row.getAttribute('data-depth') || '0');
        
        // If it has children and is deeper than root, collapse it by default.
        if (row.getAttribute('data-has-children') === 'true' && depth > 0) {
            collapsedPaths.add(path);
        }
        
        // +/- Click Handler
        const btn = row.querySelector('.group-toggle');
        if(btn) {
            btn.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                if(collapsedPaths.has(path)) collapsedPaths.delete(path);
                else collapsedPaths.add(path);
                applyFilters();
            });
        }
    });

    // Search Logic
    const searchInput = document.getElementById('permission-search');
    if(searchInput) {
        searchInput.addEventListener('input', () => {
            const clearBtn = document.getElementById('permission-search-clear');
            if(searchInput.value.trim().length > 0) clearBtn.classList.remove('hidden');
            else clearBtn.classList.add('hidden');
            applyFilters();
        });
        document.getElementById('permission-search-clear')?.addEventListener('click', () => {
            searchInput.value = '';
            document.getElementById('permission-search-clear').classList.add('hidden');
            applyFilters();
        });
    }

    // Expand/Collapse All
    document.getElementById('expand-all')?.addEventListener('click', () => {
        collapsedPaths.clear();
        applyFilters();
    });
    document.getElementById('collapse-all')?.addEventListener('click', () => {
        rows.forEach(r => {
            if(r.getAttribute('data-has-children')==='true') collapsedPaths.add(r.getAttribute('data-path'));
        });
        applyFilters();
    });

    // Permission Checkboxes
    document.querySelectorAll('input.permission-action').forEach(box => {
        box.addEventListener('change', function() { checkDependencies(this); });
    });

    // Initial State: Empty
    filterCategory('');
  });

  function toggleRow(source, scopeId) {
      const row = source.closest('tr.permission-row');
      if (!row) return;
      row.querySelectorAll("input.permission-action[type='checkbox']").forEach(cb => {
          if (cb.checked !== source.checked) {
              cb.checked = source.checked;
              // Trigger manually to ensure dependencies run and form state updates
              cb.dispatchEvent(new Event('change', { bubbles: true }));
          }
      });
  }
</script>
<script>
  (function () {
    const panel = document.getElementById('account-access-shell');
    const submitForm = document.querySelector('[data-account-access-submit-form]');
    if (!panel || !submitForm) return;

    if (typeof window.initSearchableSelects === 'function') {
      window.initSearchableSelects(panel);
    }

    const addSelect = panel.querySelector('[data-account-access-add]');
    const addButton = panel.querySelector('[data-account-access-add-btn]');
    const rowSearchInput = panel.querySelector('[data-account-access-row-search]');
    const body = panel.querySelector('[data-account-access-body]');
    const saveButton = panel.querySelector('[data-account-access-save]');
    const jsonInput = submitForm.querySelector('[data-account-access-json]');
    const isReadOnly = <%= canEditPermissions ? 'false' : 'true' %>;

    if (!(body instanceof HTMLElement)) return;

    const escapeHtml = (value) =>
      String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');

    const restrictionToFlags = (restrictionValue) => {
      if (restrictionValue === 'details') {
        return { canBlockSummary: true, canBlockDetails: true };
      }
      return { canBlockSummary: true, canBlockDetails: false };
    };

    const updateEmptyState = () => {
      const rows = body.querySelectorAll('[data-account-access-row]');
      const empty = body.querySelector('[data-account-access-empty]');
      if (rows.length > 0) {
        empty?.remove();
        return;
      }
      if (empty) return;
      const tr = document.createElement('tr');
      tr.setAttribute('data-account-access-empty', '1');
      tr.innerHTML = `<td colspan="4" class="px-3 py-6 text-center text-xs font-semibold text-slate-500"><%= t('no_records_found') %></td>`;
      body.appendChild(tr);
    };

    const updateSearchEmptyState = () => {
      const rows = Array.from(body.querySelectorAll('[data-account-access-row]'));
      const filterEmpty = body.querySelector('[data-account-access-filter-empty]');
      if (!rows.length) {
        filterEmpty?.remove();
        return;
      }
      const visibleRows = rows.filter((row) => !row.classList.contains('hidden-by-account-search'));
      if (visibleRows.length > 0) {
        filterEmpty?.remove();
        return;
      }
      if (filterEmpty) return;
      const tr = document.createElement('tr');
      tr.setAttribute('data-account-access-filter-empty', '1');
      tr.innerHTML = `<td colspan="4" class="px-3 py-6 text-center text-xs font-semibold text-slate-500"><%= t('no_records_found') %></td>`;
      body.appendChild(tr);
    };

    const applyRowSearch = () => {
      const query = String(rowSearchInput?.value || '').trim().toLowerCase();
      const rows = Array.from(body.querySelectorAll('[data-account-access-row]'));
      rows.forEach((row) => {
        const haystack = String(row.getAttribute('data-row-search') || '').toLowerCase();
        const shouldShow = !query || haystack.includes(query);
        row.classList.toggle('hidden-by-account-search', !shouldShow);
        row.classList.toggle('hidden', !shouldShow);
      });
      updateSearchEmptyState();
    };

    const collectRows = () => {
      const rows = Array.from(body.querySelectorAll('[data-account-access-row]'));
      return rows
        .map((row) => {
          const accountId = Number(row.getAttribute('data-account-id') || 0);
          if (!Number.isInteger(accountId) || accountId <= 0) return null;
          const restriction = row.querySelector('[data-account-restriction]');
          const restrictionValue = String(restriction?.value || 'details').toLowerCase() === 'summary'
            ? 'summary'
            : 'details';
          const flags = restrictionToFlags(restrictionValue);
          return {
            accountId,
            canBlockSummary: flags.canBlockSummary,
            canBlockDetails: flags.canBlockDetails,
          };
        })
        .filter(Boolean);
    };

    const createRow = ({ accountId, code, name, branches }) => {
      const safeCode = escapeHtml(code || '-');
      const safeName = escapeHtml(name || '-');
      const safeBranches = escapeHtml(branches || '');
      const searchText = `${String(code || '')} ${String(name || '')} ${String(branches || '')}`.toLowerCase();
      const safeSearchText = escapeHtml(searchText);
      const disabledAttr = isReadOnly ? 'disabled' : '';

      const tr = document.createElement('tr');
      tr.className = 'border-t border-slate-100';
      tr.setAttribute('data-account-access-row', '1');
      tr.setAttribute('data-account-id', String(accountId));
      tr.setAttribute('data-row-search', safeSearchText);
      tr.innerHTML = `
        <td class="px-3 py-2 font-semibold text-slate-700" data-account-code>${safeCode}</td>
        <td class="px-3 py-2 text-slate-700" data-account-name>
          <div class="font-medium">${safeName}</div>
          ${safeBranches ? `<div class="mt-0.5 text-[11px] text-slate-400">${safeBranches}</div>` : ''}
        </td>
        <td class="px-3 py-2 text-slate-700">
          <select data-account-restriction class="h-8 w-full rounded-md border border-slate-300 bg-white px-2 text-xs font-semibold" ${disabledAttr}>
            <option value="summary"><%= t('account_access_restriction_summary') %></option>
            <option value="details" selected><%= t('account_access_restriction_details') %></option>
          </select>
        </td>
        <td class="px-3 py-2 text-center">
          <button type="button" class="rounded-md border border-rose-200 bg-rose-50 px-2 py-1 text-[10px] font-bold uppercase tracking-[0.08em] text-rose-700 hover:bg-rose-100 disabled:cursor-not-allowed disabled:opacity-50" data-account-remove ${disabledAttr}><%= t('delete') %></button>
        </td>
      `;
      body.appendChild(tr);
      updateEmptyState();
      applyRowSearch();
    };

    const addSelectedAccount = () => {
      if (!(addSelect instanceof HTMLSelectElement)) return;
      const accountId = Number(addSelect.value || 0);
      if (!Number.isInteger(accountId) || accountId <= 0) return;

      const exists = body.querySelector(`[data-account-access-row][data-account-id="${accountId}"]`);
      if (exists) return;

      const selected = addSelect.options[addSelect.selectedIndex];
      const code = selected?.getAttribute('data-code') || '';
      const name = selected?.getAttribute('data-name') || selected?.textContent || '';
      const branches = selected?.getAttribute('data-branches') || '';
      createRow({ accountId, code, name, branches });

      addSelect.value = '';
      addSelect.dispatchEvent(new Event('change', { bubbles: true }));
    };

    body.addEventListener('click', (event) => {
      const button = event.target.closest('[data-account-remove]');
      if (!button) return;
      const row = button.closest('[data-account-access-row]');
      if (!row) return;
      row.remove();
      updateEmptyState();
      applyRowSearch();
    });

    addButton?.addEventListener('click', addSelectedAccount);

    addSelect?.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter') return;
      event.preventDefault();
      addSelectedAccount();
    });

    rowSearchInput?.addEventListener('input', applyRowSearch);

    saveButton?.addEventListener('click', () => {
      if (!(jsonInput instanceof HTMLInputElement)) return;
      jsonInput.value = JSON.stringify(collectRows());
      if (typeof submitForm.requestSubmit === 'function') submitForm.requestSubmit();
      else submitForm.submit();
    });

    updateEmptyState();
    applyRowSearch();
  })();
</script>

<style>
  .permissions-no-scroll { overflow: hidden; }
  .permissions-shell { height: calc(100vh - 6rem); }
  .custom-scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
  .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
  .custom-scrollbar::-webkit-scrollbar-thumb { background-color: #cbd5e1; border-radius: 3px; }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover { background-color: #94a3b8; }
</style>
