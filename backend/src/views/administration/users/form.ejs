<div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
  <h3 class="text-lg font-semibold leading-6 text-slate-900 mb-4"><%= title %></h3>
  <form action="/administration/users/save" method="POST" class="space-y-5" autocomplete="off" data-translate-mode="transliterate">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input type="hidden" name="id" value="<%= user ? user.id : '' %>">
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1"><%= t('name')  %> *</label>
        <input type="text" name="name" value="<%= user ? user.name : '' %>" required autocomplete="off" class="w-full rounded-lg border-slate-300 focus:ring-accent focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1"><%= t('name_ur')  %></label>
        <input type="text" name="name_ur" value="<%= user ? user.name_ur : '' %>" autocomplete="off" class="w-full rounded-lg border-slate-300 focus:ring-accent focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1"><%= t('username') %> *</label>
        <input type="text" name="username" value="<%= user ? user.username : '' %>" required autocomplete="off" autocapitalize="off" spellcheck="false" class="w-full rounded-lg border-slate-300 focus:ring-accent focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1"><%= t('password') %> <%= user ? t('leave_blank_keep') : '*' %></label>
        <input type="password" name="password" <%= user ? '' : 'required' %> autocomplete="new-password" autocapitalize="off" spellcheck="false" class="w-full rounded-lg border-slate-300 focus:ring-accent focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1"><%= t('email') %></label>
        <input type="email" name="email" value="<%= user ? user.email : '' %>" class="w-full rounded-lg border-slate-300 focus:ring-accent focus:border-accent">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 mb-1"><%= t('role') %> *</label>
        <select name="primary_role_id" required class="w-full rounded-lg border-slate-300 focus:ring-accent focus:border-accent">
          <option value=""><%= t('select_role') %></option>
          <% roles.forEach(r => { %>
            <option value="<%= r.id %>" data-role-name="<%= String(r.name || '').trim().toLowerCase() %>" <%= user && user.primary_role_id == r.id ? 'selected' : '' %>><%= r.name %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-slate-700 mb-2"><%= t('assigned_branches') %></label>
      <p class="mb-3 text-xs text-slate-500"><%= t('branch_access_hint') %></p>
      <select
        class="w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-accent/30"
        name="branch_ids"
        data-searchable-select="true"
        data-searchable-variant="unified"
        data-all-multi-select="true"
        multiple
      >
        <option value="__all__" <%= hasAllBranches ? 'selected' : '' %>><%= t('all') %> <%= t('branches') %></option>
        <% allBranches.forEach(b => { %>
          <option value="<%= b.id %>" <%= userBranches.includes(Number(b.id)) ? 'selected' : '' %>><%= b.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="mt-5 sm:mt-6 sm:grid sm:grid-flow-row-dense sm:grid-cols-2 sm:gap-3">
      <button type="submit" class="inline-flex w-full justify-center rounded-md bg-accent px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-accent/90 sm:col-start-2">
        <%= t('save') %>
      </button>
      <button type="button" onclick="document.getElementById('modal-backdrop').classList.add('hidden'); document.getElementById('modal-shell').classList.add('hidden');" class="mt-3 inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 sm:col-start-1 sm:mt-0">
        <%= t('cancel') %>
      </button>
    </div>
  </form>
</div>
<%- include("../../base/partials/urdu-translate-utils") %>

<script>
  (function () {
    const form = document.querySelector("form[action='/administration/users/save']");
    if (!form) return;

    const roleSelect = form.querySelector("select[name='primary_role_id']");
    const branchSelect = form.querySelector("select[name='branch_ids']");
    if (!(roleSelect instanceof HTMLSelectElement) || !(branchSelect instanceof HTMLSelectElement)) return;

    const allOption = Array.from(branchSelect.options).find((opt) => String(opt.value || "").trim().toLowerCase() === "__all__");
    if (!allOption) return;

    const getSelectedSet = () =>
      new Set(
        Array.from(branchSelect.selectedOptions).map((opt) =>
          String(opt.value || "").trim().toLowerCase(),
        ),
      );

    const isAdminRoleSelected = () => {
      const selected = roleSelect.options[roleSelect.selectedIndex];
      const roleName = String(selected?.dataset?.roleName || selected?.textContent || "")
        .trim()
        .toLowerCase();
      return roleName === "admin";
    };

    const applyAdminAllBranches = () => {
      Array.from(branchSelect.options).forEach((opt) => {
        opt.selected = opt === allOption;
      });
    };

    let previousSelection = getSelectedSet();

    const normalizeAllSelection = () => {
      const allKey = "__all__";
      const currentSelection = getSelectedSet();

      if (isAdminRoleSelected()) {
        applyAdminAllBranches();
        previousSelection = getSelectedSet();
        return;
      }

      const allSelected = allOption.selected;
      const nonAllOptions = Array.from(branchSelect.options).filter(
        (opt) => opt !== allOption,
      );
      const selectedNonAll = nonAllOptions.filter((opt) => opt.selected);
      const changedValues = Array.from(
        new Set([...currentSelection, ...previousSelection]),
      ).filter((value) => currentSelection.has(value) !== previousSelection.has(value));
      const nonAllChanged = changedValues.some((value) => value !== allKey);
      const allChanged = changedValues.includes(allKey);

      if (allSelected && allChanged) {
        nonAllOptions.forEach((opt) => {
          opt.selected = false;
        });
      } else if (allSelected && nonAllChanged) {
        allOption.selected = false;
      }

      const hasSelectedNonAll = nonAllOptions.some((opt) => opt.selected);
      if (!allOption.selected && !hasSelectedNonAll) {
        allOption.selected = true;
      }

      previousSelection = getSelectedSet();
    };

    roleSelect.addEventListener("change", () => {
      if (isAdminRoleSelected()) {
        applyAdminAllBranches();
      }
      previousSelection = getSelectedSet();
      branchSelect.dispatchEvent(new Event("change", { bubbles: true }));
    });

    branchSelect.addEventListener("change", () => {
      normalizeAllSelection();
    });

    normalizeAllSelection();
  })();
</script>
