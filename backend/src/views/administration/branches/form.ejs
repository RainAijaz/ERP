<div class="bg-white px-6 py-5">
  <h3 class="text-lg font-semibold leading-6 text-slate-900"><%= title %></h3>

  <form action="<%= branch && branch.id ? '/administration/branches/' + branch.id : '/administration/branches' %>" method="POST" class="mt-5 space-y-5" data-modal-form data-translate-mode="transliterate">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          <div>
            <label class="block text-sm font-semibold text-slate-600"><%= t('branch_code') %></label>
            <input type="text" name="code" value="<%= branch ? branch.code : '' %>" required class="mt-2 block w-full rounded-xl border border-slate-200 px-4 py-3 text-sm text-slate-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-accent/30 uppercase <%= branch && branch.id ? 'cursor-not-allowed bg-slate-100 text-slate-500' : 'bg-white' %>" <%= branch && branch.id ? 'readonly disabled' : '' %>>
            <p class="mt-1 text-xs text-slate-500"><%= t('unique_identifier_hint') %></p>
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-600"><%= t('branch_name') %></label>
            <input type="text" name="name" value="<%= branch ? branch.name : '' %>" required class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-accent/30">
          </div>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-600"><%= t('branch_name_ur') || t('name_ur') %></label>
          <input type="text" name="name_ur" value="<%= branch ? branch.name_ur : '' %>" class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-accent/30">
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-600"><%= t('city') %></label>
          <input type="text" name="city" value="<%= branch ? branch.city : '' %>" class="mt-2 block w-full rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-700 shadow-sm focus:outline-none focus:ring-2 focus:ring-accent/30">
        </div>

        <div class="mt-6 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <button type="submit" class="inline-flex w-full justify-center rounded-md bg-accent px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-accent/90 sm:col-start-2">
            <%= t('save') %>
          </button>
          <button type="button" onclick="document.getElementById('modal-backdrop').classList.add('hidden'); document.getElementById('modal-shell').classList.add('hidden');" class="inline-flex w-full justify-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 sm:col-start-1">
            <%= t('cancel') %>
          </button>
        </div>
  </form>
</div>

<%- include("../../base/partials/urdu-translate-utils") %>
