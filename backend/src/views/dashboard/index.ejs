  <!-- ===== SECTION 4: Latest activity (admin only) — one most-recent entry + View All ===== -->
  <% if (isAdminUser) { %>
    <section
      class="rounded-2xl border border-slate-200 bg-white/95 shadow-md"
      data-activity-feed
      data-activity-endpoint="/dashboard/activity"
      data-i18n='<%- JSON.stringify({ noData: t("no_entries"), loading: t("loading"), viewRecord: t("view_record"), system: t("system") }) %>'
    >
      <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-700"><%= t("recent_activity") %></h3>
        <a href="/administration/audit-logs" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-accent transition hover:bg-slate-50">
          <%= t("view_all") %>
          <%- svg("chevron-right", "h-3.5 w-3.5") %>
        </a>
      </div>

      <div class="px-5 py-4">
        <ul class="space-y-2" data-activity-list></ul>
