      </div>
    </section>
  <% } %>
</div>

<!-- ===== Section 3 analytics: lazy Chart.js renderer ===== -->
<script>
  (function () {
    const root = document.querySelector("[data-analytics]");
    if (!root) return;

    const endpoint = root.dataset.analyticsEndpoint || "/dashboard/analytics";
    const locale = root.dataset.locale || "en";
    let I18N = {};
    try { I18N = JSON.parse(root.dataset.i18n || "{}"); } catch (_e) { I18N = {}; }

    const PALETTE = {
      emerald: "#059669", blue: "#2563eb", amber: "#d97706", rose: "#e11d48",
      indigo: "#4f46e5", cyan: "#0891b2", violet: "#7c3aed", slate: "#94a3b8",
    };
    const alpha = (hex, a) => {
      const n = parseInt(hex.slice(1), 16);
      return `rgba(${(n >> 16) & 255}, ${(n >> 8) & 255}, ${n & 255}, ${a})`;
    };
    const MONTHS = ["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
    const nf = new Intl.NumberFormat("en-US", { maximumFractionDigits: 0 });
    const compact = (v) => {
      const a = Math.abs(Number(v) || 0);
      if (a >= 1e6) return (v / 1e6).toFixed(a >= 1e7 ? 0 : 1) + "M";
      if (a >= 1e3) return (v / 1e3).toFixed(a >= 1e5 ? 0 : 1) + "K";
      return nf.format(v);
    };
    const fmtBucket = (k) => {
      if (/^\d{4}-\d{2}-\d{2}$/.test(k)) { const p = k.split("-"); return `${+p[2]} ${MONTHS[+p[1] - 1]}`; }
      if (/^\d{4}-\d{2}$/.test(k)) { const p = k.split("-"); return `${MONTHS[+p[1] - 1]} ${p[0].slice(2)}`; }
      return k;
    };

    const charts = {};
    let loaded = false;
    let currentPeriod = "month";

    const gridColor = "rgba(148, 163, 184, 0.18)";
    const tickColor = "#64748b";

    const loadChartJs = () => {
      if (window.Chart) return Promise.resolve(window.Chart);
      if (window.__erpChartJsPromise) return window.__erpChartJsPromise;
      window.__erpChartJsPromise = new Promise((resolve, reject) => {
        const s = document.createElement("script");
        s.src = "/vendor/chart.umd.min.js";
        s.async = true;
        s.onload = () => (window.Chart ? resolve(window.Chart) : reject(new Error("Chart.js missing")));
        s.onerror = () => reject(new Error("Failed to load Chart.js"));
        document.head.appendChild(s);
      });
      return window.__erpChartJsPromise;
    };

    const canvasFor = (id) => root.querySelector(`[data-chart="${id}"]`);
    const setState = (id, msg) => {
      const el = root.querySelector(`[data-chart-state="${id}"]`);
      if (!el) return;
      if (msg) { el.textContent = msg; el.classList.remove("hidden"); }
      else { el.classList.add("hidden"); }
    };
    const drill = (id) => {
      const cv = canvasFor(id);
      if (cv && cv.dataset.href) window.location.href = cv.dataset.href;
    };
    const destroy = (id) => { if (charts[id]) { charts[id].destroy(); delete charts[id]; } };

    const commonOpts = (id, extra = {}) => Object.assign({
      responsive: true,
      maintainAspectRatio: false,
      onClick: () => drill(id),
      interaction: { mode: "index", intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => {
              const v = typeof c.raw === "number" ? c.raw : (c.parsed && typeof c.parsed === "object" ? (c.parsed.x ?? c.parsed.y) : c.parsed);
              const lbl = c.dataset && c.dataset.label ? c.dataset.label + ": " : "";
              return lbl + nf.format(Number(v) || 0);
            },
          },
        },
      },
    }, extra);

    const linearAxis = { grid: { color: gridColor, drawBorder: false }, ticks: { color: tickColor, font: { size: 11 }, callback: (v) => compact(v) } };
    const catAxis = { grid: { display: false }, ticks: { color: tickColor, font: { size: 11 } } };

    const RENDER = {
      salesTrend(Chart, id, d) {
        if (!d) return setState(id, I18N.noAccess);
        const labels = (d.labels || []).map(fmtBucket);
        destroy(id);
        charts[id] = new Chart(canvasFor(id).getContext("2d"), {
          type: "line",
          data: { labels, datasets: [{ label: I18N.sales, data: d.values || [], borderColor: PALETTE.emerald, backgroundColor: alpha(PALETTE.emerald, 0.12), borderWidth: 2, pointRadius: 0, pointHoverRadius: 5, tension: 0.3, fill: true }] },
          options: commonOpts(id, { scales: { x: catAxis, y: linearAxis } }),
        });
        setState(id, null);
      },
      revenueVsExpenses(Chart, id, d) {
        if (!d) return setState(id, I18N.noAccess);
        const labels = (d.labels || []).map(fmtBucket);
        destroy(id);
        charts[id] = new Chart(canvasFor(id).getContext("2d"), {
          type: "line",
          data: { labels, datasets: [
            { label: I18N.revenue, data: d.revenue || [], borderColor: PALETTE.emerald, backgroundColor: "transparent", borderWidth: 2, pointRadius: 0, pointHoverRadius: 5, tension: 0.3 },
            { label: I18N.expense, data: d.expense || [], borderColor: PALETTE.rose, backgroundColor: "transparent", borderWidth: 2, pointRadius: 0, pointHoverRadius: 5, tension: 0.3 },
          ] },
          options: commonOpts(id, { plugins: { legend: { display: true, position: "bottom", labels: { boxWidth: 12, font: { size: 11 }, color: tickColor } } }, scales: { x: catAxis, y: linearAxis } }),
        });
        setState(id, null);
      },
      topProducts(Chart, id, d) {
        if (!d) return setState(id, I18N.noAccess);
        if (!d.labels || !d.labels.length) return setState(id, I18N.noData);
        destroy(id);
        charts[id] = new Chart(canvasFor(id).getContext("2d"), {
          type: "bar",
          data: { labels: d.labels, datasets: [{ label: I18N.sales, data: d.values || [], backgroundColor: alpha(PALETTE.blue, 0.85), borderColor: PALETTE.blue, borderWidth: 0, borderRadius: 4, barPercentage: 0.75, categoryPercentage: 0.8 }] },
          options: commonOpts(id, { indexAxis: "y", scales: { x: linearAxis, y: catAxis } }),
        });
        setState(id, null);
      },
      productionByStage(Chart, id, d) {
        if (!d) return setState(id, I18N.noAccess);
        if (!d.labels || !d.labels.length) return setState(id, I18N.noData);
        const labels = (locale && String(locale).startsWith("ur") && d.labels_ur) ? d.labels_ur : d.labels;
        destroy(id);
        charts[id] = new Chart(canvasFor(id).getContext("2d"), {
          type: "bar",
          data: { labels, datasets: [{ label: I18N.production, data: d.values || [], backgroundColor: alpha(PALETTE.indigo, 0.85), borderColor: PALETTE.indigo, borderWidth: 0, borderRadius: 4, barPercentage: 0.7, categoryPercentage: 0.8 }] },
          options: commonOpts(id, { indexAxis: "y", scales: { x: linearAxis, y: catAxis } }),
        });
        setState(id, null);
      },
      inventoryStatus(Chart, id, d) {
        if (!d) return setState(id, I18N.noAccess);
        const vals = [d.available || 0, d.reserved || 0, d.lowStock || 0, d.outOfStock || 0];
        if (vals.reduce((a, b) => a + b, 0) === 0) return setState(id, I18N.noData);
        destroy(id);
        charts[id] = new Chart(canvasFor(id).getContext("2d"), {
          type: "doughnut",
          data: { labels: [I18N.available, I18N.reserved, I18N.lowStock, I18N.outOfStock],
            datasets: [{ data: vals, backgroundColor: [PALETTE.emerald, PALETTE.slate, PALETTE.amber, PALETTE.rose], borderColor: "#ffffff", borderWidth: 2 }] },
          options: commonOpts(id, { cutout: "62%", plugins: { legend: { display: true, position: "right", labels: { boxWidth: 12, font: { size: 11 }, color: tickColor } }, tooltip: { callbacks: { label: (c) => `${c.label}: ${nf.format(c.parsed)}` } } } }),
        });
        setState(id, null);
      },
      receivablesVsPayables(Chart, id, d) {
        if (!d) return setState(id, I18N.noAccess);
        const labels = [], data = [], colors = [];
        if (d.receivable !== null && d.receivable !== undefined) { labels.push(I18N.receivable); data.push(d.receivable); colors.push(PALETTE.cyan); }
        if (d.payable !== null && d.payable !== undefined) { labels.push(I18N.payable); data.push(d.payable); colors.push(PALETTE.amber); }
        if (!labels.length) return setState(id, I18N.noData);
        destroy(id);
        charts[id] = new Chart(canvasFor(id).getContext("2d"), {
          type: "bar",
          data: { labels, datasets: [{ data, backgroundColor: colors.map((c) => alpha(c, 0.85)), borderColor: colors, borderWidth: 0, borderRadius: 4, barPercentage: 0.5, categoryPercentage: 0.6 }] },
          options: commonOpts(id, { scales: { x: catAxis, y: linearAxis } }),
        });
        setState(id, null);
      },
    };

    let inFlight = null;
    async function refresh(period, from, to) {
      currentPeriod = period;
      root.querySelectorAll("[data-chart]").forEach((cv) => setState(cv.dataset.chart, I18N.loading));
      let Chart;
      try { Chart = await loadChartJs(); } catch (_e) {
        root.querySelectorAll("[data-chart]").forEach((cv) => setState(cv.dataset.chart, I18N.noData));
        return;
      }
      const params = new URLSearchParams({ period });
      if (period === "custom" && from && to) { params.set("from", from); params.set("to", to); }
      const token = Symbol("req");
      inFlight = token;
      let payload;
      try {
        const resp = await fetch(`${endpoint}?${params.toString()}`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
        payload = await resp.json();
      } catch (_e) {
        root.querySelectorAll("[data-chart]").forEach((cv) => setState(cv.dataset.chart, I18N.noData));
        return;
      }
      if (inFlight !== token) return; // a newer request superseded this one
      const data = (payload && payload.charts) || {};
      root.querySelectorAll("[data-chart]").forEach((cv) => {
        const id = cv.dataset.chart;
        if (RENDER[id]) { try { RENDER[id](Chart, id, data[id]); } catch (e) { setState(id, I18N.noData); } }
      });
    }

    // Preset buttons
    const group = root.querySelector("[data-period-group]");
    const customRange = root.querySelector("[data-custom-range]");
    group?.addEventListener("click", (ev) => {
      const btn = ev.target.closest("button[data-period]");
      if (!btn) return;
      group.querySelectorAll("button[data-period]").forEach((b) => b.removeAttribute("data-active"));
      btn.setAttribute("data-active", "true");
      const period = btn.dataset.period;
      if (period === "custom") { customRange.classList.remove("hidden"); customRange.classList.add("flex"); return; }
      customRange.classList.add("hidden"); customRange.classList.remove("flex");
      refresh(period);
    });
    root.querySelector("[data-apply]")?.addEventListener("click", () => {
      const from = root.querySelector("[data-from]")?.value;
      const to = root.querySelector("[data-to]")?.value;
      if (from && to) refresh("custom", from, to);
    });

    // Lazy-load when the section scrolls into view.
    const start = () => { if (loaded) return; loaded = true; refresh("month"); };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { start(); io.disconnect(); } });
      }, { rootMargin: "120px" });
      io.observe(root);
    } else {
      start();
    }
  })();
</script>

<!-- ===== Section 4 activity feed: latest entry only, lazy ===== -->
<script>
  (function () {
    const root = document.querySelector("[data-activity-feed]");
    if (!root) return;

    const endpoint = root.dataset.activityEndpoint || "/dashboard/activity";
    let I18N = {};
    try { I18N = JSON.parse(root.dataset.i18n || "{}"); } catch (_e) { I18N = {}; }

    const list = root.querySelector("[data-activity-list]");
    const stateEl = root.querySelector("[data-activity-state]");

    const AVATAR_COLORS = ["#059669","#2563eb","#d97706","#e11d48","#4f46e5","#0891b2","#7c3aed"];
    const esc = (s) => String(s == null ? "" : s).replace(/[&<>"']/g, (m) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[m]));
    const initials = (name) => {
      const parts = String(name || "?").trim().split(/\s+/).filter(Boolean);
      if (!parts.length) return "?";
      return (parts[0][0] + (parts.length > 1 ? parts[parts.length - 1][0] : "")).toUpperCase();
    };
    const colorFor = (name) => {
      let h = 0; const s = String(name || "");
      for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) >>> 0;
      return AVATAR_COLORS[h % AVATAR_COLORS.length];
    };

    let started = false;

    const renderItem = (it) => {
      const li = document.createElement("li");
      li.className = "flex items-start gap-3 rounded-xl border border-slate-200 bg-white px-4 py-3 transition hover:bg-slate-50";
      const color = colorFor(it.user_name);
      const view = it.href
        ? `<a href="${esc(it.href)}" class="shrink-0 self-center rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-accent transition hover:bg-slate-50">${esc(I18N.viewRecord || "View Record")}</a>`
        : "";
      li.innerHTML =
        `<span class="mt-0.5 inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-xs font-bold text-white" style="background:${color}">${esc(initials(it.user_name))}</span>` +
        `<div class="min-w-0 flex-1">` +
          `<div class="flex flex-wrap items-center gap-2">` +
            `<span class="text-sm font-semibold text-slate-800">${esc(it.user_name || I18N.system)}</span>` +
            `<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] font-semibold ring-1 ring-inset ${esc(it.action_class || "bg-slate-50 text-slate-600 ring-slate-200")}">${esc(it.action)}</span>` +
            `<span class="text-xs text-slate-400">• ${esc(it.module || "")}</span>` +
          `</div>` +
          `<div class="mt-0.5 truncate text-sm text-slate-600">${esc(it.summary || "")}</div>` +
          `<div class="mt-1 text-xs text-slate-400">${esc(it.date || "")} · ${esc(it.time || "")}${it.reference && it.reference !== "-" ? " · #" + esc(it.reference) : ""}</div>` +
        `</div>` +
        view;
      return li;
    };

    async function load() {
      stateEl.hidden = false;
      stateEl.textContent = I18N.loading || "Loading…";
      let payload;
      try {
        const resp = await fetch(`${endpoint}?page=1&pageSize=1`, { headers: { Accept: "application/json" }, credentials: "same-origin" });
        payload = await resp.json();
      } catch (_e) {
        stateEl.hidden = false; stateEl.textContent = I18N.noData || "No data"; return;
      }

      const items = (payload && payload.items) || [];
      list.innerHTML = "";
      if (!items.length) { stateEl.hidden = false; stateEl.textContent = I18N.noData || "No entries"; return; }
      list.appendChild(renderItem(items[0]));
      stateEl.hidden = true;
    }

    // Lazy start when the section enters view; render only the latest entry.
    const start = () => { if (started) return; started = true; load(); };
    if ("IntersectionObserver" in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { start(); io.disconnect(); } });
      }, { rootMargin: "160px" });
      io.observe(root);
    } else {
      start();
    }
  })();
</script>
