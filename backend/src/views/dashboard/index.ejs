<%
  const canViewApprovals = typeof can === "function" ? can("SCREEN", "administration.approvals", "view") : false;
  const canViewUsers = typeof can === "function" ? can("SCREEN", "administration.users", "view") : false;
  const summary = dashboard?.summary || {};
  const recentApprovals = Array.isArray(dashboard?.recentApprovals) ? dashboard.recentApprovals : [];
  const recentVouchers = Array.isArray(dashboard?.recentVouchers) ? dashboard.recentVouchers : [];
  const recentActivity = Array.isArray(dashboard?.recentActivity) ? dashboard.recentActivity : [];
  const activeSessionWindowMinutes = Number(summary.activeSessionWindowMinutes || 15);

  const pendingApprovalsTooltip = t("pending_approvals_dashboard_tooltip");
  const vouchersTodayTooltip = t("vouchers_today_dashboard_tooltip");
  const masterDataChangesTooltip = t("master_data_changes_dashboard_tooltip");
  const totalLogsTodayTooltip = t("total_logs_today_dashboard_tooltip");
  const activeUsersTooltip = t("active_users_dashboard_tooltip").replace("{minutes}", String(activeSessionWindowMinutes));
%>

<div class="mx-auto w-full max-w-7xl space-y-6">
  <section class="rounded-3xl border border-slate-200 bg-white/95 p-8 shadow-xl">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div class="space-y-2">
        <h1 class="text-3xl font-display text-ink"><%= t("dashboard") %></h1>
        <p class="text-sm text-muted"><%= t("welcome") %></p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-5">
      <% if (canViewApprovals) { %>
        <a href="/administration/approvals" class="group rounded-2xl border border-amber-100 bg-amber-50 p-5 transition hover:border-amber-200 hover:bg-amber-100/70">
          <div class="flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] text-amber-700">
            <span><%= t("pending_approvals") %></span>
            <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-amber-300 text-[10px] font-bold normal-case tracking-normal text-amber-700" title="<%= pendingApprovalsTooltip %>">i</span>
          </div>
          <div class="mt-2 text-3xl font-semibold text-amber-900"><%= Number(summary.pendingApprovals || 0) %></div>
        </a>
      <% } else { %>
        <div class="rounded-2xl border border-amber-100 bg-amber-50 p-5">
          <div class="flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] text-amber-700">
            <span><%= t("pending_approvals") %></span>
            <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-amber-300 text-[10px] font-bold normal-case tracking-normal text-amber-700" title="<%= pendingApprovalsTooltip %>">i</span>
          </div>
          <div class="mt-2 text-3xl font-semibold text-amber-900"><%= Number(summary.pendingApprovals || 0) %></div>
        </div>
      <% } %>
      <div class="rounded-2xl border border-blue-100 bg-blue-50 p-5">
        <div class="flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] text-blue-700">
          <span><%= t("vouchers_today") %></span>
          <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-blue-200 text-[10px] font-bold normal-case tracking-normal text-blue-700" title="<%= vouchersTodayTooltip %>">i</span>
        </div>
        <div class="mt-2 text-3xl font-semibold text-blue-900"><%= Number(summary.vouchersToday || 0) %></div>
      </div>
      <div class="rounded-2xl border border-indigo-100 bg-indigo-50 p-5">
        <div class="flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] text-indigo-700">
          <span><%= t("md_changes_today") %></span>
          <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-indigo-200 text-[10px] font-bold normal-case tracking-normal text-indigo-700" title="<%= masterDataChangesTooltip %>">i</span>
        </div>
        <div class="mt-2 text-3xl font-semibold text-indigo-900"><%= Number(summary.masterDataChangesToday || 0) %></div>
      </div>
      <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
        <div class="flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] text-emerald-700">
          <span><%= t("total_logs_today") %></span>
          <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-emerald-200 text-[10px] font-bold normal-case tracking-normal text-emerald-700" title="<%= totalLogsTodayTooltip %>">i</span>
        </div>
        <div class="mt-2 text-3xl font-semibold text-emerald-900"><%= Number(summary.totalLogsToday || 0) %></div>
      </div>
      <% if (canViewUsers) { %>
        <div class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
          <div class="flex items-center gap-1 text-[11px] uppercase tracking-[0.3em] text-slate-600">
            <span><%= t("active_users") %></span>
            <span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-slate-300 text-[10px] font-bold normal-case tracking-normal text-slate-700" title="<%= activeUsersTooltip %>">i</span>
          </div>
          <div class="mt-2 text-3xl font-semibold text-slate-900"><%= Number(summary.activeUsers || 0) %>/<span class="text-xl"><%= Number(summary.totalUsers || 0) %></span></div>
          <div class="mt-1 text-[11px] text-slate-500"><%= t("active_users_window").replace("{minutes}", String(activeSessionWindowMinutes)) %></div>
        </div>
      <% } %>
    </div>
  </section>

  <section class="grid gap-6 xl:grid-cols-2">
    <article class="rounded-2xl border border-slate-200 bg-white/95 shadow-md">
      <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-700"><%= t("recent_vouchers") %></h3>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-widest text-slate-500">
            <tr>
              <th class="px-4 py-3 text-left"><%= t("voucher_no") %></th>
              <th class="px-4 py-3 text-left"><%= t("type") %></th>
              <th class="px-4 py-3 text-left"><%= t("branch") %></th>
              <th class="px-4 py-3 text-left"><%= t("date") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (!recentVouchers.length) { %>
              <tr><td class="px-4 py-4 text-slate-500" colspan="4"><%= t("no_entries") %></td></tr>
            <% } %>
            <% recentVouchers.forEach((row) => { %>
              <tr class="hover:bg-amber-50/40">
                <td class="px-4 py-3 font-medium text-slate-800"><%= row.voucher_no || '-' %></td>
                <td class="px-4 py-3 text-slate-600"><%= row.voucher_type_code || '-' %></td>
                <td class="px-4 py-3 text-slate-600"><%= row.branch_name || '-' %></td>
                <td class="px-4 py-3 text-slate-600"><%= formatDateDisplay(row.voucher_date, '-') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </article>

    <article class="rounded-2xl border border-slate-200 bg-white/95 shadow-md">
      <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-700"><%= t("recent_activity") %></h3>
      </div>
      <div class="px-5 py-3">
        <% if (!recentActivity.length) { %>
          <p class="py-2 text-sm text-slate-500"><%= t("no_entries") %></p>
        <% } %>
        <ul class="space-y-3">
          <% recentActivity.forEach((row) => { %>
            <li class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2">
              <div class="text-sm font-semibold text-slate-800"><%= row.action || '-' %> <span class="text-slate-500">• <%= row.entity_type || '-' %></span></div>
              <div class="mt-1 text-xs text-slate-500"><%= row.username || t("system") %> • <%= formatDateDisplay(row.created_at, '-') %></div>
            </li>
          <% }) %>
        </ul>
      </div>
    </article>
  </section>

  <% if (canViewApprovals) { %>
    <section class="rounded-2xl border border-slate-200 bg-white/95 shadow-md">
      <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4">
        <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-700"><%= t("pending_approvals") %></h3>
        <a href="/administration/approvals" class="text-xs font-semibold uppercase tracking-[0.18em] text-accent hover:text-accent/80"><%= t("view_all") %></a>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
          <thead class="bg-slate-50 text-xs font-semibold uppercase tracking-widest text-slate-500">
            <tr>
              <th class="px-4 py-3 text-left">ID</th>
              <th class="px-4 py-3 text-left"><%= t("entity") %></th>
              <th class="px-4 py-3 text-left"><%= t("requested_by") %></th>
              <th class="px-4 py-3 text-left"><%= t("date") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% if (!recentApprovals.length) { %>
              <tr><td class="px-4 py-4 text-slate-500" colspan="4"><%= t("no_entries") %></td></tr>
            <% } %>
            <% recentApprovals.forEach((row) => { %>
              <tr class="hover:bg-amber-50/40">
                <td class="px-4 py-3 font-medium text-slate-800">#<%= row.id %></td>
                <td class="px-4 py-3 text-slate-600"><%= row.entity_type || '-' %></td>
                <td class="px-4 py-3 text-slate-600"><%= row.requested_by_name || '-' %></td>
                <td class="px-4 py-3 text-slate-600"><%= formatDateDisplay(row.requested_at, '-') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  <% } %>
</div>
