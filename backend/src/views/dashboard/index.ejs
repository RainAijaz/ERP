<div class="mx-auto w-full max-w-6xl space-y-6">
  <% const canViewApprovals = typeof can === "function" ? can("SCREEN", "administration.approvals", "view") : false; %>
  <section class="rounded-3xl border border-slate-200 bg-white/95 p-8 shadow-xl">
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="space-y-2">
        <h1 class="text-3xl font-display text-ink"><%= t("dashboard") %></h1>
        <p class="text-sm text-muted"><%= t("welcome") %></p>
      </div>
    </div>
    <section class="grid gap-4 md:grid-cols-3">
      <% if (canViewApprovals) { %>
        <a href="/administration/approvals" class="group rounded-2xl border border-amber-100 bg-amber-50 p-5 transition hover:border-amber-200 hover:bg-amber-100/70">
          <div class="flex items-start justify-between gap-3">
            <div class="text-[11px] uppercase tracking-[0.3em] text-amber-700"><%= t("pending_approvals") %></div>
            <svg class="h-6 w-6 text-amber-700 transition group-hover:scale-105" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <div class="mt-2 text-3xl font-semibold text-amber-900">0</div>
        </a>
      <% } else { %>
        <div class="rounded-2xl border border-amber-100 bg-amber-50 p-5">
          <div class="text-[11px] uppercase tracking-[0.3em] text-amber-700"><%= t("pending_approvals") %></div>
          <div class="mt-2 text-3xl font-semibold text-amber-900">0</div>
        </div>
      <% } %>
      <div class="rounded-2xl border border-blue-100 bg-blue-50 p-5">
        <div class="text-[11px] uppercase tracking-[0.3em] text-blue-700"><%= t("vouchers") %></div>
        <div class="mt-2 text-3xl font-semibold text-blue-900">0</div>
      </div>
      <div class="rounded-2xl border border-emerald-100 bg-emerald-50 p-5">
        <div class="text-[11px] uppercase tracking-[0.3em] text-emerald-700"><%= t("inventory") %></div>
        <div class="mt-2 text-3xl font-semibold text-emerald-900">0</div>
      </div>
    </section>
  </section>
</div>
