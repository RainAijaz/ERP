<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= t("gate_pass") %> - <%= voucher.voucher_no %></title>
  <link rel="icon" type="image/png" href="/favicon.png?v=20260411" />
  <%- include("../../base/partials/gate-pass-print-style") %>
</head>
<body>
  <%
    const returnableRows = voucher.lines || [];
    const gatePassView = {
      titleKey: "gate_pass",
      subtitleKey: "returnable_dispatch_voucher",
      topInfo: [
        { labelKey: "vr_no", value: voucher.voucher_no || "-" },
        { labelKey: "date", value: formatDateDisplay(voucher.voucher_date) || "-" },
        { labelKey: "status", value: voucher.status || "-" },
        { labelKey: "returnable_status", value: voucher.outward_status || "-" },
      ],
      metaInfo: [
        { labelKey: "vendor_party", value: voucher.vendor_name || "-" },
        { labelKey: "reason", value: voucher.reason_code || "-" },
        { labelKey: "expected_return_date", value: formatDateDisplay(voucher.expected_return_date) || "-" },
        { labelKey: "remarks", value: voucher.remarks || "-", full: true },
      ],
      columns: [
        { key: "sr_no", labelKey: "sr_no" },
        { key: "asset_name", labelKey: "asset_name" },
        { key: "item_type_code", labelKey: "item_type" },
        { key: "item_description", labelKey: "description" },
        { key: "qty", labelKey: "quantity", align: "right" },
        { key: "condition_out_code", labelKey: "condition_at_dispatch" },
        { key: "serial_no", labelKey: "serial_no" },
      ],
      rows: returnableRows,
      cellValue: (line, column, rowIndex) => {
        if (column.key === "sr_no") return rowIndex + 1;
        if (column.key === "qty") return formatNumberDisplay(line?.qty || 0, { decimals: 3, fallback: "0" });
        return line?.[column.key] || "-";
      },
    };
  %>

  <%- include("../../base/partials/gate-pass-document", { gatePassView }) %>
</body>
</html>
