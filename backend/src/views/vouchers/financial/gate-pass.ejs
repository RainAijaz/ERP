<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= t("gate_pass") %> - <%= voucher?.voucher_no || "" %></title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <%- include("../../base/partials/gate-pass-print-style") %>
  </head>
  <body>
    <%
      const gatePassView = {
        titleKey: "gate_pass",
        subtitleText: t(subtitleKey || titleKey || "financial"),
        topInfo: [
          { labelKey: "voucher_no", value: voucher?.voucher_no || "-" },
          { labelKey: "date", value: formatDateDisplay(voucher?.voucher_date, "") || "-" },
          { labelKey: "status", value: voucher?.status || "-" },
        ],
        metaInfo: [
          { labelKey: "remarks", value: voucher?.remarks_display || voucher?.remarks_raw || "-", full: true },
        ],
        columns: [
          { key: "sr_no", labelKey: "sr_no" },
          { key: "code", labelKey: "code" },
          { key: "account_name", labelKey: "account_name" },
          { key: "description", labelKey: "description" },
          { key: "debit", labelKey: "debit", align: "right" },
          { key: "credit", labelKey: "credit", align: "right" },
        ],
        rows: voucher?.lines || [],
        cellValue: (line, column, rowIndex) => {
          if (column.key === "sr_no") return rowIndex + 1;
          if (column.key === "debit") return formatNumberDisplay(line?.debit || 0, { decimals: 2, fallback: "0" });
          if (column.key === "credit") return formatNumberDisplay(line?.credit || 0, { decimals: 2, fallback: "0" });
          return line?.[column.key] || "-";
        },
      };
    %>

    <%- include("../../base/partials/gate-pass-document", { gatePassView }) %>
  </body>
</html>
