            <tr class="bg-slate-50" data-total-qty-by-unit-row>
              <td colspan="${totalColspan}" class="border-t border-slate-200 px-2 py-2">
                <div class="flex flex-wrap items-center gap-2" data-total-qty-by-unit></div>
              </td>
            </tr>
          `;
        } else {
          linesFooter.innerHTML = `
            <tr class="bg-slate-50">
              <td colspan="${descriptorColspan}" class="border-t border-slate-200 px-2 py-2 text-right text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-700">${escapeHtml(totalLabel)}</td>
              <td class="border-t border-slate-200 px-2 py-1.5">
                <input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-qty aria-label="${escapeHtml(quantityLabel)}">
