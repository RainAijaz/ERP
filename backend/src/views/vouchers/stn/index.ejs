        { key: 'rejected', label: <%- JSON.stringify(toFriendlyLabel('rejected_qty', 'Rejected Qty')) %>, align: 'text-right' },
        { key: 'variance', label: <%- JSON.stringify(toFriendlyLabel('variance_qty', 'Variance Qty')) %>, align: 'text-right' },
