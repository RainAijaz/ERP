          </tr>
          <tr class="bg-slate-50 hidden" data-total-qty-by-unit-row>
            <td colspan="${cols.length}" class="border-t border-slate-200 px-2 py-2">
              <div class="flex flex-wrap items-center gap-2" data-total-qty-by-unit></div>
            </td>
          </tr>
        `;
      }

      totalQtyInput = linesFooter.querySelector('[data-total-qty]');
      totalExpectedQtyInput = linesFooter.querySelector('[data-total-expected-qty]');
      totalReceivedQtyInput = linesFooter.querySelector('[data-total-received-qty]');
      totalRejectedQtyInput = linesFooter.querySelector('[data-total-rejected-qty]');
      totalVarianceQtyInput = linesFooter.querySelector('[data-total-variance-qty]');
      totalAmountInput = linesFooter.querySelector('[data-total-amount]');
      totalQtyByUnitWrap = linesFooter.querySelector('[data-total-qty-by-unit]');
      totalQtyByUnitRow = linesFooter.querySelector('[data-total-qty-by-unit-row]');
    };

    const renderHead = () => {
      const cols = mode === 'out' ? outHeadColumns() : inHeadColumns();
      linesHeadRow.innerHTML = cols
        .map((col) => `<th class="border-b border-slate-200 px-2 py-2 ${col.align || 'text-left'}">${escapeHtml(col.label)}</th>`)
        .join('');
      renderFooter();
    };

    const renderOutRows = () => {
      ensureOutRows();
      const showCostAmount = shouldShowCostAmountColumns();
      linesBody.innerHTML = outRows
        .map((row, rowIndex) => {
          const stockType = activeStockType;
          const unitOptions = getOutUnitOptions(row, stockType);
          const itemCell = stockType === 'RM'
            ? `<select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-out-change="item_id" data-row-index="${rowIndex}" data-row-field="item" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? '' : 'disabled'}><option value=""></option>${rmItems.map((item) => `<option value="${Number(item.id)}" ${Number(row.item_id || 0) === Number(item.id) ? 'selected' : ''}>${escapeHtml(item.name || item.code || item.id)}</option>`).join('')}</select>`
            : `<select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-out-change="sku_id" data-row-index="${rowIndex}" data-row-field="item" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? '' : 'disabled'}><option value=""></option>${skuList.filter((sku) => String(sku.stock_type || '').toUpperCase() === stockType).map((sku) => `<option value="${Number(sku.id)}" ${Number(row.sku_id || 0) === Number(sku.id) ? 'selected' : ''}>${escapeHtml(sku.sku_name || sku.sku_code || sku.id)}</option>`).join('')}</select>`;

          const colorCell = stockType === 'RM'
            ? (() => {
                const state = getRmColorState(row.item_id);
                const disabled = !canSave || state.disabled;
                return `<select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-out-change="color_id" data-row-index="${rowIndex}" data-row-field="color" data-searchable-select="true" data-searchable-variant="unified" ${disabled ? 'disabled' : ''}><option value="">${state.allowNone ? 'None' : ''}</option>${state.entries.map((entry) => `<option value="${Number(entry.id)}" ${Number(row.color_id || 0) === Number(entry.id) ? 'selected' : ''}>${escapeHtml(entry.name || entry.id)}</option>`).join('')}</select>`;
              })()
            : '';

          const sizeCell = stockType === 'RM'
            ? (() => {
                const state = getRmSizeState(row.item_id);
                const disabled = !canSave || state.disabled;
                return `<select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-out-change="size_id" data-row-index="${rowIndex}" data-row-field="size" data-searchable-select="true" data-searchable-variant="unified" ${disabled ? 'disabled' : ''}><option value="">${state.allowNone ? 'None' : ''}</option>${state.entries.map((entry) => `<option value="${Number(entry.id)}" ${Number(row.size_id || 0) === Number(entry.id) ? 'selected' : ''}>${escapeHtml(entry.name || entry.id)}</option>`).join('')}</select>`;
              })()
            : '';

          const uomCell = `<select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-out-change="uom_id" data-row-index="${rowIndex}" data-row-field="uom" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? '' : 'disabled'}><option value=""></option>${unitOptions.map((entry) => `<option value="${Number(entry.id)}" ${Number(row.uom_id || 0) === Number(entry.id) ? 'selected' : ''}>${escapeHtml(entry.name || entry.code || entry.id)}</option>`).join('')}</select>`;

          const cols = [
            `<td class="border-t border-slate-200 px-2 py-1">${itemCell}</td>`,
            ...(stockType === 'RM' ? [`<td class="border-t border-slate-200 px-2 py-1">${colorCell}</td>`, `<td class="border-t border-slate-200 px-2 py-1">${sizeCell}</td>`] : []),
            `<td class="border-t border-slate-200 px-2 py-1">${uomCell}</td>`,
            `<td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs" value="${qty3(row.available_qty).toFixed(3)}" readonly></td>`,
            `<td class="border-t border-slate-200 px-2 py-1"><input type="number" step="0.001" min="0" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${qty3(row.transfer_qty).toFixed(3)}" data-out-input="transfer_qty" data-row-index="${rowIndex}" data-row-field="qty" ${canSave ? '' : 'readonly'}></td>`,
            ...(showCostAmount
              ? [
                  `<td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs" value="${cost1(row.unit_cost).toFixed(1)}" readonly></td>`,
                  `<td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs" value="${amount2(row.amount).toFixed(2)}" readonly></td>`,
                ]
              : []),
            `<td class="border-t border-slate-200 px-2 py-1 text-center"><button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-rose-200 bg-white p-2 text-rose-600 disabled:opacity-40" data-remove-row="${rowIndex}" aria-label="${escapeHtml(deleteButtonTitle)}" title="${escapeHtml(deleteButtonTitle)}" ${!canSave || outRows.length <= 1 ? 'disabled' : ''}><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M9 7V5h6v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M6 7l1 13h10l1-13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg></button></td>`,
            `<td class="border-t border-slate-200 px-2 py-2 text-center text-xs font-semibold text-slate-500">${rowIndex + 1}</td>`,
          ];

          return `<tr data-row-index="${rowIndex}">${cols.join('')}</tr>`;
        })
        .join('');
      updateTotals();
    };

    const renderInRows = () => {
      const showCostAmount = shouldShowCostAmountColumns();
      linesBody.innerHTML = inRows
        .map((row, rowIndex) => {
          const stockType = activeStockType;
          const variance = qty3(Number(row.expected_qty || 0) - (Number(row.received_qty || 0) + Number(row.rejected_qty || 0)));
          row.variance_qty = variance;
          row.unit_cost = cost1(row.unit_cost);
          row.amount = amount2(Number(row.received_qty || 0) * Number(row.unit_cost || 0));
          const itemName = resolveLineDisplayName(row);
          const colorName = stockType === 'RM'
            ? (colorMap.get(Number(row.color_id || 0))?.name || '')
            : '';
          const sizeName = stockType === 'RM'
            ? (sizeMap.get(Number(row.size_id || 0))?.name || '')
            : '';
          return `<tr data-row-index="${rowIndex}">
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-xs" value="${escapeHtml(itemName)}" readonly></td>
            ${stockType === 'RM'
              ? `<td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-xs" value="${escapeHtml(colorName)}" readonly></td>
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-xs" value="${escapeHtml(sizeName)}" readonly></td>`
              : ''}
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-xs" value="${escapeHtml(row.uom_name || '')}" readonly></td>
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs" value="${qty3(row.expected_qty).toFixed(3)}" readonly></td>
            <td class="border-t border-slate-200 px-2 py-1"><input type="number" step="0.001" min="0" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${qty3(row.received_qty).toFixed(3)}" data-in-input="received_qty" data-row-index="${rowIndex}" data-row-field="received" ${canSave ? '' : 'readonly'}></td>
            <td class="border-t border-slate-200 px-2 py-1"><input type="number" step="0.001" min="0" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${qty3(row.rejected_qty).toFixed(3)}" data-in-input="rejected_qty" data-row-index="${rowIndex}" data-row-field="rejected" ${canSave ? '' : 'readonly'}></td>
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs ${variance !== 0 ? 'text-amber-700' : ''}" value="${variance.toFixed(3)}" readonly></td>
            ${showCostAmount
              ? `<td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs" value="${cost1(row.unit_cost).toFixed(1)}" readonly></td>
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" class="w-full rounded-lg border border-slate-300 bg-slate-100 px-2 text-right text-xs" value="${amount2(row.amount).toFixed(2)}" readonly></td>`
              : ''}
            <td class="border-t border-slate-200 px-2 py-1"><input type="text" maxlength="250" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" value="${escapeHtml(row.variance_reason || '')}" data-in-input="variance_reason" data-row-index="${rowIndex}" data-row-field="reason" ${canSave ? '' : 'readonly'}></td>
            <td class="border-t border-slate-200 px-2 py-2 text-center text-xs font-semibold text-slate-500">${rowIndex + 1}</td>
          </tr>`;
        })
        .join('');
      updateTotals();
    };

    const renderRows = () => {
      renderHead();
      if (mode === 'out') {
        renderOutRows();
      } else {
        renderInRows();
      }
      if (typeof window.initSearchableSelects === 'function') {
        window.initSearchableSelects(form);
      }
      bindNavigator();
    };

    const updateOutRow = (rowIndex, key, value) => {
      const row = outRows[rowIndex];
      if (!row) return;
      const focusState = captureActiveRowField();
      const next = { ...row };
      if ([ 'item_id', 'sku_id', 'color_id', 'size_id', 'uom_id' ].includes(key)) {
        next[key] = toInt(value);
      } else if (key === 'transfer_qty') {
        next.transfer_qty = qty3(value);
      }
      if (key === 'item_id') {
        next.color_id = null;
        next.size_id = null;
        next.uom_id = null;
      }
      if (key === 'sku_id') {
        next.uom_id = null;
      }
      if (key === 'uom_id') {
        next.uom_id = toInt(value);
      }
      outRows[rowIndex] = applyOutDerived(next);
      renderRows();
      restoreActiveRowField(focusState);
    };

    const setInRowsFromTransfer = (transfer) => {
      if (!transfer || !Array.isArray(transfer.lines)) {
        inRows = [];
        return;
      }
      inRows = transfer.lines.map((line) => {
        const expectedQty = qty3(line.qty || line.expected_qty || 0);
        return toInLine({
          ...line,
          stn_line_id: line.id,
          expected_qty: expectedQty,
          received_qty: expectedQty,
          rejected_qty: 0,
          variance_qty: 0,
        });
      });
    };

    const clearInTransferSelection = () => {
      if (stnOutIdInput) stnOutIdInput.value = '';
      if (transferRefTextInput) transferRefTextInput.value = '';
      if (billBookNoInput) billBookNoInput.value = '';
      if (stockTypeSelect) stockTypeSelect.value = '';
      if (destinationBranchNameInput) destinationBranchNameInput.value = '';
      inRows = [];
    };

    const applyInTransferSelection = (transfer, { syncSourceBranch = true } = {}) => {
      if (!transfer) {
        clearInTransferSelection();
        return;
      }
      const stnOutId = Number(transfer.stn_out_voucher_id || 0) || null;
      if (!stnOutId) {
        clearInTransferSelection();
        return;
      }
      if (stnOutIdInput) stnOutIdInput.value = String(stnOutId);
      if (transferRefTextInput) {
        transferRefTextInput.value = String(transfer.transfer_ref_no || '').trim();
      }
      if (sourceBranchSelect && syncSourceBranch) {
        const sourceId = Number(transfer.source_branch_id || 0) || null;
        sourceBranchSelect.value = sourceId ? String(sourceId) : '';
      }
      if (sourceBranchNameInput) {
        sourceBranchNameInput.value = transfer.source_branch_name || String(transfer.source_branch_id || '');
      }
      if (destinationBranchNameInput) {
        destinationBranchNameInput.value = transfer.destination_branch_name || String(transfer.destination_branch_id || '');
      }
      if (billBookNoInput) {
        billBookNoInput.value = String(transfer.bill_book_no || '');
      }
      if (stockTypeSelect) {
        stockTypeSelect.value = normalizeStockType(transfer.stock_type);
        activeStockType = normalizeStockType(transfer.stock_type);
      }
      setInRowsFromTransfer(transfer);
    };

    const pendingTransfersForSelectedSource = () => {
      const sourceBranchId = Number(sourceBranchSelect?.value || 0) || null;
      if (!sourceBranchId) return [];
      const branchRows = pendingTransfers.filter(
        (entry) => Number(entry?.source_branch_id || 0) === Number(sourceBranchId),
      );
      if (stiTransferPickerShowAll) return branchRows;
      const selectedDate = normalizeDateInputValue(
        stiTransferPickerDateInput?.value || voucherDateInput?.value || '',
      );
      if (!selectedDate) return branchRows;
      return branchRows.filter(
        (entry) => normalizeDateInputValue(entry?.dispatch_date || entry?.voucher_date || '') === selectedDate,
      );
    };

    const refreshStiTransferPickerFilterUi = () => {
      if (!(stiTransferPickerDateOnlyToggle instanceof HTMLButtonElement)) return;
      const dateOnlyEnabled = !stiTransferPickerShowAll;
      stiTransferPickerDateOnlyToggle.setAttribute('aria-pressed', dateOnlyEnabled ? 'true' : 'false');
      stiTransferPickerDateOnlyToggle.classList.toggle('bg-accent', dateOnlyEnabled);
      stiTransferPickerDateOnlyToggle.classList.toggle('text-white', dateOnlyEnabled);
      stiTransferPickerDateOnlyToggle.classList.toggle('border-accent', dateOnlyEnabled);
      stiTransferPickerDateOnlyToggle.classList.toggle('bg-white', !dateOnlyEnabled);
      stiTransferPickerDateOnlyToggle.classList.toggle('text-slate-700', !dateOnlyEnabled);
      stiTransferPickerDateOnlyToggle.classList.toggle('border-slate-300', !dateOnlyEnabled);
    };

    const closeStiTransferPicker = () => {
      if (!stiTransferPickerModal) return;
      stiTransferPickerModal.classList.add('hidden');
      stiTransferPickerModal.classList.remove('flex');
      stiTransferPickerModal.setAttribute('aria-hidden', 'true');
    };

    const renderStiTransferPickerRows = () => {
      if (!stiTransferPickerBody) return;
      refreshStiTransferPickerFilterUi();
      const rows = pendingTransfersForSelectedSource();
      if (!rows.length) {
        stiTransferPickerBody.innerHTML = `
          <tr>
            <td colspan="5" class="px-2 py-6 text-center text-sm text-slate-500">${escapeHtml(noPendingTransfersMessage)}</td>
          </tr>
        `;
        stiTransferPickerSelectedId = null;
        return;
      }
      if (!rows.some((entry) => Number(entry.stn_out_voucher_id || 0) === Number(stiTransferPickerSelectedId || 0))) {
        stiTransferPickerSelectedId = Number(rows[0].stn_out_voucher_id || 0) || null;
      }
      stiTransferPickerBody.innerHTML = rows.map((entry) => {
        const stnOutId = Number(entry.stn_out_voucher_id || 0) || 0;
        const checked = Number(stiTransferPickerSelectedId || 0) === stnOutId ? 'checked' : '';
        const rowClass = checked ? 'bg-accent/5 ring-1 ring-inset ring-accent/25' : 'hover:bg-slate-50';
        return `
          <tr data-sti-transfer-row="${stnOutId}" class="cursor-pointer ${rowClass}">
            <td class="border-t border-slate-200 px-2 py-2 text-left text-slate-700">${escapeHtml(String(entry.transfer_ref_no || ''))}</td>
            <td class="border-t border-slate-200 px-2 py-2 text-left text-slate-700">${escapeHtml(String(entry.bill_book_no || '-'))}</td>
            <td class="border-t border-slate-200 px-2 py-2 text-left text-slate-700">${escapeHtml(String(entry.stock_type || '-'))}</td>
            <td class="border-t border-slate-200 px-2 py-2 text-left text-slate-700">${escapeHtml(formatDateDisplay(entry.dispatch_date))}</td>
            <td class="border-t border-slate-200 px-2 py-2 text-center">
              <input type="radio" name="sti_transfer_picker_row" class="h-4 w-4 rounded border-slate-300 text-accent focus:ring-accent" value="${stnOutId}" ${checked}>
            </td>
          </tr>
        `;
      }).join('');
    };

    const openStiTransferPicker = () => {
      if (!stiTransferPickerModal) return;
      const sourceBranchId = Number(sourceBranchSelect?.value || 0) || null;
      if (!sourceBranchId) {
        window.alert(selectBranchMessage);
        focusControl(sourceBranchSelect, { openSearchable: true });
        return;
      }
      if (stiTransferPickerDateInput) {
        stiTransferPickerDateInput.value = normalizeDateInputValue(voucherDateInput?.value || '');
      }
      stiTransferPickerShowAll = true;
      const selectedStnOutId = Number(stnOutIdInput?.value || 0) || null;
      stiTransferPickerSelectedId = selectedStnOutId;
      renderStiTransferPickerRows();
      stiTransferPickerModal.classList.remove('hidden');
      stiTransferPickerModal.classList.add('flex');
      stiTransferPickerModal.setAttribute('aria-hidden', 'false');
    };

    linesBody.addEventListener('change', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.matches('[data-out-change]')) {
        const key = String(target.getAttribute('data-out-change') || '');
        const rowIndex = Number(target.getAttribute('data-row-index') || -1);
        if (rowIndex < 0) return;
        updateOutRow(rowIndex, key, target.value);
        return;
      }
      if (target.matches('[data-in-input]')) {
        const rowIndex = Number(target.getAttribute('data-row-index') || -1);
        const key = String(target.getAttribute('data-in-input') || '');
        if (rowIndex < 0 || !inRows[rowIndex]) return;
        if (key === 'variance_reason') {
          inRows[rowIndex].variance_reason = String(target.value || '').trim();
          return;
        }
        const focusState = captureActiveRowField();
        renderRows();
        restoreActiveRowField(focusState);
      }
    });

    linesBody.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.matches('[data-out-input]')) {
        const key = String(target.getAttribute('data-out-input') || '');
        const rowIndex = Number(target.getAttribute('data-row-index') || -1);
        if (rowIndex < 0) return;
        updateOutRow(rowIndex, key, target.value);
        return;
      }
      if (target.matches('[data-in-input]')) {
        const rowIndex = Number(target.getAttribute('data-row-index') || -1);
        const key = String(target.getAttribute('data-in-input') || '');
        if (rowIndex < 0 || !inRows[rowIndex]) return;
        if (key === 'received_qty' || key === 'rejected_qty') {
          inRows[rowIndex][key] = qty3(target.value);
          const focusState = captureActiveRowField();
          renderRows();
          restoreActiveRowField(focusState);
          return;
        }
        if (key === 'variance_reason') {
          inRows[rowIndex].variance_reason = String(target.value || '').trim();
          return;
        }
      }
    });

    linesBody.addEventListener('click', (event) => {
      const btn = event.target instanceof HTMLElement
        ? event.target.closest('[data-remove-row]')
        : null;
      if (!btn || mode !== 'out' || !canSave) return;
      const rowIndex = Number(btn.getAttribute('data-remove-row') || -1);
      if (rowIndex < 0) return;
      outRows.splice(rowIndex, 1);
      ensureOutRows();
      renderRows();
    });

    form.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' || event.defaultPrevented) return;
      if (event.altKey || event.ctrlKey || event.metaKey) return;
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (target.matches('textarea')) return;
      if (linesBody.contains(target)) return;

      const currentField = resolveHeaderFieldHost(target);
      if (!currentField) return;
      const headerFields = getHeaderEnterFields();
      if (!headerFields.length) return;

      const currentIndex = headerFields.indexOf(currentField);
      if (currentIndex < 0) return;
      event.preventDefault();

      for (let index = currentIndex + 1; index < headerFields.length; index += 1) {
        if (focusControl(headerFields[index], { openSearchable: true })) {
          return;
        }
      }
      focusFirstRowField();
    });

    if (stockTypeSelect) {
      stockTypeSelect.addEventListener('change', () => {
        activeStockType = normalizeStockType(stockTypeSelect.value);
        outRows = outRows.map((row) => applyOutDerived({ ...defaultOutRow(), transfer_qty: row.transfer_qty }));
        renderRows();
      });
    }

    if (sourceBranchSelect && mode === 'in') {
      sourceBranchSelect.addEventListener('change', () => {
        if (!canSave) return;
        clearInTransferSelection();
        renderRows();
      });
    }

    if (stiTransferPickerDateInput) {
      stiTransferPickerDateInput.addEventListener('change', () => {
        renderStiTransferPickerRows();
      });
    }

    if (stiTransferPickerDateOnlyToggle) {
      stiTransferPickerDateOnlyToggle.addEventListener('click', () => {
        stiTransferPickerShowAll = !stiTransferPickerShowAll;
        renderStiTransferPickerRows();
      });
    }

    if (mode === 'in' && voucherDateInput && receivedDateInput) {
      const syncReceivedDateWithVoucherDate = () => {
        receivedDateInput.value = String(voucherDateInput.value || '');
      };
      syncReceivedDateWithVoucherDate();
      voucherDateInput.addEventListener('change', syncReceivedDateWithVoucherDate);
      voucherDateInput.addEventListener('input', syncReceivedDateWithVoucherDate);
    }

    if (openStiTransferPickerButton) {
      openStiTransferPickerButton.addEventListener('click', openStiTransferPicker);
    }

    if (stiTransferPickerBody) {
      stiTransferPickerBody.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const row = target.closest('[data-sti-transfer-row]');
        if (!row) return;
        const stnOutId = Number(row.getAttribute('data-sti-transfer-row') || 0) || null;
        if (!stnOutId) return;
        stiTransferPickerSelectedId = stnOutId;
        renderStiTransferPickerRows();
      });
      stiTransferPickerBody.addEventListener('change', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) return;
        if (target.name !== 'sti_transfer_picker_row') return;
        stiTransferPickerSelectedId = Number(target.value || 0) || null;
        renderStiTransferPickerRows();
      });
    }

    if (stiTransferPickerApplyButton) {
      stiTransferPickerApplyButton.addEventListener('click', () => {
        const selectedId = Number(stiTransferPickerSelectedId || 0) || null;
        const transfer = readPendingTransfer(selectedId);
        if (!transfer) {
          window.alert(noPendingTransfersMessage);
          return;
        }
        applyInTransferSelection(transfer);
        renderRows();
        closeStiTransferPicker();
      });
    }

    if (stiTransferPickerCloseButtons.length) {
      stiTransferPickerCloseButtons.forEach((button) => {
        button.addEventListener('click', closeStiTransferPicker);
      });
    }

    if (stiTransferPickerModal) {
      stiTransferPickerModal.addEventListener('click', (event) => {
        if (event.target === stiTransferPickerModal) {
          closeStiTransferPicker();
        }
      });
      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape') return;
        if (stiTransferPickerModal.classList.contains('hidden')) return;
        closeStiTransferPicker();
      });
    }

    form.addEventListener('click', (event) => {
      const addButton = event.target instanceof HTMLElement
        ? event.target.closest('[data-add-row]')
        : null;
      if (!addButton || mode !== 'out' || !canSave) return;
      outRows.push(applyOutDerived(defaultOutRow()));
      renderRows();
    });

    if (loadVoucherButton) {
      loadVoucherButton.addEventListener('click', () => {
        const voucherNo = Number(voucherNoInput?.value || 0);
        if (!Number.isInteger(voucherNo) || voucherNo <= 0) return;
        window.location.href = `${basePath}?voucher_no=${voucherNo}&view=1`;
      });
    }

    if (deleteButton && deleteForm) {
      deleteButton.addEventListener('click', () => {
        if (!canSave && !initialVoucher) return;
        const confirmMessage = <%- JSON.stringify(toFriendlyLabel('confirm_delete', 'Delete this voucher?')) %>;
        if (!window.confirm(confirmMessage)) return;
        deleteForm.submit();
      });
    }

    const validateBeforeSubmit = () => {
      if (mode === 'out') {
        if (!destinationBranchSelect?.value) {
          window.alert(<%- JSON.stringify(toFriendlyLabel('destination_branch_required', 'Destination branch is required.')) %>);
          return false;
        }
        if (!billBookNoInput?.value.trim()) {
          window.alert(<%- JSON.stringify(toFriendlyLabel('bill_book_no_required', 'Bill Book No is required.')) %>);
          return false;
        }
        if (!outRows.length) {
          window.alert(<%- JSON.stringify(toFriendlyLabel('error_required_fields', 'Required fields are missing.')) %>);
          return false;
        }
        for (let index = 0; index < outRows.length; index += 1) {
          const row = outRows[index];
          if (activeStockType === 'RM') {
            if (!row.item_id || !(Number(row.transfer_qty || 0) > 0)) {
              window.alert(`${<%- JSON.stringify(toFriendlyLabel('error_required_fields', 'Required fields are missing.')) %>} #${index + 1}`);
              return false;
            }
          } else if (!row.sku_id || !(Number(row.transfer_qty || 0) > 0)) {
            window.alert(`${<%- JSON.stringify(toFriendlyLabel('error_required_fields', 'Required fields are missing.')) %>} #${index + 1}`);
            return false;
          }
        }
      } else {
        if (!sourceBranchSelect?.value) {
          window.alert(selectBranchMessage);
          return false;
        }
        if (!stnOutIdInput?.value) {
          window.alert(<%- JSON.stringify(toFriendlyLabel('transfer_reference_required', 'Transfer reference is required.')) %>);
          return false;
        }
        if (!inRows.length) {
          window.alert(<%- JSON.stringify(toFriendlyLabel('error_required_fields', 'Required fields are missing.')) %>);
          return false;
        }
        for (let index = 0; index < inRows.length; index += 1) {
          const row = inRows[index];
          const processed = Number(row.received_qty || 0) + Number(row.rejected_qty || 0);
          if (!(processed > 0)) {
            window.alert(`${<%- JSON.stringify(toFriendlyLabel('received_qty_required', 'Received quantity is required.')) %>} #${index + 1}`);
            return false;
          }
          const variance = qty3(Number(row.expected_qty || 0) - processed);
          if (Math.abs(variance) > 0.0005 && !String(row.variance_reason || '').trim()) {
            window.alert(`${<%- JSON.stringify(toFriendlyLabel('variance_reason_required', 'Variance reason is required.')) %>} #${index + 1}`);
            return false;
          }
        }
      }
      return true;
    };

    form.addEventListener('submit', (event) => {
      if (!validateBeforeSubmit()) {
        event.preventDefault();
        return;
      }

      if (mode === 'out') {
        const payloadRows = outRows
          .filter((row) => Number(row.transfer_qty || 0) > 0)
          .map((row) => ({
            sku_id: toInt(row.sku_id),
            item_id: toInt(row.item_id),
            color_id: toInt(row.color_id),
            size_id: toInt(row.size_id),
            uom_id: toInt(row.uom_id),
            transfer_qty: qty3(row.transfer_qty),
          }));
        linesJsonInput.value = JSON.stringify(payloadRows);
      } else {
        const payloadRows = inRows.map((row) => ({
          stn_line_id: toInt(row.stn_line_id),
          received_qty: qty3(row.received_qty),
          rejected_qty: qty3(row.rejected_qty),
          variance_reason: String(row.variance_reason || '').trim() || null,
        }));
        linesJsonInput.value = JSON.stringify(payloadRows);
      }
    });

    if (mode === 'out') {
      if (initialVoucher?.lines?.length) {
        outRows = initialVoucher.lines.map((line) => applyOutDerived(toOutLine(line)));
      } else {
        outRows = [applyOutDerived(defaultOutRow())];
      }
      if (transferRefTextInput && !transferRefTextInput.value.trim()) {
        const sourceBranchId = Number(options?.sourceBranch?.id || 0) || Number(<%- JSON.stringify(branchId || 0) %>) || 0;
        const voucherNo = Number(voucherNoInput?.value || 0) || '';
        transferRefTextInput.value = sourceBranchId > 0
          ? `TRF-${sourceBranchId}-${voucherNo}`
          : `TRF-${voucherNo}`;
      }
    } else {
      if (sourceBranchSelect && Number(initialVoucher?.source_branch_id || 0) > 0) {
        sourceBranchSelect.value = String(Number(initialVoucher.source_branch_id));
      }
      if (initialVoucher?.lines?.length) {
        inRows = initialVoucher.lines.map((line) => toInLine(line));
      } else {
        const stnOutId = Number(stnOutIdInput?.value || 0) || null;
        if (stnOutId) {
          const transfer = readPendingTransfer(stnOutId);
          if (transfer) {
            applyInTransferSelection(transfer, { syncSourceBranch: true });
          } else {
            clearInTransferSelection();
          }
        }
      }
    }

    let unbindNavigator = null;
    const bindNavigator = () => {
      if (typeof unbindNavigator === 'function') {
        unbindNavigator();
        unbindNavigator = null;
      }
      if (typeof window.createVoucherRowEnterNavigator !== 'function') return;
      unbindNavigator = window.createVoucherRowEnterNavigator({
        form,
        linesBody,
        rowSelector: 'tr[data-row-index]',
        fieldAttr: 'data-row-field',
        fieldOrder: fieldOrderForMode(),
        appendRow: mode === 'out' && canSave
          ? () => {
              outRows.push(applyOutDerived(defaultOutRow()));
              renderRows();
              return true;
            }
          : null,
        canAppendRow: () => mode === 'out' && canSave,
      });
      if (unbindNavigator && typeof unbindNavigator.bind === 'function') {
        unbindNavigator = unbindNavigator.bind();
      } else {
        unbindNavigator = null;
      }
    };

    renderRows();
  })();
</script>
