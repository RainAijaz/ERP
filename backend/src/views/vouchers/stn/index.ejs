        const rejectedCell = `<td class="border-t border-slate-200 px-2 py-1.5"><input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-rejected-qty></td>`;
        const varianceCell = `<td class="border-t border-slate-200 px-2 py-1.5"><input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-variance-qty></td>`;
        const amountCell = `<td class="border-t border-slate-200 px-2 py-1.5"><input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.00" data-total-amount></td>`;
        const spacerCell = '<td class="border-t border-slate-200 px-2 py-1.5"></td>';

        linesFooter.innerHTML = `
          <tr class="bg-slate-50">
            <td colspan="${descriptorColspan}" class="border-t border-slate-200 px-2 py-2 text-right text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-700">${escapeHtml(totalLabel)}</td>
            ${expectedCell}
            ${receivedCell}
            ${rejectedCell}
            ${varianceCell}
            ${showCostAmount ? `${spacerCell}${amountCell}` : ''}
