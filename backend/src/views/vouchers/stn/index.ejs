<%
  const formatDateInput = (value) => {
    if (!value) return "";
    const asText = String(value);
    const textMatch = asText.match(/^(\d{4}-\d{2}-\d{2})/);
    if (textMatch) return textMatch[1];
    const dt = value instanceof Date ? value : new Date(value);
    if (Number.isNaN(dt.getTime())) return "";
    const yyyy = dt.getFullYear();
    const mm = String(dt.getMonth() + 1).padStart(2, "0");
    const dd = String(dt.getDate()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd}`;
  };

  const toFriendlyLabel = (key, fallback = "") => {
    const translated = String(t(key) || "").trim();
    if (translated && translated !== key) return translated;
    if (fallback) return fallback;
    return String(key || "")
      .trim()
      .toLowerCase()
      .replace(/[_-]+/g, " ")
      .replace(/\b[a-z]/g, (ch) => ch.toUpperCase());
  };

  const currentMode = String(mode || "out").toLowerCase() === "in" ? "in" : "out";
  const selectedVoucherNo = selectedVoucher ? Number(selectedVoucher.voucher_no || 0) : null;
  const suggestedVoucherNo = selectedVoucherNo || (Number(latestVoucherNo || 0) + 1);
  const selectedDate = selectedVoucher && selectedVoucher.voucher_date
    ? formatDateInput(selectedVoucher.voucher_date)
    : formatDateInput(new Date());
  const selectedStatus = String(selectedVoucher?.status || "").toUpperCase();
  const isDeletedVoucher = selectedStatus === "REJECTED";
  const statusLabel = selectedStatus === "APPROVED"
    ? t("approved")
    : selectedStatus === "REJECTED"
      ? t("rejected")
      : selectedStatus === "PENDING"
        ? t("pending")
        : selectedStatus;
  const statusToneClass = selectedStatus === "APPROVED"
    ? "border-emerald-200 bg-emerald-50 text-emerald-800"
    : selectedStatus === "REJECTED"
      ? "border-rose-200 bg-rose-50 text-rose-800"
      : "border-amber-200 bg-amber-50 text-amber-800";

  const canCreateVoucher = typeof allowCreate === "boolean" ? allowCreate : true;
  const canEditVoucher = typeof allowEdit === "boolean" ? allowEdit : true;
  const canDeleteVoucher = typeof allowDelete === "boolean" ? allowDelete : true;
  const canSaveVoucher = !isDeletedVoucher && (selectedVoucher ? canEditVoucher : canCreateVoucher);
  const canDeleteCurrentVoucher = !!selectedVoucher && !isDeletedVoucher && canDeleteVoucher;

  const defaultStockType = currentMode === "in"
    ? String(selectedVoucher?.stock_type || "").toUpperCase()
    : String(selectedVoucher?.stock_type || "FG").toUpperCase();
  const sourceBranchLabel = options?.sourceBranch?.name || "";
%>

<style>
  [data-stock-transfer-form] [data-lines-table] thead th {
    font-size: 10.5px;
    letter-spacing: 0.08em;
  }
  [data-stock-transfer-form] [data-lines-table] td {
    padding: 0.3rem 0.4rem;
  }
  [data-stock-transfer-form] [data-lines-table] tbody tr:nth-child(even) td {
    background-color: #f8fafc;
  }
  [data-stock-transfer-form] [data-lines-table] tbody tr:hover td {
    background-color: #f1f5f9;
  }
  [data-stock-transfer-form] [data-lines-table] input,
  [data-stock-transfer-form] [data-lines-table] select,
  [data-stock-transfer-form] [data-lines-table] button[data-enhanced-select-trigger="1"] {
    height: 2.1rem !important;
    font-size: 0.81rem !important;
  }
  [data-stock-transfer-form] input[readonly],
  [data-stock-transfer-form] input:disabled,
  [data-stock-transfer-form] select:disabled,
  [data-stock-transfer-form] textarea[readonly] {
    background-color: #f1f5f9 !important;
    border-color: #cbd5e1 !important;
    color: #475569 !important;
    cursor: not-allowed;
  }
  [data-stock-transfer-form] input:focus,
  [data-stock-transfer-form] select:focus,
  [data-stock-transfer-form] textarea:focus,
  [data-stock-transfer-form] [data-lines-table] button[data-enhanced-select-trigger="1"]:focus {
    border-color: #111827 !important;
    box-shadow: 0 0 0 1px #111827 !important;
    outline: none !important;
  }
  @media (max-width: 640px) {
    [data-stock-transfer-form] [data-lines-table] th {
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      line-height: 1.2;
    }
  }
</style>

<div class="mx-auto w-full max-w-none space-y-3 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white/95 px-4 py-4 shadow-sm">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-2xl font-display font-semibold tracking-tight text-ink">
          <%= currentMode === 'in' ? toFriendlyLabel('stock_transfer_in_voucher', 'Stock Transfer In') : toFriendlyLabel('stock_transfer_out_voucher', 'Stock Transfer Out') %>
        </h1>
        <p class="text-sm text-muted"><%= toFriendlyLabel('inventory', 'Inventory') %></p>
      </div>
      <% if (selectedVoucher) { %>
        <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] <%= statusToneClass %>">
          <span><%= toFriendlyLabel('status', 'Status') %></span>
          <span class="rounded-full bg-white/80 px-2 py-0.5 text-slate-800"><%= statusLabel %></span>
        </div>
      <% } %>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <form method="post" action="<%= basePath || '' %>" class="space-y-4" data-stock-transfer-form data-voucher-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
      <input type="hidden" name="mode" value="<%= currentMode %>" data-mode-input>
      <input type="hidden" name="lines_json" value="[]" data-lines-json>
      <input type="hidden" name="stn_out_voucher_id" value="<%= selectedVoucher?.stn_out_voucher_id || '' %>" data-stn-out-id>
      <% if (currentMode === 'out') { %>
        <input type="hidden" name="transfer_ref_no" value="<%= selectedVoucher?.transfer_ref_no || '' %>" data-transfer-ref-text>
      <% } %>
      <% if (currentMode === 'in') { %>
        <input type="hidden" name="received_date_time" value="<%= selectedDate %>" data-received-date-hidden>
      <% } %>

      <div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50/60 p-3">
        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel('voucher_no', 'Voucher No') %></label>
          <div class="lg:col-span-2">
            <input type="text" value="<%= suggestedVoucherNo %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-700" data-voucher-no-input>
          </div>
          <div class="flex flex-wrap items-center gap-2 lg:col-span-8">
            <a href="<%= prevVoucherNo ? ((basePath || '') + '?voucher_no=' + prevVoucherNo + '&view=1') : '#' %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 <%= prevVoucherNo ? '' : 'pointer-events-none opacity-40' %>"><%= toFriendlyLabel('prev', 'Prev') %></a>
            <a href="<%= nextVoucherNo ? ((basePath || '') + '?voucher_no=' + nextVoucherNo + '&view=1') : ((basePath || '') + '?new=1') %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= toFriendlyLabel('next', 'Next') %></a>
            <button type="button" class="rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm" data-load-voucher><%= toFriendlyLabel('load', 'Load') %></button>
            <div class="ml-auto flex items-center gap-2">
              <a href="<%= selectedVoucherNo ? ((basePath || '') + '/gate-pass?voucher_no=' + selectedVoucherNo) : '#' %>" target="_blank" rel="noopener" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 <%= selectedVoucherNo ? '' : 'pointer-events-none opacity-40' %>"><%= toFriendlyLabel('gate_pass', 'Gate Pass') %></a>
              <button type="button" class="rounded-xl border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-rose-700 disabled:opacity-40" data-delete-voucher <%= canDeleteCurrentVoucher ? '' : 'disabled' %>><%= toFriendlyLabel('delete', 'Delete') %></button>
              <button type="button" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700" onclick="window.print()"><%= toFriendlyLabel('print', 'Print') %></button>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel('date', 'Date') %></label>
          <div class="lg:col-span-4">
            <input type="date" name="voucher_date" value="<%= selectedDate %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" required <%= canSaveVoucher ? '' : 'readonly' %>>
          </div>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= currentMode === 'out' ? toFriendlyLabel('stock_type', 'Stock Type') : toFriendlyLabel('source_branch', 'Source Branch') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <select name="stock_type" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-stock-type data-searchable-select="true" data-searchable-variant="unified" <%= !canSaveVoucher ? 'disabled' : '' %>>
                <% (options.stockTypes || []).forEach((entry) => { %>
                  <option value="<%= entry.value %>" <%= String(defaultStockType || 'FG').toUpperCase() === String(entry.value || '').toUpperCase() ? 'selected' : '' %>><%= toFriendlyLabel(entry.labelKey || entry.value, entry.value) %></option>
                <% }) %>
              </select>
            <% } else { %>
              <select class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-source-branch-select data-searchable-select="true" data-searchable-variant="unified" <%= canSaveVoucher ? '' : 'disabled' %>>
                <option value=""><%= toFriendlyLabel('select_branch', 'Select Branch') %></option>
                <% (options.sourceBranches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= Number(selectedVoucher?.source_branch_id || 0) === Number(branch.id) ? 'selected' : '' %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= currentMode === 'out' ? toFriendlyLabel('bill_book_no', 'Bill Book No') : toFriendlyLabel('transfer_ref_no', 'Transfer Ref No') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <input type="text" name="bill_book_no" value="<%= selectedVoucher?.bill_book_no || '' %>" maxlength="120" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-bill-book-no <%= canSaveVoucher ? 'required' : 'readonly' %>>
            <% } else { %>
              <div class="flex items-center gap-2">
                <input type="text" name="transfer_ref_no" value="<%= selectedVoucher?.transfer_ref_no || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-slate-100 px-3 text-sm text-slate-700" readonly data-transfer-ref-text>
                <button type="button" class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-slate-300 bg-white text-slate-700 disabled:opacity-40" data-open-sti-transfer-picker aria-label="<%= toFriendlyLabel('select_transfer_reference', 'Select Transfer Reference') %>" title="<%= toFriendlyLabel('select_transfer_reference', 'Select Transfer Reference') %>" <%= canSaveVoucher ? '' : 'disabled' %>>
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M9 12h6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                    <path d="M8.5 8.5l-2 2a3 3 0 0 0 4.24 4.24l1.06-1.06" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                    <path d="M15.5 15.5l2-2a3 3 0 0 0-4.24-4.24l-1.06 1.06" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                  </svg>
                </button>
              </div>
            <% } %>
          </div>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= currentMode === 'out' ? toFriendlyLabel('destination_branch', 'Destination Branch') : toFriendlyLabel('remarks', 'Remarks') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <select name="destination_branch_id" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-destination-branch data-searchable-select="true" data-searchable-variant="unified" <%= canSaveVoucher ? '' : 'disabled' %>>
                <option value=""><%= toFriendlyLabel('select_branch', 'Select Branch') %></option>
                <% (options.destinationBranches || []).forEach((branch) => { %>
                  <option value="<%= branch.id %>" <%= Number(selectedVoucher?.destination_branch_id || 0) === Number(branch.id) ? 'selected' : '' %>><%= branch.name %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" name="remarks" maxlength="1000" value="<%= selectedVoucher?.remarks || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" <%= canSaveVoucher ? '' : 'readonly' %>>
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= currentMode === 'out' ? toFriendlyLabel('transfer_reason', 'Transfer Reason') : toFriendlyLabel('bill_book_no', 'Bill Book No') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <select name="transfer_reason" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified" <%= canSaveVoucher ? '' : 'disabled' %>>
                <% (options.transferReasons || []).forEach((entry) => { %>
                  <option value="<%= entry.value %>" <%= String(selectedVoucher?.transfer_reason || 'REBALANCING').toUpperCase() === String(entry.value || '').toUpperCase() ? 'selected' : '' %>><%= toFriendlyLabel(entry.labelKey || entry.value, entry.value) %></option>
                <% }) %>
              </select>
            <% } else { %>
              <input type="text" name="bill_book_no" value="<%= selectedVoucher?.bill_book_no || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-slate-100 px-3 text-sm" data-bill-book-no readonly>
            <% } %>
          </div>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= currentMode === 'out' ? toFriendlyLabel('transporter_name', 'Transporter Name') : toFriendlyLabel('destination_branch', 'Destination Branch') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <input type="text" name="transporter_name" maxlength="120" value="<%= selectedVoucher?.transporter_name || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" <%= canSaveVoucher ? '' : 'readonly' %>>
            <% } else { %>
              <input type="text" value="<%= selectedVoucher?.destination_branch_name || sourceBranchLabel %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" readonly data-destination-branch-name>
            <% } %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= currentMode === 'out' ? toFriendlyLabel('remarks', 'Remarks') : toFriendlyLabel('stock_type', 'Stock Type') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <input type="text" name="remarks" maxlength="1000" value="<%= selectedVoucher?.remarks || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" <%= canSaveVoucher ? '' : 'readonly' %>>
            <% } else { %>
              <select name="stock_type" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-stock-type data-searchable-select="true" data-searchable-variant="unified" disabled>
                <option value="" <%= !defaultStockType ? 'selected' : '' %>><%= toFriendlyLabel('select_stock_type', 'Select Stock Type') %></option>
                <% (options.stockTypes || []).forEach((entry) => { %>
                  <option value="<%= entry.value %>" <%= String(defaultStockType || '').toUpperCase() === String(entry.value || '').toUpperCase() ? 'selected' : '' %>><%= toFriendlyLabel(entry.labelKey || entry.value, entry.value) %></option>
                <% }) %>
              </select>
            <% } %>
          </div>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= currentMode === 'out' ? toFriendlyLabel('source_branch', 'Source Branch') : toFriendlyLabel('received_by_user_name', 'Received By') %></label>
          <div class="lg:col-span-4">
            <% if (currentMode === 'out') { %>
              <input type="text" value="<%= selectedVoucher?.source_branch_name || sourceBranchLabel %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" readonly data-source-branch-name>
            <% } else { %>
              <input type="text" value="<%= selectedVoucher?.received_by_user_name || user?.full_name || user?.username || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" readonly>
            <% } %>
          </div>
        </div>

        <% if (isDeletedVoucher) { %>
          <div class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800">
            <%= toFriendlyLabel('voucher_deleted_read_only', 'Voucher is deleted and read-only.') %>
          </div>
        <% } %>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="w-full min-w-[1160px] text-xs" data-lines-table>
            <thead class="bg-slate-50 text-xs uppercase tracking-[0.12em] text-slate-500">
              <tr data-lines-head-row></tr>
            </thead>
            <tbody data-lines-body></tbody>
            <tfoot data-lines-footer></tfoot>
          </table>
        </div>
      </div>

      <div class="flex items-center justify-center gap-2">
        <button type="submit" class="rounded-xl bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" <%= canSaveVoucher ? '' : 'disabled' %>><%= toFriendlyLabel('confirm', 'Confirm') %></button>
      </div>
    </form>

    <form method="post" action="<%= `${basePath}/delete` %>" class="hidden" data-delete-voucher-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
      <input type="hidden" name="mode" value="<%= currentMode %>">
    </form>

    <% if (currentMode === 'in') { %>
      <div class="fixed inset-0 z-40 hidden items-center justify-center bg-slate-900/45 p-4 backdrop-blur-[1px]" data-sti-transfer-picker-modal aria-hidden="true">
        <div class="w-full max-w-5xl overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-xl">
          <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50/70 px-4 py-3">
            <h3 class="text-base font-semibold text-slate-800"><%= toFriendlyLabel('select_transfer_reference', 'Select Transfer Reference') %></h3>
            <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-700" data-sti-transfer-picker-close aria-label="<%= toFriendlyLabel('cancel', 'Cancel') %>" title="<%= toFriendlyLabel('cancel', 'Cancel') %>">
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
            </button>
          </div>
          <div class="space-y-3 px-4 py-3">
            <div class="flex flex-wrap items-center gap-2 rounded-lg border border-slate-200 bg-slate-50/70 px-2 py-2">
              <input type="date" class="h-8 rounded-lg border border-slate-300 bg-white px-2 text-xs text-slate-700" data-sti-transfer-picker-date>
              <button
                type="button"
                class="inline-flex h-8 w-8 items-center justify-center rounded-lg border border-slate-300 bg-white text-slate-700"
                data-sti-transfer-picker-date-only
                aria-pressed="false"
                title="<%= toFriendlyLabel('match_voucher_date_only', 'Match voucher date only') %>">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M4 7h16M7 4v3m10-3v3M5 10h14v9H5z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                </svg>
              </button>
            </div>
            <div class="max-h-[50vh] overflow-auto rounded-xl border border-slate-200">
              <table class="w-full min-w-[980px] table-fixed text-xs">
                <thead class="sticky top-0 z-10 bg-slate-100 uppercase tracking-[0.08em] text-slate-500">
                  <tr>
                    <th class="border-b border-slate-200 px-2 py-2 text-left"><%= toFriendlyLabel('transfer_ref_no', 'Transfer Ref No') %></th>
                    <th class="border-b border-slate-200 px-2 py-2 text-left"><%= toFriendlyLabel('bill_book_no', 'Bill Book No') %></th>
                    <th class="border-b border-slate-200 px-2 py-2 text-left"><%= toFriendlyLabel('stock_type', 'Stock Type') %></th>
                    <th class="border-b border-slate-200 px-2 py-2 text-left"><%= toFriendlyLabel('date', 'Date') %></th>
                    <th class="border-b border-slate-200 px-2 py-2 text-center"><%= toFriendlyLabel('select', 'Select') %></th>
                  </tr>
                </thead>
                <tbody data-sti-transfer-picker-body></tbody>
              </table>
            </div>
          </div>
          <div class="flex items-center justify-end gap-2 border-t border-slate-200 bg-white px-4 py-3">
            <button type="button" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-slate-700" data-sti-transfer-picker-close><%= toFriendlyLabel('cancel', 'Cancel') %></button>
            <button type="button" class="rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.08em] text-white" data-sti-transfer-picker-apply><%= toFriendlyLabel('apply', 'Apply') %></button>
          </div>
        </div>
      </div>
    <% } %>
  </section>
</div>

<script><%- include('../../base/partials/searchable-select.js') %></script>
<script><%- include('../../base/partials/voucher-row-enter-navigation.js') %></script>
<script>
  (() => {
    const form = document.querySelector('[data-stock-transfer-form]');
    if (!form) return;

    const options = <%- JSON.stringify(options || {}) %>;
    const initialVoucher = <%- JSON.stringify(selectedVoucher || null) %>;
    const mode = <%- JSON.stringify(currentMode) %>;
    const basePath = <%- JSON.stringify(basePath || '') %>;
    const canSave = <%- JSON.stringify(Boolean(canSaveVoucher)) %>;

    const voucherNoInput = form.querySelector('[data-voucher-no-input]');
    const loadVoucherButton = form.querySelector('[data-load-voucher]');
    const linesJsonInput = form.querySelector('[data-lines-json]');
    const linesBody = form.querySelector('[data-lines-body]');
    const linesHeadRow = form.querySelector('[data-lines-head-row]');
    const linesFooter = form.querySelector('[data-lines-footer]');
    let totalQtyInput = null;
    let totalAmountInput = null;
    let totalQtyByUnitWrap = null;
    let totalQtyByUnitRow = null;
    let totalExpectedQtyInput = null;
    let totalReceivedQtyInput = null;
    let totalRejectedQtyInput = null;
    let totalVarianceQtyInput = null;
    const deleteButton = form.querySelector('[data-delete-voucher]');
    const deleteForm = document.querySelector('[data-delete-voucher-form]');
    const stockTypeSelect = form.querySelector('[data-stock-type]');
    const destinationBranchSelect = form.querySelector('[data-destination-branch]');
    const sourceBranchSelect = form.querySelector('[data-source-branch-select]');
    const transferRefTextInput = form.querySelector('[data-transfer-ref-text]');
    const openStiTransferPickerButton = form.querySelector('[data-open-sti-transfer-picker]');
    const stiTransferPickerModal = document.querySelector('[data-sti-transfer-picker-modal]');
    const stiTransferPickerBody = stiTransferPickerModal?.querySelector('[data-sti-transfer-picker-body]');
    const stiTransferPickerDateInput = stiTransferPickerModal?.querySelector('[data-sti-transfer-picker-date]');
    const stiTransferPickerDateOnlyToggle = stiTransferPickerModal?.querySelector('[data-sti-transfer-picker-date-only]');
    const stiTransferPickerApplyButton = stiTransferPickerModal?.querySelector('[data-sti-transfer-picker-apply]');
    const stiTransferPickerCloseButtons = stiTransferPickerModal
      ? Array.from(stiTransferPickerModal.querySelectorAll('[data-sti-transfer-picker-close]'))
      : [];
    const stnOutIdInput = form.querySelector('[data-stn-out-id]');
    const billBookNoInput = form.querySelector('[data-bill-book-no]');
    const voucherDateInput = form.querySelector('[name="voucher_date"]');
    const transferReasonSelect = form.querySelector('[name="transfer_reason"]');
    const transporterNameInput = form.querySelector('[name="transporter_name"]');
    const receivedDateInput = form.querySelector('[name="received_date_time"]');
    const remarksInput = form.querySelector('[name="remarks"]');
    const sourceBranchNameInput = form.querySelector('[data-source-branch-name]');
    const destinationBranchNameInput = form.querySelector('[data-destination-branch-name]');

    const toNum = (value, fallback = 0) => {
      const n = Number(value);
      return Number.isFinite(n) ? n : fallback;
    };
    const toInt = (value) => {
      const n = Number(value);
      if (!Number.isInteger(n) || n <= 0) return null;
      return n;
    };
    const qty3 = (value) => Number(toNum(value, 0).toFixed(3));
    const amount2 = (value) => Number(toNum(value, 0).toFixed(2));
    const cost1 = (value) => Number(toNum(value, 0).toFixed(1));
    const escapeHtml = (value) =>
      String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/\"/g, '&quot;')
        .replace(/'/g, '&#39;');

    const stockTypeValues = ['FG', 'SFG', 'RM'];
    const normalizeStockType = (value) => {
      const normalized = String(value || '').trim().toUpperCase();
      return stockTypeValues.includes(normalized) ? normalized : 'FG';
    };

    const skuList = Array.isArray(options.skus) ? options.skus : [];
    const rmItems = Array.isArray(options.rmItems) ? options.rmItems : [];
    const colors = Array.isArray(options.colors) ? options.colors : [];
    const sizes = Array.isArray(options.sizes) ? options.sizes : [];
    const rmColorPolicy = options.rawMaterialColorPolicyByItem || {};
    const rmSizePolicy = options.rawMaterialSizePolicyByItem || {};
    const sourceStock = options.sourceStock || { skuMap: {}, rmMap: {} };
    const pendingTransfers = Array.isArray(options.pendingTransfers) ? options.pendingTransfers : [];

    const skuMap = new Map(skuList.map((entry) => [Number(entry.id), entry]));
    const rmMap = new Map(rmItems.map((entry) => [Number(entry.id), entry]));
    const colorMap = new Map(colors.map((entry) => [Number(entry.id), entry]));
    const sizeMap = new Map(sizes.map((entry) => [Number(entry.id), entry]));
    const pendingTransferMap = new Map(
      pendingTransfers.map((entry) => [Number(entry.stn_out_voucher_id || 0), entry]),
    );
    let stiTransferPickerSelectedId = null;
    let stiTransferPickerShowAll = true;
    const totalLabel = <%- JSON.stringify(toFriendlyLabel('total', 'Total')) %>;
    const quantityLabel = <%- JSON.stringify(toFriendlyLabel('quantity', 'Quantity')) %>;
    const amountLabel = <%- JSON.stringify(toFriendlyLabel('amount', 'Amount')) %>;
    const unitsLabel = <%- JSON.stringify(toFriendlyLabel('units', 'Units')) %>;
    const addButtonTitle = <%- JSON.stringify(toFriendlyLabel('add', 'Add')) %>;
    const deleteButtonTitle = <%- JSON.stringify(toFriendlyLabel('delete', 'Delete')) %>;
    const selectBranchMessage = <%- JSON.stringify(toFriendlyLabel('select_source_branch_first', 'Select source branch first.')) %>;
    const noPendingTransfersMessage = <%- JSON.stringify(toFriendlyLabel('no_pending_transfer_vouchers', 'No pending transfer vouchers found for selected source branch.')) %>;

    const stockMapKey = (itemId, colorId = null, sizeId = null) =>
      `${Number(itemId || 0)}|${Number(colorId || 0)}|${Number(sizeId || 0)}`;

    const getOutUnitOptions = (row, stockType) => {
      if (stockType === 'RM') {
        const item = rmMap.get(Number(row.item_id || 0));
        return Array.isArray(item?.unit_options) ? item.unit_options : [];
      }
      const sku = skuMap.get(Number(row.sku_id || 0));
      return Array.isArray(sku?.unit_options) ? sku.unit_options : [];
    };

    const getOutUomLabel = (row, stockType) => {
      const optionsList = getOutUnitOptions(row, stockType);
      const matched = optionsList.find((entry) => Number(entry.id || 0) === Number(row.uom_id || 0));
      if (!matched) return '';
      return String(matched.name || matched.code || matched.symbol || '').trim();
    };

    const getDefaultUnitId = (row, stockType) => {
      const optionsList = getOutUnitOptions(row, stockType);
      if (!optionsList.length) return null;
      const preferred = optionsList.find((entry) => entry.is_base !== true) || optionsList[0];
      return toInt(preferred?.id);
    };

    const getRmColorState = (itemId) => {
      const normalizedItemId = toInt(itemId);
      if (!normalizedItemId) return { entries: [], allowNone: true, disabled: true };
      const policy = rmColorPolicy[String(normalizedItemId)] || null;
      const entries = Array.isArray(policy?.colors)
        ? policy.colors
          .map((entry) => ({ id: toInt(entry?.id), name: String(entry?.name || '').trim() }))
          .filter((entry) => entry.id)
        : [];
      const allowNone = Boolean(policy?.hasColorless) || entries.length === 0;
      return { entries, allowNone, disabled: false };
    };

    const getRmSizeState = (itemId) => {
      const normalizedItemId = toInt(itemId);
      if (!normalizedItemId) return { entries: [], allowNone: true, disabled: true };
      const policy = rmSizePolicy[String(normalizedItemId)] || null;
      const entries = Array.isArray(policy?.sizes)
        ? policy.sizes
          .map((entry) => ({ id: toInt(entry?.id), name: String(entry?.name || '').trim() }))
          .filter((entry) => entry.id)
        : [];
      const allowNone = Boolean(policy?.hasSizeless) || entries.length === 0;
      return { entries, allowNone, disabled: false };
    };
    const resolveRmPurchaseRate = (rateRows, colorId, sizeId) => {
      const rows = Array.isArray(rateRows) ? rateRows : [];
      const normalizedColorId = Number(colorId || 0);
      const normalizedSizeId = Number(sizeId || 0);
      const pickRate = (entry) => {
        const rate = Number(entry?.purchase_rate || 0);
        return rate > 0 ? rate : 0;
      };
      const exact = rows.find((entry) => Number(entry?.color_id || 0) === normalizedColorId && Number(entry?.size_id || 0) === normalizedSizeId);
      if (exact) return pickRate(exact);
      const colorOnly = rows.find((entry) => Number(entry?.color_id || 0) === normalizedColorId && Number(entry?.size_id || 0) === 0);
      if (colorOnly) return pickRate(colorOnly);
      const sizeOnly = rows.find((entry) => Number(entry?.color_id || 0) === 0 && Number(entry?.size_id || 0) === normalizedSizeId);
      if (sizeOnly) return pickRate(sizeOnly);
      const fallback = rows.find((entry) => Number(entry?.color_id || 0) === 0 && Number(entry?.size_id || 0) === 0);
      return fallback ? pickRate(fallback) : 0;
    };

    const defaultOutRow = () => ({
      sku_id: null,
      item_id: null,
      color_id: null,
      size_id: null,
      uom_id: null,
      available_qty: 0,
      transfer_qty: 0,
      unit_cost: 0,
      amount: 0,
    });

    const toOutLine = (line) => ({
      sku_id: toInt(line?.sku_id),
      item_id: toInt(line?.item_id),
      color_id: toInt(line?.color_id),
      size_id: toInt(line?.size_id),
      uom_id: toInt(line?.uom_id),
      available_qty: qty3(line?.available_qty),
      transfer_qty: qty3(line?.transfer_qty ?? line?.qty),
      unit_cost: cost1(line?.unit_cost ?? line?.rate),
      amount: amount2(line?.amount),
    });

    const isFocusableControl = (field) => {
      if (!(field instanceof HTMLElement)) return false;
      if (
        !(field instanceof HTMLInputElement
          || field instanceof HTMLSelectElement
          || field instanceof HTMLTextAreaElement)
      ) {
        return false;
      }
      if (field instanceof HTMLInputElement && field.type === 'hidden') return false;
      if (field instanceof HTMLInputElement && field.readOnly) return false;
      if (field instanceof HTMLTextAreaElement && field.readOnly) return false;
      if (field.disabled) return false;
      const style = window.getComputedStyle(field);
      if (style.display === 'none' || style.visibility === 'hidden') return false;
      return field.offsetParent !== null || style.position === 'fixed';
    };

    const focusControl = (field, { openSearchable = true, selectText = false } = {}) => {
      if (!(field instanceof HTMLElement)) return false;
      if (field instanceof HTMLSelectElement && window.VoucherRowEnterNavigation?.focusFieldElement) {
        return window.VoucherRowEnterNavigation.focusFieldElement(field, { openSearchable });
      }
      if (!isFocusableControl(field)) return false;
      field.focus();
      if (selectText && field instanceof HTMLInputElement && typeof field.select === 'function') {
        field.select();
      }
      return true;
    };

    const resolveFieldHost = (node) => {
      if (!(node instanceof HTMLElement)) return null;
      const direct = node.matches('[data-row-field][data-row-index]')
        ? node
        : node.closest('[data-row-field][data-row-index]');
      if (direct instanceof HTMLElement) return direct;
      const wrapper = node.closest('[data-searchable-wrapper]');
      const linkedSelect = wrapper?.querySelector('select[data-row-field][data-row-index]') || null;
      return linkedSelect instanceof HTMLElement ? linkedSelect : null;
    };

    const captureActiveRowField = () => {
      const active = document.activeElement;
      if (!(active instanceof HTMLElement)) return null;
      const host = resolveFieldHost(active);
      if (!(host instanceof HTMLElement)) return null;
      return {
        rowIndex: String(host.getAttribute('data-row-index') || ''),
        fieldKey: String(host.getAttribute('data-row-field') || ''),
      };
    };

    const restoreActiveRowField = (state) => {
      if (!state?.rowIndex || !state?.fieldKey) return false;
      window.setTimeout(() => {
        const selector = `[data-row-index="${state.rowIndex}"][data-row-field="${state.fieldKey}"]`;
        const field = linesBody.querySelector(selector);
        if (!(field instanceof HTMLElement)) return;
        focusControl(field, { openSearchable: false });
      }, 0);
      return true;
    };

    const fieldOrderForMode = () => (
      mode === 'out'
        ? (activeStockType === 'RM' ? ['item', 'color', 'size', 'uom', 'qty'] : ['item', 'uom', 'qty'])
        : ['received', 'rejected', 'reason']
    );

    const shouldShowCostAmountColumns = () => String(activeStockType || '').toUpperCase() !== 'SFG';

    const focusFirstRowField = () => {
      const firstRow = linesBody.querySelector('tr[data-row-index]');
      if (!(firstRow instanceof HTMLElement)) return false;
      const order = fieldOrderForMode();
      for (let index = 0; index < order.length; index += 1) {
        const field = firstRow.querySelector(`[data-row-field="${order[index]}"]`);
        if (focusControl(field, { openSearchable: true })) return true;
      }
      return false;
    };

    const getHeaderEnterFields = () => {
      const fields = [];
      const push = (field) => {
        if (isFocusableControl(field)) fields.push(field);
      };
      push(voucherDateInput);
      if (mode === 'in') {
        push(sourceBranchSelect);
      }
      if (mode === 'out') {
        push(stockTypeSelect);
        push(billBookNoInput);
        push(destinationBranchSelect);
        push(transferReasonSelect);
        push(transporterNameInput);
      }
      push(remarksInput);
      return fields;
    };

    const resolveHeaderFieldHost = (node) => {
      if (!(node instanceof HTMLElement)) return null;
      if (isFocusableControl(node) && !linesBody.contains(node)) return node;
      const wrapper = node.closest('[data-searchable-wrapper]');
      const linkedSelect = wrapper?.querySelector('select') || null;
      if (linkedSelect && isFocusableControl(linkedSelect) && !linesBody.contains(linkedSelect)) {
        return linkedSelect;
      }
      return null;
    };

    const resolveLineDisplayName = (line) => {
      const explicit = String(line?.display_name || '').trim();
      if (explicit) return explicit;
      const skuParts = [
        String(line?.sku_item_name || line?.item_name || '').trim(),
        String(line?.size_name || '').trim(),
        String(line?.color_name || '').trim(),
        String(line?.packing_name || '').trim(),
        String(line?.grade_name || '').trim(),
      ].filter(Boolean);
      if (skuParts.length) return skuParts.join(' ');
      return String(line?.sku_code || line?.item_id || '').trim();
    };

    const toInLine = (line) => ({
      stn_line_id: toInt(line?.stn_line_id || line?.id),
      sku_id: toInt(line?.sku_id),
      item_id: toInt(line?.item_id),
      color_id: toInt(line?.color_id),
      size_id: toInt(line?.size_id),
      uom_id: toInt(line?.uom_id),
      uom_name: String(line?.uom_name || ''),
      item_name: resolveLineDisplayName(line),
      sku_code: String(line?.sku_code || ''),
      expected_qty: qty3(line?.expected_qty ?? line?.qty),
      received_qty: qty3(line?.received_qty ?? line?.qty),
      rejected_qty: qty3(line?.rejected_qty),
      variance_qty: qty3(line?.variance_qty),
      variance_reason: String(line?.variance_reason || ''),
      unit_cost: cost1(line?.unit_cost ?? line?.rate),
      amount: amount2(line?.amount ?? (Number(line?.received_qty ?? line?.qty ?? 0) * Number(line?.unit_cost ?? line?.rate ?? 0))),
    });

    let outRows = [];
    let inRows = [];
    let activeStockType = normalizeStockType(stockTypeSelect?.value || initialVoucher?.stock_type || 'FG');

    const applyOutDerived = (row) => {
      const next = { ...row };
      const stockType = activeStockType;
      const unitOptions = getOutUnitOptions(next, stockType);
      if (!next.uom_id) next.uom_id = getDefaultUnitId(next, stockType);
      const selectedUnit = unitOptions.find((entry) => Number(entry.id) === Number(next.uom_id || 0));
      const factorToBase = Number(selectedUnit?.factor_to_base || 0) || 1;

      if (stockType === 'RM') {
        const exactKey = stockMapKey(next.item_id, next.color_id, next.size_id);
        const fallbackKey = stockMapKey(next.item_id, null, null);
        const stock = sourceStock.rmMap?.[exactKey] || sourceStock.rmMap?.[fallbackKey] || {};
        const rmItem = rmMap.get(Number(next.item_id || 0));
        const availableBase = Number(stock.qty || 0);
        const unitCostBase = Number(
          resolveRmPurchaseRate(rmItem?.rate_rows, next.color_id, next.size_id),
        );
        next.available_qty = factorToBase > 0 ? qty3(availableBase / factorToBase) : 0;
        next.unit_cost = cost1(unitCostBase * factorToBase);
      } else {
        const stockKey = `${stockType}:${Number(next.sku_id || 0)}`;
        const stock = sourceStock.skuMap?.[stockKey] || {};
        const sku = skuMap.get(Number(next.sku_id || 0));
        const rowStatus = selectedUnit?.is_base === true ? 'LOOSE' : 'PACKED';
        const availablePairs = stockType === 'FG'
          ? Number(rowStatus === 'LOOSE' ? stock.loose_qty_pairs : stock.packed_qty_pairs)
          : Number(stock.qty_pairs || 0);
        const unitCostBase = stockType === 'FG' && Number(sku?.sale_rate || 0) > 0
          ? Number(sku.sale_rate)
          : 0;
        next.available_qty = factorToBase > 0 ? qty3(availablePairs / factorToBase) : 0;
        next.unit_cost = cost1(unitCostBase * factorToBase);
      }

      next.transfer_qty = qty3(next.transfer_qty);
      next.amount = amount2(Number(next.transfer_qty || 0) * Number(next.unit_cost || 0));
      return next;
    };

    const readPendingTransfer = (stnOutId) => {
      const id = Number(stnOutId || 0);
      if (!id) return null;
      return pendingTransferMap.get(id) || null;
    };

    const formatDateDisplay = (value) => {
      if (!value) return '';
      const text = String(value);
      if (/^\d{4}-\d{2}-\d{2}$/.test(text)) {
        const [yyyy, mm, dd] = text.split('-');
        return `${dd}/${mm}/${yyyy}`;
      }
      const dt = new Date(value);
      if (Number.isNaN(dt.getTime())) return text;
      const dd = String(dt.getDate()).padStart(2, '0');
      const mm = String(dt.getMonth() + 1).padStart(2, '0');
      const yyyy = dt.getFullYear();
      return `${dd}/${mm}/${yyyy}`;
    };

    const normalizeDateInputValue = (value) => {
      if (!value) return '';
      const text = String(value);
      const direct = text.match(/^(\d{4}-\d{2}-\d{2})/);
      if (direct) return direct[1];
      const dt = new Date(value);
      if (Number.isNaN(dt.getTime())) return '';
      const yyyy = dt.getFullYear();
      const mm = String(dt.getMonth() + 1).padStart(2, '0');
      const dd = String(dt.getDate()).padStart(2, '0');
      return `${yyyy}-${mm}-${dd}`;
    };

    const transferTotals = (transfer) => {
      if (!transfer || typeof transfer !== 'object') {
        return { baseQty: 0, dozenQty: 0 };
      }
      const explicitBase = Number(transfer.total_base_qty);
      const explicitDozen = Number(transfer.total_dozen_qty);
      if (Number.isFinite(explicitBase) || Number.isFinite(explicitDozen)) {
        return {
          baseQty: qty3(Number.isFinite(explicitBase) ? explicitBase : 0),
          dozenQty: qty3(Number.isFinite(explicitDozen) ? explicitDozen : 0),
        };
      }
      const totals = (Array.isArray(transfer.lines) ? transfer.lines : []).reduce(
        (acc, line) => {
          const factorToBase = Number(line?.uom_factor_to_base || 1) > 0
            ? Number(line.uom_factor_to_base || 1)
            : 1;
          const qty = Number(line?.qty || line?.expected_qty || 0);
          const baseQty = Number(line?.transfer_qty_base || 0);
          const lineBaseQty = Number.isFinite(baseQty) && baseQty !== 0
            ? baseQty
            : qty * factorToBase;
          let pairQty = Number(line?.transfer_qty_pairs || 0);
          if (!(pairQty > 0) && String(line?.line_kind || '').toUpperCase() === 'SKU') {
            pairQty = qty * factorToBase;
          }
          acc.baseQty += Number(lineBaseQty || 0);
          acc.pairQty += Number(pairQty || 0);
          return acc;
        },
        { baseQty: 0, pairQty: 0 },
      );
      return {
        baseQty: qty3(totals.baseQty),
        dozenQty: qty3(totals.pairQty / 12),
      };
    };

    const ensureOutRows = () => {
      if (!outRows.length) outRows = [applyOutDerived(defaultOutRow())];
    };

    const updateTotals = () => {
      if (mode === 'out') {
        const totalQty = outRows.reduce((sum, row) => sum + Number(row.transfer_qty || 0), 0);
        const totalAmount = outRows.reduce((sum, row) => sum + Number(row.amount || 0), 0);
        if (totalQtyInput) {
          totalQtyInput.value = qty3(totalQty).toFixed(3);
        }
        if (totalAmountInput) {
          totalAmountInput.value = amount2(totalAmount).toFixed(2);
        }
        if (totalQtyByUnitWrap) {
          const totalsByUnit = new Map();
          outRows.forEach((row) => {
            if (!(Number(row.transfer_qty || 0) > 0) || !Number(row.uom_id || 0)) return;
            const unitLabel = getOutUomLabel(row, activeStockType);
            if (!unitLabel) return;
            totalsByUnit.set(unitLabel, Number(totalsByUnit.get(unitLabel) || 0) + Number(row.transfer_qty || 0));
          });
          if (totalsByUnit.size) {
            if (totalQtyByUnitRow) totalQtyByUnitRow.classList.remove('hidden');
            totalQtyByUnitWrap.innerHTML = Array.from(totalsByUnit.entries())
              .map(([label, value]) => {
                const safeLabel = escapeHtml(label);
                const safeValue = qty3(value).toFixed(3);
                return `<span class="rounded-md border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500">${safeLabel}: ${safeValue}</span>`;
              })
              .join('');
          } else {
            if (totalQtyByUnitRow) totalQtyByUnitRow.classList.add('hidden');
            totalQtyByUnitWrap.innerHTML = '';
          }
        }
        return;
      }
      const totalQty = inRows.reduce((sum, row) => sum + Number(row.received_qty || 0), 0);
      const totalExpectedQty = inRows.reduce((sum, row) => sum + Number(row.expected_qty || 0), 0);
      const totalRejectedQty = inRows.reduce((sum, row) => sum + Number(row.rejected_qty || 0), 0);
      const totalAmount = inRows.reduce((sum, row) => sum + Number(row.amount || 0), 0);
      const totalVarianceQty = inRows.reduce((sum, row) => sum + Number(row.variance_qty || 0), 0);
      if (totalQtyInput) {
        totalQtyInput.value = qty3(totalQty).toFixed(3);
      }
      if (totalExpectedQtyInput) {
        totalExpectedQtyInput.value = qty3(totalExpectedQty).toFixed(3);
      }
      if (totalReceivedQtyInput) {
        totalReceivedQtyInput.value = qty3(totalQty).toFixed(3);
      }
      if (totalRejectedQtyInput) {
        totalRejectedQtyInput.value = qty3(totalRejectedQty).toFixed(3);
      }
      if (totalVarianceQtyInput) {
        totalVarianceQtyInput.value = qty3(totalVarianceQty).toFixed(3);
      }
      if (totalAmountInput) {
        totalAmountInput.value = amount2(totalAmount).toFixed(2);
      }
      if (totalQtyByUnitWrap) {
        const totalsByUnit = new Map();
        inRows.forEach((row) => {
          if (!(Number(row.received_qty || 0) > 0)) return;
          const unitLabel = String(row.uom_name || '').trim();
          if (!unitLabel) return;
          totalsByUnit.set(
            unitLabel,
            Number(totalsByUnit.get(unitLabel) || 0) + Number(row.received_qty || 0),
          );
        });
        if (totalsByUnit.size) {
          if (totalQtyByUnitRow) totalQtyByUnitRow.classList.remove('hidden');
          totalQtyByUnitWrap.innerHTML = Array.from(totalsByUnit.entries())
            .map(([label, value]) => {
              const safeLabel = escapeHtml(label);
              const safeValue = qty3(value).toFixed(3);
