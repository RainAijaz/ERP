<!doctype html>
<%
  const normalizedLocale = String(locale || "en").trim().toLowerCase() === "ur" ? "ur" : "en";
  const normalizedDir = normalizedLocale === "ur" ? "rtl" : "ltr";
%>
<html lang="<%= normalizedLocale %>" dir="<%= normalizedDir %>">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= t("print_gate_pass") %> - <%= gatePass?.voucher_no || "" %></title>
    <%- include("../../base/partials/gate-pass-print-style") %>
  </head>
  <body>
    <%
      const salesRows = gatePass?.lines || [];
      const unitTotals = { pair: 0, dozen: 0 };
      salesRows.forEach((line) => {
        const unitKey = String(line?.row_status || "").trim().toUpperCase() === "LOOSE" ? "pair" : "dozen";
        const qty = Number(line?.sale_qty || 0);
        if (!Number.isFinite(qty) || qty <= 0) return;
        unitTotals[unitKey] = Number((Number(unitTotals[unitKey] || 0) + qty).toFixed(3));
      });

      const unitPairLabel = String(t("unit_pair") || "Pair").trim();
      const unitDozenLabel = String(t("unit_dozen") || "Dozen").trim();
      const thankYouText =
        t("thank_you_for_your_visit") === "thank_you_for_your_visit"
          ? "THANK YOU FOR YOUR VISIT"
          : t("thank_you_for_your_visit");
      const preparedByText =
        t("prepared_by") === "prepared_by" ? "Prepared By" : t("prepared_by");
      const checkedByText =
        t("checked_by") === "checked_by" ? "Checked By" : t("checked_by");
      const approvedByText =
        t("approved_by") === "approved_by" ? "Approved By" : t("approved_by");

      const summaryRows = [];
      if (Number(unitTotals.dozen || 0) > 0) {
        summaryRows.push({
          labelText: `${t("total")} ${unitDozenLabel}`,
          value: formatNumberDisplay(unitTotals.dozen, { decimals: 3, fallback: "0" }),
        });
      }
      if (Number(unitTotals.pair || 0) > 0) {
        summaryRows.push({
          labelText: `${t("total")} ${unitPairLabel}`,
          value: formatNumberDisplay(unitTotals.pair, { decimals: 3, fallback: "0" }),
        });
      }

      const gatePassView = {
        titleKey: "print_gate_pass",
        subtitleKey: "sales_voucher",
        hideToolbar: Boolean(embedMode),
        topInfo: [
          { labelKey: "voucher_no", value: gatePass?.voucher_no || "-" },
          { labelKey: "date", value: formatDateDisplay(gatePass?.voucher_date, "") || "-" },
          { labelKey: "delivery_method", value: gatePass?.delivery_method || "-" },
          { labelKey: "status", value: gatePass?.status || "-" },
        ],
        metaInfo: [
          { labelKey: "customer_name", value: gatePass?.customer_name || "-" },
          { labelKey: "remarks", value: gatePass?.remarks || "-", full: true },
        ],
        columns: [
          { key: "sr_no", labelKey: "sr_no" },
          { key: "sku_code", labelKey: "sku_code" },
          { key: "item_name", labelKey: "article_name" },
          { key: "unit", labelKey: "unit" },
          { key: "sale_qty", labelKey: "sale_qty", align: "right" },
        ],
        rows: salesRows,
        summaryRows,
        closingNoteText: thankYouText,
        signatures: [
          { labelText: preparedByText },
          { labelText: checkedByText },
          { labelText: approvedByText },
        ],
        cellValue: (line, column, rowIndex) => {
          if (column.key === "sr_no") return rowIndex + 1;
          if (column.key === "unit") {
            return String(line?.row_status || "").trim().toUpperCase() === "LOOSE" ? unitPairLabel : unitDozenLabel;
          }
          if (column.key === "sale_qty") return formatNumberDisplay(line?.sale_qty || 0, { decimals: 3, fallback: "0" });
          return line?.[column.key] || "-";
        },
      };
    %>

    <%- include("../../base/partials/gate-pass-document", { gatePassView }) %>
  </body>
</html>
