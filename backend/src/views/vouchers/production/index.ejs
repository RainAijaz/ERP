<%
  const formatDateInput = (value) => {
    if (!value) return "";
    const asText = String(value);
    const textMatch = asText.match(/^(\d{4}-\d{2}-\d{2})/);
    if (textMatch) return textMatch[1];
    const dt = value instanceof Date ? value : new Date(value);
    if (Number.isNaN(dt.getTime())) return "";
    const yyyy = dt.getFullYear();
    const mm = String(dt.getMonth() + 1).padStart(2, "0");
    const dd = String(dt.getDate()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd}`;
  };
  const selectedVoucherNo = selectedVoucher ? Number(selectedVoucher.voucher_no || 0) : null;
  const suggestedVoucherNo = selectedVoucherNo || (Number(latestVoucherNo || 0) + 1);
  const selectedDate = selectedVoucher && selectedVoucher.voucher_date ? formatDateInput(selectedVoucher.voucher_date) : formatDateInput(new Date());
  const selectedStatus = String(selectedVoucher?.status || "").toUpperCase();
  const isDeletedVoucher = selectedStatus === "REJECTED";
  const statusLabel = selectedStatus === "APPROVED" ? t("approved") : selectedStatus === "REJECTED" ? t("rejected") : t("pending");
  const statusToneClass = selectedStatus === "APPROVED" ? "border-emerald-200 bg-emerald-50 text-emerald-800" : selectedStatus === "REJECTED" ? "border-rose-200 bg-rose-50 text-rose-800" : "border-amber-200 bg-amber-50 text-amber-800";
  const isLoss = mode === "loss";
  const isDcv = mode === "dcv";
  const isPlanning = mode === "planning";
  const isConsumption = mode === "consumption";
  const isLabour = mode === "labour";
  const isAutoGenerated = !!options?.isAutoGeneratedVoucher;
  const canCreateNow = allowCreate === true && !isAutoGenerated;
  const canEditNow = allowEdit === true && !isAutoGenerated;
  const canDeleteNow = allowDelete === true && !isAutoGenerated;
  const canSave = !isDeletedVoucher && ((selectedVoucher ? canEditNow : canCreateNow));
  const canDeleteVoucher = !isDeletedVoucher && !!selectedVoucher && canDeleteNow;
  const initialRows = selectedVoucher?.lines || [];
%>

<style>
  [data-production-form] [data-lines-table] thead th {
    font-size: 11px;
    letter-spacing: 0.08em;
  }
  [data-production-form] [data-lines-table] td {
    padding: 0.2rem 0.35rem;
  }
  [data-production-form] [data-lines-table] tbody tr:nth-child(even) td {
    background-color: #f8fafc;
  }
  [data-production-form] [data-lines-table] tbody tr:hover td {
    background-color: #f1f5f9;
  }
  [data-production-form] [data-lines-table] input,
  [data-production-form] [data-lines-table] select,
  [data-production-form] [data-lines-table] button[data-enhanced-select-trigger="1"] {
    height: 1.95rem !important;
    font-size: 0.76rem !important;
  }
  [data-production-form] [data-voucher-grid] label {
    font-size: 0.9rem;
  }
  [data-production-form] [data-header-nav-btn] {
    min-width: 4.4rem;
    text-align: center;
  }
  [data-production-form] input[readonly],
  [data-production-form] input:disabled,
  [data-production-form] select:disabled,
  [data-production-form] textarea[readonly] {
    background-color: #f1f5f9 !important;
    border-color: #cbd5e1 !important;
    color: #475569 !important;
    cursor: not-allowed;
  }
  [data-production-form] input:focus,
  [data-production-form] select:focus,
  [data-production-form] textarea:focus,
  [data-production-form] [data-searchable-wrapper] > input:focus,
  [data-production-form] [data-lines-table] button[data-enhanced-select-trigger="1"]:focus {
    border-color: #111827 !important;
    box-shadow: 0 0 0 1px #111827 !important;
    outline: none !important;
  }
  @media (max-width: 640px) {
    [data-production-form] [data-lines-table] th {
      white-space: normal;
      overflow-wrap: anywhere;
      word-break: break-word;
      line-height: 1.2;
    }
  }
</style>

<div class="mx-auto w-full max-w-none space-y-3 px-2">
  <section class="rounded-2xl border border-slate-200 bg-white/95 px-4 py-4 shadow-sm">
    <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <h1 class="text-2xl font-display font-semibold tracking-tight text-ink"><%= t(titleKey) %></h1>
        <p class="text-sm text-muted"><%= t("production") %></p>
      </div>
      <% if (selectedVoucher) { %>
        <div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] <%= statusToneClass %>">
          <span><%= t("status") %></span>
          <span class="rounded-full bg-white/80 px-2 py-0.5 text-slate-800"><%= statusLabel %></span>
        </div>
      <% } %>
    </div>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
    <form method="post" action="<%= basePath || '' %>" class="space-y-4" data-production-form data-voucher-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
      <input type="hidden" name="lines_json" value="[]" data-lines-json>

      <div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50/60 p-3">
        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("voucher_no") %></label>
          <div class="lg:col-span-2">
            <input type="text" value="<%= suggestedVoucherNo %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-700" data-voucher-no-input>
          </div>
          <div class="flex flex-wrap items-center gap-2 lg:col-span-8">
            <a href="<%= prevVoucherNo ? ((basePath || '') + '?voucher_no=' + prevVoucherNo + '&view=1') : '#' %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.1em] text-slate-700 <%= prevVoucherNo ? '' : 'pointer-events-none opacity-40' %>" data-header-nav-btn><%= t("prev") %></a>
            <a href="<%= nextVoucherNo ? ((basePath || '') + '?voucher_no=' + nextVoucherNo + '&view=1') : ((basePath || '') + '?new=1') %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.1em] text-slate-700" data-header-nav-btn><%= t("next") %></a>
            <button type="button" class="rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.1em] text-white shadow-sm" data-load-voucher data-header-nav-btn><%= t("load") %></button>
            <div class="ml-auto flex items-center gap-2">
              <button type="button" class="rounded-xl border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.1em] text-rose-700 disabled:opacity-40" data-delete-voucher <%= canDeleteVoucher ? '' : 'disabled' %>><%= t("delete") %></button>
              <button type="button" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.1em] text-slate-700" onclick="window.print()"><%= t("print") %></button>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("date") %></label>
          <div class="lg:col-span-4">
            <input type="date" name="voucher_date" value="<%= selectedDate %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" required <%= canSave ? '' : 'readonly' %>>
          </div>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= t("reference_no") %></label>
          <div class="lg:col-span-4">
            <input type="text" name="reference_no" value="<%= selectedVoucher?.reference_no || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" <%= canSave ? '' : 'readonly' %>>
          </div>
        </div>

        <% if (isDcv) { %>
          <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
            <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("labour") %></label>
            <div class="lg:col-span-4">
              <select
                name="labour_id"
                class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm"
                data-dcv-labour
                data-searchable-select="true"
                data-searchable-variant="unified"
                <%= canSave ? '' : 'disabled' %>
                required
              >
                <option value=""><%= t("select_labour") %></option>
                <% (options.labours || []).forEach((labour) => { %>
                  <option value="<%= labour.id %>" <%= Number(selectedVoucher?.labour_id || 0) === Number(labour.id) ? "selected" : "" %>><%= labour.name %></option>
                <% }) %>
              </select>
            </div>
            <label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= t("department") %></label>
            <div class="lg:col-span-4">
              <select
                name="dept_id"
                class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm"
                data-dcv-department
                data-searchable-select="true"
                data-searchable-variant="unified"
                <%= canSave ? '' : 'disabled' %>
                required
              >
                <option value=""><%= t("select_department") %></option>
                <% (options.departments || []).forEach((department) => { %>
                  <option value="<%= department.id %>" <%= Number(selectedVoucher?.dept_id || 0) === Number(department.id) ? "selected" : "" %>><%= department.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
          <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
            <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("stage") || "Stage" %></label>
            <div class="lg:col-span-10">
              <select
                name="stage_id"
                class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm"
                data-dcv-stage
                data-searchable-select="true"
                data-searchable-variant="unified"
                <%= canSave ? '' : 'disabled' %>
              >
                <option value=""><%= t("select_stage") || "Select Stage" %></option>
                <% (options.productionStages || []).forEach((stage) => { %>
                  <option value="<%= stage.id %>" <%= Number(selectedVoucher?.stage_id || 0) === Number(stage.id) ? "selected" : "" %>>
                    <%= `${stage.name || stage.id}` %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>
        <% } %>

        <% if (isPlanning) { %>
          <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
            <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("plan_kind") %></label>
            <div class="lg:col-span-10">
              <select name="plan_kind" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified" <%= canSave ? '' : 'disabled' %>>
                <option value="FG" <%= String(selectedVoucher?.plan_kind || "FG").toUpperCase() === "FG" ? "selected" : "" %>><%= t("finished") %></option>
                <option value="SFG" <%= String(selectedVoucher?.plan_kind || "FG").toUpperCase() === "SFG" ? "selected" : "" %>><%= t("semi_finished") %></option>
              </select>
            </div>
          </div>
        <% } %>

        <% if (isLoss) { %>
          <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
            <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("reason") %></label>
            <div class="lg:col-span-10">
              <select name="reason_code_id" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-searchable-select="true" data-searchable-variant="unified" <%= canSave ? '' : 'disabled' %>>
                <option value=""><%= t("select_reason") %></option>
                <% (options.reasonCodes || []).forEach((reason) => { %>
                  <option value="<%= reason.id %>" <%= Number(selectedVoucher?.reason_code_id || 0) === Number(reason.id) ? "selected" : "" %>><%= reason.name %></option>
                <% }) %>
              </select>
            </div>
          </div>
        <% } %>

        <div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center" data-voucher-grid>
          <label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= t("remarks") %></label>
          <div class="lg:col-span-10">
            <input type="text" name="remarks" maxlength="1000" value="<%= selectedVoucher?.remarks || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" <%= canSave ? '' : 'readonly' %>>
          </div>
        </div>
      </div>

      <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
          <table class="w-full min-w-[1080px] table-fixed text-xs xl:min-w-full" data-lines-table>
            <thead class="bg-slate-50 text-xs uppercase tracking-[0.12em] text-slate-500">
              <tr data-lines-head-row></tr>
            </thead>
            <tbody data-lines-body></tbody>
            <tfoot>
              <tr class="bg-slate-50">
                <td class="border-t border-slate-200 px-2 py-2 text-xs font-semibold text-slate-700" colspan="5">
                  <div class="flex flex-wrap items-center gap-2">
                    <span class="uppercase tracking-[0.08em]"><%= t("total") %></span>
                    <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t("pairs") || "Pairs" %></span>
                    <input
                      type="text"
                      readonly
                      class="h-8 w-20 rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700"
                      value="0.000"
                      data-total-pairs
                    >
                    <span class="text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500"><%= t("dozens") || "Dozens" %></span>
                    <input
                      type="text"
                      readonly
                      class="h-8 w-20 rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700"
                      value="0.000"
                      data-total-dozens
                    >
                  </div>
                </td>
                <td class="border-t border-slate-200 px-2 py-2 text-right">
                  <input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.00" data-total-amount>
                </td>
                <td class="border-t border-slate-200 px-2 py-2 text-center">
                  <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white p-2 text-slate-700 disabled:opacity-40" data-add-row <%= canSave ? '' : 'disabled' %>>
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
                  </button>
                </td>
                <td class="border-t border-slate-200 px-2 py-2"></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>

      <% if (selectedVoucher?.generated_links && (selectedVoucher.generated_links.consumption_voucher_no || selectedVoucher.generated_links.labour_voucher_no)) { %>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-xs text-slate-600">
          <%= t("consumption_voucher") %>: <strong><%= selectedVoucher.generated_links.consumption_voucher_no || "-" %></strong>
          <span class="mx-2">|</span>
          <%= t("labour_production_voucher") %>: <strong><%= selectedVoucher.generated_links.labour_voucher_no || "-" %></strong>
        </div>
      <% } %>

      <div class="flex items-center justify-center gap-2">
        <button type="submit" class="rounded-xl bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-[0.1em] text-white shadow-sm disabled:opacity-40" <%= canSave ? '' : 'disabled' %>><%= t("confirm") %></button>
      </div>
    </form>

    <form method="post" action="<%= `${basePath}/delete` %>" class="hidden" data-delete-voucher-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
    </form>
  </section>
</div>

<script><%- include("../../base/partials/searchable-select.js") %></script>
<script><%- include("../../base/partials/voucher-row-enter-navigation.js") %></script>
<script>
  (() => {
    const form = document.querySelector("[data-production-form]");
    if (!form) return;

    const mode = <%- JSON.stringify(mode || "production") %>;
    const canSave = <%- JSON.stringify(Boolean(canSave)) %>;
    const options = <%- JSON.stringify(options || {}) %>;
    const initialRows = <%- JSON.stringify(initialRows || []) %>;
    const linesJsonInput = form.querySelector("[data-lines-json]");
    const linesBody = form.querySelector("[data-lines-body]");
    const linesHeadRow = form.querySelector("[data-lines-head-row]");
    const addRowButton = form.querySelector("[data-add-row]");
    const totalAmountInput = form.querySelector("[data-total-amount]");
    const totalPairsInput = form.querySelector("[data-total-pairs]");
    const totalDozensInput = form.querySelector("[data-total-dozens]");
    const dcvLabourSelect = form.querySelector("[data-dcv-labour]");
    const dcvDepartmentSelect = form.querySelector("[data-dcv-department]");
    const dcvStageSelect = form.querySelector("[data-dcv-stage]");
    const rowsState = [];

    const toNum = (value, fallback = 0) => {
      const n = Number(value);
      return Number.isFinite(n) ? n : fallback;
    };
    const toPositiveInt = (value) => {
      const n = Number(value);
      if (!Number.isInteger(n) || n <= 0) return null;
      return n;
    };
    const toQty = (value) => Number(toNum(value, 0).toFixed(3));
    const toAmount = (value) => Number(toNum(value, 0).toFixed(2));
    const showError = (message) => {
      if (!message) return;
      if (typeof window.showVoucherError === "function") {
        window.showVoucherError(message);
        return;
      }
      window.alert(message);
    };

    const isLoss = mode === "loss";
    const isDcv = mode === "dcv";
    const showUnit = mode === "production";
    const showStatus = mode === "planning";
    const productionStages = Array.isArray(options.productionStages) ? options.productionStages : [];
    const defaultStageId = productionStages.length ? toPositiveInt(productionStages[0]?.id) : null;
    const allDepartments = Array.isArray(options.departments)
      ? options.departments
        .map((department) => ({
          id: toPositiveInt(department?.id),
          name: String(department?.name || "").trim(),
        }))
        .filter((department) => department.id)
      : [];
    const labourDeptMap = new Map(
      (Array.isArray(options.labours) ? options.labours : [])
        .map((labour) => {
          const labourId = toPositiveInt(labour?.id);
          if (!labourId) return null;
          const deptIds = new Set(
            (Array.isArray(labour?.dept_ids) ? labour.dept_ids : [])
              .map((deptId) => toPositiveInt(deptId))
              .filter(Boolean),
          );
          return [labourId, deptIds];
        })
        .filter(Boolean),
    );
    const stageRows = (Array.isArray(productionStages) ? productionStages : [])
      .map((stage) => ({
        id: toPositiveInt(stage?.id),
        code: String(stage?.code || "").trim(),
        name: String(stage?.name || "").trim(),
        dept_id: toPositiveInt(stage?.dept_id),
      }))
      .filter((stage) => stage.id && stage.dept_id);

    const syncSearchableReadonlyState = (selectEl) => {
      if (!(selectEl instanceof HTMLSelectElement)) return;
      const wrapper =
        selectEl.closest("[data-searchable-wrapper]")
        || (selectEl.parentElement?.matches?.("[data-searchable-wrapper]")
          ? selectEl.parentElement
          : null);
      const input = wrapper?.querySelector('input[type="text"]');
      if (!(input instanceof HTMLInputElement)) return;
      const isDisabled = selectEl.disabled;
      input.readOnly = isDisabled;
      input.tabIndex = isDisabled ? -1 : 0;
      if (isDisabled) {
        input.setAttribute("aria-disabled", "true");
        input.classList.add("cursor-not-allowed");
        return;
      }
      input.removeAttribute("aria-disabled");
      input.classList.remove("cursor-not-allowed");
    };

    const getAllowedDepartmentsForLabour = (labourId) => {
      const normalizedLabourId = toPositiveInt(labourId);
      if (!normalizedLabourId) return [];
      const allowedDeptIds = labourDeptMap.get(normalizedLabourId);
      if (!(allowedDeptIds instanceof Set) || !allowedDeptIds.size) return [];
      return allDepartments.filter((department) => allowedDeptIds.has(Number(department.id)));
    };

    const refreshDcvDepartmentOptions = ({ preserveSelection = true } = {}) => {
      if (!isDcv) return;
      if (!(dcvLabourSelect instanceof HTMLSelectElement) || !(dcvDepartmentSelect instanceof HTMLSelectElement)) {
        return;
      }
      const selectedLabourId = toPositiveInt(dcvLabourSelect.value);
      const previousDepartmentId = toPositiveInt(dcvDepartmentSelect.value);
      const allowedDepartments = getAllowedDepartmentsForLabour(selectedLabourId);

      const optionsHtml = [`<option value="">${<%- JSON.stringify(t("select_department")) %>}</option>`]
        .concat(
          allowedDepartments.map(
            (department) =>
              `<option value="${department.id}">${department.name}</option>`,
          ),
        )
        .join("");
      dcvDepartmentSelect.innerHTML = optionsHtml;

      if (preserveSelection && previousDepartmentId) {
        const stillAllowed = allowedDepartments.some(
          (department) => Number(department.id) === Number(previousDepartmentId),
        );
        if (stillAllowed) {
          dcvDepartmentSelect.value = String(previousDepartmentId);
        }
      }

      if (!dcvDepartmentSelect.value && canSave && allowedDepartments.length === 1) {
        dcvDepartmentSelect.value = String(allowedDepartments[0].id);
      }

      const shouldDisable = !canSave || !selectedLabourId || allowedDepartments.length === 0;
      if (shouldDisable) {
        dcvDepartmentSelect.setAttribute("disabled", "disabled");
      } else {
        dcvDepartmentSelect.removeAttribute("disabled");
      }
      dcvDepartmentSelect.dispatchEvent(new Event("change", { bubbles: true }));
      syncSearchableReadonlyState(dcvDepartmentSelect);
      syncSearchableReadonlyState(dcvLabourSelect);
    };

    const refreshDcvStageOptions = ({ preserveSelection = true } = {}) => {
      if (!isDcv) return;
      if (!(dcvStageSelect instanceof HTMLSelectElement)) return;
      const selectedDeptId = toPositiveInt(dcvDepartmentSelect?.value);
      const previousStageId = toPositiveInt(dcvStageSelect.value);
      const allowedStages = selectedDeptId
        ? stageRows.filter((stage) => Number(stage.dept_id) === Number(selectedDeptId))
        : [];
      const optionsHtml = [`<option value="">${<%- JSON.stringify(t("select_stage") || "Select Stage") %>}</option>`]
        .concat(
          allowedStages.map(
            (stage) => `<option value="${stage.id}">${stage.name}</option>`,
          ),
        )
        .join("");
      dcvStageSelect.innerHTML = optionsHtml;
      if (preserveSelection && previousStageId) {
        const stillAllowed = allowedStages.some((stage) => Number(stage.id) === Number(previousStageId));
        if (stillAllowed) dcvStageSelect.value = String(previousStageId);
      }
      if (!dcvStageSelect.value && canSave && allowedStages.length === 1) {
        dcvStageSelect.value = String(allowedStages[0].id);
      }
      const shouldDisable = !canSave || !selectedDeptId || allowedStages.length === 0;
      if (shouldDisable) dcvStageSelect.setAttribute("disabled", "disabled");
      else dcvStageSelect.removeAttribute("disabled");
      syncSearchableReadonlyState(dcvStageSelect);
    };

    const buildLossEntityOptions = (lossType, selectedItemId, selectedSkuId) => {
      if (lossType === "RM_LOSS") {
        const base = [`<option value="">${<%- JSON.stringify(t("select_item")) %>}</option>`];
        (options.rmItems || []).forEach((item) => {
          const selected = Number(selectedItemId || 0) === Number(item.id || 0) ? "selected" : "";
          base.push(`<option value="RM:${item.id}" ${selected}>${item.name}</option>`);
        });
        return base.join("");
      }
      const base = [`<option value="">${<%- JSON.stringify(t("select_sku")) %>}</option>`];
      (options.skus || []).forEach((sku) => {
        const selected = Number(selectedSkuId || 0) === Number(sku.id || 0) ? "selected" : "";
        base.push(`<option value="SKU:${sku.id}" ${selected}>${sku.sku_code} - ${sku.item_name || ""}</option>`);
      });
      return base.join("");
    };

    const getSkuLabel = (skuId) => {
      const row = (options.skus || []).find((sku) => Number(sku.id || 0) === Number(skuId || 0));
      if (!row) return "";
      return `${row.sku_code} - ${row.item_name || ""}`;
    };

    const makeRow = (seed = {}) => {
      if (isLoss) {
        return {
          loss_type: String(seed.loss_type || "RM_LOSS").toUpperCase(),
          item_id: Number(seed.item_id || 0) || null,
          sku_id: Number(seed.sku_id || 0) || null,
          dept_id: Number(seed.dept_id || 0) || null,
          qty: toQty(seed.qty || 0),
          rate: toNum(seed.rate, 0),
          amount: toAmount(seed.amount || 0),
        };
      }
      return {
        sku_id: Number(seed.sku_id || 0) || null,
        stage_id: toPositiveInt(seed.stage_id) || defaultStageId,
        status: String(seed.status || "LOOSE").toUpperCase(),
        unit: String(seed.unit || (String(seed.status || "").toUpperCase() === "PACKED" ? "DZN" : "PAIR")).toUpperCase(),
        qty: toQty(seed.qty || 0),
        rate: toNum(seed.rate, 0),
        amount: toAmount(seed.amount || 0),
      };
    };

    const createEmptyRow = () => makeRow({ stage_id: defaultStageId, qty: 0, rate: 0, amount: 0 });

    const setHead = () => {
      if (isLoss) {
        linesHeadRow.innerHTML = `
          <th class="w-40 border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("loss_type")) %>}</th>
          <th class="w-[28rem] border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("item_name")) %>}/${<%- JSON.stringify(t("sku")) %>}</th>
          <th class="w-44 border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("department")) %>}</th>
          <th class="w-32 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("quantity")) %>}</th>
          <th class="w-32 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("rate")) %>}</th>
          <th class="w-36 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("amount")) %>}</th>
          <th class="w-20 border-b border-slate-200 px-2 py-2 text-center">${<%- JSON.stringify(t("actions")) %>}</th>
          <th class="w-20 border-b border-slate-200 px-2 py-2 text-center">${<%- JSON.stringify(t("sr_no")) %>}</th>
        `;
        return;
      }
      if (showUnit) {
        linesHeadRow.innerHTML = `
          <th class="w-[28rem] border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("sku")) %>}</th>
          <th class="w-44 border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("stage") || "Stage") %>}</th>
          <th class="w-40 border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("unit")) %>}</th>
          <th class="w-32 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("quantity")) %>}</th>
          <th class="w-32 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("rate")) %>}</th>
          <th class="w-36 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("amount")) %>}</th>
          <th class="w-20 border-b border-slate-200 px-2 py-2 text-center">${<%- JSON.stringify(t("actions")) %>}</th>
          <th class="w-20 border-b border-slate-200 px-2 py-2 text-center">${<%- JSON.stringify(t("sr_no")) %>}</th>
        `;
        return;
      }
      linesHeadRow.innerHTML = `
        <th class="w-[34rem] border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("sku")) %>}</th>
        <th class="w-40 border-b border-slate-200 px-2 py-2 text-left">${<%- JSON.stringify(t("status")) %>}</th>
        <th class="w-32 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("quantity")) %>}</th>
        <th class="w-32 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("rate")) %>}</th>
        <th class="w-36 border-b border-slate-200 px-2 py-2 text-right">${<%- JSON.stringify(t("amount")) %>}</th>
        <th class="w-20 border-b border-slate-200 px-2 py-2 text-center">${<%- JSON.stringify(t("actions")) %>}</th>
        <th class="w-20 border-b border-slate-200 px-2 py-2 text-center">${<%- JSON.stringify(t("sr_no")) %>}</th>
      `;
    };

    const renderRows = () => {
      if (!rowsState.length) rowsState.push(createEmptyRow());
      const rowsHtml = rowsState.map((row, rowIndex) => {
        if (isLoss) {
          const entityOptions = buildLossEntityOptions(row.loss_type, row.item_id, row.sku_id);
          const deptDisabled = row.loss_type !== "DVC_ABANDON" ? "disabled" : "";
          const deptOptions = [`<option value="">${<%- JSON.stringify(t("select_department")) %>}</option>`]
            .concat((options.departments || []).map((department) => `<option value="${department.id}" ${Number(row.dept_id || 0) === Number(department.id || 0) ? "selected" : ""}>${department.name}</option>`))
            .join("");
          return `
            <tr data-row-index="${rowIndex}">
              <td class="border-b border-slate-200 px-2 py-2"><select data-row-field="loss_type" data-field="loss_type" data-row-index="${rowIndex}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"}>${(options.lossTypes || []).map((type) => `<option value="${type}" ${row.loss_type === type ? "selected" : ""}>${type}</option>`).join("")}</select></td>
              <td class="border-b border-slate-200 px-2 py-2"><select data-row-field="entity_ref" data-field="entity_ref" data-row-index="${rowIndex}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"}>${entityOptions}</select></td>
              <td class="border-b border-slate-200 px-2 py-2"><select data-row-field="dept_id" data-field="dept_id" data-row-index="${rowIndex}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"} ${deptDisabled}>${deptOptions}</select></td>
              <td class="border-b border-slate-200 px-2 py-2"><input data-row-field="qty" data-field="qty" data-row-index="${rowIndex}" type="number" min="0" step="0.001" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${row.qty || 0}" ${canSave ? "" : "readonly"}></td>
              <td class="border-b border-slate-200 px-2 py-2"><input data-row-field="rate" data-field="rate" data-row-index="${rowIndex}" type="number" min="0" step="0.0001" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${row.rate || 0}" ${canSave ? "" : "readonly"}></td>
              <td class="border-b border-slate-200 px-2 py-2"><input data-row-field="amount" data-field="amount" data-row-index="${rowIndex}" type="number" min="0" step="0.01" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${row.amount || 0}" ${canSave ? "" : "readonly"}></td>
              <td class="border-b border-slate-200 px-2 py-2 text-center"><button type="button" data-remove-row="${rowIndex}" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-rose-200 bg-white p-2 text-rose-600 ${canSave ? "" : "opacity-40 pointer-events-none"}" aria-label="${<%- JSON.stringify(t("delete")) %>}" title="${<%- JSON.stringify(t("delete")) %>}"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M9 7V5h6v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M6 7l1 13h10l1-13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg></button></td>
              <td class="border-b border-slate-200 px-2 py-2 text-center font-semibold text-slate-600">${rowIndex + 1}</td>
            </tr>
          `;
        }

        const skuOptions = [`<option value="">${<%- JSON.stringify(t("select_sku")) %>}</option>`]
          .concat((options.skus || []).map((sku) => `<option value="${sku.id}" ${Number(row.sku_id || 0) === Number(sku.id || 0) ? "selected" : ""}>${sku.sku_code} - ${sku.item_name || ""}</option>`))
          .join("");
        const secondFieldName = showUnit ? "unit" : "status";
        const secondFieldValue = showUnit ? (row.unit || "PAIR") : (row.status || "LOOSE");
        const secondFieldDisabled = (showUnit || showStatus) ? "" : "disabled";
        const secondOptionsHtml = showUnit
          ? `<option value="PAIR" ${secondFieldValue === "PAIR" ? "selected" : ""}>${<%- JSON.stringify(t("unit_pair")) %>}</option><option value="DZN" ${secondFieldValue === "DZN" ? "selected" : ""}>${<%- JSON.stringify(t("unit_dozen")) %>}</option>`
          : `<option value="LOOSE" ${secondFieldValue === "LOOSE" ? "selected" : ""}>LOOSE</option><option value="PACKED" ${secondFieldValue === "PACKED" ? "selected" : ""}>PACKED</option>`;
        const stageOptions = [`<option value="">${<%- JSON.stringify(t("select_stage") || "Select Stage") %>}</option>`]
          .concat(productionStages.map((stage) => {
            const selected = Number(row.stage_id || 0) === Number(stage.id || 0) ? "selected" : "";
            const label = `${stage.name || stage.id}`;
            return `<option value="${stage.id}" ${selected}>${label}</option>`;
          }))
          .join("");
        const stageCellHtml = showUnit
          ? `<td class="border-b border-slate-200 px-2 py-2"><select data-row-field="stage_id" data-field="stage_id" data-row-index="${rowIndex}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"}>${stageOptions}</select></td>`
          : "";
        const qtyStep = showUnit
          ? ((secondFieldValue === "DZN") ? "0.5" : "1")
          : ((secondFieldValue === "PACKED") ? "0.5" : "1");
        return `
          <tr data-row-index="${rowIndex}">
            <td class="border-b border-slate-200 px-2 py-2"><select data-row-field="sku_id" data-field="sku_id" data-row-index="${rowIndex}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"}>${skuOptions}</select></td>
            ${stageCellHtml}
            <td class="border-b border-slate-200 px-2 py-2"><select data-row-field="${secondFieldName}" data-field="${secondFieldName}" data-row-index="${rowIndex}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"} ${secondFieldDisabled}>${secondOptionsHtml}</select></td>
            <td class="border-b border-slate-200 px-2 py-2"><input data-row-field="qty" data-field="qty" data-row-index="${rowIndex}" type="number" min="0" step="${qtyStep}" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${row.qty || 0}" ${canSave ? "" : "readonly"}></td>
            <td class="border-b border-slate-200 px-2 py-2"><input data-row-field="rate" data-field="rate" data-row-index="${rowIndex}" type="number" min="0" step="0.0001" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${row.rate || 0}" ${canSave ? "" : "readonly"}></td>
            <td class="border-b border-slate-200 px-2 py-2"><input data-row-field="amount" data-field="amount" data-row-index="${rowIndex}" type="number" min="0" step="0.01" class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right text-xs" value="${row.amount || 0}" ${canSave ? "" : "readonly"}></td>
            <td class="border-b border-slate-200 px-2 py-2 text-center"><button type="button" data-remove-row="${rowIndex}" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-rose-200 bg-white p-2 text-rose-600 ${canSave ? "" : "opacity-40 pointer-events-none"}" aria-label="${<%- JSON.stringify(t("delete")) %>}" title="${<%- JSON.stringify(t("delete")) %>}"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 7h16" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M9 7V5h6v2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M10 11v6M14 11v6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path><path d="M6 7l1 13h10l1-13" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg></button></td>
            <td class="border-b border-slate-200 px-2 py-2 text-center font-semibold text-slate-600">${rowIndex + 1}</td>
          </tr>
        `;
      }).join("");

      linesBody.innerHTML = rowsHtml;
      if (typeof window.initSearchableSelects === "function") window.initSearchableSelects();
      Array.from(linesBody.querySelectorAll("tr[data-row-index]")).forEach((rowEl) => {
        syncQtyStepForRow(rowEl);
      });
      syncTotals();
    };

    const syncTotals = () => {
      const totalAmount = rowsState.reduce((sum, row) => sum + toAmount(row.amount), 0);
      const totalPairs = rowsState.reduce((sum, row) => {
        if (isLoss) return sum;
        if (!toPositiveInt(row?.sku_id)) return sum;
        const qty = toNum(row?.qty, 0);
        if (qty <= 0) return sum;
        const unit = String(showUnit ? row?.unit : row?.status === "PACKED" ? "DZN" : "PAIR").toUpperCase();
        return sum + (unit === "DZN" ? (qty * 12) : qty);
      }, 0);
      const totalDozens = totalPairs / 12;

      if (totalAmountInput instanceof HTMLInputElement) {
        totalAmountInput.value = totalAmount.toFixed(2);
      }
      if (totalPairsInput instanceof HTMLInputElement) {
        totalPairsInput.value = totalPairs.toFixed(3);
      }
      if (totalDozensInput instanceof HTMLInputElement) {
        totalDozensInput.value = totalDozens.toFixed(3);
      }
    };

    const syncRowFromDom = (rowEl) => {
      const rowIndex = Number(rowEl?.getAttribute("data-row-index") || -1);
      if (rowIndex < 0 || !rowsState[rowIndex]) return false;
      const row = rowsState[rowIndex];
      if (isLoss) {
        row.loss_type = String(rowEl.querySelector('[data-field="loss_type"]')?.value || row.loss_type || "RM_LOSS").toUpperCase();
        const entityRef = String(rowEl.querySelector('[data-field="entity_ref"]')?.value || "");
        row.item_id = entityRef.startsWith("RM:") ? Number(entityRef.split(":")[1] || 0) || null : null;
        row.sku_id = entityRef.startsWith("SKU:") ? Number(entityRef.split(":")[1] || 0) || null : null;
        row.dept_id = Number(rowEl.querySelector('[data-field="dept_id"]')?.value || 0) || null;
      } else {
        row.sku_id = Number(rowEl.querySelector('[data-field="sku_id"]')?.value || 0) || null;
        row.stage_id = Number(rowEl.querySelector('[data-field="stage_id"]')?.value || 0) || null;
        if (showUnit) {
          row.unit = String(rowEl.querySelector('[data-field="unit"]')?.value || row.unit || "PAIR").toUpperCase();
          row.status = row.unit === "DZN" ? "PACKED" : "LOOSE";
        } else {
          row.status = showStatus ? String(rowEl.querySelector('[data-field="status"]')?.value || row.status || "LOOSE").toUpperCase() : "LOOSE";
          row.unit = row.status === "PACKED" ? "DZN" : "PAIR";
        }
      }
      row.qty = toQty(rowEl.querySelector('[data-field="qty"]')?.value || row.qty || 0);
      row.rate = toNum(rowEl.querySelector('[data-field="rate"]')?.value || row.rate || 0);
      row.amount = toAmount(rowEl.querySelector('[data-field="amount"]')?.value || (row.qty * row.rate));
      return true;
    };

    const syncAllRowsFromDom = () => {
      Array.from(linesBody.querySelectorAll("tr")).forEach((rowEl) => {
        syncRowFromDom(rowEl);
      });
      syncTotals();
    };

    const syncQtyStepForRow = (rowEl) => {
      if (!(rowEl instanceof HTMLElement)) return;
      const rowIndex = Number(rowEl.getAttribute("data-row-index") || -1);
      if (rowIndex < 0 || !rowsState[rowIndex]) return;
      const row = rowsState[rowIndex];
      const qtyInput = rowEl.querySelector('[data-field="qty"]');
      if (!(qtyInput instanceof HTMLInputElement)) return;
      if (showUnit) {
        qtyInput.step = String((row.unit || "PAIR").toUpperCase() === "DZN" ? "0.5" : "1");
        return;
      }
      qtyInput.step = String((row.status || "LOOSE").toUpperCase() === "PACKED" ? "0.5" : "1");
    };

    const addRow = () => {
      rowsState.push(createEmptyRow());
      renderRows();
    };

    const removeRow = (rowIndex) => {
      rowsState.splice(rowIndex, 1);
      if (!rowsState.length) rowsState.push(createEmptyRow());
      renderRows();
    };

    const serializeRows = () => {
      if (isLoss) {
        return rowsState.map((row) => ({
          loss_type: row.loss_type,
          item_id: row.item_id || null,
          sku_id: row.sku_id || null,
          dept_id: row.dept_id || null,
          qty: toQty(row.qty),
          rate: toNum(row.rate, 0),
          amount: toAmount(row.amount),
        }));
      }
      return rowsState.map((row) => ({
        sku_id: row.sku_id || null,
        stage_id: showUnit ? (row.stage_id || null) : null,
        unit: row.unit || (row.status === "PACKED" ? "DZN" : "PAIR"),
        status: row.status || "LOOSE",
        qty: toQty(row.qty),
        rate: toNum(row.rate, 0),
        amount: toAmount(row.amount),
      }));
    };

    const validateRows = () => {
      const lines = serializeRows().filter((line) => toNum(line.qty, 0) > 0 || line.sku_id || line.item_id);
      if (!lines.length) {
        showError(<%- JSON.stringify(t("voucher_lines_required") || "Voucher lines are required") %>);
        return null;
      }
      for (let i = 0; i < lines.length; i += 1) {
        const line = lines[i];
        const lineNo = i + 1;
        if (isLoss) {
          if (!line.loss_type) {
            showError(`Line ${lineNo}: ${<%- JSON.stringify(t("loss_type")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
            return null;
          }
          if (line.loss_type === "RM_LOSS" && !line.item_id) {
            showError(`Line ${lineNo}: ${<%- JSON.stringify(t("item_name")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
            return null;
          }
          if (line.loss_type !== "RM_LOSS" && !line.sku_id) {
            showError(`Line ${lineNo}: ${<%- JSON.stringify(t("sku")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
            return null;
          }
          if (line.loss_type === "DVC_ABANDON" && !line.dept_id) {
            showError(`Line ${lineNo}: ${<%- JSON.stringify(t("department")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
            return null;
          }
        } else if (!line.sku_id) {
          showError(`Line ${lineNo}: ${<%- JSON.stringify(t("sku")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
          return null;
        }
        if (showUnit && productionStages.length && !toPositiveInt(line.stage_id)) {
          showError(`Line ${lineNo}: ${<%- JSON.stringify(t("stage") || "Stage") %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
          return null;
        }
        if (toNum(line.qty, 0) <= 0) {
          showError(`Line ${lineNo}: ${<%- JSON.stringify(t("quantity")) %>} ${<%- JSON.stringify(t("must_be_positive") || "must be greater than zero") %>}`);
          return null;
        }
      }
      return lines;
    };

    setHead();
    if (initialRows.length) {
      initialRows.forEach((row) => rowsState.push(makeRow(row)));
    } else {
      rowsState.push(createEmptyRow());
    }
    renderRows();
    refreshDcvDepartmentOptions({ preserveSelection: true });
    refreshDcvStageOptions({ preserveSelection: true });

    if (isDcv && dcvLabourSelect instanceof HTMLSelectElement) {
      dcvLabourSelect.addEventListener("change", () => {
        refreshDcvDepartmentOptions({ preserveSelection: false });
        refreshDcvStageOptions({ preserveSelection: false });
      });
    }
    if (isDcv && dcvDepartmentSelect instanceof HTMLSelectElement) {
      dcvDepartmentSelect.addEventListener("change", () => {
        refreshDcvStageOptions({ preserveSelection: false });
      });
    }

    addRowButton?.addEventListener("click", () => {
      if (!canSave) return;
      syncAllRowsFromDom();
      addRow();
    });

    linesBody.addEventListener("click", (event) => {
      const button = event.target.closest("[data-remove-row]");
      if (!button || !canSave) return;
      const rowIndex = Number(button.getAttribute("data-remove-row") || -1);
      if (rowIndex < 0) return;
      syncAllRowsFromDom();
      removeRow(rowIndex);
    });

    linesBody.addEventListener("input", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      if (!target.hasAttribute("data-field") && !target.hasAttribute("data-row-field")) return;
      const rowEl = target.closest("tr[data-row-index]");
      if (!rowEl) return;
      if (!syncRowFromDom(rowEl)) return;
      syncTotals();
    });

    linesBody.addEventListener("change", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const rowEl = target.closest("tr[data-row-index]");
      if (!rowEl) return;
      if (!syncRowFromDom(rowEl)) return;
      const field = String(target.getAttribute("data-field") || target.getAttribute("data-row-field") || "").trim();
      if (isLoss && field === "loss_type") {
        renderRows();
        const rowIndex = Number(rowEl.getAttribute("data-row-index") || -1);
        window.setTimeout(() => {
          const nextField = linesBody.querySelector(`tr[data-row-index="${rowIndex}"] [data-row-field="entity_ref"]`);
          if (!(nextField instanceof HTMLElement)) return;
          const focusHelper = window.VoucherRowEnterNavigation?.focusFieldElement;
          if (typeof focusHelper === "function") {
            focusHelper(nextField, { openSearchable: true });
            return;
          }
          nextField.focus();
        }, 0);
        return;
      }
      if (!isLoss && (field === "unit" || field === "status")) {
        syncQtyStepForRow(rowEl);
      }
      syncTotals();
    });

    const rowNavigator = window.createVoucherRowEnterNavigator?.({
      form,
      linesBody,
      fieldAttr: "data-row-field",
      fieldOrder: isLoss
        ? ["loss_type", "entity_ref", "dept_id", "qty", "rate", "amount"]
        : showUnit
          ? ["sku_id", "stage_id", "unit", "qty", "rate", "amount"]
          : ["sku_id", "status", "qty", "rate", "amount"],
      appendRow: () => {
        if (!canSave) return false;
        syncAllRowsFromDom();
        addRow();
        return true;
      },
      canAppendRow: () => Boolean(canSave),
    });
    rowNavigator?.bind();

    form.addEventListener("submit", (event) => {
      if (!canSave) {
        event.preventDefault();
        return;
      }
      if (isDcv) {
        const labourId = toPositiveInt(dcvLabourSelect?.value);
        const departmentId = toPositiveInt(dcvDepartmentSelect?.value);
        const stageId = toPositiveInt(dcvStageSelect?.value);
        if (!labourId) {
          showError(`${<%- JSON.stringify(t("labour")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
          event.preventDefault();
          return;
        }
        if (!departmentId) {
          showError(`${<%- JSON.stringify(t("department")) %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
          event.preventDefault();
          return;
        }
        if (productionStages.length > 0 && !stageId) {
          showError(`${<%- JSON.stringify(t("stage") || "Stage") %>} ${<%- JSON.stringify(t("is_required") || "is required") %>}`);
          event.preventDefault();
          return;
        }
      }
      syncAllRowsFromDom();
      const validatedLines = validateRows();
      if (!validatedLines) {
        event.preventDefault();
        return;
      }
      linesJsonInput.value = JSON.stringify(validatedLines);
    });

    form.querySelector("[data-load-voucher]")?.addEventListener("click", () => {
      const voucherNo = Number(form.querySelector("[data-voucher-no-input]")?.value || 0);
      if (!Number.isInteger(voucherNo) || voucherNo <= 0) return;
      const url = `${window.location.pathname}?voucher_no=${voucherNo}&view=1`;
      window.location.assign(url);
    });

    const deleteForm = document.querySelector("[data-delete-voucher-form]");
    form.querySelector("[data-delete-voucher]")?.addEventListener("click", () => {
      if (!deleteForm) return;
      deleteForm.submit();
    });
  })();
</script>
