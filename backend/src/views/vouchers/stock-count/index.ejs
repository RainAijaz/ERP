<%
	const formatDateInput = (value) => {
		if (!value) return "";
		const asText = String(value);
		const textMatch = asText.match(/^(\d{4}-\d{2}-\d{2})/);
		if (textMatch) return textMatch[1];
		const dt = value instanceof Date ? value : new Date(value);
		if (Number.isNaN(dt.getTime())) return "";
		const yyyy = dt.getFullYear();
		const mm = String(dt.getMonth() + 1).padStart(2, "0");
		const dd = String(dt.getDate()).padStart(2, "0");
		return `${yyyy}-${mm}-${dd}`;
	};

	const selectedVoucherNo = selectedVoucher ? Number(selectedVoucher.voucher_no || 0) : null;
	const suggestedVoucherNo = selectedVoucherNo || (Number(latestVoucherNo || 0) + 1);
	const selectedDate = selectedVoucher && selectedVoucher.voucher_date
		? formatDateInput(selectedVoucher.voucher_date)
		: formatDateInput(new Date());
	const selectedStatus = String(selectedVoucher?.status || "").toUpperCase();
	const isDeletedVoucher = selectedStatus === "REJECTED";
	const statusLabel = selectedStatus === "APPROVED" ? t("approved") : selectedStatus === "REJECTED" ? t("rejected") : selectedStatus === "PENDING" ? t("pending") : selectedStatus;
	const statusToneClass = selectedStatus === "APPROVED" ? "border-emerald-200 bg-emerald-50 text-emerald-800" : selectedStatus === "REJECTED" ? "border-rose-200 bg-rose-50 text-rose-800" : "border-amber-200 bg-amber-50 text-amber-800";
	const defaultStockType = String(selectedVoucher?.stock_type || "FG").toUpperCase();

	const canCreateVoucher = typeof allowCreate === "boolean" ? allowCreate : true;
	const canEditVoucher = typeof allowEdit === "boolean" ? allowEdit : true;
	const canDeleteVoucher = typeof allowDelete === "boolean" ? allowDelete : true;
	const canSaveVoucher = !isDeletedVoucher && (selectedVoucher ? canEditVoucher : canCreateVoucher);
	const canDeleteCurrentVoucher = !!selectedVoucher && !isDeletedVoucher && canDeleteVoucher;

	const toFriendlyLabel = (key, fallback = "") => {
		const translated = String(t(key) || "").trim();
		if (translated && translated !== key) return translated;
		if (fallback) return fallback;
		return String(key || "")
			.trim()
			.toLowerCase()
			.replace(/[_-]+/g, " ")
			.replace(/\b[a-z]/g, (ch) => ch.toUpperCase());
	};
%>

<style>
	[data-stock-count-form] [data-lines-table] thead th {
		font-size: 10.5px;
		letter-spacing: 0.08em;
	}
	[data-stock-count-form] [data-lines-table] td {
		padding: 0.3rem 0.4rem;
	}
	[data-stock-count-form] [data-lines-table] tbody tr:nth-child(even) td {
		background-color: #f8fafc;
	}
	[data-stock-count-form] [data-lines-table] tbody tr:hover td {
		background-color: #f1f5f9;
	}
	[data-stock-count-form] [data-lines-table] input,
	[data-stock-count-form] [data-lines-table] select,
	[data-stock-count-form] [data-lines-table] button[data-enhanced-select-trigger="1"] {
		height: 2.15rem !important;
		font-size: 0.82rem !important;
	}
	[data-stock-count-form] input[readonly],
	[data-stock-count-form] input:disabled,
	[data-stock-count-form] select:disabled,
	[data-stock-count-form] textarea[readonly] {
		background-color: #f1f5f9 !important;
		border-color: #cbd5e1 !important;
		color: #475569 !important;
		cursor: not-allowed;
	}
</style>

<div class="mx-auto w-full max-w-none space-y-3 px-2">
	<section class="rounded-2xl border border-slate-200 bg-white/95 px-4 py-4 shadow-sm">
		<div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
			<div>
				<h1 class="text-2xl font-display font-semibold tracking-tight text-ink"><%= toFriendlyLabel("stock_count_adjustment_voucher", "Stock Count Voucher") %></h1>
				<p class="text-sm text-muted"><%= toFriendlyLabel("inventory", "Inventory") %></p>
			</div>
			<% if (selectedVoucher) { %>
				<div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] <%= statusToneClass %>">
					<span><%= toFriendlyLabel("status", "Status") %></span>
					<span class="rounded-full bg-white/80 px-2 py-0.5 text-slate-800"><%= statusLabel %></span>
				</div>
			<% } %>
		</div>
	</section>

	<section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
		<form method="post" action="<%= basePath || '' %>" class="space-y-4" data-stock-count-form data-voucher-form>
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
			<input type="hidden" name="lines_json" value="[]" data-lines-json>

			<div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50/60 p-3">
				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("voucher_no", "Voucher No") %></label>
					<div class="lg:col-span-2">
						<input type="text" value="<%= suggestedVoucherNo %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-700" data-voucher-no-input>
					</div>
					<div class="flex flex-wrap items-center gap-2 lg:col-span-8">
						<a href="<%= prevVoucherNo ? ((basePath || '') + '?voucher_no=' + prevVoucherNo + '&view=1') : '#' %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 <%= prevVoucherNo ? '' : 'pointer-events-none opacity-40' %>"><%= toFriendlyLabel("prev", "Prev") %></a>
						<a href="<%= nextVoucherNo ? ((basePath || '') + '?voucher_no=' + nextVoucherNo + '&view=1') : ((basePath || '') + '?new=1') %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= toFriendlyLabel("next", "Next") %></a>
						<button type="button" class="rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm" data-load-voucher><%= toFriendlyLabel("load", "Load") %></button>
						<div class="ml-auto flex items-center gap-2">
							<button type="button" class="rounded-xl border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-rose-700 disabled:opacity-40" data-delete-voucher <%= canDeleteCurrentVoucher ? '' : 'disabled' %>><%= toFriendlyLabel("delete", "Delete") %></button>
							<button type="button" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700" onclick="window.print()"><%= toFriendlyLabel("print", "Print") %></button>
						</div>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("date", "Date") %></label>
					<div class="lg:col-span-4">
						<input type="date" name="voucher_date" value="<%= selectedDate %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" required <%= canSaveVoucher ? '' : 'readonly' %>>
					</div>
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= toFriendlyLabel("stock_type", "Stock Type") %></label>
					<div class="lg:col-span-4">
						<select name="stock_type" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-stock-type data-searchable-select="true" data-searchable-variant="unified" <%= canSaveVoucher ? '' : 'disabled' %>>
							<% (options.stockTypes || []).forEach((entry) => { %>
								<option value="<%= entry.value %>" <%= String(defaultStockType || 'FG').toUpperCase() === String(entry.value || '').toUpperCase() ? 'selected' : '' %>><%= toFriendlyLabel(entry.labelKey || entry.value, entry.value) %></option>
							<% }) %>
						</select>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("reason", "Reason") %></label>
					<div class="lg:col-span-4">
						<select name="reason_code_id" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-reason-code data-searchable-select="true" data-searchable-variant="unified" required <%= canSaveVoucher ? '' : 'disabled' %>>
							<option value=""><%= toFriendlyLabel("select_reason", "Select Reason") %></option>
							<% (options.reasonCodes || []).forEach((reason) => { %>
								<option value="<%= reason.id %>" data-requires-notes="<%= reason.requires_notes ? '1' : '0' %>" data-reason-value="<%= reason.code || '' %>" <%= Number(selectedVoucher?.reason_code_id || 0) === Number(reason.id) ? 'selected' : '' %>><%= reason.name %></option>
							<% }) %>
						</select>
					</div>
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= toFriendlyLabel("reason_notes", "Reason Notes") %></label>
					<div class="lg:col-span-4">
						<input type="text" name="reason_notes" maxlength="1000" value="<%= selectedVoucher?.reason_notes || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-reason-notes <%= canSaveVoucher ? '' : 'readonly' %>>
					</div>
				</div>

				<% if (isDeletedVoucher) { %>
					<div class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800">
						<%= toFriendlyLabel("voucher_deleted_read_only", "Voucher is deleted and read-only.") %>
					</div>
				<% } %>
			</div>

			<div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
				<div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
					<table class="w-full min-w-280 table-fixed text-xs" data-lines-table>
						<thead class="bg-slate-50 text-xs uppercase tracking-[0.12em] text-slate-500">
							<tr data-lines-head-row></tr>
						</thead>
						<tbody data-lines-body="stock-count"></tbody>
						<tfoot data-lines-footer></tfoot>
					</table>
				</div>
			</div>

			<div class="flex items-center justify-center gap-2">
				<button type="submit" class="rounded-xl bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" <%= canSaveVoucher ? '' : 'disabled' %>><%= toFriendlyLabel("confirm", "Confirm") %></button>
			</div>
		</form>

		<form method="post" action="<%= `${basePath}/delete` %>" class="hidden" data-delete-voucher-form>
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
		</form>
	</section>
</div>

<script>
	(() => {
		const form = document.querySelector("[data-stock-count-form]");
		if (!form) return;

		const options = <%- JSON.stringify(options || {}) %>;
		const initialVoucher = <%- JSON.stringify(selectedVoucher || null) %>;
		const basePath = <%- JSON.stringify(basePath || "") %>;
		const canSave = <%- JSON.stringify(Boolean(canSaveVoucher)) %>;
		const reasonRequiredMessage = <%- JSON.stringify(toFriendlyLabel("reason_required", "Reason is required.")) %>;
		const reasonNotesRequiredMessage = <%- JSON.stringify(toFriendlyLabel("reason_notes_required", "Reason notes are required.")) %>;
		const deleteConfirmMessage = <%- JSON.stringify(toFriendlyLabel("confirm_delete", "Are you sure?")) %>;
		const atLeastOneValidLineMessage = <%- JSON.stringify(toFriendlyLabel("at_least_one_valid_line_required", "At least one valid line is required.")) %>;

		const showUiMessage = (message) => {
			const text = String(message || "").trim();
			if (!text) return;
			if (typeof window.showVoucherError === "function") {
				window.showVoucherError(text);
				return;
			}
			window.alert(text);
		};

		const confirmUi = async (message) => {
			const text = String(message || "").trim();
			if (!text) return true;
			if (typeof window.showUiConfirmModal === "function") {
				return window.showUiConfirmModal({ message: text });
			}
			return window.confirm(text);
		};

		const stockTypeValues = ["FG", "SFG", "RM"];
		const PHYSICAL_COUNT_REASON_CODES = new Set(["PHYSICALCOUNT", "PHYSICALCOUNTCORRECTION"]);
		const toNum = (value, fallback = 0) => {
			const n = Number(value);
			return Number.isFinite(n) ? n : fallback;
		};
		const toInt = (value) => {
			const n = Number(value);
			if (!Number.isInteger(n) || n <= 0) return null;
			return n;
		};
		const qty3 = (value) => Number(toNum(value, 0).toFixed(3));
		const rate6 = (value) => Number(toNum(value, 0).toFixed(6));
		const amount2 = (value) => Number(toNum(value, 0).toFixed(2));

		const isTruthyFlag = (value) => {
			if (value === true) return true;
			if (value === false || value === null || value === undefined) return false;
			if (typeof value === "string") {
				const normalized = value.trim().toLowerCase();
				return ["1", "true", "t", "yes", "y"].includes(normalized);
			}
			return Number(value) === 1;
		};

		const isBaseUnitOption = (option) => isTruthyFlag(option?.is_base);

		const resolveFgSnapshotByStatus = ({ sku, requestedStatus }) => {
			const normalizedRequested = String(requestedStatus || "").toUpperCase() === "PACKED" ? "PACKED" : "LOOSE";
			const looseQty = qty3(Number(sku?.system_loose_qty_pairs || 0));
			const packedQty = qty3(Number(sku?.system_packed_qty_pairs || 0));
			const looseWac = rate6(Number(sku?.system_loose_wac || 0));
			const packedWac = rate6(Number(sku?.system_packed_wac || 0));

			const pickByStatus = (status) => status === "PACKED"
				? { qtyPairs: packedQty, wac: packedWac }
				: { qtyPairs: looseQty, wac: looseWac };

			const preferred = pickByStatus(normalizedRequested);
			return {
				rowStatus: normalizedRequested,
				qtyPairs: qty3(preferred.qtyPairs || 0),
				wac: rate6(preferred.wac || 0),
			};
		};

		const normalizeStockType = (value) => {
			const normalized = String(value || "").trim().toUpperCase();
			return stockTypeValues.includes(normalized) ? normalized : "FG";
		};
		const normalizeReasonCode = (value) => String(value || "").replace(/[^a-z0-9]+/gi, "").toUpperCase();

		const stockTypeSelect = form.querySelector("[data-stock-type]");
		const reasonSelect = form.querySelector("[data-reason-code]");
		const reasonNotes = form.querySelector("[data-reason-notes]");
		const voucherNoInput = form.querySelector("[data-voucher-no-input]");
		const loadVoucherButton = form.querySelector("[data-load-voucher]");
		const linesJsonInput = form.querySelector("[data-lines-json]");
		const linesBody = form.querySelector("[data-lines-body]");
		const linesHeadRow = form.querySelector("[data-lines-head-row]");
		const linesFooter = form.querySelector("[data-lines-footer]");
		const deleteButton = form.querySelector("[data-delete-voucher]");
		const deleteForm = document.querySelector("[data-delete-voucher-form]");

		const skuList = Array.isArray(options.skus) ? options.skus : [];
		const rmItems = Array.isArray(options.rmItems) ? options.rmItems : [];
		const skuMap = new Map(skuList.map((entry) => [Number(entry.id), entry]));
		const rmMap = new Map(rmItems.map((entry) => [Number(entry.id), entry]));
		const rmColorPolicy = options.rawMaterialColorPolicyByItem || {};
		const rmSizePolicy = options.rawMaterialSizePolicyByItem || {};
		const rmRatesByItem = options.rawMaterialRatesByItem || {};
		const rmSnapshotByKey = options.rmSnapshotByKey || {};
		const isPhysicalCountReasonActive = () => {
			if (!reasonSelect) return false;
			const selected = reasonSelect.options[reasonSelect.selectedIndex];
			const code = selected ? selected.getAttribute("data-reason-value") : "";
			return PHYSICAL_COUNT_REASON_CODES.has(normalizeReasonCode(code));
		};

		const rowTemplate = (stockType) => ({
			sku_id: null,
			item_id: null,
			color_id: null,
			size_id: null,
			uom_id: null,
			row_status: stockType === "FG" ? "LOOSE" : null,
			system_qty: 0,
			qty_in: 0,
			qty_out: 0,
			physical_qty: 0,
			counted_stock_qty: null,
			difference_qty: 0,
			rate: 0,
			amount: 0,
		});

		let rowsState = [];
		let unbindNavigator = null;
		let pendingEnterFocus = null;
		let totalSystemQtyInput = null;
		let totalCountedQtyInput = null;
		let totalQtyInInput = null;
		let totalQtyOutInput = null;
		let totalDiffInput = null;
		let totalAmountInput = null;
		let totalQtyByUnitRow = null;
		let totalQtyByUnitWrap = null;

		const currentStockType = () => normalizeStockType(stockTypeSelect?.value);

		const getUomOptions = (row, stockType) => {
			if (stockType === "RM") {
				const item = rmMap.get(Number(row.item_id || 0));
				return Array.isArray(item?.unit_options) ? item.unit_options : [];
			}
			const sku = skuMap.get(Number(row.sku_id || 0));
			return Array.isArray(sku?.unit_options) ? sku.unit_options : [];
		};

		const getRowUnitLabel = (row, stockType) => {
			const unitOptions = getUomOptions(row, stockType);
			const matched = unitOptions.find((entry) => Number(entry?.id || 0) === Number(row?.uom_id || 0));
			return String(matched?.name || matched?.code || "").trim();
		};

		const defaultUomId = (row, stockType) => {
			const optionsList = getUomOptions(row, stockType);
			if (!optionsList.length) return null;
			const preferredNonBase = optionsList.find((entry) => !isBaseUnitOption(entry));
			return toInt((preferredNonBase || optionsList[0])?.id);
		};

		const resolveRmRate = (row) => {
			const itemId = toInt(row.item_id);
			if (!itemId) return 0;
			const itemRates = Array.isArray(rmRatesByItem[String(itemId)]) ? rmRatesByItem[String(itemId)] : [];
			const colorId = toInt(row.color_id);
			const sizeId = toInt(row.size_id);

			const exact = itemRates.find((entry) => Number(entry?.color_id || 0) === Number(colorId || 0) && Number(entry?.size_id || 0) === Number(sizeId || 0));
			if (exact) return rate6(exact.purchase_rate);

			const colorOnly = itemRates.find((entry) => Number(entry?.color_id || 0) === Number(colorId || 0) && Number(entry?.size_id || 0) === 0);
			if (colorOnly) return rate6(colorOnly.purchase_rate);

			const sizeOnly = itemRates.find((entry) => Number(entry?.color_id || 0) === 0 && Number(entry?.size_id || 0) === Number(sizeId || 0));
			if (sizeOnly) return rate6(sizeOnly.purchase_rate);

			const fallback = itemRates.find((entry) => Number(entry?.color_id || 0) === 0 && Number(entry?.size_id || 0) === 0);
			return fallback ? rate6(fallback.purchase_rate) : 0;
		};

		const getRmColorState = (itemId) => {
			const normalizedItemId = toInt(itemId);
			if (!normalizedItemId) return { entries: [], allowNone: true, disabled: true };
			const policy = rmColorPolicy[String(normalizedItemId)] || null;
			const entries = Array.isArray(policy?.colors)
				? policy.colors.map((entry) => ({ id: toInt(entry?.id), name: String(entry?.name || "").trim() })).filter((entry) => entry.id)
				: [];
			if (policy?.hasAnyRate) {
				return {
					entries,
					allowNone: policy.hasColorless === true || entries.length === 0,
					disabled: entries.length === 0 && policy.hasColorless !== true,
				};
			}
			return { entries: [], allowNone: true, disabled: true };
		};

		const getRmSizeState = (itemId) => {
			const normalizedItemId = toInt(itemId);
			if (!normalizedItemId) return { entries: [], allowNone: true, disabled: true };
			const policy = rmSizePolicy[String(normalizedItemId)] || null;
			const entries = Array.isArray(policy?.sizes)
				? policy.sizes.map((entry) => ({ id: toInt(entry?.id), name: String(entry?.name || "").trim() })).filter((entry) => entry.id)
				: [];
			if (policy?.hasAnyRate) {
				return {
					entries,
					allowNone: policy.hasSizeless === true || entries.length === 0,
					disabled: entries.length === 0 && policy.hasSizeless !== true,
				};
			}
			return { entries: [], allowNone: true, disabled: true };
		};

		const resolveSystemSnapshot = (row, stockType, selectedUnit) => {
			// System quantity/rate snapshots always come from current stock balances and are read-only in UI.
			const factor = Number(selectedUnit?.factor_to_base || 1);
			const safeFactor = factor > 0 ? factor : 1;

			if (stockType === "RM") {
				const key = `${Number(row.item_id || 0)}:${Number(row.color_id || 0)}:${Number(row.size_id || 0)}`;
				const snapshot = rmSnapshotByKey[key] || { qty: 0, wac: 0 };
				const baseQty = qty3(snapshot.qty || 0);
				return {
					systemQty: qty3(baseQty / safeFactor),
					systemWac: rate6(snapshot.wac || 0),
				};
			}

			const sku = skuMap.get(Number(row.sku_id || 0));
			// FG availability is unit-status aware and strictly bound to requested status bucket.
			const requestedStatus = isBaseUnitOption(selectedUnit) ? "LOOSE" : "PACKED";
			const fgResolved = resolveFgSnapshotByStatus({ sku, requestedStatus });
			// Keep fractional pair balances to avoid collapsing valid stock to zero.
			const pairs = stockType === "FG" ? Number(fgResolved.qtyPairs || 0) : Number(sku?.system_qty_pairs || 0);
			return {
				systemQty: qty3(pairs / safeFactor),
				systemWac: rate6(stockType === "FG" ? fgResolved.wac : Number(sku?.system_wac || 0)),
				rowStatus: stockType === "FG" ? fgResolved.rowStatus : null,
			};
		};

		// Keep each row internally consistent after every change.
		const applyDerivedRow = (row, stockType) => {
			const next = { ...row };
			if (!next.uom_id) next.uom_id = defaultUomId(next, stockType);
			const usePhysicalCountField = isPhysicalCountReasonActive();

			if (stockType === "RM") {
				if (!next.item_id) {
					next.color_id = null;
					next.size_id = null;
				} else {
					const colorState = getRmColorState(next.item_id);
					const allowedColors = new Set((colorState.entries || []).map((entry) => Number(entry.id || 0)));
					if (next.color_id && !allowedColors.has(Number(next.color_id))) next.color_id = null;
					if (!next.color_id && !colorState.allowNone && colorState.entries.length) {
						next.color_id = Number(colorState.entries[0].id);
					}

					const sizeState = getRmSizeState(next.item_id);
					const allowedSizes = new Set((sizeState.entries || []).map((entry) => Number(entry.id || 0)));
					if (next.size_id && !allowedSizes.has(Number(next.size_id))) next.size_id = null;
					if (!next.size_id && !sizeState.allowNone && sizeState.entries.length) {
						next.size_id = Number(sizeState.entries[0].id);
					}
				}
			}

			const selectedUnit = getUomOptions(next, stockType).find((entry) => Number(entry.id || 0) === Number(next.uom_id || 0));
			const snapshot = resolveSystemSnapshot(next, stockType, selectedUnit);
			const factorToBase = Number(selectedUnit?.factor_to_base || 1) > 0 ? Number(selectedUnit?.factor_to_base || 1) : 1;
			next.system_qty = qty3(snapshot.systemQty || 0);
			// Difference is derived from either split quantities (in/out) or counted stock based on reason code.
			if (usePhysicalCountField) {
				const countedRaw = Number(next.counted_stock_qty);
				const fallbackPhysical = Number(next.physical_qty);
				const defaultCounted = Number(next.system_qty || 0);
				const normalizedCounted = Number.isFinite(countedRaw)
					? Math.max(countedRaw, 0)
					: Number.isFinite(fallbackPhysical)
						? Math.max(fallbackPhysical, 0)
						: Math.max(defaultCounted, 0);
				next.counted_stock_qty = qty3(normalizedCounted);
				next.physical_qty = qty3(next.counted_stock_qty);
				next.difference_qty = qty3(Number(next.physical_qty) - Number(next.system_qty));
				next.qty_in = next.difference_qty > 0 ? qty3(next.difference_qty) : 0;
				next.qty_out = next.difference_qty < 0 ? qty3(Math.abs(next.difference_qty)) : 0;
			} else {
				next.qty_in = qty3(next.qty_in || 0);
				next.qty_out = qty3(next.qty_out || 0);
				next.difference_qty = qty3(Number(next.qty_in) - Number(next.qty_out));
				next.physical_qty = qty3(Number(next.system_qty) + Number(next.difference_qty));
				next.counted_stock_qty = qty3(next.physical_qty || 0);
			}

			if (stockType === "RM") {
				const rmRate = resolveRmRate(next);
				next.rate = rate6(rmRate > 0 ? rmRate : Number(snapshot.systemWac || 0) * factorToBase);
			} else {
				const sku = skuMap.get(Number(next.sku_id || 0));
				// SKU rate is always displayed as pair-rate for consistency across unit selections.
				next.rate = rate6(Number(sku?.default_rate || 0) > 0 ? Number(sku.default_rate || 0) : Number(snapshot.systemWac || 0));
				next.row_status = String(snapshot.rowStatus || (isBaseUnitOption(selectedUnit) ? "LOOSE" : "PACKED")).toUpperCase();
			}

			const differenceBaseQty = stockType === "RM"
				? Number(next.difference_qty || 0)
				: Number(next.difference_qty || 0) * factorToBase;
			next.amount = amount2(differenceBaseQty * Number(next.rate || 0));
			return next;
		};

		const optionMarkup = (entries, selectedId, placeholderLabel) => {
			const normalizedSelected = Number(selectedId || 0);
			let html = "";
			if (String(placeholderLabel || "").trim()) {
				html += `<option value="">${placeholderLabel}</option>`;
			}
			html += (entries || []).map((entry) => {
				const id = Number(entry?.id || 0);
				const selected = normalizedSelected === id ? " selected" : "";
				const label = String(entry?.label || entry?.name || entry?.code || id);
				return `<option value="${id}"${selected}>${label}</option>`;
			}).join("");
			return html;
		};

		const renderHead = (stockType) => {
			const usePhysicalCountField = isPhysicalCountReasonActive();
			const cols = stockType === "RM"
				? usePhysicalCountField
					? ["Raw Material", "Color", "Size", "Unit", "System Qty", "Counted Stock", "Difference Qty", "Rate", "Amount Diff", "Actions", "Sr #"]
					: ["Raw Material", "Color", "Size", "Unit", "System Qty", "Qty In", "Qty Out", "Difference Qty", "Rate", "Amount Diff", "Actions", "Sr #"]
				: usePhysicalCountField
					? ["SKU", "Unit", "System Qty", "Counted Stock", "Difference Qty", "Pair Rate", "Amount Diff", "Actions", "Sr #"]
					: ["SKU", "Unit", "System Qty", "Qty In", "Qty Out", "Difference Qty", "Pair Rate", "Amount Diff", "Actions", "Sr #"];
			linesHeadRow.innerHTML = cols.map((label, idx) => {
				const rightAligned = ["System Qty", "Qty In", "Qty Out", "Counted Stock", "Difference Qty", "Rate", "Pair Rate", "Amount Diff"].includes(label);
				const align = rightAligned ? "text-right" : idx >= cols.length - 2 ? "text-center" : "text-left";
				return `<th class="border-b border-slate-200 px-2 py-2 ${align}">${label}</th>`;
			}).join("");
			renderFooter(stockType);
		};

		const renderFooter = (stockType) => {
			// Footer keeps adjustment totals visible while rows are edited.
			const usePhysicalCountField = isPhysicalCountReasonActive();
			const descriptorColspan = stockType === "RM" ? 4 : 2;
			const addButtonTitle = "Add";
			if (usePhysicalCountField) {
				linesFooter.innerHTML = `
					<tr class="bg-slate-50">
						<td colspan="${descriptorColspan}" class="border-t border-slate-200 px-2 py-2 text-right text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-700">Total</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-system-qty>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-counted-qty>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-diff>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5"></td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.00" data-total-amount>
						</td>
						<td class="border-t border-slate-200 px-2 py-1 text-center">
							<button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white p-2 text-slate-700 disabled:opacity-40" data-add-row aria-label="${addButtonTitle}" title="${addButtonTitle}" ${canSave ? "" : "disabled"}>
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
							</button>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500">Units</td>
					</tr>
				`;
			} else {
				linesFooter.innerHTML = `
					<tr class="bg-slate-50">
						<td colspan="${descriptorColspan}" class="border-t border-slate-200 px-2 py-2 text-right text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-700">Total</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-system-qty>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-qty-in>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-qty-out>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-diff>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5"></td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.00" data-total-amount>
						</td>
						<td class="border-t border-slate-200 px-2 py-1 text-center">
							<button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white p-2 text-slate-700 disabled:opacity-40" data-add-row aria-label="${addButtonTitle}" title="${addButtonTitle}" ${canSave ? "" : "disabled"}>
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
