						<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="pair_rate" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" value="${rate6(normalized.rate).toFixed(4)}"></td>
						<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="amount_diff" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold" value="${amount2(normalized.amount).toFixed(2)}"></td>
