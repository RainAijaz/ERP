						<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="uom_id" data-row-field="uom_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${canSave ? "" : "disabled"}>${optionMarkup(getUomOptions(normalized, stockType), normalized.uom_id, "Select Unit")}</select></td>
						<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="system_qty" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" value="${normalized.system_qty.toFixed(3)}"></td>
