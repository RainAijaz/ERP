<%
	const formatDateInput = (value) => {
		if (!value) return "";
		const asText = String(value);
		const textMatch = asText.match(/^(\d{4}-\d{2}-\d{2})/);
		if (textMatch) return textMatch[1];
		const dt = value instanceof Date ? value : new Date(value);
		if (Number.isNaN(dt.getTime())) return "";
		const yyyy = dt.getFullYear();
		const mm = String(dt.getMonth() + 1).padStart(2, "0");
		const dd = String(dt.getDate()).padStart(2, "0");
		return `${yyyy}-${mm}-${dd}`;
	};

	const selectedVoucherNo = selectedVoucher ? Number(selectedVoucher.voucher_no || 0) : null;
	const suggestedVoucherNo = selectedVoucherNo || (Number(latestVoucherNo || 0) + 1);
	const selectedDate = selectedVoucher && selectedVoucher.voucher_date
		? formatDateInput(selectedVoucher.voucher_date)
		: formatDateInput(new Date());
	const selectedStatus = String(selectedVoucher?.status || "").toUpperCase();
	const isDeletedVoucher = selectedStatus === "REJECTED";
	const statusLabel = selectedStatus === "APPROVED" ? t("approved") : selectedStatus === "REJECTED" ? t("rejected") : selectedStatus === "PENDING" ? t("pending") : selectedStatus;
	const statusToneClass = selectedStatus === "APPROVED" ? "border-emerald-200 bg-emerald-50 text-emerald-800" : selectedStatus === "REJECTED" ? "border-rose-200 bg-rose-50 text-rose-800" : "border-amber-200 bg-amber-50 text-amber-800";
	const defaultStockType = String(selectedVoucher?.stock_type || "FG").toUpperCase();

	const canCreateVoucher = typeof allowCreate === "boolean" ? allowCreate : true;
	const canEditVoucher = typeof allowEdit === "boolean" ? allowEdit : true;
	const canDeleteVoucher = typeof allowDelete === "boolean" ? allowDelete : true;
	const canSaveVoucher = !isDeletedVoucher && (selectedVoucher ? canEditVoucher : canCreateVoucher);
	const canDeleteCurrentVoucher = !!selectedVoucher && !isDeletedVoucher && canDeleteVoucher;

	const toFriendlyLabel = (key, fallback = "") => {
		const translated = String(t(key) || "").trim();
		if (translated && translated !== key) return translated;
		if (fallback) return fallback;
		return String(key || "")
			.trim()
			.toLowerCase()
			.replace(/[_-]+/g, " ")
			.replace(/\b[a-z]/g, (ch) => ch.toUpperCase());
	};
%>

<style>
	[data-stock-count-form] [data-lines-table] thead th {
		font-size: 10.5px;
		letter-spacing: 0.08em;
	}
	[data-stock-count-form] [data-lines-table] td {
		padding: 0.3rem 0.4rem;
	}
	[data-stock-count-form] [data-lines-table] tbody tr:nth-child(even) td {
		background-color: #f8fafc;
	}
	[data-stock-count-form] [data-lines-table] tbody tr:hover td {
		background-color: #f1f5f9;
	}
	[data-stock-count-form] [data-lines-table] input,
	[data-stock-count-form] [data-lines-table] select,
	[data-stock-count-form] [data-lines-table] button[data-enhanced-select-trigger="1"] {
		height: 2.15rem !important;
		font-size: 0.82rem !important;
	}
	[data-stock-count-form] input[readonly],
	[data-stock-count-form] input:disabled,
	[data-stock-count-form] select:disabled,
	[data-stock-count-form] textarea[readonly] {
		background-color: #f1f5f9 !important;
		border-color: #cbd5e1 !important;
		color: #475569 !important;
		cursor: not-allowed;
	}
	[data-stock-count-form] input[data-unfilled-required] {
		border-color: #f59e0b !important;
		background-color: #fffbeb !important;
	}
</style>

<div class="mx-auto w-full max-w-none space-y-3 px-2">
	<section class="rounded-2xl border border-slate-200 bg-white/95 px-4 py-4 shadow-sm">
		<div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
			<div>
				<h1 class="text-2xl font-display font-semibold tracking-tight text-ink"><%= toFriendlyLabel("stock_count_adjustment_voucher", "Stock Count Voucher") %></h1>
				<p class="text-sm text-muted"><%= toFriendlyLabel("inventory", "Inventory") %></p>
			</div>
			<% if (selectedVoucher) { %>
				<div class="inline-flex items-center gap-2 rounded-full border px-3 py-1.5 text-[11px] font-semibold uppercase tracking-[0.12em] <%= statusToneClass %>">
					<span><%= toFriendlyLabel("status", "Status") %></span>
					<span class="rounded-full bg-white/80 px-2 py-0.5 text-slate-800"><%= statusLabel %></span>
				</div>
			<% } %>
		</div>
	</section>

	<section class="rounded-2xl border border-slate-200 bg-white p-3 shadow-sm">
		<form method="post" action="<%= basePath || '' %>" class="space-y-4" data-stock-count-form data-voucher-form>
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
			<input type="hidden" name="lines_json" value="[]" data-lines-json>

			<div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50/60 p-3">
				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("voucher_no", "Voucher No") %></label>
					<div class="lg:col-span-2">
						<input type="text" value="<%= suggestedVoucherNo %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm font-semibold text-slate-700" data-voucher-no-input>
					</div>
					<div class="flex flex-wrap items-center gap-2 lg:col-span-8">
						<a href="<%= prevVoucherNo ? ((basePath || '') + '?voucher_no=' + prevVoucherNo + '&view=1') : '#' %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700 <%= prevVoucherNo ? '' : 'pointer-events-none opacity-40' %>"><%= toFriendlyLabel("prev", "Prev") %></a>
						<a href="<%= nextVoucherNo ? ((basePath || '') + '?voucher_no=' + nextVoucherNo + '&view=1') : ((basePath || '') + '?new=1') %>" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700"><%= toFriendlyLabel("next", "Next") %></a>
						<button type="button" class="rounded-xl bg-accent px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-white shadow-sm" data-load-voucher><%= toFriendlyLabel("load", "Load") %></button>
						<div class="ml-auto flex items-center gap-2">
							<button type="button" class="rounded-xl border border-rose-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-rose-700 disabled:opacity-40" data-delete-voucher <%= canDeleteCurrentVoucher ? '' : 'disabled' %>><%= toFriendlyLabel("delete", "Delete") %></button>
							<button type="button" class="rounded-xl border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold uppercase tracking-widest text-slate-700" onclick="window.print()"><%= toFriendlyLabel("print", "Print") %></button>
						</div>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("date", "Date") %></label>
					<div class="lg:col-span-4">
						<input type="date" name="voucher_date" value="<%= selectedDate %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" required <%= canSaveVoucher ? '' : 'readonly' %>>
					</div>
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= toFriendlyLabel("stock_type", "Stock Type") %></label>
					<div class="lg:col-span-4">
						<select name="stock_type" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-stock-type data-searchable-select="true" data-searchable-variant="unified" <%= canSaveVoucher ? '' : 'disabled' %>>
							<% (options.stockTypes || []).forEach((entry) => { %>
								<option value="<%= entry.value %>" <%= String(defaultStockType || 'FG').toUpperCase() === String(entry.value || '').toUpperCase() ? 'selected' : '' %>><%= toFriendlyLabel(entry.labelKey || entry.value, entry.value) %></option>
							<% }) %>
						</select>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center">
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("reason", "Reason") %></label>
					<div class="lg:col-span-4">
						<select name="reason_code_id" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-reason-code data-searchable-select="true" data-searchable-variant="unified" required <%= canSaveVoucher ? '' : 'disabled' %>>
							<option value=""><%= toFriendlyLabel("select_reason", "Select Reason") %></option>
							<% (options.reasonCodes || []).forEach((reason) => { %>
								<option value="<%= reason.id %>" data-requires-notes="<%= reason.requires_notes ? '1' : '0' %>" data-reason-value="<%= reason.code || '' %>" <%= Number(selectedVoucher?.reason_code_id || 0) === Number(reason.id) ? 'selected' : '' %>><%= reason.name %></option>
							<% }) %>
						</select>
					</div>
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2 lg:text-right lg:pr-3"><%= toFriendlyLabel("reason_notes", "Reason Notes") %></label>
					<div class="lg:col-span-4">
						<input type="text" name="reason_notes" maxlength="1000" value="<%= selectedVoucher?.reason_notes || '' %>" class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-reason-notes <%= canSaveVoucher ? '' : 'readonly' %>>
					</div>
				</div>

				<div class="grid grid-cols-1 gap-3 lg:grid-cols-12 lg:items-center hidden" data-product-group-row>
					<label class="text-sm font-semibold text-slate-700 lg:col-span-2"><%= toFriendlyLabel("product_group", "Product Group") %></label>
					<div class="lg:col-span-4">
						<select class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-product-group data-searchable-select="true" data-searchable-variant="unified" <%= canSaveVoucher ? '' : 'disabled' %>>
							<option value=""><%= toFriendlyLabel("select_product_group", "Select Product Group") %></option>
						</select>
					</div>
					<div class="lg:col-span-3">
						<select class="h-10 w-full rounded-xl border border-slate-300 bg-white px-3 text-sm" data-product-group-status <%= canSaveVoucher ? '' : 'disabled' %>>
							<option value=""><%= toFriendlyLabel("all_status", "All Status") %></option>
							<option value="PACKED" selected><%= toFriendlyLabel("packed", "Packed") %></option>
							<option value="LOOSE"><%= toFriendlyLabel("loose", "Loose") %></option>
						</select>
					</div>
					<div class="lg:col-start-3 lg:col-span-10 flex items-start gap-2 text-xs text-slate-500">
						<svg class="h-4 w-4 text-amber-500 flex-shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"></path></svg>
						<%= toFriendlyLabel("physical_count_correction_note", "Add each SKU you counted. Any SKU in this group with stock as of the selected date that you haven't added will be added automatically when you save — enter a quantity for those too (0 is valid).") %>
					</div>
				</div>

				<% if (isDeletedVoucher) { %>
					<div class="rounded-xl border border-amber-200 bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800">
						<%= toFriendlyLabel("voucher_deleted_read_only", "Voucher is deleted and read-only.") %>
					</div>
				<% } %>
			</div>

			<div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
				<div class="relative">
					<div class="hidden absolute inset-0 z-10 flex items-center justify-center bg-white/80 rounded-2xl" data-table-loading-overlay style="min-height:4rem">
						<div class="flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-4 py-2.5 shadow-sm text-slate-600 text-sm font-medium">
							<svg class="animate-spin h-4 w-4 text-accent flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
								<circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
								<path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 22 6.477 22 12h-4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
							</svg>
							<span data-table-loading-text><%= toFriendlyLabel("loading_articles", "Loading articles...") %></span>
						</div>
					</div>
					<div class="overflow-x-auto lg:overflow-visible overflow-y-visible" data-searchable-boundary>
						<table class="w-full min-w-280 table-fixed text-xs" data-lines-table>
							<thead class="bg-slate-50 text-xs uppercase tracking-[0.12em] text-slate-500">
								<tr data-lines-head-row></tr>
							</thead>
							<tbody data-lines-body="stock-count"></tbody>
							<tfoot data-lines-footer></tfoot>
						</table>
					</div>
				</div>
			</div>

			<div class="flex items-center justify-center gap-2">
				<button type="submit" class="rounded-xl bg-accent px-4 py-2 text-xs font-semibold uppercase tracking-widest text-white shadow-sm disabled:opacity-40" <%= canSaveVoucher ? '' : 'disabled' %>><%= toFriendlyLabel("confirm", "Confirm") %></button>
			</div>
		</form>

		<form method="post" action="<%= `${basePath}/delete` %>" class="hidden" data-delete-voucher-form>
			<input type="hidden" name="_csrf" value="<%= csrfToken %>">
			<input type="hidden" name="voucher_id" value="<%= selectedVoucher?.id || '' %>">
		</form>
	</section>
</div>

<script>
	(() => {
		const form = document.querySelector("[data-stock-count-form]");
		if (!form) return;

		const options = <%- JSON.stringify(options || {}) %>;
		const initialVoucher = <%- JSON.stringify(selectedVoucher || null) %>;
		const basePath = <%- JSON.stringify(basePath || "") %>;
		const canSave = <%- JSON.stringify(Boolean(canSaveVoucher)) %>;
		const reasonRequiredMessage = <%- JSON.stringify(toFriendlyLabel("reason_required", "Reason is required.")) %>;
		const reasonNotesRequiredMessage = <%- JSON.stringify(toFriendlyLabel("reason_notes_required", "Reason notes are required.")) %>;
		const deleteConfirmMessage = <%- JSON.stringify(toFriendlyLabel("confirm_delete", "Are you sure?")) %>;
		const atLeastOneValidLineMessage = <%- JSON.stringify(toFriendlyLabel("at_least_one_valid_line_required", "At least one valid line is required.")) %>;
		const articlesMissingAddedMessage = <%- JSON.stringify(toFriendlyLabel("articles_missing_added", "Some articles with stock were not in the list and have been added below. Please enter their counted quantity before confirming.")) %>;
		const reconcileArticlesFailedMessage = <%- JSON.stringify(toFriendlyLabel("reconcile_articles_failed", "Unable to verify the article list before saving. Please check your connection and try again.")) %>;

		const _t = {
			raw_material: <%- JSON.stringify(t("raw_material")) %>,
			color: <%- JSON.stringify(t("color")) %>,
			size: <%- JSON.stringify(t("size")) %>,
			unit: <%- JSON.stringify(t("unit")) %>,
			system_qty: <%- JSON.stringify(t("system_qty")) %>,
			counted_stock: <%- JSON.stringify(t("counted_stock")) %>,
			qty_in: <%- JSON.stringify(t("qty_in")) %>,
			qty_out: <%- JSON.stringify(t("qty_out")) %>,
			difference_qty: <%- JSON.stringify(t("difference_qty")) %>,
			rate: <%- JSON.stringify(t("rate")) %>,
			pair_rate: <%- JSON.stringify(t("pair_rate")) %>,
			amount_diff: <%- JSON.stringify(t("amount_diff")) %>,
			actions: <%- JSON.stringify(t("actions")) %>,
			sr_no: <%- JSON.stringify(t("sr_no")) %>,
			sku: <%- JSON.stringify(t("sku")) %>,
			total: <%- JSON.stringify(t("total")) %>,
			add: <%- JSON.stringify(t("add")) %>,
			units: <%- JSON.stringify(t("units")) %>,
			select_product_group_first: <%- JSON.stringify(t("select_product_group_first") || "Please select a product group before saving.") %>,
			fill_all_quantities: <%- JSON.stringify(t("fill_all_quantities") || "Please enter a counted quantity for every article. Enter 0 if none were found.") %>,
			change_article: <%- JSON.stringify(t("change_article") || "Change article") %>,
		};

		const showUiMessage = (message) => {
			const text = String(message || "").trim();
			if (!text) return;
			if (typeof window.showVoucherError === "function") {
				window.showVoucherError(text);
				return;
			}
			window.alert(text);
		};

		const confirmUi = async (message) => {
			const text = String(message || "").trim();
			if (!text) return true;
			if (typeof window.showUiConfirmModal === "function") {
				return window.showUiConfirmModal({ message: text });
			}
			return window.confirm(text);
		};

		const stockTypeValues = ["FG", "SFG", "RM"];
		const PHYSICAL_COUNT_REASON_CODES = new Set(["PHYSICALCOUNT", "PHYSICALCOUNTCORRECTION"]);
		const toNum = (value, fallback = 0) => {
			const n = Number(value);
			return Number.isFinite(n) ? n : fallback;
		};
		const toInt = (value) => {
			const n = Number(value);
			if (!Number.isInteger(n) || n <= 0) return null;
			return n;
		};
		const qty3 = (value) => Number(toNum(value, 0).toFixed(3));
		const rate6 = (value) => Number(toNum(value, 0).toFixed(6));
		const amount2 = (value) => Number(toNum(value, 0).toFixed(2));

		const isTruthyFlag = (value) => {
			if (value === true) return true;
			if (value === false || value === null || value === undefined) return false;
			if (typeof value === "string") {
				const normalized = value.trim().toLowerCase();
				return ["1", "true", "t", "yes", "y"].includes(normalized);
			}
			return Number(value) === 1;
		};

		const isBaseUnitOption = (option) => isTruthyFlag(option?.is_base);

		const resolveFgSnapshotByStatus = ({ sku, requestedStatus }) => {
			const normalizedRequested = String(requestedStatus || "").toUpperCase() === "PACKED" ? "PACKED" : "LOOSE";
			const looseQty = qty3(Number(sku?.system_loose_qty_pairs || 0));
			const packedQty = qty3(Number(sku?.system_packed_qty_pairs || 0));
			const looseWac = rate6(Number(sku?.system_loose_wac || 0));
			const packedWac = rate6(Number(sku?.system_packed_wac || 0));

			const pickByStatus = (status) => status === "PACKED"
				? { qtyPairs: packedQty, wac: packedWac }
				: { qtyPairs: looseQty, wac: looseWac };

			const preferred = pickByStatus(normalizedRequested);
			return {
				rowStatus: normalizedRequested,
				qtyPairs: qty3(preferred.qtyPairs || 0),
				wac: rate6(preferred.wac || 0),
			};
		};

		const normalizeStockType = (value) => {
			const normalized = String(value || "").trim().toUpperCase();
			return stockTypeValues.includes(normalized) ? normalized : "FG";
		};
		const normalizeReasonCode = (value) => String(value || "").replace(/[^a-z0-9]+/gi, "").toUpperCase();

		const stockTypeSelect = form.querySelector("[data-stock-type]");
		const reasonSelect = form.querySelector("[data-reason-code]");
		const reasonNotes = form.querySelector("[data-reason-notes]");
		const voucherNoInput = form.querySelector("[data-voucher-no-input]");
		const loadVoucherButton = form.querySelector("[data-load-voucher]");
		const linesJsonInput = form.querySelector("[data-lines-json]");
		const linesBody = form.querySelector("[data-lines-body]");
		const linesHeadRow = form.querySelector("[data-lines-head-row]");
		const linesFooter = form.querySelector("[data-lines-footer]");
		const deleteButton = form.querySelector("[data-delete-voucher]");
		const deleteForm = document.querySelector("[data-delete-voucher-form]");
		const productGroupRow = form.querySelector("[data-product-group-row]");
		const productGroupSelect = form.querySelector("[data-product-group]");
		const productGroupStatusSelect = form.querySelector("[data-product-group-status]");
		const tableLoadingOverlay = form.querySelector("[data-table-loading-overlay]");

		const skuList = Array.isArray(options.skus) ? options.skus : [];
		const rmItems = Array.isArray(options.rmItems) ? options.rmItems : [];
		const skuMap = new Map(skuList.map((entry) => [Number(entry.id), entry]));
		const rmMap = new Map(rmItems.map((entry) => [Number(entry.id), entry]));
		const rmColorPolicy = options.rawMaterialColorPolicyByItem || {};
		const rmSizePolicy = options.rawMaterialSizePolicyByItem || {};
		const rmRatesByItem = options.rawMaterialRatesByItem || {};
		const rmSnapshotByKey = options.rmSnapshotByKey || {};
		const isPhysicalCountReasonActive = () => {
			if (!reasonSelect) return false;
			const selected = reasonSelect.options[reasonSelect.selectedIndex];
			const code = selected ? selected.getAttribute("data-reason-value") : "";
			return PHYSICAL_COUNT_REASON_CODES.has(normalizeReasonCode(code));
		};

		const isPhysicalCountCorrectionActive = () => {
			if (!reasonSelect) return false;
			const selected = reasonSelect.options[reasonSelect.selectedIndex];
			const code = selected ? selected.getAttribute("data-reason-value") : "";
			const normalized = normalizeReasonCode(code);
			return normalized === "PHYSICALCOUNT" || normalized === "PHYSICALCOUNTCORRECTION";
		};

		const getAvailableGroups = (stockType) => {
			const seen = new Map();
			const sourceList = stockType === "RM"
				? rmItems
				: skuList.filter((s) => String(s.item_type || "").toUpperCase() === stockType);
			sourceList.forEach((item) => {
				const gid = Number(item.group_id || 0);
				if (gid && !seen.has(gid)) seen.set(gid, String(item.group_name || gid));
			});
			return Array.from(seen.entries())
				.map(([id, name]) => ({ id, name }))
				.sort((a, b) => String(a.name).localeCompare(String(b.name)));
		};

		const populateProductGroupOptions = (stockType) => {
			if (!productGroupSelect) return;
			const groups = getAvailableGroups(stockType);
			const currentVal = productGroupSelect.value;
			const allGroupsOption = stockType === "RM" ? `<option value="all">All Groups</option>` : "";
			productGroupSelect.innerHTML = `<option value="">Select Product Group</option>` + allGroupsOption +
				groups.map((g) => `<option value="${g.id}"${Number(currentVal) === g.id ? " selected" : ""}>${g.name}</option>`).join("");
			if (typeof window.initSearchableSelects === "function") {
				window.initSearchableSelects(productGroupSelect.closest("[data-product-group-row]") || form);
			}
		};

		const syncStatusDropdownVisibility = () => {
			if (!productGroupStatusSelect) return;
			const isFg = currentStockType() === "FG";
			const wrapper = productGroupStatusSelect.closest("div");
			if (wrapper) wrapper.classList.toggle("hidden", !isFg);
			if (!isFg) productGroupStatusSelect.value = "";
		};

		const syncProductGroupVisibility = () => {
			if (!productGroupRow) return;
			const show = isPhysicalCountCorrectionActive() && !initialVoucher;
			productGroupRow.classList.toggle("hidden", !show);
			if (show) populateProductGroupOptions(currentStockType());
			syncStatusDropdownVisibility();
		};

		const showTableLoading = () => {
			if (tableLoadingOverlay) tableLoadingOverlay.classList.remove("hidden");
		};

		const hideTableLoading = () => {
			if (tableLoadingOverlay) tableLoadingOverlay.classList.add("hidden");
		};

		const buildArticlesUrl = (groupId, stockType) => {
			const voucherDateInput = form.querySelector('[name="voucher_date"]');
			const voucherDate = voucherDateInput ? voucherDateInput.value : "";
			const statusSelect = form.querySelector("[data-product-group-status]");
			const statusFilter = statusSelect ? statusSelect.value : "";
			return `${basePath}/articles?group_id=${encodeURIComponent(groupId)}&stock_type=${encodeURIComponent(stockType)}&date=${encodeURIComponent(voucherDate)}&status=${encodeURIComponent(statusFilter)}`;
		};

		// Used by the pre-save reconciliation check so an auto-appended "missing
		// article" row looks and behaves the same as a manually-added one.
		const articleToRow = (article, stockType) => {
			if (stockType === "RM") {
				return {
					...rowTemplate(stockType),
					item_id: article.item_id,
					color_id: article.color_id || null,
					size_id: article.size_id || null,
					_auto_loaded: true,
					_unfilled: true,
					_snap_base: article.system_qty_base,
					counted_stock_qty: null,
				};
			}
			// Update skuMap in-place so resolveSystemSnapshot picks up date-specific WAC/bucket split.
			const existing = skuMap.get(Number(article.sku_id));
			if (existing) {
				existing.system_qty_pairs = Number(article.system_qty_pairs || 0);
				existing.system_loose_qty_pairs = Number(article.system_loose_qty_pairs || 0);
				existing.system_packed_qty_pairs = Number(article.system_packed_qty_pairs || 0);
				existing.system_loose_wac = Number(article.system_loose_wac || 0);
				existing.system_packed_wac = Number(article.system_packed_wac || 0);
			}
			return {
				...rowTemplate(stockType),
				sku_id: article.sku_id,
				_auto_loaded: true,
				_unfilled: true,
				// Don't freeze _snap_pairs for FG — resolveSystemSnapshot will use
				// fgResolved.qtyPairs which correctly splits PACKED/LOOSE based on
				// the selected unit (non-base → packed, base → loose).
				_snap_pairs: null,
				counted_stock_qty: null,
			};
		};

		const articleIdentityKey = (source, stockType) => stockType === "RM"
			? `${toInt(source.item_id) || 0}|${toInt(source.color_id) || 0}|${toInt(source.size_id) || 0}`
			: `${toInt(source.sku_id) || 0}`;

		// Pre-save safety net: re-fetch the authoritative article list for the
		// selected group/status/date and append any article with stock that
		// isn't represented by a row yet (e.g. stock appeared after the page
		// loaded, or a manually-added row was skipped). Returns how many were
		// appended so the caller can decide whether to block the save.
		const reconcileMissingArticles = async () => {
			const stockType = currentStockType();
			const groupVal = productGroupSelect?.value || "";
			if (!groupVal) return { appended: 0 };
			const url = buildArticlesUrl(groupVal, stockType);
			const resp = await fetch(url, { credentials: "same-origin" });
			if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
			const data = await resp.json();
			const articles = Array.isArray(data.articles) ? data.articles : [];
			const existingKeys = new Set(
				rowsState
					.filter((row) => (stockType === "RM" ? toInt(row.item_id) : toInt(row.sku_id)))
					.map((row) => articleIdentityKey(row, stockType)),
			);
			const missingArticles = articles.filter((article) => !existingKeys.has(articleIdentityKey(article, stockType)));
			if (!missingArticles.length) return { appended: 0 };
			const missingRows = missingArticles.map((article) => articleToRow(article, stockType));
			rowsState = [...rowsState, ...missingRows];
			renderRows();
			return { appended: missingRows.length };
		};

		const rowTemplate = (stockType) => ({
			sku_id: null,
			item_id: null,
			color_id: null,
			size_id: null,
			uom_id: null,
			row_status: stockType === "FG" ? "LOOSE" : null,
			system_qty: 0,
			qty_in: 0,
			qty_out: 0,
			physical_qty: 0,
			counted_stock_qty: null,
			difference_qty: 0,
			rate: 0,
			amount: 0,
		});

		let rowsState = [];
		let unbindNavigator = null;
		let pendingEnterFocus = null;
		let totalSystemQtyInput = null;
		let totalCountedQtyInput = null;
		let totalQtyInInput = null;
		let totalQtyOutInput = null;
		let totalDiffInput = null;
		let totalAmountInput = null;
		let totalQtyByUnitRow = null;
		let totalQtyByUnitWrap = null;

		const currentStockType = () => normalizeStockType(stockTypeSelect?.value);

		const getUomOptions = (row, stockType) => {
			if (stockType === "RM") {
				const item = rmMap.get(Number(row.item_id || 0));
				return Array.isArray(item?.unit_options) ? item.unit_options : [];
			}
			const sku = skuMap.get(Number(row.sku_id || 0));
			return Array.isArray(sku?.unit_options) ? sku.unit_options : [];
		};

		const getRowUnitLabel = (row, stockType) => {
			const unitOptions = getUomOptions(row, stockType);
			const matched = unitOptions.find((entry) => Number(entry?.id || 0) === Number(row?.uom_id || 0));
			return String(matched?.name || matched?.code || "").trim();
		};

		const defaultUomId = (row, stockType) => {
			const optionsList = getUomOptions(row, stockType);
			if (!optionsList.length) return null;
			const preferredNonBase = optionsList.find((entry) => !isBaseUnitOption(entry));
			return toInt((preferredNonBase || optionsList[0])?.id);
		};

		// For a new Physical Count Correction voucher, FG unit isn't a free per-row
		// choice — it mirrors whichever stock bucket the header's Packed/Loose filter
		// loaded the article from (system_packed_qty_pairs vs system_loose_qty_pairs),
		// so it must be re-derived from that filter rather than left as a per-row pick.
		// Loaded/saved vouchers keep their persisted uom_id untouched (see applyDerivedRow).
		const forcedFgUomId = (row) => {
			const optionsList = getUomOptions(row, "FG");
			if (!optionsList.length) return null;
			const wantPacked = String(productGroupStatusSelect?.value || "").toUpperCase() === "PACKED";
			const match = optionsList.find((entry) => isBaseUnitOption(entry) === !wantPacked);
			return toInt((match || optionsList[0])?.id);
		};

		const resolveRmRate = (row) => {
			const itemId = toInt(row.item_id);
			if (!itemId) return 0;
			const itemRates = Array.isArray(rmRatesByItem[String(itemId)]) ? rmRatesByItem[String(itemId)] : [];
			const colorId = toInt(row.color_id);
			const sizeId = toInt(row.size_id);

			const exact = itemRates.find((entry) => Number(entry?.color_id || 0) === Number(colorId || 0) && Number(entry?.size_id || 0) === Number(sizeId || 0));
			if (exact) return rate6(exact.purchase_rate);

			const colorOnly = itemRates.find((entry) => Number(entry?.color_id || 0) === Number(colorId || 0) && Number(entry?.size_id || 0) === 0);
			if (colorOnly) return rate6(colorOnly.purchase_rate);

			const sizeOnly = itemRates.find((entry) => Number(entry?.color_id || 0) === 0 && Number(entry?.size_id || 0) === Number(sizeId || 0));
			if (sizeOnly) return rate6(sizeOnly.purchase_rate);

			const fallback = itemRates.find((entry) => Number(entry?.color_id || 0) === 0 && Number(entry?.size_id || 0) === 0);
			return fallback ? rate6(fallback.purchase_rate) : 0;
		};

		const getRmColorState = (itemId) => {
			const normalizedItemId = toInt(itemId);
			if (!normalizedItemId) return { entries: [], allowNone: true, disabled: true };
			const policy = rmColorPolicy[String(normalizedItemId)] || null;
			const entries = Array.isArray(policy?.colors)
				? policy.colors.map((entry) => ({ id: toInt(entry?.id), name: String(entry?.name || "").trim() })).filter((entry) => entry.id)
				: [];
			if (policy?.hasAnyRate) {
				return {
					entries,
					allowNone: policy.hasColorless === true || entries.length === 0,
					disabled: entries.length === 0 && policy.hasColorless !== true,
				};
			}
			return { entries: [], allowNone: true, disabled: true };
		};

		const getRmSizeState = (itemId) => {
			const normalizedItemId = toInt(itemId);
			if (!normalizedItemId) return { entries: [], allowNone: true, disabled: true };
			const policy = rmSizePolicy[String(normalizedItemId)] || null;
			const entries = Array.isArray(policy?.sizes)
				? policy.sizes.map((entry) => ({ id: toInt(entry?.id), name: String(entry?.name || "").trim() })).filter((entry) => entry.id)
				: [];
			if (policy?.hasAnyRate) {
				return {
					entries,
					allowNone: policy.hasSizeless === true || entries.length === 0,
					disabled: entries.length === 0 && policy.hasSizeless !== true,
				};
			}
			return { entries: [], allowNone: true, disabled: true };
		};

		const resolveSystemSnapshot = (row, stockType, selectedUnit) => {
			const factor = Number(selectedUnit?.factor_to_base || 1);
			const safeFactor = factor > 0 ? factor : 1;

			if (stockType === "RM") {
				// Use the immutable snapshot captured at voucher save time when available.
				if (row._snap_base != null) {
					const key = `${Number(row.item_id || 0)}:${Number(row.color_id || 0)}:${Number(row.size_id || 0)}`;
					const live = rmSnapshotByKey[key] || { wac: 0 };
					return {
						systemQty: qty3(row._snap_base / safeFactor),
						systemWac: rate6(live.wac || 0),
					};
				}
				const key = `${Number(row.item_id || 0)}:${Number(row.color_id || 0)}:${Number(row.size_id || 0)}`;
				const snapshot = rmSnapshotByKey[key] || { qty: 0, wac: 0 };
				const baseQty = qty3(snapshot.qty || 0);
				return {
					systemQty: qty3(baseQty / safeFactor),
					systemWac: rate6(snapshot.wac || 0),
				};
			}

			const sku = skuMap.get(Number(row.sku_id || 0));
			// FG availability is unit-status aware and strictly bound to requested status bucket.
			const requestedStatus = isBaseUnitOption(selectedUnit) ? "LOOSE" : "PACKED";
			const fgResolved = resolveFgSnapshotByStatus({ sku, requestedStatus });
			// Use the immutable snapshot captured at voucher save time when available.
			if (row._snap_pairs != null) {
				return {
					systemQty: qty3(row._snap_pairs / safeFactor),
					systemWac: rate6(stockType === "FG" ? fgResolved.wac : Number(sku?.system_wac || 0)),
					rowStatus: stockType === "FG" ? fgResolved.rowStatus : null,
				};
			}
			// Keep fractional pair balances to avoid collapsing valid stock to zero.
			const pairs = stockType === "FG" ? Number(fgResolved.qtyPairs || 0) : Number(sku?.system_qty_pairs || 0);
			return {
				systemQty: qty3(pairs / safeFactor),
				systemWac: rate6(stockType === "FG" ? fgResolved.wac : Number(sku?.system_wac || 0)),
				rowStatus: stockType === "FG" ? fgResolved.rowStatus : null,
			};
		};

		// Keep each row internally consistent after every change.
		const applyDerivedRow = (row, stockType) => {
			const next = { ...row };
			if (stockType === "FG" && isPhysicalCountCorrectionActive() && !initialVoucher) {
				next.uom_id = forcedFgUomId(next);
			} else if (!next.uom_id) {
				next.uom_id = defaultUomId(next, stockType);
			}
			const usePhysicalCountField = isPhysicalCountReasonActive();

			if (stockType === "RM") {
				if (!next.item_id) {
					next.color_id = null;
					next.size_id = null;
				} else {
					const colorState = getRmColorState(next.item_id);
					const allowedColors = new Set((colorState.entries || []).map((entry) => Number(entry.id || 0)));
					if (next.color_id && !allowedColors.has(Number(next.color_id))) next.color_id = null;
					if (!next.color_id && !colorState.allowNone && colorState.entries.length) {
						next.color_id = Number(colorState.entries[0].id);
					}

					const sizeState = getRmSizeState(next.item_id);
					const allowedSizes = new Set((sizeState.entries || []).map((entry) => Number(entry.id || 0)));
					if (next.size_id && !allowedSizes.has(Number(next.size_id))) next.size_id = null;
					if (!next.size_id && !sizeState.allowNone && sizeState.entries.length) {
						next.size_id = Number(sizeState.entries[0].id);
					}
				}
			}

			const selectedUnit = getUomOptions(next, stockType).find((entry) => Number(entry.id || 0) === Number(next.uom_id || 0));
			const snapshot = resolveSystemSnapshot(next, stockType, selectedUnit);
			const factorToBase = Number(selectedUnit?.factor_to_base || 1) > 0 ? Number(selectedUnit?.factor_to_base || 1) : 1;
			next.system_qty = qty3(snapshot.systemQty || 0);
			// Difference is derived from either split quantities (in/out) or counted stock based on reason code.
			if (usePhysicalCountField) {
				if (next._unfilled) {
					// Row not yet filled by user (auto-loaded or newly added) — keep blank, no difference computed.
					next.counted_stock_qty = null;
					next.physical_qty = 0;
					next.difference_qty = 0;
					next.qty_in = 0;
					next.qty_out = 0;
				} else {
					const countedRaw = Number(next.counted_stock_qty);
					const fallbackPhysical = Number(next.physical_qty);
					const defaultCounted = Number(next.system_qty || 0);
					const normalizedCounted = Number.isFinite(countedRaw)
						? Math.max(countedRaw, 0)
						: Number.isFinite(fallbackPhysical)
							? Math.max(fallbackPhysical, 0)
							: Math.max(defaultCounted, 0);
					next.counted_stock_qty = qty3(normalizedCounted);
					next.physical_qty = qty3(next.counted_stock_qty);
					next.difference_qty = qty3(Number(next.physical_qty) - Number(next.system_qty));
					next.qty_in = next.difference_qty > 0 ? qty3(next.difference_qty) : 0;
					next.qty_out = next.difference_qty < 0 ? qty3(Math.abs(next.difference_qty)) : 0;
				}
			} else {
				next.qty_in = qty3(next.qty_in || 0);
				next.qty_out = qty3(next.qty_out || 0);
				next.difference_qty = qty3(Number(next.qty_in) - Number(next.qty_out));
				next.physical_qty = qty3(Number(next.system_qty) + Number(next.difference_qty));
				next.counted_stock_qty = qty3(next.physical_qty || 0);
			}

			if (stockType === "RM") {
				const rmRate = resolveRmRate(next);
				next.rate = rate6(rmRate > 0 ? rmRate : Number(snapshot.systemWac || 0) * factorToBase);
			} else {
				const sku = skuMap.get(Number(next.sku_id || 0));
				// SKU rate is always displayed as pair-rate for consistency across unit selections.
				next.rate = rate6(Number(sku?.default_rate || 0) > 0 ? Number(sku.default_rate || 0) : Number(snapshot.systemWac || 0));
				next.row_status = String(snapshot.rowStatus || (isBaseUnitOption(selectedUnit) ? "LOOSE" : "PACKED")).toUpperCase();
			}

			const differenceBaseQty = stockType === "RM"
				? Number(next.difference_qty || 0)
				: Number(next.difference_qty || 0) * factorToBase;
			next.amount = amount2(differenceBaseQty * Number(next.rate || 0));
			return next;
		};

		const optionMarkup = (entries, selectedId, placeholderLabel) => {
			const normalizedSelected = Number(selectedId || 0);
			let html = "";
			if (String(placeholderLabel || "").trim()) {
				html += `<option value="">${placeholderLabel}</option>`;
			}
			html += (entries || []).map((entry) => {
				const id = Number(entry?.id || 0);
				const selected = normalizedSelected === id ? " selected" : "";
				const label = String(entry?.label || entry?.name || entry?.code || id);
				return `<option value="${id}"${selected}>${label}</option>`;
			}).join("");
			return html;
		};

		const renderHead = (stockType) => {
			const usePhysicalCountField = isPhysicalCountReasonActive();
			const COL_RIGHT = new Set(["system_qty", "counted_stock", "qty_in", "qty_out", "difference_qty", "rate", "pair_rate", "amount_diff"]);
			const COL_WIDTHS = {
				sku: "w-52 min-w-[200px]",
				raw_material: "w-44 min-w-[160px]",
				color: "w-28 min-w-[100px]",
				size: "w-28 min-w-[100px]",
				unit: "w-24 min-w-[80px]",
				system_qty: "w-24",
				counted_stock: "w-24",
				qty_in: "w-24",
				qty_out: "w-24",
				difference_qty: "w-24",
				rate: "w-24",
				pair_rate: "w-24",
				amount_diff: "w-28",
				actions: "w-14",
				sr_no: "w-12",
			};
			const cols = stockType === "RM"
				? usePhysicalCountField
					? ["raw_material", "color", "size", "unit", "system_qty", "counted_stock", "difference_qty", "rate", "amount_diff", "actions", "sr_no"]
					: ["raw_material", "color", "size", "unit", "system_qty", "qty_in", "qty_out", "difference_qty", "rate", "amount_diff", "actions", "sr_no"]
				: usePhysicalCountField
					? ["sku", "unit", "system_qty", "counted_stock", "difference_qty", "pair_rate", "amount_diff", "actions", "sr_no"]
					: ["sku", "unit", "system_qty", "qty_in", "qty_out", "difference_qty", "pair_rate", "amount_diff", "actions", "sr_no"];
			linesHeadRow.innerHTML = cols.map((key, idx) => {
				const label = _t[key] || key;
				const align = COL_RIGHT.has(key) ? "text-right" : idx >= cols.length - 2 ? "text-center" : "text-left";
				const widthClass = COL_WIDTHS[key] || "";
				return `<th class="border-b border-slate-200 px-2 py-2 ${align} ${widthClass}">${label}</th>`;
			}).join("");
			renderFooter(stockType);
		};

		const renderFooter = (stockType) => {
			// Footer keeps adjustment totals visible while rows are edited.
			const usePhysicalCountField = isPhysicalCountReasonActive();
			const descriptorColspan = stockType === "RM" ? 4 : 2;
			const addButtonTitle = _t.add;
			const addButtonMarkup = `
				<button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 bg-white p-2 text-slate-700 disabled:opacity-40" data-add-row aria-label="${addButtonTitle}" title="${addButtonTitle}" ${canSave ? "" : "disabled"}>
					<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path></svg>
				</button>
			`;
			if (usePhysicalCountField) {
				linesFooter.innerHTML = `
					<tr class="bg-slate-50">
						<td colspan="${descriptorColspan}" class="border-t border-slate-200 px-2 py-2 text-right text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-700">${_t.total}</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-system-qty>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-counted-qty>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-diff>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5"></td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.00" data-total-amount>
						</td>
						<td class="border-t border-slate-200 px-2 py-1 text-center">${addButtonMarkup}</td>
						<td class="border-t border-slate-200 px-2 py-1.5 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500">${_t.units}</td>
					</tr>
				`;
			} else {
				linesFooter.innerHTML = `
					<tr class="bg-slate-50">
						<td colspan="${descriptorColspan}" class="border-t border-slate-200 px-2 py-2 text-right text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-700">${_t.total}</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-system-qty>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-qty-in>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-qty-out>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.000" data-total-diff>
						</td>
						<td class="border-t border-slate-200 px-2 py-1.5"></td>
						<td class="border-t border-slate-200 px-2 py-1.5">
							<input type="text" readonly class="h-8 w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold text-slate-700" value="0.00" data-total-amount>
						</td>
						<td class="border-t border-slate-200 px-2 py-1 text-center">${addButtonMarkup}</td>
						<td class="border-t border-slate-200 px-2 py-1.5 text-center text-[10px] font-semibold uppercase tracking-[0.08em] text-slate-500">${_t.units}</td>
					</tr>
					<tr class="bg-slate-50 hidden" data-total-qty-by-unit-row>
						<td colspan="${stockType === "RM" ? 12 : 10}" class="border-t border-slate-200 px-2 py-2">
							<div class="flex flex-wrap items-center gap-2" data-total-qty-by-unit></div>
						</td>
					</tr>
				`;
			}
			totalSystemQtyInput = linesFooter.querySelector("[data-total-system-qty]");
			totalCountedQtyInput = linesFooter.querySelector("[data-total-counted-qty]");
			totalQtyInInput = linesFooter.querySelector("[data-total-qty-in]");
			totalQtyOutInput = linesFooter.querySelector("[data-total-qty-out]");
			totalDiffInput = linesFooter.querySelector("[data-total-diff]");
			totalAmountInput = linesFooter.querySelector("[data-total-amount]");
			totalQtyByUnitRow = linesFooter.querySelector("[data-total-qty-by-unit-row]");
			totalQtyByUnitWrap = linesFooter.querySelector("[data-total-qty-by-unit]");
		};

		const syncTotals = () => {
			const totalSystemQty = rowsState.reduce((sum, row) => sum + Number(row.system_qty || 0), 0);
			const totalCountedQty = rowsState.reduce((sum, row) => sum + Number(row.counted_stock_qty || 0), 0);
			const totalQtyIn = rowsState.reduce((sum, row) => sum + Number(row.qty_in || 0), 0);
			const totalQtyOut = rowsState.reduce((sum, row) => sum + Number(row.qty_out || 0), 0);
			const totalDiff = rowsState.reduce((sum, row) => sum + Number(row.difference_qty || 0), 0);
			const totalAmount = rowsState.reduce((sum, row) => sum + Number(row.amount || 0), 0);
			if (totalSystemQtyInput) totalSystemQtyInput.value = qty3(totalSystemQty).toFixed(3);
			if (totalCountedQtyInput) totalCountedQtyInput.value = qty3(totalCountedQty).toFixed(3);
			if (totalQtyInInput) totalQtyInInput.value = qty3(totalQtyIn).toFixed(3);
			if (totalQtyOutInput) totalQtyOutInput.value = qty3(totalQtyOut).toFixed(3);
			if (totalDiffInput) totalDiffInput.value = qty3(totalDiff).toFixed(3);
			if (totalAmountInput) totalAmountInput.value = amount2(totalAmount).toFixed(2);
			if (totalQtyByUnitWrap) {
				const stockType = currentStockType();
				const inByUnit = new Map();
				const outByUnit = new Map();
				rowsState.forEach((row) => {
					const unitLabel = getRowUnitLabel(row, stockType);
					if (!unitLabel) return;
					const inQty = Number(row.qty_in || 0);
					const outQty = Number(row.qty_out || 0);
					if (inQty > 0) inByUnit.set(unitLabel, Number(inByUnit.get(unitLabel) || 0) + inQty);
					if (outQty > 0) outByUnit.set(unitLabel, Number(outByUnit.get(unitLabel) || 0) + outQty);
				});
				const chips = [];
				inByUnit.forEach((value, label) => {
					chips.push(`<span class="rounded-md border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-emerald-700">IN ${label}: ${qty3(value).toFixed(3)}</span>`);
				});
				outByUnit.forEach((value, label) => {
					chips.push(`<span class="rounded-md border border-slate-200 bg-white px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.08em] text-rose-700">OUT ${label}: ${qty3(value).toFixed(3)}</span>`);
				});
				if (chips.length) {
					totalQtyByUnitWrap.innerHTML = chips.join("");
					if (totalQtyByUnitRow) totalQtyByUnitRow.classList.remove("hidden");
				} else {
					totalQtyByUnitWrap.innerHTML = "";
					if (totalQtyByUnitRow) totalQtyByUnitRow.classList.add("hidden");
				}
			}
		};

		const renderRows = () => {
			const stockType = currentStockType();
			const usePhysicalCountField = isPhysicalCountReasonActive();
			if (!rowsState.length) rowsState = [rowTemplate(stockType)];

			const selectedGroupVal = productGroupSelect?.value || "";
			const selectedGroupId = selectedGroupVal === "all" ? "all" : Number(selectedGroupVal || 0);
			// Correction vouchers are scoped to a single product group — until one is
			// picked there is no valid article list to offer, so the dropdowns must
			// stay empty rather than falling back to "every SKU/item in the system".
			const groupRequiredButMissing = isPhysicalCountCorrectionActive() && !initialVoucher && !selectedGroupVal;
			const skuRows = groupRequiredButMissing ? [] : skuList.filter((entry) => {
				if (String(entry.item_type || "").toUpperCase() !== stockType) return false;
				if (selectedGroupId && selectedGroupId !== "all") {
					return Number(entry.group_id || 0) === selectedGroupId;
				}
				return true;
			});
			const availableRmItems = groupRequiredButMissing
				? []
				: (selectedGroupId && selectedGroupId !== "all")
					? rmItems.filter((entry) => Number(entry.group_id || 0) === selectedGroupId)
					: rmItems;
			// A SKU already picked on another row must not be offered again — no duplicate articles in one voucher.
			const usedSkuIds = new Set(rowsState.map((r) => toInt(r.sku_id)).filter(Boolean));

			linesBody.innerHTML = rowsState.map((row, index) => {
				const normalized = applyDerivedRow(row, stockType);
				rowsState[index] = normalized;

				const removeDisabled = !canSave || rowsState.length <= 1 || Boolean(normalized._auto_loaded);
				const actionCell = `
					<td class="border-t border-slate-200 px-2 py-1 text-center">
						<button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-rose-200 bg-white p-2 text-rose-600 disabled:opacity-40" data-remove-row="${index}" ${removeDisabled ? "disabled" : ""}>
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path><path d="M8 6V4.75A1.75 1.75 0 0 1 9.75 3h4.5A1.75 1.75 0 0 1 16 4.75V6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path><path d="M6.5 6l.9 12.2A2 2 0 0 0 9.39 20h5.22a2 2 0 0 0 1.99-1.8L17.5 6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path><path d="M10 10v6M14 10v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path></svg>
						</button>
					</td>
				`;
				const rowNoCell = `<td class="border-t border-slate-200 px-2 py-2 text-center text-xs font-semibold text-slate-500">${index + 1}</td>`;

				if (stockType === "RM") {
					const colorState = getRmColorState(normalized.item_id);
					const sizeState = getRmSizeState(normalized.item_id);
					const diffCellMarkup = `<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="difference_qty" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold" value="${normalized.difference_qty.toFixed(3)}"></td>`;
					const isUnfilled = Boolean(normalized._unfilled);
					const qtyCellMarkup = usePhysicalCountField
						? `<td class="border-t border-slate-200 px-2 py-1"><input type="number" min="0" step="0.001" class="w-full rounded-lg border ${isUnfilled ? "border-amber-400 bg-amber-50" : "border-slate-300 bg-white"} px-2 text-right" data-field="counted_stock_qty" data-row-field="counted_stock_qty" data-line-index="${index}" value="${isUnfilled ? "" : qty3(normalized.counted_stock_qty).toFixed(3)}" ${isUnfilled ? 'placeholder="Enter qty" data-unfilled-required' : ""} ${canSave ? "" : "readonly"}></td>`
						: `
							<td class="border-t border-slate-200 px-2 py-1"><input type="number" min="0" step="0.001" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" data-field="qty_in" data-row-field="qty_in" data-line-index="${index}" value="${normalized.qty_in}" ${canSave ? "" : "readonly"}></td>
							<td class="border-t border-slate-200 px-2 py-1"><input type="number" min="0" step="0.001" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" data-field="qty_out" data-row-field="qty_out" data-line-index="${index}" value="${normalized.qty_out}" ${canSave ? "" : "readonly"}></td>
						`;
					// Any row with a determined item uses static display by default — same
					// reason as FG. A per-row "change" button lazily reopens the dropdowns.
					const rmItemIsSet = normalized.item_id !== null && normalized.item_id !== undefined;
					const rmItemEditing = Boolean(normalized._editSku);
					const rmItemCellMarkup = (rmItemIsSet && !rmItemEditing)
						? (() => {
							const item = rmMap.get(Number(normalized.item_id || 0));
							const itemLabel = String(item?.name || `Item ${normalized.item_id || ""}`).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
							const colorEntry = colorState.entries.find((e) => Number(e.id) === Number(normalized.color_id || 0));
							const colorLabel = String(colorEntry?.name || (normalized.color_id ? String(normalized.color_id) : "")).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
							const sizeEntry = sizeState.entries.find((e) => Number(e.id) === Number(normalized.size_id || 0));
							const sizeLabel = String(sizeEntry?.name || (normalized.size_id ? String(normalized.size_id) : "")).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
							const editButton = canSave
								? `<button type="button" class="inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-500 hover:text-slate-700" data-edit-sku="${index}" title="${_t.change_article}" aria-label="${_t.change_article}"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4L18.5 9.5a2.121 2.121 0 0 0-3-3L5 17v3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></button>`
								: "";
							return `
								<td class="border-t border-slate-200 px-2 py-1"><div class="flex items-center gap-1"><input type="text" readonly class="w-full rounded-lg border border-slate-300 bg-slate-50 px-2 py-1 text-xs text-slate-700 cursor-default" value="${itemLabel}">${editButton}</div></td>
								<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly class="w-full rounded-lg border border-slate-300 bg-slate-50 px-2 py-1 text-xs text-slate-500 cursor-default" value="${colorLabel}"></td>
								<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly class="w-full rounded-lg border border-slate-300 bg-slate-50 px-2 py-1 text-xs text-slate-500 cursor-default" value="${sizeLabel}"></td>`;
						})()
						: `
							<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="item_id" data-row-field="item_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${(canSave && !groupRequiredButMissing) ? "" : "disabled"}>${optionMarkup(availableRmItems.map((entry) => ({ id: entry.id, label: entry.name })), normalized.item_id, groupRequiredButMissing ? "Select product group first" : "Select Raw Material")}</select></td>
							<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="color_id" data-row-field="color_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${(canSave && !colorState.disabled) ? "" : "disabled"}>${optionMarkup(colorState.entries, normalized.color_id, colorState.allowNone ? "None" : "")}</select></td>
							<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="size_id" data-row-field="size_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${(canSave && !sizeState.disabled) ? "" : "disabled"}>${optionMarkup(sizeState.entries, normalized.size_id, sizeState.allowNone ? "None" : "")}</select></td>`;
					// Unit lists are short (a couple of entries per item), so keep this an
					// editable select even after a default has been chosen — unlike the
					// item dropdown, there's no perf reason to freeze it into static text.
					const rmUomCellMarkup = `<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="uom_id" data-row-field="uom_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${(canSave && rmItemIsSet) ? "" : "disabled"}>${optionMarkup(getUomOptions(normalized, stockType), normalized.uom_id, "Select Unit")}</select></td>`;
					return `
						<tr data-line-index="${index}" data-row-index="${index}">
							${rmItemCellMarkup}
							${rmUomCellMarkup}
							<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="system_qty" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" value="${normalized.system_qty.toFixed(3)}"></td>
							${qtyCellMarkup}
							${diffCellMarkup}
							<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="rate" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" value="${rate6(normalized.rate).toFixed(4)}"></td>
							<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="amount_diff" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold" value="${amount2(normalized.amount).toFixed(2)}"></td>
							${actionCell}
							${rowNoCell}
						</tr>
					`;
				}

				const diffCellMarkup = `<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="difference_qty" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold" value="${normalized.difference_qty.toFixed(3)}"></td>`;
				const isUnfilled = Boolean(normalized._unfilled);
				const qtyCellMarkup = usePhysicalCountField
					? `<td class="border-t border-slate-200 px-2 py-1"><input type="number" min="0" step="0.001" class="w-full rounded-lg border ${isUnfilled ? "border-amber-400 bg-amber-50" : "border-slate-300 bg-white"} px-2 text-right" data-field="counted_stock_qty" data-row-field="counted_stock_qty" data-line-index="${index}" value="${isUnfilled ? "" : qty3(normalized.counted_stock_qty).toFixed(3)}" ${isUnfilled ? 'placeholder="Enter qty" data-unfilled-required' : ""} ${canSave ? "" : "readonly"}></td>`
					: `
						<td class="border-t border-slate-200 px-2 py-1"><input type="number" min="0" step="0.001" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" data-field="qty_in" data-row-field="qty_in" data-line-index="${index}" value="${normalized.qty_in}" ${canSave ? "" : "readonly"}></td>
						<td class="border-t border-slate-200 px-2 py-1"><input type="number" min="0" step="0.001" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" data-field="qty_out" data-row-field="qty_out" data-line-index="${index}" value="${normalized.qty_out}" ${canSave ? "" : "readonly"}></td>
					`;
				// Any row with a determined SKU uses static display by default — avoids
				// generating hundreds of <option> elements per row (and running
				// initSearchableSelects on each), which was the root cause of multi-minute
				// freezes on vouchers with many lines. A per-row "change" button lazily
				// swaps just that one cell into an editable dropdown on demand.
				const skuIsSet = normalized.sku_id !== null && normalized.sku_id !== undefined;
				const skuEditing = Boolean(normalized._editSku);
				const skuCellMarkup = (skuIsSet && !skuEditing)
					? (() => {
						const sku = skuMap.get(Number(normalized.sku_id || 0));
						const label = String(sku?.sku_name || `SKU ${normalized.sku_id || ""}`).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
						const editButton = canSave
							? `<button type="button" class="inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-md border border-slate-300 bg-white text-slate-500 hover:text-slate-700" data-edit-sku="${index}" title="${_t.change_article}" aria-label="${_t.change_article}"><svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 20h4L18.5 9.5a2.121 2.121 0 0 0-3-3L5 17v3z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></button>`
							: "";
						return `<td class="border-t border-slate-200 px-2 py-1"><div class="flex items-center gap-1"><input type="text" readonly class="w-full rounded-lg border border-slate-300 bg-slate-50 px-2 py-1 text-xs text-slate-700 cursor-default" value="${label}">${editButton}</div></td>`;
					})()
					: `<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="sku_id" data-row-field="sku_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${(canSave && !groupRequiredButMissing) ? "" : "disabled"}>${optionMarkup(skuRows.filter((entry) => !usedSkuIds.has(Number(entry.id)) || Number(entry.id) === Number(normalized.sku_id || 0)).map((entry) => ({ id: entry.id, label: entry.sku_name })), normalized.sku_id, groupRequiredButMissing ? "Select product group first" : "Select SKU")}</select></td>`;
				// Under Physical Count Correction, FG unit isn't a free per-row choice —
				// it's forced to match the header's Packed/Loose filter (Packed → Dozen,
				// Loose/All Status → Pair), so it's rendered as static text. Other FG
				// reasons keep the free, editable dropdown.
				const fgUomCellMarkup = isPhysicalCountCorrectionActive()
					? (() => {
						const uomLabel = getRowUnitLabel(normalized, stockType).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
						return `<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly class="w-full rounded-lg border border-slate-300 bg-slate-50 px-2 py-1 text-xs text-slate-500 cursor-default" value="${uomLabel}"></td>`;
					})()
					: `<td class="border-t border-slate-200 px-2 py-1"><select class="w-full rounded-lg border border-slate-300 bg-white px-2 text-xs" data-field="uom_id" data-row-field="uom_id" data-line-index="${index}" data-searchable-select="true" data-searchable-variant="unified" ${(canSave && skuIsSet) ? "" : "disabled"}>${optionMarkup(getUomOptions(normalized, stockType), normalized.uom_id, "Select Unit")}</select></td>`;
				return `
					<tr data-line-index="${index}" data-row-index="${index}">
						${skuCellMarkup}
						${fgUomCellMarkup}
						<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="system_qty" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" value="${normalized.system_qty.toFixed(3)}"></td>
						${qtyCellMarkup}
						${diffCellMarkup}
						<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="pair_rate" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right" value="${rate6(normalized.rate).toFixed(4)}"></td>
						<td class="border-t border-slate-200 px-2 py-1"><input type="text" readonly data-display-field="amount_diff" class="w-full rounded-lg border border-slate-300 bg-white px-2 text-right font-semibold" value="${amount2(normalized.amount).toFixed(2)}"></td>
						${actionCell}
						${rowNoCell}
					</tr>
				`;
			}).join("");

			if (typeof window.initSearchableSelects === "function") {
				window.initSearchableSelects(linesBody);
			}
			bindNavigator();
			syncTotals();
		};

		const fieldOrderForType = (stockType) => {
			const baseOrder = stockType === "RM"
				? ["item_id", "color_id", "size_id", "uom_id"]
				: ["sku_id", "uom_id"];
			return isPhysicalCountReasonActive()
				? [...baseOrder, "counted_stock_qty"]
				: [...baseOrder, "qty_in", "qty_out"];
		};

		const bindNavigator = () => {
			if (typeof unbindNavigator === "function") {
				unbindNavigator();
				unbindNavigator = null;
			}
			if (typeof window.createVoucherRowEnterNavigator !== "function") return;
			const nav = window.createVoucherRowEnterNavigator({
				form,
				linesBody,
				rowSelector: "tr[data-line-index]",
				fieldAttr: "data-row-field",
				fieldOrder: fieldOrderForType(currentStockType()),
				canAppendRow: () => canSave,
				appendRow: () => {
					if (!canSave) return false;
					rowsState.push(rowTemplate(currentStockType()));
					renderRows();
					return true;
				},
			});
			if (nav && typeof nav.bind === "function") {
				unbindNavigator = nav.bind();
			}
		};

		const captureActiveRowField = () => {
			const active = document.activeElement;
			if (!(active instanceof HTMLElement)) return null;

			const directField = active.matches("[data-line-index][data-row-field]")
				? active
				: active.closest("[data-line-index][data-row-field]");
			if (directField instanceof HTMLElement) {
				return {
					lineIndex: String(directField.getAttribute("data-line-index") || ""),
					fieldKey: String(directField.getAttribute("data-row-field") || ""),
				};
			}

			const searchableWrapper = active.closest("[data-searchable-wrapper]");
			const linkedSelect = searchableWrapper?.querySelector("select[data-line-index][data-row-field]") || null;
			if (linkedSelect instanceof HTMLElement) {
				return {
					lineIndex: String(linkedSelect.getAttribute("data-line-index") || ""),
					fieldKey: String(linkedSelect.getAttribute("data-row-field") || ""),
				};
			}
			return null;
		};

		const restoreActiveRowField = (state) => {
			if (!state || !state.lineIndex || !state.fieldKey) return;
			window.setTimeout(() => {
				const selector = `[data-line-index="${state.lineIndex}"][data-row-field="${state.fieldKey}"]`;
				const field = linesBody.querySelector(selector);
				if (!(field instanceof HTMLElement)) return;

				if (window.VoucherRowEnterNavigation?.focusFieldElement) {
					window.VoucherRowEnterNavigation.focusFieldElement(field, { openSearchable: false });
					return;
				}

				field.focus();
				if (field instanceof HTMLInputElement && typeof field.select === "function") {
					field.select();
				}
			}, 0);
		};

		const syncRenderedRowDerivedFields = (lineIndex, rowData) => {
			const rowElement = linesBody.querySelector(`tr[data-line-index="${lineIndex}"]`);
			if (!(rowElement instanceof HTMLElement) || !rowData) return;
			const setValue = (selector, value, formatter = (v) => String(v ?? "")) => {
				const input = rowElement.querySelector(selector);
				if (input instanceof HTMLInputElement) input.value = formatter(value);
			};
			setValue('input[data-display-field="system_qty"]', rowData.system_qty, (v) => qty3(v).toFixed(3));
			setValue('input[data-display-field="difference_qty"]', rowData.difference_qty, (v) => qty3(v).toFixed(3));
			setValue('input[data-display-field="pair_rate"]', rowData.rate, (v) => rate6(v).toFixed(4));
			setValue('input[data-display-field="rate"]', rowData.rate, (v) => rate6(v).toFixed(4));
			setValue('input[data-display-field="amount_diff"]', rowData.amount, (v) => amount2(v).toFixed(2));
		};

		const commitNumericFieldImmediately = ({ lineIndex, fieldKey, rawValue }) => {
			const row = rowsState[lineIndex];
			if (!row) return;
			if (fieldKey === "qty_in") row.qty_in = qty3(rawValue);
			if (fieldKey === "qty_out") row.qty_out = qty3(rawValue);
			if (fieldKey === "counted_stock_qty") {
				row.counted_stock_qty = qty3(rawValue);
				if (row._unfilled) {
					row._unfilled = false;
					const rowEl = linesBody.querySelector(`tr[data-line-index="${lineIndex}"]`);
					const countedInput = rowEl?.querySelector('[data-row-field="counted_stock_qty"]');
					if (countedInput instanceof HTMLInputElement) {
						countedInput.classList.remove("border-amber-400", "bg-amber-50");
						countedInput.classList.add("border-slate-300", "bg-white");
						countedInput.removeAttribute("data-unfilled-required");
						countedInput.removeAttribute("placeholder");
					}
				}
			}
			const normalized = applyDerivedRow(row, currentStockType());
			rowsState[lineIndex] = normalized;
			syncRenderedRowDerivedFields(lineIndex, normalized);
			syncTotals();
		};

		linesBody.addEventListener("keydown", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const lineIndex = Number(target.getAttribute("data-line-index") || -1);
			const fieldKey = String(target.getAttribute("data-row-field") || "").trim();

			if (
				(event.key === "ArrowDown" || event.key === "ArrowUp")
				&& target instanceof HTMLInputElement
				&& target.type === "number"
			) {
				if (lineIndex < 0 || !fieldKey) return;
				// Arrows must never step the number value; they move between rows instead.
				event.preventDefault();
				if (fieldKey === "qty_in" || fieldKey === "qty_out" || fieldKey === "counted_stock_qty") {
					commitNumericFieldImmediately({ lineIndex, fieldKey, rawValue: target.value });
				}
				const nextLineIndex = event.key === "ArrowDown" ? lineIndex + 1 : lineIndex - 1;
				if (nextLineIndex < 0 || nextLineIndex >= rowsState.length) return;
				pendingEnterFocus = { lineIndex: String(nextLineIndex), fieldKey: String(fieldKey) };
				// Blurring fires "change" when the value was edited; updateRowField then
				// re-renders and restores focus from pendingEnterFocus. If no change event
				// fired, pendingEnterFocus is still set and we move focus manually.
				target.blur();
				if (pendingEnterFocus) {
					pendingEnterFocus = null;
					const nextInput = linesBody.querySelector(`[data-line-index="${nextLineIndex}"][data-row-field="${fieldKey}"]`);
					if (nextInput instanceof HTMLInputElement) {
						nextInput.focus();
						nextInput.select();
					}
				}
				return;
			}

			if (event.key !== "Enter") return;
			if (lineIndex < 0 || !fieldKey) return;
			if (fieldKey === "qty_in" || fieldKey === "qty_out" || fieldKey === "counted_stock_qty") {
				commitNumericFieldImmediately({ lineIndex, fieldKey, rawValue: target.value });
			}
			const order = fieldOrderForType(currentStockType());
			const currentPos = order.indexOf(fieldKey);
			if (currentPos < 0) return;
			const nextFieldKey = currentPos < order.length - 1 ? order[currentPos + 1] : order[0];
			const nextLineIndex = currentPos < order.length - 1 ? lineIndex : lineIndex + 1;
			pendingEnterFocus = {
				lineIndex: String(nextLineIndex),
				fieldKey: String(nextFieldKey),
			};
		}, true);

		// The browser default for a focused number input is to spin the value on
		// mouse wheel instead of scrolling. Block that and scroll the page manually.
		linesBody.addEventListener("wheel", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLInputElement) || target.type !== "number") return;
			if (document.activeElement !== target) return;
			event.preventDefault();
			const scale = event.deltaMode === 1 ? 16 : event.deltaMode === 2 ? window.innerHeight : 1;
			let node = target.parentElement;
			while (node && node !== document.documentElement) {
				const style = window.getComputedStyle(node);
				if (/(auto|scroll)/.test(style.overflowY) && node.scrollHeight > node.clientHeight) {
					node.scrollBy({ top: event.deltaY * scale, left: event.deltaX * scale });
					return;
				}
				node = node.parentElement;
			}
			window.scrollBy({ top: event.deltaY * scale, left: event.deltaX * scale });
		}, { passive: false });

		const updateRowField = ({ index, field, value }) => {
			const row = rowsState[index];
			if (!row) return;
			const stockType = currentStockType();
			const focusState = captureActiveRowField();
			const enterFocusState = pendingEnterFocus;
			pendingEnterFocus = null;

			if (["sku_id", "item_id", "uom_id", "color_id", "size_id"].includes(field)) {
				row[field] = toInt(value);
			}
			if (field === "qty_in") {
				row.qty_in = qty3(value);
			}
			if (field === "qty_out") {
				row.qty_out = qty3(value);
			}
			if (field === "counted_stock_qty") {
				row.counted_stock_qty = qty3(value);
				row._unfilled = false;
			}

			const articleJustPicked = (field === "sku_id" || field === "item_id") && Boolean(toInt(value));
			if (field === "sku_id") {
				row.uom_id = null;
				row._snap_base = null;
				row._snap_pairs = null;
				row._editSku = false;
			}
			if (field === "item_id") {
				row.uom_id = null;
				row.color_id = null;
				row.size_id = null;
				row._snap_base = null;
				row._snap_pairs = null;
				row._editSku = false;
			}
			if (field === "color_id" || field === "size_id") {
				row._snap_base = null;
				row._snap_pairs = null;
			}
			if (articleJustPicked && isPhysicalCountReasonActive()) {
				// A manually added row starts with counted_stock_qty null, same as an
				// auto-loaded one — it must not silently default to 0 on submit.
				row._unfilled = true;
				row.counted_stock_qty = null;
			}

			rowsState[index] = applyDerivedRow(row, stockType);
			renderRows();
			if (articleJustPicked) {
				if (stockType === "FG" && isPhysicalCountCorrectionActive() && !initialVoucher) {
					// FG unit is forced from the header Packed/Loose filter under
					// correction, not editable per row, so skip straight to qty.
					const qtyFieldKey = isPhysicalCountReasonActive() ? "counted_stock_qty" : "qty_in";
					restoreActiveRowField({ lineIndex: String(index), fieldKey: qtyFieldKey });
				} else {
					// Unit auto-resolves to a sensible default the instant the article is
					// chosen, but stays editable — jump focus there so the user can confirm
					// or change it before moving on to qty.
					restoreActiveRowField({ lineIndex: String(index), fieldKey: "uom_id" });
				}
				return;
			}
			if (enterFocusState) {
				restoreActiveRowField(enterFocusState);
				return;
			}
			restoreActiveRowField(focusState);
		};

		linesBody.addEventListener("change", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const index = Number(target.getAttribute("data-line-index") || -1);
			const field = String(target.getAttribute("data-field") || "").trim();
			if (!Number.isInteger(index) || index < 0 || !field) return;
			updateRowField({ index, field, value: target.value });
		});

		linesBody.addEventListener("click", (event) => {
			const removeButton = event.target.closest("[data-remove-row]");
			if (removeButton) {
				if (!canSave) return;
				const index = Number(removeButton.getAttribute("data-remove-row") || -1);
				if (!Number.isInteger(index) || index < 0) return;
				rowsState.splice(index, 1);
				if (!rowsState.length) rowsState = [rowTemplate(currentStockType())];
				renderRows();
				return;
			}

			const editButton = event.target.closest("[data-edit-sku]");
			if (editButton) {
				if (!canSave) return;
				const index = Number(editButton.getAttribute("data-edit-sku") || -1);
				if (!Number.isInteger(index) || index < 0 || !rowsState[index]) return;
				rowsState[index]._editSku = true;
				renderRows();
				const stockType = currentStockType();
				const fieldKey = stockType === "RM" ? "item_id" : "sku_id";
				restoreActiveRowField({ lineIndex: String(index), fieldKey });
			}
		});

		form.addEventListener("click", (event) => {
			const addButton = event.target.closest("[data-add-row]");
			if (!addButton || !canSave) return;
			rowsState.push(rowTemplate(currentStockType()));
			renderRows();
		});

		if (stockTypeSelect) {
			stockTypeSelect.addEventListener("change", () => {
				if (isPhysicalCountCorrectionActive() && productGroupSelect) {
					productGroupSelect.value = "";
					populateProductGroupOptions(currentStockType());
				}
				syncStatusDropdownVisibility();
				rowsState = [rowTemplate(currentStockType())];
				renderHead(currentStockType());
				renderRows();
			});
		}

		if (reasonSelect && reasonNotes) {
			const syncReasonSettings = () => {
				const selected = reasonSelect.options[reasonSelect.selectedIndex];
				const required = selected && selected.getAttribute("data-requires-notes") === "1";
				reasonNotes.required = Boolean(required);
				const isCorrection = isPhysicalCountCorrectionActive();
				syncProductGroupVisibility();
				if (!isCorrection && productGroupSelect) productGroupSelect.value = "";
				// New vouchers start clean on every reason change — correction rows
				// only make sense once a product group is chosen, so leftover rows
				// from a previous reason must not carry over. Existing vouchers keep
				// their loaded rows unless the reason is switched away from correction.
				if (!initialVoucher || !isCorrection) rowsState = [rowTemplate(currentStockType())];
				renderHead(currentStockType());
				renderRows();
			};
			reasonSelect.addEventListener("change", syncReasonSettings);
			syncReasonSettings();
		}

		if (productGroupSelect) {
			// Switching product group invalidates rows picked against the old group's
			// SKU list — start the operator over on a blank row rather than mixing groups.
			productGroupSelect.addEventListener("change", () => {
				rowsState = [rowTemplate(currentStockType())];
				renderRows();
			});
		}

		if (productGroupStatusSelect) {
			// Changing Packed/Loose after rows already exist must flip every FG row's
			// forced unit (and its system qty snapshot) to match the new bucket —
			// otherwise counted rows would keep referencing the wrong bucket.
			productGroupStatusSelect.addEventListener("change", () => {
				const stockType = currentStockType();
				if (stockType !== "FG" || !isPhysicalCountCorrectionActive() || initialVoucher) return;
				rowsState = rowsState.map((row) => applyDerivedRow(row, stockType));
				renderRows();
			});
		}

		if (loadVoucherButton) {
			loadVoucherButton.addEventListener("click", () => {
				const voucherNo = toInt(voucherNoInput?.value);
				if (!voucherNo) return;
				window.location.href = `${basePath}?voucher_no=${voucherNo}&view=1`;
			});
		}

		if (deleteButton && deleteForm) {
			deleteButton.addEventListener("click", async () => {
				const shouldDelete = await confirmUi(deleteConfirmMessage);
				if (!shouldDelete) return;
				if (typeof deleteForm.requestSubmit === "function") {
					deleteForm.requestSubmit();
					return;
				}
				deleteForm.submit();
			});
		}

		const setRowsFromVoucher = () => {
			const stockType = normalizeStockType(initialVoucher?.stock_type || stockTypeSelect?.value);
			if (stockTypeSelect) stockTypeSelect.value = stockType;
			rowsState = Array.isArray(initialVoucher?.lines)
				? initialVoucher.lines.map((line) => ({
						sku_id: toInt(line?.sku_id),
						item_id: toInt(line?.item_id),
						color_id: toInt(line?.color_id),
						size_id: toInt(line?.size_id),
						uom_id: toInt(line?.uom_id),
						row_status: String(line?.row_status || "").toUpperCase() || "LOOSE",
						system_qty: qty3(line?.system_qty),
						qty_in: qty3(line?.qty_in),
						qty_out: qty3(line?.qty_out),
						physical_qty: qty3(line?.physical_qty),
						counted_stock_qty: qty3(line?.counted_stock_qty ?? line?.physical_qty),
						difference_qty: qty3(line?.difference_qty),
						rate: rate6(line?.rate),
						amount: amount2(line?.amount),
						// Frozen base-unit snapshots so system_qty always reflects the balance
						// at voucher save time, not the live balance after stock movements.
						_snap_base: line?.system_qty_snapshot != null ? Number(line.system_qty_snapshot) : null,
						_snap_pairs: line?.system_qty_pairs_snapshot != null ? Number(line.system_qty_pairs_snapshot) : null,
					}))
				: [rowTemplate(stockType)];
			if (!rowsState.length) rowsState = [rowTemplate(stockType)];
		};

		const buildPayloadLines = () => {
			const stockType = currentStockType();
			const usePhysicalCountField = isPhysicalCountReasonActive();
			return rowsState
				.map((row) => applyDerivedRow(row, stockType))
				.filter((row) => stockType === "RM" ? toInt(row.item_id) : toInt(row.sku_id))
				.map((row) => stockType === "RM"
					? (usePhysicalCountField
						? {
								item_id: toInt(row.item_id),
								color_id: toInt(row.color_id),
								size_id: toInt(row.size_id),
								uom_id: toInt(row.uom_id),
								counted_stock_qty: qty3(row.physical_qty),
								physical_qty: qty3(row.physical_qty),
							}
						: {
								item_id: toInt(row.item_id),
								color_id: toInt(row.color_id),
								size_id: toInt(row.size_id),
								uom_id: toInt(row.uom_id),
								qty_in: qty3(row.qty_in),
								qty_out: qty3(row.qty_out),
							})
					: (usePhysicalCountField
						? {
								sku_id: toInt(row.sku_id),
								uom_id: toInt(row.uom_id),
								counted_stock_qty: qty3(row.physical_qty),
								physical_qty: qty3(row.physical_qty),
							}
						: {
								sku_id: toInt(row.sku_id),
								uom_id: toInt(row.uom_id),
								qty_in: qty3(row.qty_in),
								qty_out: qty3(row.qty_out),
							}));
		};

		const focusFirstUnfilledRow = () => {
			const firstUnfilledIndex = rowsState.findIndex((r) => r._unfilled);
			if (firstUnfilledIndex < 0) return;
			const el = linesBody.querySelector(`[data-line-index="${firstUnfilledIndex}"][data-row-field="counted_stock_qty"]`);
			if (!(el instanceof HTMLElement)) return;
			el.scrollIntoView({ block: "center" });
			// showUiMessage's error modal schedules its own focus(close button) on the
			// next animation frame; queue ours after so it wins the race instead of the
			// field losing focus back to the modal a frame later.
			window.requestAnimationFrame(() => window.requestAnimationFrame(() => el.focus()));
		};

		// Used once the submit event has already been prevented (the async
		// reconciliation path below): builds the payload and, if valid, performs
		// the actual save. form.submit() bypasses the 'submit' event entirely, so
		// this never re-enters this handler.
		const finalizeSubmit = () => {
			const payloadLines = buildPayloadLines();
			if (!payloadLines.length) {
				showUiMessage(atLeastOneValidLineMessage);
				return;
			}
			linesJsonInput.value = JSON.stringify(payloadLines);
			form.submit();
		};

		let reconciling = false;
		const reconcileThenSubmit = async () => {
			if (reconciling) return;
			reconciling = true;
			showTableLoading();
			let reconcileResult = { appended: 0 };
			try {
				reconcileResult = await reconcileMissingArticles();
			} catch (err) {
				console.error("Failed to reconcile stock count articles before save:", err);
				hideTableLoading();
				reconciling = false;
				showUiMessage(reconcileArticlesFailedMessage);
				return;
			}
			hideTableLoading();
			reconciling = false;
			if (rowsState.some((r) => r._unfilled)) {
				showUiMessage(reconcileResult.appended > 0 ? articlesMissingAddedMessage : _t.fill_all_quantities);
				focusFirstUnfilledRow();
				return;
			}
			finalizeSubmit();
		};

		form.addEventListener("submit", (event) => {
			// Send only editable inputs; backend recomputes system snapshots and differences for integrity.
			const selectedReasonId = toInt(reasonSelect?.value);
			if (!selectedReasonId) {
				event.preventDefault();
				showUiMessage(reasonRequiredMessage);
				reasonSelect?.focus();
				return;
			}
			if (reasonNotes?.required && !String(reasonNotes.value || "").trim()) {
				event.preventDefault();
				showUiMessage(reasonNotesRequiredMessage);
				reasonNotes.focus();
				return;
			}
			if (isPhysicalCountCorrectionActive() && !initialVoucher) {
				const groupVal = productGroupSelect?.value || "";
				if (!groupVal || (groupVal !== "all" && !Number(groupVal))) {
					event.preventDefault();
					showUiMessage(_t.select_product_group_first);
					productGroupSelect?.focus();
					return;
				}
				// Reconciliation needs a network round trip, so this path must go
				// async: prevent the native submission now, and only actually save
				// (via finalizeSubmit's form.submit()) once nothing is missing.
				event.preventDefault();
				reconcileThenSubmit();
				return;
			}

			const payloadLines = buildPayloadLines();
			if (!payloadLines.length) {
				event.preventDefault();
				showUiMessage(atLeastOneValidLineMessage);
				return;
			}

			linesJsonInput.value = JSON.stringify(payloadLines);
		});

		if (initialVoucher) {
			setRowsFromVoucher();
		} else {
			rowsState = [rowTemplate(currentStockType())];
		}

		renderHead(currentStockType());
		renderRows();
	})();
</script>
